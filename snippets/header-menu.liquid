
{%- doc -%}
  Renders the header menu (desktop mega menu, mobile drawer, or navigation bar).
  @param {object} block_settings - Pass section.settings.
  @param {string} [variant] - 'mobile', 'navigation_bar', or blank for desktop.
  @param {string} [transparent] - Pass the transparent variable from header.liquid.
{%- enddoc -%}

{% case variant %}
  {% when 'mobile' %}
    <div
      class="header__drawer"
      ref="headerDrawerContainer"
      data-hydration-key="header-drawer-mobile"
    >
      {% render 'header-drawer', linklist: block_settings.menu, block_settings: block_settings, data_header_drawer_type: 'mobile-drawer' %}
    </div>

  {% when 'navigation_bar' %}
    {% if block_settings.navigation_bar == true %}
      <div
        class="menu-list menu-list--mobile{% if block_settings.menu_fill_width %} menu-list--fill-width{% endif %}{% if transparent == blank %} color-{{ block_settings.color_scheme_navigation_bar }}{% endif %}"
        style="--menu-horizontal-gap: 15px; --mobile-nav-margin: auto;"
        data-hydration-key="header-menu-mobile-navigation-bar"
      >
        <div class="menu-list__scroll-container">
          <ul
            class="menu-list__list list-unstyled"
            role="list"
          >
            {% for link in block_settings.menu.links %}
              <li>
                <a
                  href="{{ link.url }}"
                  id="MenuItem-{{ link.handle }}"
                  class="menu-list__item"
                  {% if link.current %}
                    aria-current="page"
                  {% endif %}
                >
                  {{- link.title -}}
                </a>
              </li>
            {% endfor %}
          </ul>
        </div>
      </div>
    {% endif %}
  {% else %}
    {% liquid
      assign menu_content_type = block_settings.menu_style | default: 'text'
      assign image_border_radius = block_settings.image_border_radius
      assign color_scheme_classes = ''
      assign color_scheme_setting_id = 'color_scheme_' | append: section.settings.menu_row
      assign current_color_scheme = block_settings.color_scheme
      assign parent_color_scheme = section.settings[color_scheme_setting_id]

      if parent_color_scheme.id != current_color_scheme.id
        assign color_scheme_classes = ' color-' | append: current_color_scheme
      endif

      # Check if header and menu colors match. This is used to apply different padding styles in css
      if parent_color_scheme.settings.background.rgb == current_color_scheme.settings.background.rgb
        assign color_scheme_classes = color_scheme_classes | append: ' color-scheme-matches-parent'
      endif

      if block_settings.menu_style == 'featured_collections'
        assign ratio = block_settings.featured_collections_aspect_ratio
      elsif block_settings.menu_style == 'featured_products'
        assign ratio = block_settings.featured_products_aspect_ratio
      endif
    %}

    {% capture children %}
      {% for link in block_settings.menu.links %}
        {% liquid
          assign matched_promo = nil
          assign matched_megamenu = nil
          assign matched_collection_list = nil
          assign link_title_lower = link.title | downcase | strip
          for blk in section.blocks
            assign blk_title_lower = blk.settings.heading | downcase | strip
            if blk_title_lower == link_title_lower
              if blk.type == 'mega_menu_promo'
                assign matched_promo = blk
              elsif blk.type == 'header_megamenu'
                assign matched_megamenu = blk
              elsif blk.type == 'mega_menu_collection_list'
                assign matched_collection_list = blk
              endif
            endif
          endfor
          assign item_promo_columns = nil
          assign item_promo_columns_tablet = nil
          if matched_promo != nil
            assign item_promo_columns = 2
            assign item_promo_columns_tablet = 1
          endif
          assign is_flat_list = true
          for sub_link in link.links
            if sub_link.links != blank
              assign is_flat_list = false
              break
            endif
          endfor
        %}
        <li
          role="presentation"
          class="menu-list__list-item"
          on:focus="/activate"
          on:pointerenter="/activate"
        >
          <a
            href="{{ link.url }}"
            data-skip-node-update="true"
            class="menu-list__link{% if link.active %} menu-list__link--active{% endif %}"
            {%- if link.links != blank or matched_megamenu != nil or matched_collection_list != nil -%}
              aria-controls="submenu-{{ forloop.index }}"
              aria-haspopup="true"
              aria-expanded="false"
            {%- endif -%}
            {% if link.current %}aria-current="page"{% endif %}
            ref="menuitem"
          >
            <span class="menu-list__link-title">{{- link.title -}}</span>
          </a>
          {%- if link.links != blank or matched_megamenu != nil or matched_collection_list != nil -%}
            <div class="menu-list__submenu{{ color_scheme_classes }}" ref="submenu[]">
              <div
                id="submenu-{{ forloop.index }}"
                class="menu-list__submenu-inner{% if matched_megamenu != nil or matched_collection_list != nil %} menu-list__submenu-inner--megamenu{% elsif is_flat_list %} menu-list__submenu-inner--flat{% endif %}"
                style="{% render 'submenu-font-styles', settings: block_settings %}"
              >
                {%- if matched_megamenu != nil -%}
                  {% render 'mega-menu-custom', block: matched_megamenu %}
                {%- elsif matched_collection_list != nil -%}
                  <div class="mega-menu section section--full-width-margin section--{{ section.settings.section_width }}">
                    {% render 'mega-menu-collection-list', block: matched_collection_list %}
                  </div>
                {%- else -%}
                  {% assign list_id = 'MegaMenuList-' | append: forloop.index %}
                  {%- if is_flat_list -%}
                    {%- assign grid_cols = 1 -%}
                    {%- assign grid_cols_tablet = 1 -%}
                  {%- else -%}
                    {%- assign grid_cols = 6 -%}
                    {%- assign grid_cols_tablet = 4 -%}
                  {%- endif -%}
                  <div class="mega-menu section section--full-width-margin section--{{ section.settings.section_width }}">
                    <div
                      class="mega-menu__grid"
                      data-menu-grid-id="{{ list_id }}"
                    >
                      {% render 'mega-menu-list',
                        parent_link: link,
                        id: list_id,
                        section: section,
                        grid_columns_count: grid_cols,
                        grid_columns_count_tablet: grid_cols_tablet,
                        grid_columns_count_collection_images: 8,
                        menu_content_type: menu_content_type,
                        content_aspect_ratio: ratio,
                        image_border_radius: image_border_radius,
                        promo_columns: item_promo_columns,
                        promo_columns_tablet: item_promo_columns_tablet
                      %}
                      {%- if matched_promo != nil -%}
                        {% render 'mega-menu-promo', block: matched_promo, image_border_radius: image_border_radius %}
                      {%- endif -%}
                    </div>
                  </div>
                {%- endif -%}
              </div>
            </div>
          {%- endif -%}
        </li>
      {% endfor %}
      <li
        class="menu-list__list-item"
        role="presentation"
        slot="more"
        on:focus="/activate"
        on:pointerenter="/activate"
      >
        <button role="listitem" class="menu-list__link button-unstyled">
          <span class="menu-list__link-title">{{ 'actions.more' | t }}</span>
        </button>
      </li>
    {% endcapture %}

    <header-menu
      ref="headerMenu"
      class="header-menu"
      data-hydration-key="header-menu"
    >
      <div class="header-menu__inner">
        <nav
          class="menu-list{% if block_settings.menu_fill_width %} menu-list--fill-width{% endif %}"
          aria-label="{{ 'accessibility.header_navigation_label' | t }}"
          style="{% render 'menu-font-styles', settings: block_settings, menu_type: 'mega_menu' %}"
        >
          {% assign class = 'overflow-menu' | append: color_scheme_classes %}
          {% render 'overflow-list',
            class: class,
            ref: 'overflowMenu',
            children: children,
            minimum-items: 2,
            data-testid: 'header-menu-overflow-list',
            attributes: 'data-skip-node-update'
          %}
        </nav>
      </div>

      <script
        src="{{ 'header-menu.js' | asset_url }}"
        type="module"
      ></script>
    </header-menu>
{% endcase %}

{% style %}
  .header__underlay {
    --color-submenu: rgb({{ block_settings.color_scheme.settings.background.rgba }});
  }
{% endstyle %}
{% stylesheet %}
  .header__drawer {
    --header-drawer-min-height: 60px;
    display: flex;
    min-height: var(--header-drawer-min-height);
    align-items: center;
  }
  @media screen and (max-width: 750px) {
	.header__drawer {
		/*margin-left: auto;*/
		margin-left: 0;
	}
  }
  @media screen and (min-width: 1500px) {
    #header-component:not(:has(overflow-list[minimum-reached])) .header__drawer {
      display: none;
      min-height: 0;
    }
  }

  .header--compact .header__drawer {
    min-height: var(--minimum-touch-target);
  }

  .menu-list--mobile {
    &.menu-list {
      display: grid;
    }

    & .menu-list__list {
      width: max-content;
      margin-inline: auto;
      gap: var(--menu-horizontal-gap);
    }

    & li {
      width: max-content;
      padding-block: var(--padding-sm);
    }

    & li:first-of-type {
      padding-inline-start: var(--menu-horizontal-gap);
    }

    & li:last-of-type {
      padding-inline-end: var(--menu-horizontal-gap);
    }

    & a {
      color: var(--color-foreground);
    }
  }

  .menu-list--fill-width.menu-list--mobile .menu-list__scroll-container {
    overflow-x: visible;
    mask-image: none;
  }

  .menu-list--fill-width.menu-list--mobile .menu-list__list {
    width: 100%;
    justify-content: space-around;
    gap: 0;
  }

  .menu-list--fill-width.menu-list--mobile li:first-of-type {
    padding-inline-start: 0;
  }

  .menu-list--fill-width.menu-list--mobile li:last-of-type {
    padding-inline-end: 0;
  }

  .menu-list__scroll-container {
    position: relative;
    overflow-x: auto;
    mask-image: linear-gradient(to right, transparent, #000 20px, #000 calc(100% - 20px), transparent);
    padding-block: var(--padding-2xs);
  }

  .menu-list {
    --menu-horizontal-gap: var(--gap-xl);
    --menu-vertical-gap: var(--gap-xl);

    display: flex;
    height: 100%;
  }

  .menu-list__list {
    display: flex;
    justify-content: var(--grid-area-alignment);
  }

  .menu-list__list-item {
    flex-shrink: 0;
    white-space: nowrap;
    display: flex;
    align-items: center;
    height: 100%;
  }
  .menu-list__list-item[aria-hidden='true'] {
    visibility: hidden;
  }

  .menu-list__link {
    font-family: var(--menu-top-level-font-family);
    font-style: var(--menu-top-level-font-style);
    font-weight: var(--menu-top-level-font-weight);
    font-size: var(--menu-top-level-font-size);
    line-height: var(--menu-top-level-font-line-height);
    text-transform: var(--menu-top-level-font-case);
    color: var(--menu-top-level-font-color);
    text-decoration: none;
    display: flex;
    flex-direction: column;
    justify-content: center;
    cursor: pointer;
    height: 100%;
    margin-block: 0;
    position: relative;
    padding-bottom: var(--menu-bottom-padding);

    &:hover,
    &:focus {
      color: var(--menu-top-level-font-hover-color);
    }

    @media screen and (min-width: 750px) {
      font-size: var(--menu-top-level-font-size-desktop);
    }
  }

  .menu-list__link-title {
    padding-inline: calc(var(--gap-xl) / 2);
  }
  [slot='overflow'] .menu-list__link-title {
    padding-inline: 0;
  }

  .menu-list__list-item:not([slot='overflow']) {
    flex-direction: column;
  }


  .menu-list .menu-list__link[aria-expanded='true'] {
    color: var(--menu-top-level-font-hover-color);
  }

  /* Underline on hovered menu items — only visible when both header bottom border
     and dropdown top border are enabled. Inset box-shadow sits inside the header
     so the dropdown panel cannot cover it. #header-component::after is now 1px
     below the link's bottom edge so they no longer overlap. */
  .menu-list .menu-list__list-item:not([slot='overflow']):where(:hover, :focus-within) .menu-list__link {
    box-shadow: inset 0 calc(-1 * var(--border-bottom-width, 0px) * (var(--submenu-border-width, 0px) / 1px)) 0 0 var(--color-primary);
  }

  /* Current page link always shown in primary color */
  /* stylelint-disable-next-line selector-max-specificity */
  .menu-list:not(:has(.menu-list__link:hover)) .menu-list__link--active,
  .menu-list:has(.menu-list__link:hover) .menu-list__link--active {
    color: var(--color-primary);
  }

  .overflow-menu::part(list) {
    /* Make sure focus outline is not cut off by overflow hidden */
    --focus-outline-size: calc(var(--focus-outline-offset) + var(--focus-outline-width));

    gap: 0;
    margin-inline: calc(-1 * var(--menu-horizontal-gap) / 2);
  }

  .header-menu__inner:has(.menu-list--fill-width) {
    width: 100%;
  }

  .menu-list--fill-width .overflow-menu {
    width: 100%;
    --overflow-list-alignment: space-around;
  }

  .menu-list--fill-width .overflow-menu::part(list) {
    margin-inline: 0;
  }

  .overflow-menu {
    background-color: transparent;
    padding: var(--focus-outline-size);
    margin: calc(-1 * var(--focus-outline-size));
  }

  /** mega menu **/
  .menu-list__submenu,
  .overflow-menu::part(overflow) {
    --submenu-padding-block-start: var(--padding-3xl);
    --submenu-padding-block-end: var(--padding-3xl);
  }


  .menu-list__list-item:where(:not([slot='overflow'])) > .menu-list__submenu {
    visibility: hidden;
    clip-path: inset(0 0 100% 0);
    pointer-events: none;
    background-color: var(--color-background);
    border-top: var(--submenu-border-width, 0px) solid var(--color-border);
    transition: clip-path 0.3s ease, visibility 0s 0.3s;
    position: absolute;
    width: 100%;
    left: 0;
    top: 100%;
    z-index: var(--layer-header-menu);
    padding-inline: var(--padding-inline);
    overflow: hidden;
  }

  .overflow-menu::part(overflow) {
    visibility: hidden;
    position: absolute;
    width: 100%;
    left: 0;
    top: 100%;
    z-index: var(--layer-header-menu);
    padding-inline: var(--padding-inline);
    overflow: hidden;
    border-top: var(--submenu-border-width, 0px) solid var(--color-border);
  }

  /* Show submenus on CSS :hover/:focus-within (works before JS loads).
     The submenu is a DOM descendant of <li>, so :hover propagates through
     position:absolute, keeping the submenu visible while cursor moves from
     the nav link down to the submenu panel. */
  .menu-list__list-item:is(:hover, :focus-within) > .menu-list__submenu,
  .menu-list__list-item:has([aria-expanded='true']) > .menu-list__submenu {
    visibility: visible;
    clip-path: inset(0 0 0% 0);
    pointer-events: auto;
    transition: clip-path 0.25s ease;
  }

  .overflow-menu:has([slot="overflow"] [aria-expanded='true'])::part(overflow),
  .overflow-menu::part(overflow):hover {
    visibility: visible;
  }

  .overflow-menu::part(overflow) {
    --menu-top-level-font-size: var(--font-size--xlarge);

    display: grid;
    grid-template-columns: var(--full-page-grid-with-margins);
  }

  .overflow-menu::part(overflow-list) {
    position: relative;
    display: grid;
    grid-template-columns: minmax(auto, 200px) 1fr;
    grid-template-areas: 'left right';
    grid-template-rows: max-content;
    grid-gap: 0;
    grid-column: 2;
  }

  .menu-list__list-item:is([slot='overflow']) {
    --menu-top-level-font-color: var(--color-foreground);
    --menu-top-level-font-hover-color: var(--color-foreground);

    display: contents;
    white-space: normal;

    .menu-list__link {
      grid-area: left;
      grid-row: auto;
      height: min-content;
      font-size: var(--font-size--xl);
    }

    .menu-list__submenu {
      visibility: hidden;
      grid-row: 1;
      grid-area: right;
      grid-row-end: span calc(var(--overflow-count) + 1);
      padding-inline-start: var(--menu-horizontal-gap);
    }

    .menu-list__submenu-inner {
      grid-column: unset;
      padding-block: 0;
    }

    .menu-list__link[aria-expanded='true'] + .menu-list__submenu {
      visibility: visible;
    }
  }

  .header-menu {
    height: 100%;
    width: 100%;
  }

  .menu-list__submenu-inner {
    position: relative;
    display: flex;
    justify-content: space-between;
    flex-wrap: wrap;
    opacity: 0;
    transform: translateY(-100%);
    transition: opacity 0.3s ease, transform 0.3s ease;
  }

  .menu-list__submenu-inner,
  .overflow-menu::part(overflow-list) {
    padding-block-start: var(--submenu-padding-block-start);
    padding-block-end: var(--submenu-padding-block-end);
    padding-inline: var(--section-padding-inline);

    /* Make overflow menu scrollable when content exceeds viewport */
    max-height: calc(90vh - var(--header-height));
    overflow-y: auto;
    overflow-x: hidden;
    scrollbar-width: thin;
    scrollbar-color: rgb(var(--color-foreground-rgb) / 0.4) transparent;
    border-bottom: var(--border-bottom-width, 0px) solid var(--color-border);
  }

  a.mega-menu__link {
    font-family: var(--menu-child-font-family);
    font-style: var(--menu-child-font-style);
    font-weight: var(--menu-child-font-weight);
    font-size: var(--menu-child-font-size);
    line-height: var(--menu-child-font-line-height);
    text-transform: var(--menu-child-font-case);
    color: var(--menu-child-font-color);
    white-space: normal;
    text-decoration: none;
    display: inline-flex;
    margin: var(--padding-xs) 0;
    border-bottom: 1px solid transparent;
    transition: all 0.2s ease;

    &:hover {
      color: var(--menu-child-active-font-color);
      border-bottom: 1px solid currentColor;
    }
  }

  a.mega-menu__link--parent {
    font-family: var(--menu-parent-font-family);
    font-style: var(--menu-parent-font-style);
    font-weight: var(--menu-parent-font-weight);
    font-size: var(--menu-parent-font-size);
    line-height: var(--menu-parent-font-line-height);
    text-transform: var(--menu-parent-font-case);
    color: var(--menu-parent-font-color);
    display: block;
    width: 100%;
    border-bottom: 1px solid var(--color-border);
    padding-bottom: var(--padding-xs);
    margin-bottom: var(--padding-xs);

    &:hover {
      color: var(--menu-parent-active-font-color);
    }
  }


  @media screen and (max-width: 989px) {
    .mega-menu__content-list-item--hidden-tablet {
      display: none;
    }
  }

  .mega-menu__link:has(.mega-menu__link-image) {
    display: flex;
    flex-direction: column;
    padding-inline: 0;
    padding-block: var(--padding-sm) 0;
  }

  .mega-menu__link-image {
    width: 100%;
    position: relative;
    aspect-ratio: 16 / 9;
    margin-bottom: var(--padding-sm);
    object-fit: cover;
    border-radius: var(--menu-image-border-radius);
  }

  /* Fix alignment for collection image mode links without images */

  /* Target only top-level links (direct children of column > div) in collection image mode */
  .mega-menu__grid:has(.mega-menu__link-image)
    .mega-menu__column
    > div
    > .mega-menu__link:not(:has(.mega-menu__link-image)) {
    display: flex;
    flex-direction: column;
    padding-inline: 0;
    padding-block: var(--padding-sm) 0;
  }

  .mega-menu__grid:has(.mega-menu__link-image)
    .mega-menu__column
    > div
    > .mega-menu__link:not(:has(.mega-menu__link-image))::before {
    content: '';
    display: block;
    width: 100%;
    aspect-ratio: 16 / 9;
    margin-bottom: var(--padding-sm);
    background-color: var(--color-foreground-muted);
    opacity: 0.1;
    border-radius: var(--menu-image-border-radius);
  }

  .mega-menu__grid {
    display: grid;
    grid-template-columns: repeat(var(--menu-columns-tablet), minmax(0, 1fr));
    gap: var(--menu-vertical-gap) var(--menu-horizontal-gap);
    width: 100%;

    @media screen and (min-width: 990px) {
      grid-template-columns: repeat(var(--menu-columns-desktop), minmax(0, 1fr));
    }
  }

  .mega-menu__column {
    grid-column: span 1;
  }

  .mega-menu__column--span-2 {
    grid-column: span 2;
  }

  .mega-menu__column--span-3 {
    grid-column: span 3;
  }

  .mega-menu__column--span-4 {
    grid-column: span 4;
  }

  .mega-menu__column--wide-collection-image {
    grid-column: span 1;

    @media screen and (min-width: 990px) {
      grid-column: span 2;
    }
  }

  .mega-menu__submenu .mega-menu__column--wide-collection-image {
    grid-column: span 1;
  }

  .mega-menu__content-list {
    display: grid;
    justify-content: end;
    gap: var(--menu-vertical-gap) var(--menu-horizontal-gap);
  }

  .mega-menu__content-list--products {
    grid-template-columns: repeat(var(--menu-content-columns-tablet), minmax(0, 1fr));

    @media screen and (min-width: 990px) {
      grid-template-columns: repeat(var(--menu-content-columns-desktop), minmax(0, 1fr));
    }
  }

  .mega-menu__content-list--collections {
    grid-template-columns: repeat(var(--menu-content-columns-tablet), minmax(0, 300px));

    @media screen and (min-width: 990px) {
      grid-template-columns: repeat(var(--menu-content-columns-desktop), minmax(0, 300px));
    }
  }

  .mega-menu__list {
    display: grid;
    grid-template-columns: subgrid;
    grid-column: span var(--menu-columns-tablet);
    gap: var(--menu-vertical-gap) var(--menu-horizontal-gap);

    @media screen and (min-width: 990px) {
      grid-column: span var(--menu-columns-desktop);
    }
  }

  .mega-menu__content {
    grid-column: span var(--menu-content-columns-tablet) / -1;

    @media screen and (min-width: 990px) {
      grid-column: span var(--menu-content-columns-desktop) / -1;
    }
  }

  .menu-list__list-item[slot='overflow'] .section {
    grid-template-columns: 1fr;
  }

  .menu-list__list-item[slot='overflow'] .section .mega-menu__grid {
    grid-column: 1;
  }

  .mega-menu__content-list li {
    white-space: normal;
  }

  /* mega more menu */
  .mega-menu__more-list {
    --menu-child-font-size: var(--font-size--xl);

    width: 200px;
  }

  .mega-menu__submenu {
    /* preserves the inherited grid layout when this submenu wrapper is used */
    display: contents;
  }

  /* custom 3-level megamenu — strip padding, let the snippet handle its own layout */
  .menu-list__submenu-inner--megamenu {
    padding: 0;
    display: block;
  }

  /* ── mega-menu-promo panel ───────────────────────────────────────── */
  .mega-menu__promo-panel {
    grid-column: span 2 / -1;
    position: relative;
    overflow: hidden;
    border-radius: var(--menu-image-border-radius, 0px);
    min-height: 200px;

    @media screen and (max-width: 989px) {
      grid-column: span 1 / -1;
    }
  }

  .mega-menu__promo-panel-link {
    display: flex;
    flex-direction: column;
    height: 100%;
    text-decoration: none;
    position: relative;
    color: white;
  }

  .mega-menu__promo-panel-image {
    display: block;
    width: 100%;
    height: 100%;
    object-fit: cover;
    flex: 1;
    border-radius: var(--menu-image-border-radius, 0px);
  }

  .mega-menu__promo-panel-overlay {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    padding: var(--padding-sm);
    background: linear-gradient(transparent, rgba(0, 0, 0, 0.6));
    border-radius: 0 0 var(--menu-image-border-radius, 0px) var(--menu-image-border-radius, 0px);
  }

  .mega-menu__promo-panel-heading {
    font-family: var(--menu-top-level-font-family);
    font-size: 1.125rem;
    font-weight: 700;
    margin: 0;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    line-height: 1.2;
  }

  .mega-menu__promo-panel-subheading {
    font-family: var(--menu-top-level-font-family);
    font-size: 0.8125rem;
    margin: 4px 0 0;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.06em;
  }

  @keyframes mega-menu-item-in {
    from {
      opacity: 0;
      transform: translateY(8px);
    }

    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  .menu-list__list-item:is(:hover, :focus-within) .menu-list__submenu-inner,
  .menu-list__list-item:has([aria-expanded='true']) .menu-list__submenu-inner {
    animation: mega-menu-item-in 0.5s var(--animation-easing) backwards;
    opacity: 1;
    transform: translateY(0);
  }

  /* Default: center flat submenus until JS is ready */
  .menu-list__submenu-inner--flat .mega-menu {
    display: block;
    padding-inline-start: 0;
  }

  .menu-list__submenu-inner--flat .mega-menu__grid {
    width: max-content;
    margin-inline: auto;
  }

  /* After JS is ready: position under the nav item + nav-link text indent */
  /* padding-inline-start on grid overrides the section--full-width-margin page-margin (nav-item-left handles the offset) */
  .header-menu-ready .menu-list__submenu-inner--flat .mega-menu {
    padding-inline-start: var(--nav-item-left, 0px);
  }
  .header-menu-ready .menu-list__submenu-inner--flat .mega-menu__grid {
    margin-inline: 0;
    padding-inline-start: calc(var(--gap-xl) / 2);
  }

{% endstylesheet %}

