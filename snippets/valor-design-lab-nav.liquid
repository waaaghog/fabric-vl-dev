          {%- endif -%}
        </span>
        <span class="vdn__dl-newdrop-case">
          {%- if banner_image_2 != blank -%}
            {{ banner_image_2 | image_url: width: 180 | image_tag: loading: 'lazy', class: 'vdn__dl-newdrop-img', alt: '' }}
          {%- else -%}
            <svg viewBox="0 0 78 150" xmlns="http://www.w3.org/2000/svg" preserveAspectRatio="xMidYMid slice"><defs><linearGradient id="vdnDlNewdropB-{{ banner_svg_id }}" x1="0" y1="0" x2="1" y2="1"><stop offset="0" stop-color="#2B3A55"/><stop offset="1" stop-color="#7A2629"/></linearGradient></defs><rect width="78" height="150" fill="url(#vdnDlNewdropB-{{ banner_svg_id }})"/><g stroke="#F4F5F2" stroke-width="2" fill="none" opacity="0.8"><circle cx="39" cy="48" r="16"/><circle cx="39" cy="48" r="9"/><circle cx="39" cy="104" r="16"/><circle cx="39" cy="104" r="9"/></g><g fill="#C54448" opacity="0.9"><circle cx="39" cy="48" r="4"/><circle cx="39" cy="104" r="4"/></g><rect x="9" y="9" width="26" height="20" rx="6" fill="#1D2636" opacity="0.85"/></svg>
          {%- endif -%}
        </span>
        <span class="vdn__dl-newdrop-case">
          {%- if banner_image_3 != blank -%}
            {{ banner_image_3 | image_url: width: 180 | image_tag: loading: 'lazy', class: 'vdn__dl-newdrop-img', alt: '' }}
          {%- else -%}
            <svg viewBox="0 0 78 150" xmlns="http://www.w3.org/2000/svg" preserveAspectRatio="xMidYMid slice"><defs><linearGradient id="vdnDlNewdropC-{{ banner_svg_id }}" x1="0" y1="0" x2="1" y2="1"><stop offset="0" stop-color="#1F4E8C"/><stop offset="1" stop-color="#163C6E"/></linearGradient></defs><rect width="78" height="150" fill="url(#vdnDlNewdropC-{{ banner_svg_id }})"/><g fill="#F4F5F2" opacity="0.92"><path d="M20 28l2 5 5 .4-4 3.3 1.3 5-4.3-2.8-4.3 2.8 1.3-5-4-3.3 5-.4z"/><path d="M54 52l2 5 5 .4-4 3.3 1.3 5-4.3-2.8-4.3 2.8 1.3-5-4-3.3 5-.4z"/><path d="M28 84l2 5 5 .4-4 3.3 1.3 5-4.3-2.8-4.3 2.8 1.3-5-4-3.3 5-.4z"/><path d="M56 112l2 5 5 .4-4 3.3 1.3 5-4.3-2.8-4.3 2.8 1.3-5-4-3.3 5-.4z"/></g><g fill="#C54448" opacity="0.9"><rect x="14" y="118" width="50" height="5" rx="2"/><rect x="14" y="64" width="50" height="5" rx="2"/></g><rect x="9" y="9" width="26" height="20" rx="6" fill="#0F2B52" opacity="0.85"/></svg>
          {%- endif -%}
        </span>
      </span>
      <span class="vdn__dl-newdrop-copy">
        <span class="vdn__dl-newdrop-title">
          {%- if banner_title_prefix_text != blank -%}{{ banner_title_prefix_text | escape }}{%- endif -%}
          {%- if banner_title_accent_text != blank -%}{%- if banner_title_prefix_text != blank -%}{{ ' ' }}{%- endif -%}<em>{{ banner_title_accent_text | escape }}</em>{%- endif -%}
          {%- if banner_title_suffix_text != blank -%}{%- if banner_title_prefix_text != blank or banner_title_accent_text != blank -%}{{ ' ' }}{%- endif -%}{{ banner_title_suffix_text | escape }}{%- endif -%}
        </span>
        {%- if banner_text != blank -%}
          <span class="vdn__dl-newdrop-sub">{{ banner_text | escape }}</span>
        {%- endif -%}
      </span>
      {%- if banner_cta_label != blank -%}
