{%- doc -%}
  Renders the Design Lab navigation content for desktop mega menus and the
  Valor menu drawer.

  Items are driven by a Shopify navigation menu (admin-editable) when one is
  assigned via `designlab_menu` (or the simple block's `menu`) setting. The
  expected menu shape is up to three levels:

    Top-level link   → a tab / category   (e.g. "Non-MagSafe Cases")
      2nd-level link → a brand group      (e.g. "iPhone")        — optional
        3rd-level    → a model/product link (e.g. "iPhone 15 Pro")

  A tab whose children have their own children renders as a brand grid; a tab
  whose children are plain links renders as a flat list. Add a trailing "*" to
  any item title to show a red "New" badge.

  When no menu is assigned the snippet falls back to the original hardcoded
  content, so the dropdown is never empty before the menu is built in admin.

  @param {string} variant - desktop or drawer.
  @param {object} block_settings - Section block settings.
  @param {string} block_id - Unique block id for ARIA attributes.
{%- enddoc -%}

{%- liquid
  assign variant = variant | default: 'desktop'
  assign s = block_settings
  assign id_prefix = block_id | default: 'design-lab'
  assign all_url = s.all_url | default: '/search?sort_by=relevance&q=*&filter.p.m.custom.product_designlab=1'
  assign cta_label = s.cta_label | default: 'Start Customizing'
  assign cta_url = s.cta_url | default: '/collections/design-lab-customization?filter.v.availability=1'
  assign footer_eyebrow = s.footer_eyebrow | default: 'Customization'
  assign footer_heading = s.footer_heading | default: 'Design your own.'
  assign footer_text = s.footer_text | default: 'Put your logo, colors, or local artwork on any product and build it to order - low minimums with rapid small-batch turnaround.'
  assign banner_enabled = s.designlab_banner_enabled
  assign banner_url = s.designlab_banner_url | default: all_url
  assign banner_title_prefix = s.designlab_banner_title_prefix | default: 'New'
  assign banner_title_accent = s.designlab_banner_title_accent | default: 'Summer'
  assign banner_title_suffix = s.designlab_banner_title_suffix | default: 'Designs'
  assign banner_title_prefix_text = banner_title_prefix | strip
  assign banner_title_accent_text = banner_title_accent | strip
  assign banner_title_suffix_text = banner_title_suffix | strip
  assign banner_text = s.designlab_banner_text | default: 'Explore the latest drop with 10 new designs.'
  assign banner_cta_label = s.designlab_banner_cta_label | default: 'Shop the Drop'
  assign banner_image_1 = s.designlab_banner_image_1
  assign banner_image_2 = s.designlab_banner_image_2
  assign banner_image_3 = s.designlab_banner_image_3
  assign banner_svg_id = id_prefix | handleize | default: 'design-lab'

  assign dl_menu = linklists[s.designlab_menu]
  if dl_menu == blank or dl_menu.links.size == 0
    assign dl_menu = linklists[s.menu]
  endif
-%}

