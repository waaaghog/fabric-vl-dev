  {%- endif -%}
{%- endcapture -%}

{%- if dl_menu != blank and dl_menu.links.size > 0 -%}
  {%- comment -%} ===== Menu-driven (admin-editable) ===== {%- endcomment -%}
  {%- if variant == 'drawer' -%}
    <div class="vmd-dl-menu">
      <a class="vmd-dl-all" href="{{ all_url | escape }}">
        Shop all Design Lab
        <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" aria-hidden="true"><path d="M5 12h14M13 5l7 7-7 7"/></svg>
      </a>

      {%- for tab in dl_menu.links -%}
        {%- liquid
          assign has_groups = false
          for child in tab.links
            if child.links.size > 0
              assign has_groups = true
              break
            endif
          endfor
        -%}
        <details class="vmd-dl-group"{% if forloop.first %} open{% endif %}>
          <summary>{{ tab.title | escape }}</summary>
          {%- if has_groups -%}
            <div class="vmd-dl-brandgrid">
              {%- for brand in tab.links -%}
                <div class="vmd-dl-brand">
                  <div class="vmd-dl-brand-name">{{ brand.title | escape }}</div>
                  {%- if brand.links.size > 0 -%}
                    <ul>
                      {%- for model in brand.links -%}
                        {% render 'valor-dl-link', link: model, variant: 'drawer' %}
                      {%- endfor -%}
                    </ul>
                  {%- endif -%}
                </div>
              {%- endfor -%}
            </div>
          {%- else -%}
            {%- assign flat_class = 'vmd-dl-typelist' -%}
            {%- if tab.links.size > 6 -%}{%- assign flat_class = 'vmd-dl-modellist' -%}{%- endif -%}
            <ul class="{{ flat_class }}">
              {%- for model in tab.links -%}
                {% render 'valor-dl-link', link: model, variant: 'drawer' %}
              {%- endfor -%}
            </ul>
          {%- endif -%}
        </details>
      {%- endfor -%}

      <a class="vmd-dl-cta" href="{{ cta_url | escape }}">
        {{ cta_label | escape }}
        <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" aria-hidden="true"><path d="M5 12h14M13 5l7 7-7 7"/></svg>
      </a>
    </div>
  {%- else -%}
    {{ design_lab_banner }}

    <div class="vdn__dl-shop">
      <ul class="vdn__dl-rail" role="tablist" aria-label="Design Lab categories">
        {%- for tab in dl_menu.links -%}
          {%- assign tab_key = 'dlcat-' | append: forloop.index0 -%}
          <li><button type="button" class="vdn__dl-rail-item{% if forloop.first %} is-active{% endif %}" data-vdn-dlcat="{{ tab_key }}" role="tab" aria-selected="{% if forloop.first %}true{% else %}false{% endif %}" aria-controls="vdn-dl-{{ id_prefix }}-{{ tab_key }}">{{ tab.title | escape }}<svg width="9" height="9" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" aria-hidden="true"><path d="M9 6l6 6-6 6"/></svg></button></li>
        {%- endfor -%}
      </ul>

      <div class="vdn__dl-detail">
        {%- for tab in dl_menu.links -%}
          {%- assign tab_key = 'dlcat-' | append: forloop.index0 -%}
          {%- liquid
            assign has_groups = false
            for child in tab.links
              if child.links.size > 0
                assign has_groups = true
                break
              endif
            endfor
          -%}
          <div class="vdn__dl-panel{% if forloop.first %} is-active{% endif %}" data-vdn-dlpanel="{{ tab_key }}" id="vdn-dl-{{ id_prefix }}-{{ tab_key }}" role="tabpanel"{% unless forloop.first %} hidden{% endunless %}>
            <div class="vdn__dl-section-head">{{ tab.title | escape }}</div>
            {%- if has_groups -%}
              <div class="vdn__dl-brandgrid">
                {%- for brand in tab.links -%}
                  <div class="vdn__dl-brand">
                    <div class="vdn__dl-brand-name">{{ brand.title | escape }}</div>
                    {%- if brand.links.size > 0 -%}
                      <ul>
                        {%- for model in brand.links -%}
                          {% render 'valor-dl-link', link: model, variant: 'desktop' %}
                        {%- endfor -%}
                      </ul>
                    {%- endif -%}
                  </div>
                {%- endfor -%}
              </div>
            {%- else -%}
              {%- assign flat_class = 'vdn__dl-typelist' -%}
              {%- if tab.links.size > 6 -%}{%- assign flat_class = 'vdn__dl-modellist' -%}{%- endif -%}
              <ul class="{{ flat_class }}">
                {%- for model in tab.links -%}
                  {% render 'valor-dl-link', link: model, variant: 'desktop' %}
                {%- endfor -%}
              </ul>
            {%- endif -%}
          </div>
        {%- endfor -%}
      </div>
    </div>

    <div class="vdn__dl-foot">
      <div class="vdn__dl-foot-copy">
        <span class="vdn__dl-foot-eyebrow">{{ footer_eyebrow | escape }}</span>
        <strong>{{ footer_heading | escape }}</strong> {{ footer_text | escape }}
      </div>
      <a href="{{ cta_url | escape }}" class="vdn__dl-experiment">
        {{ cta_label | escape }}
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" aria-hidden="true"><path d="M5 12h14M13 6l6 6-6 6"/></svg>
      </a>
    </div>
  {%- endif -%}

