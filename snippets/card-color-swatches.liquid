{%- doc -%}
  Renders a compact, non-interactive row of color swatches for a product card,
  matching the Valor PLP mockup (overlapping circles + "N colors" label).

  Color siblings are sourced two ways, in priority order:
  1. The `custom.related_colors` product-list metafield (this store's catalog
     keeps each color as a separate product, linked via this metafield). The
     current product is shown first, followed by its related-color products.
  2. Fallback: a true multi-value Color/Colour option on a single product,
     using each color value's variant image.

  Identical output for logged-in and logged-out customers (no customer checks).

  @param {object} product - The product object
  @param {number} [max_swatches] - Max circles to show before a "+N" count (default 6)
  @param {string} [stock_label] - Optional stock text appended after "N colors" on the same line

  @example
  {% render 'card-color-swatches', product: product %}
{%- enddoc -%}

{%- liquid
  assign max_swatches = max_swatches | default: 6
  assign related_colors = product.metafields.custom.related_colors.value

  assign related_count = 0
  if related_colors
    assign related_count = related_colors.size
  endif

  # Fallback: a single product that genuinely has multiple color variants.
  assign color_option = null
  if related_count == 0
    for option in product.options_with_values
      assign option_name = option.name | downcase
      if option_name contains 'color' or option_name contains 'colour'
        assign color_option = option
        break
      endif
    endfor
  endif

  assign option_count = 0
  if color_option
    assign option_count = color_option.values.size
  endif

  # Total distinct colors: current product + related siblings, or the option values.
  assign total_colors = 0
  if related_count > 0
    assign total_colors = related_count | plus: 1
  elsif option_count > 1
    assign total_colors = option_count
  endif
-%}

{%- if total_colors > 1 -%}
  <div class="card-color-swatches">
    <div class="card-color-swatches__row">
      {%- if related_count > 0 -%}
        {%- comment -%} Current product's color first, then its related colors {%- endcomment -%}
        {%- render 'card-color-swatch-dot', product: product -%}
        {%- assign shown = 1 -%}
        {%- for sibling in related_colors -%}
          {%- if shown >= max_swatches -%}
            {%- break -%}
          {%- endif -%}
          {%- if sibling.id == product.id -%}
            {%- continue -%}
          {%- endif -%}
          {%- render 'card-color-swatch-dot', product: sibling -%}
          {%- assign shown = shown | plus: 1 -%}
        {%- endfor -%}
      {%- else -%}
        {%- assign shown = 0 -%}
        {%- for value in color_option.values -%}
          {%- if shown >= max_swatches -%}
            {%- break -%}
          {%- endif -%}
          {%- render 'card-color-swatch-dot',
            product: product,
            variant: value.variant,
            label: value.name
          -%}
          {%- assign shown = shown | plus: 1 -%}
        {%- endfor -%}
      {%- endif -%}

      {%- if total_colors > max_swatches -%}
        <span class="card-color-swatches__count">+{{ total_colors | minus: max_swatches }}</span>
      {%- endif -%}
    </div>
    <div class="card-color-swatches__label">{{ total_colors }} colors{%- if stock_label != blank %}<span class="card-color-swatches__sub"> · {{ stock_label }}</span>{% endif -%}</div>
  </div>
{%- endif -%}

{% stylesheet %}
  .card-color-swatches {
    display: flex;
    align-items: center;
    gap: 10px;
    width: 100%;
  }

  .card-color-swatches__row {
    display: flex;
    align-items: center;
    flex-shrink: 0;
  }

  .card-color-swatches__sw {
    width: 22px;
    height: 22px;
    border-radius: 50%;
    border: 2px solid rgb(var(--color-background-rgb, 255 255 255));
    outline: 1px solid rgb(var(--color-foreground-rgb, 18 18 18) / 0.2);
    margin-left: -6px;
    background-size: cover;
    background-position: center;
    flex-shrink: 0;
  }

  .card-color-swatches__row .card-color-swatches__sw:first-child {
    margin-left: 0;
  }

  .card-color-swatches__sw--unavailable {
    background-color: transparent;
    border-style: dashed;
  }

  .card-color-swatches__sw--clear {
    background-color: rgb(var(--color-foreground-rgb, 18 18 18) / 0.04);
  }

  .card-color-swatches__count {
    font-size: 11px;
    color: rgb(var(--color-foreground-rgb, 18 18 18) / 0.6);
    margin-left: 8px;
    letter-spacing: 0.02em;
  }

  .card-color-swatches__label {
    flex: 1;
    font-size: 12px;
    color: rgb(var(--color-foreground-rgb, 18 18 18));
    font-weight: 500;
    line-height: 1.3;
  }

  .card-color-swatches__sub {
    color: rgb(var(--color-foreground-rgb, 18 18 18) / 0.6);
    font-weight: 400;
    font-size: 11px;
  }
{% endstylesheet %}
