{%- doc -%}
  Derives CSS variables from the menu typography settings for 1st level/main menu items.

  @param {object} settings - The block settings object containing typography settings.
  @param {string} menu_type - The menu type: 'drawer' or 'mega_menu'.
{%- enddoc -%}

{%- liquid
  assign menu_font = settings.type_font_primary_link | default: 'body'
-%}

--menu-top-level-font-family: var(--font-{{ menu_font }}--family);
--menu-top-level-font-size-desktop: {{ settings.type_font_primary_size }}; --menu-top-level-font-style: var(--font-{{ menu_font }}--style); --menu-top-level-font-weight: var(--font-{{ menu_font }}--weight); --menu-top-level-font-case:
{%- if settings.type_case_primary_link == 'uppercase' %}uppercase{% else %}none{% endif -%}
;
{% if menu_type == 'drawer' %}
  --menu-top-level-font-size: {{ settings.type_font_primary_size_mobile | default: '1.75rem' }}; --menu-top-level-font-line-height: 1.3;
{% else %}
  --menu-top-level-font-size: var(--menu-font-sm--size); --menu-top-level-font-line-height:
  var(--menu-font-sm--line-height);
{% endif %}
--menu-top-level-font-color: {{ settings.menu_link_color }}; --menu-top-level-font-hover-color: {{ settings.menu_link_hover_color | default: settings.menu_link_color }};
