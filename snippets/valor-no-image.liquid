{%- liquid
  assign placeholder_label = label | default: 'Image coming soon'
  assign extra_classes = class | default: ''
-%}

<div
  class="valor-no-image{% if extra_classes != blank %} {{ extra_classes }}{% endif %}"
  role="img"
  aria-label="{{ placeholder_label | escape }}"
>
  <svg
    class="valor-no-image__icon"
    viewBox="0 0 24 24"
    fill="none"
    stroke="currentColor"
    stroke-width="1.5"
    stroke-linecap="round"
    stroke-linejoin="round"
    aria-hidden="true"
    focusable="false"
  >
    <rect x="3" y="4" width="18" height="16" rx="2.5"></rect>
    <circle cx="8.5" cy="9.5" r="1.6"></circle>
    <path d="M21 15.5l-5-5L7 19.5"></path>
  </svg>
  <span class="valor-no-image__text">{{ placeholder_label }}</span>
  <span class="valor-no-image__rule" aria-hidden="true"></span>
</div>
