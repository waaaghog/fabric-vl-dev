{% doc %}
  Header Actions Component

  Renders the header actions.

  @param {object} [section] - The section object providing settings such as actions_font.
  @param {block} [block] - The block object, used for Shopify editor attributes.
  @param {string} [display_style] - Controls display mode for header actions: 'icon' or 'text'.
  @param {string} [customer_account_menu] - The menu handle passed to the shopify-account component.

  @example
  {% render 'header-actions', section: section %}
{% enddoc %}

<script
  type="module"
  src="{{ 'cart-icon.js' | asset_url }}"
  fetchpriority="low"
></script>

{% capture cart_icon %}
  <cart-icon
    class="header-actions__cart-icon{% unless cart == empty %} header-actions__cart-icon--has-cart{% endunless %}"
    data-testid="cart-icon"
  >
    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
      <path d="M6 2 3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4Z"/>
      <path d="M3 6h18"/>
      <path d="M16 10a4 4 0 0 1-8 0"/>
    </svg>
    {% render 'cart-bubble', limit: 100 %}
  </cart-icon>
{% endcapture %}

{% capture account_icon %}
  <svg
    xmlns="http://www.w3.org/2000/svg"
    width="15"
    height="17"
    viewBox="0 0 15 17"
    fill="none"
    slot="signed-out-avatar"
    class="account-button__icon"
  >
    <path
      stroke="currentColor"
      stroke-linejoin="round"
      stroke-width="var(--icon-stroke-width)"
      d="M10.375 3.813a3.063 3.063 0 1 1-6.125 0 3.063 3.063 0 0 1 6.125 0ZM7.313 9.5c-3.667 0-6.24 2.691-6.563 6.125h13.125C13.552 12.191 10.979 9.5 7.312 9.5Z"
    />
  </svg>
{% endcapture %}

<header-actions
  {% if display_style == 'text' %}
    class="header-actions--text"
  {% endif %}
  {{- block.shopify_attributes -}}
>
  {% if customer and customer['b2b?'] %}
    <a href="/pages/my-account#messages" class="header-actions__action va-icon-btn va-notif-btn" aria-label="Notifications">
      <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
        <path d="M6 8a6 6 0 0 1 12 0c0 7 3 9 3 9H3s3-2 3-9M13.73 21a2 2 0 0 1-3.46 0"/>
      </svg>
    </a>
  {% endif %}

  {% if settings.cart_type == 'drawer' and template.name != 'cart' %}
    {%- comment -%} Trigger only — drawer panel is rendered at body level in theme.liquid {%- endcomment -%}
    <button
      class="header-actions__action va-icon-btn cart-drawer"
      data-vcd-open
      aria-haspopup="dialog"
      aria-label="{{ 'accessibility.cart' | t }}"
      aria-describedby="cart-bubble-text"
      data-testid="cart-drawer-trigger"
      onclick="document.dispatchEvent(new CustomEvent('vcd:open-cart'))"
    >
      {{ cart_icon }}
    </button>
  {% else %}
    <a
      href="{{ routes.cart_url }}"
      class="header-actions__action va-icon-btn action__cart"
      aria-label="{{ 'accessibility.cart' | t }}"
      aria-describedby="cart-bubble-text"
    >
      {{ cart_icon }}
    </a>
  {% endif %}

  {% if shop.customer_accounts_enabled %}
    {% liquid
      assign account_actions_style = ''
      if display_style == 'text' and section
        assign actions_font = section.settings.actions_font | default: 'body'
        assign font_obj = settings.type_heading_font
        case actions_font
          when 'body'
            assign font_obj = settings.type_body_font
          when 'subheading'
            assign font_obj = settings.type_subheading_font
          when 'accent'
            assign font_obj = settings.type_accent_font
        endcase
        assign font_family = font_obj.family | append: ', ' | append: font_obj.fallback_families
        assign font_family_safe = font_family | replace: '"', "'"
        assign account_actions_style = '--header-actions-font-family: ' | append: font_family_safe | append: '; --header-actions-font-weight: ' | append: font_obj.weight | append: ';'
      endif
      assign using_classic_accounts = false
      if routes.account_login_url contains '/account/login'
        assign using_classic_accounts = true
      endif
    %}
    <div
      class="account-button header-actions__action{% if display_style == 'text' %} account-button--text{% endif %} color-{{ settings.popover_color_scheme }}"
    >
      {% if using_classic_accounts %}
        {%- comment -%}Keep shopify-account in DOM (hidden) so header CSS grid placement stays correct{%- endcomment -%}
        <shopify-account aria-hidden="true" style="display:none"></shopify-account>
        {% if customer %}
          {%- comment -%}Logged in: link to account page on all screen sizes{%- endcomment -%}
          <a
            href="{{ customer.url | default: routes.account_url }}"
            class="account-button__classic-link"
            {% if account_actions_style != blank %}
              style="{{ account_actions_style }}"
            {% endif %}
          >
            <span
              class="account-button__text header-actions__text-style {% if display_style == 'icon' %}hidden{% else %}mobile:hidden{% endif %}"
            >
              {{ 'content.account_title' | t }}
            </span>
            <span
              class="{% if display_style != 'icon' %}desktop:hidden{% endif %}"
              aria-hidden="true"
            >
              {{ account_icon }}
            </span>
          </a>
        {% else %}
          {%- comment -%}Not logged in: modal trigger on all screen sizes{%- endcomment -%}
          <button
            type="button"
            class="account-button__classic-link account-button__classic-login"
            on:click="#login-modal/showDialog"
            aria-label="{{ 'content.account_title' | t }}"
            {% if account_actions_style != blank %}
              style="{{ account_actions_style }}"
            {% endif %}
          >
            <span
              class="account-button__text header-actions__text-style {% if display_style == 'icon' %}hidden{% else %}mobile:hidden{% endif %}"
            >
              {{ 'content.account_title' | t }}
            </span>
            <span
              class="{% if display_style != 'icon' %}desktop:hidden{% endif %}"
              aria-hidden="true"
            >
              {{ account_icon }}
            </span>
          </button>
        {% endif %}
      {% else %}
        {% if customer and customer['b2b?'] %}
          {%- comment -%}B2B registered: keep shopify-account hidden for grid layout, show custom nav-account pill{%- endcomment -%}
          <shopify-account aria-hidden="true" style="display:none"></shopify-account>
          {%- liquid
            assign fn_init  = customer.first_name | slice: 0 | upcase
            assign ln_init  = customer.last_name  | slice: 0 | upcase
            assign initials = fn_init | append: ln_init
          -%}
          <a href="/pages/my-account" class="va-nav-account" id="va-nav-account-pill"
            aria-label="{{ 'content.account_title' | t }}">
            <span class="va-nav-avatar">{{ initials }}</span>
            <span class="va-nav-info">
              <span class="va-nav-label">{{ customer.first_name }}</span>
              <span class="va-nav-name">{{ customer.company | default: 'Account' }}</span>
            </span>
          </a>
        {% else %}
          {% if customer %}
            {%- comment -%}Non-B2B logged in: keep shopify-account component as-is{%- endcomment -%}
            <shopify-account
              class="va-nav-account--sa"
              menu="{{ customer_account_menu }}"
              {% if account_actions_style != blank %}
                style="{{ account_actions_style }}"
              {% endif %}
            >
              <div class="account-button__fallback"></div>
            </shopify-account>
          {% else %}
            {%- comment -%}Guest: shopify-account styled as pill via ::part(); handles its own click/dialog{%- endcomment -%}
            <shopify-account menu="{{ customer_account_menu }}" class="va-nav-account--sa">
              <span slot="signed-out-avatar" class="va-nav-sa-content">
                <span class="va-nav-avatar va-nav-avatar--guest">
                  <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" aria-hidden="true">
                    <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/>
                    <circle cx="12" cy="7" r="4"/>
                  </svg>
                </span>
                <span class="va-nav-info">
                  <span class="va-nav-label">Partner Portal</span>
                  <span class="va-nav-name">Sign in</span>
                </span>
              </span>
            </shopify-account>
          {% endif %}
        {% endif %}
      {% endif %}
    </div>
    {% if using_classic_accounts %}{% render 'login-modal' %}{% endif %}
  {% endif %}

  <span
    ref="liveRegion"
    class="visually-hidden"
    role="status"
    data-testid="cart-count-live-region"
  ></span>
</header-actions>

<script
  type="module"
  src="{{ 'header-actions.js' | asset_url }}"
  fetchpriority="low"
></script>

{% stylesheet %}
  .header {
    --account-offset-top: calc(
      var(--header-group-height) + (var(--header-height) * var(--transparent-header-offset-boolean))
    );

    &[data-sticky-state='active'] {
      --account-offset-top: calc(var(--header-height) - 1px);
    }
  }

  .account-button {
    /* Remove the background color from the color scheme, we want to inherit the color of the header */
    background: transparent;
	margin-left: 10px;
  }

  .account-button__classic-link {
    display: flex;
    align-items: center;
    justify-content: center;
    min-width: 44px;
    height: 44px;
    text-decoration: none;
    color: inherit;
  }

  button.account-button__classic-login {
    background: none;
    border: 0;
    padding: 0;
    cursor: pointer;
  }

  .account-button__icon,
  .account-button__text {
    color: var(--color-account-icon);
    transition: color var(--header-content-transition-timing);
    -webkit-font-smoothing: antialiased;
  }

  shopify-account {
    --shopify-account-font-heading: var(--font-heading--family);
    --shopify-account-font-heading-weight: var(--font-heading--weight);
    --shopify-account-font-body: var(--font-body--family);
    --shopify-account-font-body-weight: var(--font-body--weight);
    --shopify-account-radius-base: var(--style-border-radius-popover);
    --shopify-account-radius-button: var(--style-border-radius-buttons-primary);
    --shopify-account-radius-button-small: var(--style-border-radius-buttons-primary);
    --shopify-account-radius-input: var(--style-border-radius-buttons-primary);
    --shopify-account-color-background: var(--color-background);
    --shopify-account-color-text: var(--color-foreground);
    --shopify-account-color-accent: var(--color-primary-button-background);
    --shopify-account-color-accent-text: var(--color-primary-button-text);
    --shopify-account-dialog-position-top: var(--account-offset-top);

    &:not(:defined) {
      min-width: 44px;
      height: 44px;
      display: flex;
      justify-content: center;
      align-items: center;
      /* Match the line height of the other buttons */
      line-height: normal;
    }
  }

  .account-button__fallback {
    width: 28px;
    height: 28px;
    border-radius: 50%;
    background-color: var(--shopify-account-color-accent, #0a142f);
  }

  .account-button--text shopify-account {
    color: inherit;
  }

  .cart-drawer {
    display: flex;
    justify-content: center;
    align-items: center;
    @media screen and (min-width: 750px) {
    	margin-inline-end: -8px;
    }
    @media screen and (max-width: 750px) {
    	margin-inline-end: 8px;
    }

    --cart-drawer-padding: var(--padding-xl) var(--padding-xl);
    --cart-drawer-padding-desktop: var(--padding-xl) var(--padding-2xl);
  }

  @media screen and (min-width: 750px) {
    .cart-drawer--text {
      display: flex;
      align-items: center;
    }
  }





  header-actions dialog-component {
    display: contents;
  }

  header-actions {
    display: flex;
	gap: 10px;

    @media screen and (max-width: 749px) {
      justify-self: flex-end;
    }
  }

  @media screen and (min-width: 750px) {
    .header-actions--text {
      gap: var(--gap-xl);
    }

    .header-actions__text-style {
      font-size: var(--header-actions-font-size);
      font-family: var(--header-actions-font-family);
      font-weight: var(--header-actions-font-weight);
      text-transform: var(--header-actions-text-case);
    }
  }

  #header-component:has(overflow-list[minimum-reached]) header-actions {
    justify-self: flex-end;
  }

  @media screen and (min-width: 750px) {
    .header__column--right header-actions {
      margin-inline-start: calc(var(--gap-md) * -1);
    }
  }

  .header-actions__cart-icon {
    --cart-bubble-size: 20px;
    --cart-bubble-top: 4.5px;
    --cart-bubble-right: 2.5px;

    position: relative;
    display: flex;
    align-items: center;
  }

  .header-actions__cart-icon .cart-bubble {
    position: absolute;
    left: 10px;
    bottom: 5px;
  }

  @media screen and (min-width: 750px) {
    .header-actions__cart-icon--text.header-actions__cart-icon .cart-bubble {
      position: relative;
      top: 0;
    }
  }

  .header-actions__cart-icon .cart-bubble__text {
    font-family: var(--font-body--family);
    font-weight: 400;
  }

  .header-actions__cart-icon.header-actions__cart-icon--has-cart svg {
    /* Create donut mask where the cart bubble sits */
    /*mask: radial-gradient(
      calc(var(--cart-bubble-size) + 2px) at calc(100% - var(--cart-bubble-right)) var(--cart-bubble-top),
      transparent 45.45%,
      #fff 45.45%,
      #fff 100%
    );*/
  }


  cart-icon:has(.cart-bubble__text-count:empty) {
    --cart-bubble-size: 10px;
    --cart-bubble-top: 9px;
    --cart-bubble-right: 9px;

    .svg-wrapper {
      --cart-bubble-top: 4px;
      --cart-bubble-right: 4px;
    }
  }

  @media screen and (min-width: 750px) {
    cart-icon.header-actions__cart-icon--text:has(.cart-bubble__text-count:empty) {
      --cart-bubble-right: 2.5px;
    }
  }

  .header-actions__text {
    display: flex;
    align-items: center;
  }

  @media screen and (min-width: 750px) {
    .header-actions__cart-icon--text {
      display: flex;
      align-items: center;
      gap: var(--gap-xs);
    }

    .header__column--right .header-actions--text {
      margin-inline-start: 0;
    }
  }

  /* ===== Icon button (notification + cart) ===== */
  .va-icon-btn {
    width: 40px;
    height: 40px;
    border-radius: 999px;
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--color-foreground);
    position: relative;
    background: transparent;
    border: none;
    cursor: pointer;
    text-decoration: none;
    transition: background 0.15s;
    padding: 0;
  }
  .va-icon-btn:hover {
    background: rgb(var(--color-foreground-rgb) / 0.06);
  }
  @media screen and (max-width: 749px) {
    .va-notif-btn { display: none; }
  }

  /* ===== Custom B2B nav-account pill ===== */
  .va-nav-account {
    display: flex;
    align-items: center;
    gap: 10px;
    padding: 6px 14px 6px 6px;
    border-radius: 999px;
    background: #1D2636;
    color: #F4F5F2;
    border: 1px solid #1D2636;
    text-decoration: none;
    white-space: nowrap;
    transition: opacity 0.15s;
  }
  .va-nav-account:hover { opacity: 0.85; }
  .va-nav-avatar {
    width: 28px;
    height: 28px;
    border-radius: 50%;
    background: #F4F5F2;
    color: #1D2636;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 11px;
    font-weight: 700;
    flex-shrink: 0;
    letter-spacing: 0;
  }
  .va-nav-avatar--guest {
    background: rgba(244, 245, 242, 1);
    color: #A8B0B8;
  }
  .va-nav-info {
    display: flex;
    flex-direction: column;
    line-height: 1.2;
  }
  .va-nav-label {
    font-size: 10px;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: #A8B0B8;
    font-weight: 500;
  }
  .va-nav-name {
    font-size: 12px;
    font-weight: 500;
    color: #F4F5F2;
    max-width: 140px;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }
  @media screen and (max-width: 749px) {
    .va-nav-info { display: none; }
    .va-nav-account { padding: 6px; }
  }
  /* Guest pill: style the shopify-account internal button via ::part() */
  shopify-account.va-nav-account--sa::part(signed-out-avatar) {
    display: flex;
    align-items: center;
    padding: 6px 14px 6px 6px;
    border-radius: 999px;
    background: #1D2636;
    color: #F4F5F2;
    border: 1px solid #1D2636;
    transition: opacity 0.15s;
    min-height: unset;
    height: auto;
    line-height: 1;
  }
  shopify-account.va-nav-account--sa::part(signed-out-avatar):hover { opacity: 0.85; }
  .va-nav-sa-content { display: flex; align-items: center; gap: 10px; }
  @media screen and (max-width: 749px) {
    shopify-account.va-nav-account--sa::part(signed-out-avatar) { padding: 6px; }
    shopify-account.va-nav-account--sa .va-nav-info { display: none; }
  }
{% endstylesheet %}

<script>
(function () {
  var pill = document.getElementById('va-nav-account-pill');
  if (!pill) return;

  function handleToLabel(h) {
    return h.toLowerCase().replace(/[-_]/g, ' ').replace(/\b\w/g, function (c) { return c.toUpperCase(); });
  }
  function applyInfo(d) {
    var companyName  = d.name || d.Name || '';
    var marketHandle = d.shopifyMarketHandle || '';
    var labelEl = pill.querySelector('.va-nav-label');
    var nameEl  = pill.querySelector('.va-nav-name');
    if (marketHandle && labelEl) labelEl.textContent = handleToLabel(marketHandle);
    if (companyName  && nameEl)  nameEl.textContent  = companyName;
  }

  // window.__vaCustomerInfo is set by theme.liquid — just consume it here
  window.__vaCustomerInfo.then(function(data) { if (data) applyInfo(data); });
})();
</script>

{%- if section.settings.account_direct_link -%}
<script>
document.addEventListener('click', function (e) {
  var path = e.composedPath();
  var inSa = path.some(function (el) { return el.localName === 'shopify-account'; });
  if (!inSa) return;
  e.preventDefault();
  e.stopImmediatePropagation();
  window.location.href = '/account';
}, true);
</script>
{%- endif -%}

