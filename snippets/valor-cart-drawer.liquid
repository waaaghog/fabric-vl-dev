@keyframes vcd-spin { to { transform: rotate(360deg); } }
valor-cart-drawer .vcd-rec-card__add[data-state="added"] { background: var(--vcd-crimson); color: #fff; opacity: 1; }
valor-cart-drawer .vcd-rec-card__info { padding: 0 2px; }
