}
valor-cart-drawer .vcd-rec-card__media:hover .vcd-rec-card__add { opacity: 1; }
valor-cart-drawer .vcd-rec-card__add[data-state="loading"] { color: transparent; opacity: 1; }
valor-cart-drawer .vcd-rec-card__add[data-state="loading"]::after {
  content: '';
  position: absolute;
  inset: 0;
  margin: auto;
  width: 11px;
