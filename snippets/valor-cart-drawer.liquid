@keyframes vcd-spin { to { transform: rotate(360deg); } }
valor-cart-drawer .vcd-view-cart-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  background: transparent;
  color: var(--vcd-navy);
  border: 1px solid var(--vcd-border-strong);
  border-radius: 999px;
  padding: 12px 20px;
  font-size: 13px;
  font-weight: 500;
  text-decoration: none;
  transition: border-color 0.15s, background 0.15s;
}
valor-cart-drawer .vcd-view-cart-btn:hover { border-color: var(--vcd-navy); background: var(--vcd-chalk); }

/* ── Recommendations panel — hidden on mobile ───────────────────── */
@media (max-width: 749px) {
  valor-cart-drawer .vcd-rec { display: none; }
}

/* ── Recommendations panel — fixed left sidebar on desktop ──────── */
@media (min-width: 750px) {
  valor-cart-drawer .vcd-rec {
    position: fixed;
    top: var(--vcd-offset-top, 0px);
    right: var(--vcd-panel-width);
    height: calc(100dvh - var(--vcd-offset-top, 0px));
    width: 0;
    z-index: calc(var(--vcd-z) + 1);
    transform: translateX(calc(100% + var(--vcd-panel-width)));
    /*
     * On CLOSE: transform slides out with cart (0.28s, no delay),
     *           width snaps to 0 after the slide finishes (0s duration, 0.28s delay).
     */
    transition: transform 0.28s cubic-bezier(0.4, 0, 0.2, 1) 0s,
                width 0s 0.28s;
    display: flex;
    flex-direction: column;
    background: var(--vcd-chalk);
    overflow: hidden;
  }
  /*
   * On OPEN: transform slides in with cart (0.28s, no delay),
   *          width expands after cart is in place (0.3s, 0.28s delay).
   */
  valor-cart-drawer.vcd-open .vcd-rec {
    width: var(--vcd-rec-width);
    transform: translateX(0);
    border-right: 1px solid var(--vcd-border-strong);
    transition: transform 0.28s cubic-bezier(0.4, 0, 0.2, 1) 0s,
                width 0.3s cubic-bezier(0.22, 1, 0.36, 1) 0.28s;
  }
  valor-cart-drawer .vcd-rec-panel { display: none; }
  valor-cart-drawer .vcd-rec-panel--active {
    display: flex;
    flex-direction: column;
    flex: 1;
    min-height: 0;
  }
  valor-cart-drawer .vcd-rec-list {
    display: grid;
    grid-template-columns: repeat(3, calc((var(--vcd-rec-width) - 2 * var(--drawer-content-padding) - 24px) / 3));
    gap: var(--vcd-item-gap);
    padding: var(--drawer-content-padding);
    overflow-y: auto;
    overflow-x: hidden;
    flex: 1;
    align-content: flex-start;
    scrollbar-width: thin;
    scrollbar-color: var(--vcd-border-strong) transparent;
  }
  valor-cart-drawer .vcd-rec-card {
    flex: unset;
    width: auto;
    display: flex;
    flex-direction: column;
    gap: 5px;
  }
  valor-cart-drawer .vcd-rec-card__media { width: 100%; position: relative; }
  valor-cart-drawer .vcd-rec-card__img {
    width: 100%;
    height: auto;
    aspect-ratio: 1;
    display: block;
    border-radius: 10px;
    overflow: hidden;
    background: var(--vcd-parchment);
  }
}

