{%- doc -%}
  Self-contained valor-style cart drawer.
  Slides in from the right; shares the --vc-* design language with valor-cart page.
  Independent --vcd-* tokens for drawer-specific overrides.

  @param {string} cart_icon     - HTML for the trigger button content (passed from header-actions)
  @param {string} display_style - 'icon' or 'text'
  @param {string} section_id    - Section ID for theme editor targeting
{%- enddoc -%}

{%- liquid
  assign free_shipping_cents = settings.free_shipping_minimum_amount | times: 100
  assign store_credit_ts = 'now' | date: '%s'
  assign store_credit_secret = shop.metafields.valor.connect.value[0]
  assign store_credit_company_location_gid = ''
  if customer and customer.b2b? and customer.current_location
    assign store_credit_company_location_gid = 'gid://shopify/CompanyLocation/' | append: customer.current_location.id
  elsif customer and customer.b2b? and customer.company_contact and customer.company_contact.company and customer.company_contact.company.locations.size > 0
    assign store_credit_company_location_gid = 'gid://shopify/CompanyLocation/' | append: customer.company_contact.company.locations.first.id
  endif
  assign store_credit_token_payload = customer.id | append: '|' | append: store_credit_ts
  if store_credit_company_location_gid != blank
    assign store_credit_token_payload = store_credit_token_payload | append: '|' | append: store_credit_company_location_gid
  endif
  assign store_credit_token = store_credit_token_payload | hmac_sha256: store_credit_secret
  if free_shipping_cents > 0
    if cart.total_price >= free_shipping_cents
      assign shipping_reached = true
      assign shipping_pct = 100
    else
      assign shipping_reached = false
      assign shipping_remaining = free_shipping_cents | minus: cart.total_price
      assign shipping_pct = cart.total_price | times: 100 | divided_by: free_shipping_cents
    endif
  endif
-%}

<style>
  valor-cart-drawer { --vcd-item-gap: {{ settings.vcd_item_gap | default: '12px' }}; }
</style>
<valor-cart-drawer
  class="vcd-host{% if display_style == 'text' %} vcd-host--text{% endif %}"
  data-free-shipping-cents="{{ free_shipping_cents }}"
  data-low-stock="{{ settings.low_stock_threshold | default: 300 }}"
  data-store-credit-api-url="https://valor-middleplatform-prod.azurewebsites.net/api/store-credit/reserve"
  data-store-credit-cap-percent="50"
  data-store-credit-customer-id="{{ customer.id | default: '' }}"
  data-store-credit-company-location-id="{{ store_credit_company_location_gid }}"
  data-store-credit-auth-ts="{{ store_credit_ts }}"
  data-store-credit-auth-token="{{ store_credit_token }}"
  data-store-credit-shop-domain="{{ shop.permanent_domain }}"
>
  {%- comment -%} Panel {%- endcomment -%}
  <div
    class="vcd-panel"
    role="dialog"
    aria-label="{{ 'accessibility.cart' | t }}"
    aria-modal="true"
    data-vcd-panel
    tabindex="-1"
  >
    {%- comment -%} Panel header {%- endcomment -%}
    <div class="vcd-panel-header">
      <div class="vcd-panel-title">
        <span class="vcd-serif">Cart</span>
        <span class="vcd-count-pill" data-vcd-count>{{ cart.item_count }}</span>
      </div>
      <button class="vcd-close-btn" data-vcd-close aria-label="Close cart">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><path d="M18 6 6 18M6 6l12 12"/></svg>
      </button>
    </div>

    {%- comment -%} Freight progress bar {%- endcomment -%}
    {%- if free_shipping_cents > 0 -%}
      <div class="vcd-freight" data-vcd-freight>
        <div class="vcd-freight-label">
          {%- if shipping_reached -%}
            <span class="vcd-freight-msg vcd-freight-msg--met" data-vcd-freight-msg>
              &#x2713;&nbsp; You qualify for free shipping!
            </span>
          {%- else -%}
            <span class="vcd-freight-msg" data-vcd-freight-msg>
              Add <strong data-vcd-freight-remaining>{{ shipping_remaining | money }}</strong> for free shipping
            </span>
          {%- endif -%}
        </div>
        <div class="vcd-freight-bar">
          <div class="vcd-freight-fill" style="width:{{ shipping_pct | default: 0 }}%" data-vcd-freight-fill></div>
        </div>
      </div>
    {%- endif -%}

    {%- comment -%} Scrollable items list {%- endcomment -%}
    <div class="vcd-items-wrap" data-vcd-items>
      {%- if cart.item_count == 0 -%}
        <div class="vcd-empty" data-vcd-empty>
          <svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1" opacity="0.3"><path d="M6 2 3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4Z"/><path d="M3 6h18"/><path d="M16 10a4 4 0 0 1-8 0"/></svg>
          <p>Your cart is empty</p>
          <a href="/search?sort_by=relevance&q=*&filter.p.m.custom.product_designlab=0" class="vcd-empty-link">Start shopping</a>
        </div>
      {%- else -%}
        {%- for item in cart.items -%}
          {%- assign inv = item.variant.inventory_quantity -%}
          {%- assign is_low = false -%}
          {%- if settings.low_stock_threshold > 0 and inv > 0 and inv <= settings.low_stock_threshold -%}
            {%- assign is_low = true -%}
          {%- endif -%}
          {%- assign _ptitle = item.product.title -%}
          {%- if _ptitle == blank -%}
            {%- if item.variant_title == blank or item.variant_title == 'Default Title' -%}
              {%- assign _ptitle = item.title -%}
            {%- else -%}
              {%- assign _vsuffix = ' - ' | append: item.variant_title -%}
              {%- assign _ptitle = item.title | remove: _vsuffix -%}
            {%- endif -%}
          {%- endif -%}
          {%- assign _brand = item.vendor -%}
          <div class="vcd-item{% if is_low %} vcd-item--low{% endif %}" data-vcd-item data-key="{{ item.key }}" data-unit="{{ item.final_price }}" data-brand="{{ _brand | escape }}">
            <div class="vcd-item-thumb">
              {%- if item.image -%}
                <a href="{{ item.url }}">
                  <img src="{{ item.image | image_url: width: 160 }}" alt="{{ item.title | escape }}" width="80" height="80" loading="lazy">
                </a>
              {%- else -%}
                <a href="{{ item.url }}" class="vcd-thumb-placeholder">
                  <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.2" opacity="0.3"><rect x="3" y="3" width="18" height="18" rx="3"/><circle cx="8.5" cy="8.5" r="1.5"/><path d="M21 15l-5-5L5 21"/></svg>
                </a>
              {%- endif -%}
            </div>
            <div class="vcd-item-info">
              {%- if _brand != blank -%}
                <div class="vcd-item-vendor">{{ _brand }}</div>
              {%- endif -%}
              <div class="vcd-item-name">
                <a href="{{ item.url }}">{{ _ptitle }}</a>
              </div>
              {%- unless item.variant_title == 'Default Title' or item.variant_title == blank -%}
                <div class="vcd-item-variant">{{ item.variant_title }}</div>
              {%- endunless -%}
              {%- if item.sku != blank -%}
                <div class="vcd-item-sku">{{ item.sku }}</div>
              {%- endif -%}
            </div>
            <div class="vcd-item-right">
              <div class="vcd-item-top-row">
                <div class="vcd-item-sub" data-vcd-subtotal>{{ item.final_line_price | money }}</div>
                <button class="vcd-remove-btn" data-vcd-remove aria-label="Remove {{ item.title | escape }}">
                  <svg width="14" height="14" viewBox="0 0 14 14" fill="none" stroke="currentColor" stroke-width="1.8" aria-hidden="true"><path d="M2 2l10 10M12 2 2 12"/></svg>
                </button>
              </div>
              <div class="vcd-item-qty">
                <button class="vcd-qty-btn" data-vcd-step="-1" aria-label="Decrease">&#x2212;</button>
                <input class="vcd-qty-input" type="number" value="{{ item.quantity }}" min="0" data-vcd-qty aria-label="Quantity">
                <button class="vcd-qty-btn" data-vcd-step="1" aria-label="Increase">+</button>
              </div>
            </div>
          </div>
        {%- endfor -%}
      {%- endif -%}
    </div>

    {%- comment -%} Sticky footer {%- endcomment -%}
    <div class="vcd-footer{% if cart.item_count == 0 %} vcd-footer--empty{% endif %}" data-vcd-footer>
      <div class="vcd-subtotal-row">
        <span class="vcd-subtotal-label">Subtotal</span>
        <span class="vcd-subtotal-val" data-vcd-total>{{ cart.total_price | money }}</span>
      </div>
      <p class="vcd-footer-note">Shipping and taxes calculated at checkout</p>
      <div class="vcd-note-wrap{% if cart.note != blank %} is-open{% endif %}">
        <button type="button" class="vcd-note-toggle vcd-footer-note" data-vcd-note-toggle>
          <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/><path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"/></svg>
          Add order note
        </button>
        <div class="vcd-note-body">
          <div>
            <textarea class="vcd-note-input" rows="3" placeholder="Add a note to your order…" data-vcd-note>{{ cart.note }}</textarea>
          </div>
        </div>
      </div>
      {%- if customer == blank -%}
      <div class="vcd-footer-login">
        <p class="vcd-login-notice">Sign in to your account to proceed to checkout.</p>
        <a class="vcd-checkout-btn js-shopify-login-trigger">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><rect x="3" y="11" width="18" height="11" rx="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg>
          Sign in to proceed
        </a>
        <a href="/pages/register" class="vcd-view-cart-btn">Create an account</a>
      </div>
      {%- else -%}
      <div class="vcd-footer-actions">
        <a href="{{ routes.cart_url }}" class="vcd-view-cart-btn">View full cart</a>
        <a href="/checkout" class="vcd-checkout-btn">
          <span class="vcd-checkout-label">Checkout</span>
          <svg class="vcd-checkout-arrow" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14M13 5l7 7-7 7"/></svg>
          <svg class="vcd-checkout-spinner" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><circle cx="12" cy="12" r="9" stroke-dasharray="28 57" stroke-linecap="round"/></svg>
        </a>
      </div>
      {%- endif -%}
    </div>
  </div>

  {%- comment -%} Recommendations & recently viewed — sibling of panel, slides in together {%- endcomment -%}
  <div class="vcd-rec" data-vcd-rec>
    <vcd-rec-tabs>
      <div class="vcd-rec-nav" role="tablist">
        <button class="vcd-rec-tab is-active" role="tab" aria-selected="true"  aria-controls="vcd-tab-relate" id="vcd-tab-btn-relate" type="button">You may also like</button>
        <button class="vcd-rec-tab"           role="tab" aria-selected="false" aria-controls="vcd-tab-recent" id="vcd-tab-btn-recent" type="button">Recently viewed</button>
      </div>
    </vcd-rec-tabs>
    <div id="vcd-tab-relate"    class="vcd-rec-panel vcd-rec-panel--active" role="tabpanel" aria-labelledby="vcd-tab-btn-relate">
      <vcd-cart-rec
        class="vcd-rec-list"
        data-product-id="{{ cart.items.last.product_id }}"
        data-currency="{{ cart.currency.iso_code }}"
      ></vcd-cart-rec>
    </div>
    <div id="vcd-tab-recent" class="vcd-rec-panel"               role="tabpanel" aria-labelledby="vcd-tab-btn-recent" hidden>
      <vcd-cart-recent
        class="vcd-rec-list"
        data-currency="{{ cart.currency.iso_code }}"
        data-exclude-id="{{ cart.items.last.product_id }}"
      ></vcd-cart-recent>
    </div>
  </div>
</valor-cart-drawer>

{% stylesheet %}
/* ===== Valor Cart Drawer — independent token scope ===== */
valor-cart-drawer {
  --vcd-navy:        #2B3A55;
  --vcd-navy-deep:   #1D2636;
  --vcd-sky-pale:    #D9EEF6;
  --vcd-crimson:     #C54448;
  --vcd-crimson-soft:#F5DADB;
  --vcd-chalk:       #F4F5F2;
  --vcd-parchment:   #EEEDE7;
  --vcd-steel:       #66717E;
  --vcd-steel-light: #A8B0B8;
  --vcd-white:       #FFFFFF;
  --vcd-green:       #2d7a3f;
  --vcd-amber:       #B07E1A;
  --vcd-border:      #0002;
  --vcd-border-strong: #0003;
  --vcd-panel-width: 420px;
  --vcd-rec-width:   var(--vcd-panel-width);
  --vcd-z: 200;
}

/* Trigger wrapper: must look like part of header-actions */
valor-cart-drawer.vcd-host {
  display: contents;
}


/* Panel */
valor-cart-drawer .vcd-panel {
  position: fixed;
  top: 0;
  right: 0;
  height: calc(100dvh - var(--vcd-offset-top, 0px));
  width: var(--vcd-panel-width);
  max-width: 100vw;
  background: var(--vcd-chalk);
  z-index: calc(var(--vcd-z) + 1);
  display: flex;
  flex-direction: column;
  transform: translateX(100%);
  transition: transform 0.28s cubic-bezier(0.4, 0, 0.2, 1);
  box-shadow: -8px 0 48px rgba(29, 38, 54, 0.14);
}
valor-cart-drawer.vcd-open .vcd-panel {
  transform: translateX(0);
}

/* Panel header */
valor-cart-drawer .vcd-panel-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 18px var(--drawer-content-padding);
  background: var(--vcd-navy-deep);
  flex-shrink: 0;
}
valor-cart-drawer .vcd-panel-title {
  display: flex;
  align-items: center;
  gap: 10px;
  margin-left: 5px;
}
valor-cart-drawer .vcd-serif {
  font-family: var(--font-heading--family, Georgia, serif);
  font-size: 22px;
  font-weight: 400;
  letter-spacing: -0.01em;
  color: var(--vcd-chalk);
  line-height: 1;
}
valor-cart-drawer .vcd-count-pill {
  background: var(--vcd-crimson);
  color: var(--vcd-white);
  font-size: 11px;
  font-weight: 700;
  min-width: 20px;
  height: 20px;
  border-radius: 999px;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  padding: 0 6px;
  letter-spacing: 0;
}
valor-cart-drawer .vcd-close-btn {
  width: 32px;
  height: 32px;
  border-radius: 50%;
  color: var(--vcd-chalk);
  display: flex;
  align-items: center;
  justify-content: center;
  cursor: pointer;
  border: none;
  padding: 0;
  transition: background 0.15s;
  flex-shrink: 0;
  /*background: rgba(244, 245, 242, 0.1);*/
  background: unset;
}
valor-cart-drawer .vcd-close-btn:hover { background: rgba(244, 245, 242, 0.2); }

/* Freight bar */
valor-cart-drawer .vcd-freight {
  padding: 12px 16px 10px;
  background: var(--vcd-navy);
  flex-shrink: 0;
}
valor-cart-drawer .vcd-freight-label { margin-bottom: 7px; }
valor-cart-drawer .vcd-freight-msg {
  font-size: 12px;
  color: var(--vcd-sky-pale);
  font-weight: 500;
}
valor-cart-drawer .vcd-freight-msg--met { color: #7dd48c; }
valor-cart-drawer .vcd-freight-msg strong { color: var(--vcd-white); font-weight: 600; }
valor-cart-drawer .vcd-freight-bar {
  height: 3px;
  background: rgba(255, 255, 255, 0.15);
  border-radius: 2px;
  position: relative;
}
valor-cart-drawer .vcd-freight-fill {
  position: absolute;
  top: 0; left: 0; bottom: 0;
  background: #7dd48c;
  border-radius: 2px;
  transition: width 0.4s ease;
}

/* Items */
valor-cart-drawer .vcd-items-wrap {
  flex: 1;
  min-height: 0;
  overflow-y: auto;
  overscroll-behavior: contain;
  padding: var(--drawer-content-padding) 0;
}
valor-cart-drawer .vcd-items-wrap::-webkit-scrollbar { width: 4px; }
valor-cart-drawer .vcd-items-wrap::-webkit-scrollbar-track { background: transparent; }
valor-cart-drawer .vcd-items-wrap::-webkit-scrollbar-thumb { background: var(--vcd-border-strong); border-radius: 2px; }

/* Empty state */
valor-cart-drawer .vcd-empty {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 12px;
  padding: 60px 24px;
  color: var(--vcd-steel);
  text-align: center;
}
valor-cart-drawer .vcd-empty p { font-size: 14px; font-weight: 500; }
valor-cart-drawer .vcd-empty-link {
  font-size: 12px;
  font-weight: 600;
  color: var(--vcd-navy);
  text-decoration: underline;
  text-underline-offset: 3px;
  text-decoration-color: var(--vcd-border-strong);
}
valor-cart-drawer .vcd-empty-link:hover { text-decoration-color: var(--vcd-navy); }

/* Cart item card */
valor-cart-drawer .vcd-item {
  display: grid;
  grid-template-columns: 80px 1fr auto;
  gap: 12px;
  align-items: center;
  padding: var(--vcd-item-gap) calc(var(--vcd-item-gap) + 2px);
  background: var(--vcd-white);
  margin: 0 var(--drawer-content-padding) 10px;
  border-radius: 12px;
  border: 1px solid var(--vcd-border);
  transition: border-color 0.15s, opacity 0.2s, transform 0.2s;
}
valor-cart-drawer .vcd-item:hover { border-color: var(--vcd-border-strong); }
valor-cart-drawer .vcd-item--low { border-left: 3px solid var(--vcd-amber); }

valor-cart-drawer .vcd-item-thumb {
  width: 80px;
  height: 80px;
  border-radius: 10px;
  background: var(--vcd-parchment);
  overflow: hidden;
  flex-shrink: 0;
  display: flex;
  align-items: center;
  justify-content: center;
}
valor-cart-drawer .vcd-item-thumb img { width: 80px; height: 80px; object-fit: cover; display: block; }
valor-cart-drawer .vcd-item-thumb a { display: flex; align-items: center; justify-content: center; width: 100%; height: 100%; }
valor-cart-drawer .vcd-thumb-placeholder { width: 80px; height: 80px; display: flex; align-items: center; justify-content: center; }

valor-cart-drawer .vcd-item-info { min-width: 0; }
valor-cart-drawer .vcd-item-vendor {
  font-size: 9px;
  letter-spacing: 0.12em;
  text-transform: uppercase;
  color: var(--vcd-crimson);
  font-weight: 600;
  margin-bottom: 2px;
}
valor-cart-drawer .vcd-item-name {
  font-size: 13px;
  font-weight: 500;
  color: var(--vcd-navy-deep);
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}
valor-cart-drawer .vcd-item-name a { color: inherit; text-decoration: none; }
valor-cart-drawer .vcd-item-name a:hover { text-decoration: underline; }
valor-cart-drawer .vcd-item-variant { font-size: 11px; color: var(--vcd-steel); margin-top: 1px; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
valor-cart-drawer .vcd-item-sku {
  font-family: ui-monospace, 'SF Mono', Monaco, monospace;
  font-size: 10px;
  color: var(--vcd-navy);
  background: var(--vcd-sky-pale);
  display: inline-block;
  padding: 1px 6px;
  border-radius: 3px;
  margin-top: 3px;
  font-weight: 500;
  letter-spacing: 0.02em;
}

valor-cart-drawer .vcd-item-right {
  display: flex;
  flex-direction: column;
  align-items: flex-end;
  gap: 8px;
}
valor-cart-drawer .vcd-item-top-row {
  display: flex;
  align-items: center;
  gap: 6px;
}
valor-cart-drawer .vcd-item-sub {
  font-size: 14px;
  line-height: 20px;
  font-weight: 600;
  color: var(--vcd-navy-deep);
  letter-spacing: -0.01em;
  white-space: nowrap;
}
valor-cart-drawer .vcd-item-qty {
  display: flex;
  align-items: center;
  border: 1px solid var(--vcd-border-strong);
  border-radius: 999px;
  background: var(--vcd-white);
  overflow: hidden;
  transition: border-color 0.15s;
}
valor-cart-drawer .vcd-item-qty:focus-within { border-color: var(--vcd-navy-deep); }
valor-cart-drawer .vcd-qty-btn {
  width: 26px;
  height: 28px;
  display: flex;
  align-items: center;
  justify-content: center;
  color: var(--vcd-navy-deep);
  font-size: 13px;
  border: none;
  padding: 0;
  background: none;
  cursor: pointer;
  transition: background 0.15s;
  flex-shrink: 0;
}
valor-cart-drawer .vcd-qty-btn:hover { background: var(--vcd-chalk); }
valor-cart-drawer .vcd-qty-input {
  width: 36px;
  border: none;
  outline: none;
  text-align: center;
  font-size: 12px;
  font-weight: 600;
  color: var(--vcd-navy-deep);
  background: transparent;
  -moz-appearance: textfield;
  appearance: textfield;
  font-family: inherit;
}
valor-cart-drawer .vcd-qty-input::-webkit-outer-spin-button,
valor-cart-drawer .vcd-qty-input::-webkit-inner-spin-button { -webkit-appearance: none; margin: 0; }
valor-cart-drawer .vcd-remove-btn {
  width: 20px;
  height: 20px;
  border-radius: 50%;
  background: transparent;
  color: var(--vcd-steel-light);
  display: flex;
  align-items: center;
  justify-content: center;
  border: none;
  padding: 0;
  cursor: pointer;
  transition: all 0.15s;
  flex-shrink: 0;
}
valor-cart-drawer .vcd-remove-btn:hover { background: var(--vcd-crimson-soft); color: var(--vcd-crimson); }

/* Footer */
valor-cart-drawer .vcd-footer {
  padding: 16px 24px 24px;
  background: var(--vcd-white);
  border-top: 1px solid var(--vcd-border);
  flex-shrink: 0;
}
valor-cart-drawer .vcd-footer--empty .vcd-subtotal-row,
valor-cart-drawer .vcd-footer--empty .vcd-footer-note,
valor-cart-drawer .vcd-footer--empty .vcd-note-wrap,
