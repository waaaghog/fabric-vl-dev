valor-cart-drawer .vcd-rec-card__add {
  position: absolute;
  bottom: -5px; right: 4px;
  width: 28px; height: 28px;
  border-radius: 50%;
  border: 1px solid rgba(0,0,0,0.12);
  background: rgba(255,255,255,0.95);
  color: var(--vcd-navy-deep);
  display: flex;
  align-items: center;
