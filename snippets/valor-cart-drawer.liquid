valor-cart-drawer .vcd-rec-card__price { font-size: 11px; color: var(--vcd-steel); margin: 2px 0 0; }
valor-cart-drawer .vcd-rec-card__compare { text-decoration: line-through; color: var(--vcd-steel-light); margin-right: 3px; }

/* Body scroll lock */
body.vcd-scroll-locked { overflow: hidden; }

/* Responsive */
@media (max-width: 480px) {
  valor-cart-drawer { --vcd-panel-width: 100vw; }
}
{% endstylesheet %}

{% javascript %}
(function () {
  /* Shared overlay — same singleton as valor-menu-drawer; whichever loads first creates it */
  function _getValorOverlay() {
    if (window.__valorDrawerOverlay) return window.__valorDrawerOverlay;
    const el = document.createElement('div');
    el.className = 'valor-drawer-overlay';
    document.body.appendChild(el);
    const ov = {
      el,
      _handler: null,
      show(onClose) {
        el.classList.add('valor-open');
        if (this._handler) el.removeEventListener('click', this._handler);
        this._handler = () => { this.hide(); onClose && onClose(); };
        el.addEventListener('click', this._handler, { once: true });
      },
      hide() {
        el.classList.remove('valor-open');
        if (this._handler) { el.removeEventListener('click', this._handler); this._handler = null; }
      },
    };
    return (window.__valorDrawerOverlay = ov);
  }

  class ValorCartDrawer extends HTMLElement {
    connectedCallback() {
      this._freeShippingCents = parseInt(this.dataset.freeShippingCents || '0', 10);
      this._lowStock = parseInt(this.dataset.lowStock || '0', 10);
      this._bindEvents();
      this._initCricket();
      // Listen for theme cart update events (add-to-cart from product page, etc.)
      document.addEventListener('cart:update', this._onThemeCartUpdate.bind(this));
    }

    _initCricket() {
      const btn = this.querySelector('.vcd-checkout-btn');
      if (!btn || !window.__vaCustomerInfo) return;

      // Hide immediately for all B2B customers; restore below if not CRICKET
      btn.style.display = 'none';

      window.__vaCustomerInfo.then(function(data) {
        if (!data) { btn.style.display = ''; return; }
        const market = (data.shopifyMarketHandle || data.ShopifyMarketHandle || '').toUpperCase();
        if (market !== 'CRICKET-WIRELESS') btn.style.display = '';
      });
    }

    disconnectedCallback() {
      document.removeEventListener('cart:update', this._onThemeCartUpdate.bind(this));
    }

    /* ===== Open / Close ===== */
    open() {
      this.classList.add('vcd-open');
      document.body.classList.add('vcd-scroll-locked');
      _getValorOverlay().show(() => this.close());
      const panel = this.querySelector('[data-vcd-panel]');
      if (panel) setTimeout(() => panel.focus(), 280);
    }

    close() {
      this.classList.remove('vcd-open');
      document.body.classList.remove('vcd-scroll-locked');
      _getValorOverlay().hide();
      const trigger = document.querySelector('[data-vcd-open]');
      if (trigger) trigger.focus();
    }

    /* ===== Events ===== */
    _bindEvents() {
      // Open via custom event dispatched by trigger button in header
      document.addEventListener('vcd:open-cart', () => this.open());

      // Close button
      this.querySelector('[data-vcd-close]')?.addEventListener('click', () => this.close());

      // Single-address checkout — write a single-entry _order so order processing
      // has the BC customer info even without the distribution component.
      const checkoutBtn = this.querySelector('.vcd-checkout-btn[href]');
      if (checkoutBtn) {
        checkoutBtn.addEventListener('click', async (e) => {
          e.preventDefault();
          const href = checkoutBtn.href;
          checkoutBtn.dataset.loading = '';
          let blockCheckout = false;
          try {
            const [customerData, cartRes] = await Promise.all([
              window.__vaCustomerInfo,
              fetch('/cart.js'),
            ]);
            const shipTo = customerData?.defaultShipTo || null;
            const cart  = cartRes.ok ? await cartRes.json() : null;
            const erpNo = customerData?.No || customerData?.no || '';
            if (!erpNo) {
              const storeCreditAttrs = await this._prepareStoreCreditForCheckout(cart, customerData);
              if (Object.keys(storeCreditAttrs).length) {
                await fetch('/cart/update.js', {
                  method: 'POST',
                  headers: { 'Content-Type': 'application/json' },
                  body: JSON.stringify({ attributes: storeCreditAttrs }),
                });
              }
              window.location.href = href;
              return;
            }

            const items = {};
            if (cart?.items?.length) {
              for (const item of cart.items) {
                const vid = String(item.variant_id);
                items[vid] = (items[vid] || 0) + item.quantity;
              }
            }
            const attrs = {
              _order: JSON.stringify([{
                id:          shipTo?.systemId   || '',
                bc_customer: shipTo?.customerNo || '',
                bc_ship_to:  shipTo?.code       || '',
                addr:        shipTo?.addr       || '',
                contact:     { name: shipTo?.contact || '', phone: shipTo?.phoneNo || '' },
                items,
              }]),
              _address: JSON.stringify([{
                id:                	shipTo?.systemId          || '',
                bc_customer:       	shipTo?.customerNo        || '',
                bc_ship_to:        	shipTo?.code              || '',
                company:           	shipTo?.company           || '',
                address:           	shipTo?.address           || '',
                address2:          	shipTo?.address2          || '',
                city:              	shipTo?.city              || '',
                contact:           	shipTo?.contact           || '',
                phone:           	shipTo?.phoneNo           || '',
                country: 			shipTo?.countryRegionCode || '',
                zip:          		shipTo?.postCode          || '',
                state:             	shipTo?.state             || '',
              }]),
              _lineitems: '',
            };

            Object.assign(attrs, await this._prepareStoreCreditForCheckout(cart, customerData));

            await fetch('/cart/update.js', {
              method: 'POST',
              headers: { 'Content-Type': 'application/json' },
              body: JSON.stringify({ attributes: attrs }),
            });
          } catch (err) {
            if (err?.storeCreditCheckoutBlock || /store credit/i.test(err?.message || '')) {
              blockCheckout = true;
              const label = checkoutBtn.querySelector('.vcd-checkout-label');
              if (label) label.textContent = 'Store credit unavailable';
              checkoutBtn.title = err?.message || 'Store credit could not be prepared.';
            }
          }
          if (blockCheckout) {
            delete checkoutBtn.dataset.loading;
            setTimeout(() => {
              const label = checkoutBtn.querySelector('.vcd-checkout-label');
              if (label) label.textContent = 'Checkout';
            }, 2600);
            return;
          }
          window.location.href = href;
        });
      }

      // Escape key
      document.addEventListener('keydown', (e) => {
        if (e.key === 'Escape' && this.classList.contains('vcd-open')) this.close();
      });

      // Qty steppers
      this.addEventListener('click', (e) => {
        const btn = e.target.closest('[data-vcd-step]');
        if (!btn) return;
        const itemEl = btn.closest('[data-vcd-item]');
        if (!itemEl) return;
        const input = itemEl.querySelector('[data-vcd-qty]');
        if (!input) return;
        const step = parseInt(btn.getAttribute('data-vcd-step'), 10);
        const next = Math.max(0, parseInt(input.value || '0', 10) + step);
        input.value = next;
        this._changeQty(itemEl, next);
      });

      // Cart note toggle
      this.addEventListener('click', (e) => {
        const toggle = e.target.closest('[data-vcd-note-toggle]');
        if (!toggle) return;
        const wrap = toggle.closest('.vcd-note-wrap');
        wrap.classList.toggle('is-open');
        if (wrap.classList.contains('is-open')) wrap.querySelector('[data-vcd-note]')?.focus();
      });

      // Cart note save
      this.addEventListener('change', (e) => {
        const note = e.target.closest('[data-vcd-note]');
        if (!note) return;
        fetch('/cart/update.js', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ note: note.value })
        });
      });

      // Direct qty input
      this.addEventListener('change', (e) => {
        const input = e.target.closest('[data-vcd-qty]');
        if (!input) return;
        const itemEl = input.closest('[data-vcd-item]');
        if (!itemEl) return;
        const qty = Math.max(0, parseInt(input.value || '0', 10));
        input.value = qty;
        this._changeQty(itemEl, qty);
      });

      // Remove
      this.addEventListener('click', (e) => {
        if (!e.target.closest('[data-vcd-remove]')) return;
        const itemEl = e.target.closest('[data-vcd-item]');
        if (!itemEl) return;
        this._changeQty(itemEl, 0, true);
      });
    }

    _storeCreditApiUrl(kind) {
      const apiUrl = (this.dataset.storeCreditApiUrl || '').trim();
      if (!apiUrl) return '';
      const cleanUrl = apiUrl.replace(/\/+$/, '');
      if (new RegExp('/' + kind + '$', 'i').test(cleanUrl)) return cleanUrl;
      if (/\/reserve$/i.test(cleanUrl)) return cleanUrl.replace(/\/reserve$/i, '/' + kind);
      if (/\/quote$/i.test(cleanUrl)) return cleanUrl.replace(/\/quote$/i, '/' + kind);
      if (/\/release$/i.test(cleanUrl)) return cleanUrl.replace(/\/release$/i, '/' + kind);
      return cleanUrl + '/' + kind;
    }

    _extractStoreCreditCustomerNo(data) {
      if (!data) return '';
      return String(
        data.CustomerNo ||
        data.customerNo ||
        data.customer_no ||
        data.No ||
        data.no ||
        data.defaultShipTo?.customerNo ||
        data.defaultShipTo?.CustomerNo ||
        data.defaultShipTo?.No ||
        data.defaultShipTo?.no ||
        ''
      ).trim();
    }

    _amountToCents(value) {
      if (value === undefined || value === null || value === '') return 0;
      const amount = Number(value);
      return Number.isFinite(amount) ? Math.round(amount * 100) : 0;
    }

    _storeCreditClearAttrs() {
      return {
        _store_credit_mode: '',
        _store_credit_status: '',
        _store_credit_reservation_id: '',
        _store_credit_customer_id: '',
        _store_credit_customer_no: '',
        _store_credit_company_location_id: '',
        _store_credit_available: '',
        _store_credit_reserved: '',
        _store_credit_cart_total: '',
        _store_credit_cap_percent: '',
        _store_credit_period: '',
        _store_credit_shopify_transaction_id: '',
        _store_credit_shopify_account_id: '',
        _store_credit_shopify_balance_after: '',
        _store_credit_shopify_status: '',
        _store_credit_payload: '',
      };
    }

    async _releaseStoreCreditReservationFromCart(cart, customerData) {
      const attrs = cart?.attributes || {};
      const reservationId = String(attrs._store_credit_reservation_id || '').trim();
      if (!reservationId) return;

      const releaseUrl = this._storeCreditApiUrl('release');
      if (!releaseUrl) return;

      const customerNo = String(attrs._store_credit_customer_no || this._extractStoreCreditCustomerNo(customerData) || '').trim();
      const response = await fetch(releaseUrl, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json', 'Accept': 'application/json' },
        body: JSON.stringify({
          shop: this.dataset.storeCreditShopDomain || Shopify.shop,
          customer_id: this.dataset.storeCreditCustomerId || '',
          customer_no: customerNo,
          company_location_id: this.dataset.storeCreditCompanyLocationId || '',
          ts: Number(this.dataset.storeCreditAuthTs || 0),
          token: this.dataset.storeCreditAuthToken || '',
          reservation_id: reservationId,
          currency: cart?.currency || 'USD',
          reason: 'drawer_checkout_reprepare',
        }),
      });
      const data = await response.json().catch(() => ({}));
      if (!response.ok || data.ok === false) {
        throw new Error(data.error || 'Store credit release failed.');
      }
    }

    async _prepareStoreCreditForCheckout(cart, customerData) {
      const reserveUrl = this._storeCreditApiUrl('reserve');
      if (!reserveUrl || !this.dataset.storeCreditCustomerId) return {};

      customerData = customerData || await (window.__vaCustomerInfo || Promise.resolve(null));
      cart = cart || await fetch('/cart.js').then((r) => r.json()).catch(() => null);
      await this._releaseStoreCreditReservationFromCart(cart, customerData);

      const clearAttrs = this._storeCreditClearAttrs();
      const customerNo = this._extractStoreCreditCustomerNo(customerData);
      if (!customerNo || !cart) return clearAttrs;

      const cartTotalCents = cart.total_price || 0;
      const cartTotal = Number((cartTotalCents / 100).toFixed(2));
      const capPercent = parseFloat(this.dataset.storeCreditCapPercent || '50') || 50;
      const basePayload = {
        shop: this.dataset.storeCreditShopDomain || Shopify.shop,
        customer_id: this.dataset.storeCreditCustomerId || '',
        customer_no: customerNo,
        company_location_id: this.dataset.storeCreditCompanyLocationId || '',
        ts: Number(this.dataset.storeCreditAuthTs || 0),
        token: this.dataset.storeCreditAuthToken || '',
        currency: cart.currency || 'USD',
        cart_total: cartTotal,
        cap_percent: capPercent,
      };

      const quoteResponse = await fetch(this._storeCreditApiUrl('quote'), {
        method: 'POST',
        headers: { 'Content-Type': 'application/json', 'Accept': 'application/json' },
        body: JSON.stringify(basePayload),
      });
      const quoteData = await quoteResponse.json().catch(() => ({}));
      if (!quoteResponse.ok || quoteData.ok === false) {
        throw new Error(quoteData.error || 'Store credit quote failed.');
      }

      const quote = quoteData.data || {};
      const maxRedeemCents = Number.isFinite(Number(quote.maxRedeemCents))
        ? Number(quote.maxRedeemCents)
        : this._amountToCents(quote.maxRedeem);
      if (maxRedeemCents <= 0) return clearAttrs;

      const reservationId = 'SC-DRAWER-' + Date.now().toString(36).toUpperCase() + '-' + Math.random().toString(36).slice(2, 8).toUpperCase();
      const reserveResponse = await fetch(reserveUrl, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json', 'Accept': 'application/json' },
        body: JSON.stringify(Object.assign({}, basePayload, {
          amount: Number((maxRedeemCents / 100).toFixed(2)),
          expires_in_days: 30,
          reservation_id: reservationId,
        })),
      });
      const reserveData = await reserveResponse.json().catch(() => ({}));
      if (!reserveResponse.ok || reserveData.ok === false) {
        throw new Error(reserveData.error || 'Store credit reserve failed.');
      }

      const result = reserveData.data || {};
      const reservedCents = this._amountToCents(result.amount) || maxRedeemCents;
      const payload = {
        mode: 'shopify_store_credit',
        reservation_id: reservationId,
        customer_id: this.dataset.storeCreditCustomerId || '',
        customer_no: result.customerNo || customerNo,
        company_location_id: this.dataset.storeCreditCompanyLocationId || '',
        available_amount: ((Number.isFinite(Number(quote.availableCents)) ? Number(quote.availableCents) : this._amountToCents(quote.available)) / 100 || 0).toFixed(2),
        reserved_amount: (reservedCents / 100).toFixed(2),
        cart_total: cartTotal.toFixed(2),
        cap_percent: capPercent,
        period: result.period || quote.period || '',
        shopify_transaction_id: result.transactionId || '',
        shopify_account_id: result.accountId || '',
        shopify_balance_after: result.balanceAfterTransaction || '',
        shopify_store_credit_status: result.status || '',
      };

      return Object.assign(clearAttrs, {
        _store_credit_mode: payload.mode,
        _store_credit_status: 'reserved',
        _store_credit_reservation_id: payload.reservation_id,
        _store_credit_customer_id: payload.customer_id,
        _store_credit_customer_no: payload.customer_no,
        _store_credit_company_location_id: payload.company_location_id,
        _store_credit_available: payload.available_amount,
        _store_credit_reserved: payload.reserved_amount,
        _store_credit_cart_total: payload.cart_total,
        _store_credit_cap_percent: String(payload.cap_percent),
        _store_credit_period: payload.period,
        _store_credit_shopify_transaction_id: payload.shopify_transaction_id,
        _store_credit_shopify_account_id: payload.shopify_account_id,
        _store_credit_shopify_balance_after: payload.shopify_balance_after,
        _store_credit_shopify_status: payload.shopify_store_credit_status,
        _store_credit_payload: JSON.stringify(payload),
      });
    }

    /* ===== AJAX cart update ===== */
    _changeQty(itemEl, qty, isRemove) {
      const key = itemEl.getAttribute('data-key');
      if (!key) return;
      itemEl.style.opacity = '0.5';
      itemEl.style.pointerEvents = 'none';

      fetch('/cart/change.js', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json', 'X-Requested-With': 'XMLHttpRequest' },
        body: JSON.stringify({ id: key, quantity: isRemove ? 0 : qty }),
      })
        .then((r) => r.json())
        .then((cart) => {
          if (isRemove || qty === 0) {
            itemEl.style.transform = 'translateX(12px)';
            itemEl.style.opacity = '0';
            setTimeout(() => {
              itemEl.remove();
              this._applyCart(cart);
            }, 200);
          } else {
            itemEl.style.opacity = '1';
            itemEl.style.pointerEvents = '';
            const unitCents = parseInt(itemEl.getAttribute('data-unit'), 10) || 0;
            const subEl = itemEl.querySelector('[data-vcd-subtotal]');
            if (subEl) subEl.textContent = this._money((unitCents * qty) / 100);
            this._applyCart(cart);
          }
        })
        .catch(() => {
          itemEl.style.opacity = '1';
          itemEl.style.pointerEvents = '';
        });
    }

    /* ===== Theme cart:update event (external add-to-cart) ===== */
    _onThemeCartUpdate(e) {
      const apply = (cart) => {
        this._rebuildItems(cart);
        this._applyCart(cart);
        if (!this.classList.contains('vcd-open') && !e.detail?.noDrawer && !window.__vpNoDrawer) this.open();
      };
      // Use cart data from event detail when available (avoids a second network request)
      if (e.detail?.cart) { apply(e.detail.cart); return; }
      fetch('/cart.js', { headers: { 'X-Requested-With': 'XMLHttpRequest' } })
        .then((r) => r.json())
        .then(apply);
    }

    /* ===== Apply cart totals / freight bar ===== */
    _applyCart(cart) {
      const total = cart.total_price ?? 0;
      const itemCount = cart.item_count ?? 0;

      // Count pill
      const pill = this.querySelector('[data-vcd-count]');
      if (pill) pill.textContent = itemCount;

      // Total
      const totalEl = this.querySelector('[data-vcd-total]');
      if (totalEl) totalEl.textContent = this._money(total / 100);

      // Footer visibility
      const footer = this.querySelector('[data-vcd-footer]');
      if (footer) footer.classList.toggle('vcd-footer--empty', itemCount === 0);

      // Freight bar
      if (this._freeShippingCents > 0) {
        const pct = Math.min(100, Math.round((total / this._freeShippingCents) * 100));
        const fill = this.querySelector('[data-vcd-freight-fill]');
        if (fill) fill.style.width = pct + '%';
        const msg = this.querySelector('[data-vcd-freight-msg]');
        if (msg) {
          if (total >= this._freeShippingCents) {
            msg.className = 'vcd-freight-msg vcd-freight-msg--met';
            msg.innerHTML = '&#x2713;&nbsp; You qualify for free shipping!';
          } else {
            const rem = this._freeShippingCents - total;
            msg.className = 'vcd-freight-msg';
            msg.innerHTML = `Add <strong data-vcd-freight-remaining>${this._money(rem / 100)}</strong> for free shipping`;
          }
        }
      }

      // Update theme header cart bubble (theme's own elements)
      document.querySelectorAll('[data-cart-count], .cart-bubble__text-count').forEach((el) => {
        el.textContent = itemCount > 99 ? '99+' : (itemCount || '');
        if (el.classList.contains('cart-bubble__text-count')) {
          el.dataset.cartCountValue = String(itemCount || 0);
          el.classList.toggle('hidden', itemCount === 0);
        }
      });
    }

    /* ===== Rebuild items list from /cart.js ===== */
    _rebuildItems(cart) {
      const wrap = this.querySelector('[data-vcd-items]');
      if (!wrap) return;

      if (!cart.items || cart.items.length === 0) {
        wrap.innerHTML = `
          <div class="vcd-empty" data-vcd-empty>
            <svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1" opacity="0.3"><path d="M6 2 3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4Z"/><path d="M3 6h18"/><path d="M16 10a4 4 0 0 1-8 0"/></svg>
            <p>Your cart is empty</p>
            <a href="/search?sort_by=relevance&q=*&filter.p.m.custom.product_designlab=0" class="vcd-empty-link">Start shopping</a>
          </div>`;
        return;
      }

      const existingBrands = new Map(
        Array.from(wrap.querySelectorAll('[data-vcd-item][data-key]')).map((el) => [
          el.dataset.key,
          el.dataset.brand || el.querySelector('.vcd-item-vendor')?.textContent?.trim() || '',
        ])
      );

      wrap.innerHTML = cart.items
        .map((item) => this._buildItemHtml({ ...item, _displayBrand: this._getItemBrand(item, false) || existingBrands.get(item.key) || item.vendor || '' }))
        .join('');
    }

    _buildItemHtml(item) {
      const isLow = this._lowStock > 0 && item.variant_inventory_quantity > 0 && item.variant_inventory_quantity <= this._lowStock;
      const variant = item.variant_title && item.variant_title !== 'Default Title'
        ? `<div class="vcd-item-variant">${this._esc(item.variant_title)}</div>` : '';
      const sku = item.sku ? `<div class="vcd-item-sku">${this._esc(item.sku)}</div>` : '';
      const brand = this._getItemBrand(item);
      const vendor = brand ? `<div class="vcd-item-vendor">${this._esc(brand)}</div>` : '';
      const img = item.image
        ? `<a href="${item.url}"><img src="${item.image}" alt="${this._esc(item.title)}" width="80" height="80" loading="lazy"></a>`
        : `<a href="${item.url}" class="vcd-thumb-placeholder"><svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.2" opacity="0.3"><rect x="3" y="3" width="18" height="18" rx="3"/><circle cx="8.5" cy="8.5" r="1.5"/><path d="M21 15l-5-5L5 21"/></svg></a>`;

      return `<div class="vcd-item${isLow ? ' vcd-item--low' : ''}" data-vcd-item data-key="${item.key}" data-unit="${item.final_price}" data-brand="${this._esc(brand)}">
        <div class="vcd-item-thumb">${img}</div>
        <div class="vcd-item-info">
          ${vendor}
          <div class="vcd-item-name"><a href="${item.url}">${this._esc(item.product_title)}</a></div>
          ${variant}${sku}
        </div>
        <div class="vcd-item-right">
          <div class="vcd-item-top-row">
            <div class="vcd-item-sub" data-vcd-subtotal>${this._money(item.final_line_price / 100)}</div>
            <button class="vcd-remove-btn" data-vcd-remove aria-label="Remove ${this._esc(item.title)}">
              <svg width="14" height="14" viewBox="0 0 14 14" fill="none" stroke="currentColor" stroke-width="1.8" aria-hidden="true"><path d="M2 2l10 10M12 2 2 12"/></svg>
            </button>
          </div>
          <div class="vcd-item-qty">
            <button class="vcd-qty-btn" data-vcd-step="-1" aria-label="Decrease">&#x2212;</button>
            <input class="vcd-qty-input" type="number" value="${item.quantity}" min="0" data-vcd-qty aria-label="Quantity">
            <button class="vcd-qty-btn" data-vcd-step="1" aria-label="Increase">+</button>
          </div>
        </div>
      </div>`;
    }

    _getLineProperty(item, name) {
      const props = item?.properties;
      if (!props) return '';
      if (Array.isArray(props)) {
        const match = props.find((prop) => prop?.[0] === name || prop?.name === name || prop?.key === name);
        return match?.[1] || match?.value || '';
      }
      return props[name] || '';
    }

    _getItemBrand(item, includeVendor = true) {
      return item?._displayBrand || this._getLineProperty(item, '_brand') || item?.product_brand || (includeVendor ? item?.vendor : '') || '';
    }

    _money(amount) {
      return new Intl.NumberFormat('en-US', { style: 'currency', currency: 'USD' }).format(amount);
    }

    _esc(str) {
      return String(str || '').replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;').replace(/"/g, '&quot;');
    }
  }

  customElements.define('valor-cart-drawer', ValorCartDrawer);
})();

/* ── Rec strip custom elements (self-contained, no external deps) ── */
(function () {
  const _bagSvg = `<svg aria-hidden="true" width="14" height="14" viewBox="0 0 20 20" fill="none" xmlns="http://www.w3.org/2000/svg"><path stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M16.608 9.421V6.906H3.392v8.016c0 .567.224 1.112.624 1.513.4.402.941.627 1.506.627H8.63M8.818 3h2.333c.618 0 1.212.247 1.649.686a2.35 2.35 0 0 1 .683 1.658v1.562H6.486V5.344c0-.622.246-1.218.683-1.658A2.33 2.33 0 0 1 8.82 3"/><path stroke="currentColor" stroke-linecap="round" stroke-width="1.5" d="M14.608 12.563v5m2.5-2.5h-5"/></svg>`;

  function _recMoney(cents, currency) {
    return new Intl.NumberFormat(document.documentElement.lang || 'en', {
      style: 'currency', currency, minimumFractionDigits: 2,
    }).format(cents);
  }

  function _recBuildCard(p, currency) {
    const v = p.variants?.[0];
    // Recommendations API returns price as integer cents; Collections API returns dollar string (e.g. "8.00")
    const toAmt = n => n == null ? null : (typeof n === 'string' ? parseFloat(n) : n / 100);
    const priceAmt   = toAmt(v?.price);
    const compareAmt = toAmt(v?.compare_at_price);
    const price   = priceAmt != null ? _recMoney(priceAmt, currency) : '';
    const compare = compareAmt > priceAmt ? _recMoney(compareAmt, currency) : null;
    const raw = p.featured_image ?? p.images?.[0];
    const imgUrl = typeof raw === 'string' ? raw : raw?.src ?? '';
    const imgSrc = imgUrl ? imgUrl.replace(/\?.*$/, '') + '?width=220' : '';
    const url = `/products/${p.handle}`;
    const isMulti = (p.variants?.length ?? 1) > 1;
    const avail = v?.available !== false;
    const title = p.title.replace(/"/g, '&quot;');
    const addBtn = isMulti
      ? `<a href="${url}" class="vcd-rec-card__add" aria-label="View options">${_bagSvg}</a>`
      : (avail && v?.id ? `<button class="vcd-rec-card__add" data-rec-add data-variant-id="${v.id}" aria-label="Add to cart" type="button">${_bagSvg}</button>` : '');
    return `<div class="vcd-rec-card">
      <div class="vcd-rec-card__media">
        <a href="${url}" class="vcd-rec-card__img">
          ${imgSrc ? `<img src="${imgSrc}" alt="${title}" loading="lazy" width="110" height="110">` : ''}
          ${compare ? '<span class="vcd-rec-card__badge">Sale</span>' : ''}
        </a>${addBtn}
      </div>
      <div class="vcd-rec-card__info">
        <a href="${url}" style="text-decoration:none"><p class="vcd-rec-card__title">${p.title}</p></a>
        <p class="vcd-rec-card__price">${compare ? `<s class="vcd-rec-card__compare">${compare}</s> ` : ''}${price}</p>
      </div>
    </div>`;
  }

  async function _recAddVariant(variantId, btn) {
    if (!variantId || btn.disabled) return;
    btn.disabled = true; btn.dataset.state = 'loading';
    try {
      const res = await fetch('/cart/add.js', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json', 'X-Requested-With': 'XMLHttpRequest' },
        body: JSON.stringify({ id: Number(variantId), quantity: 1 }),
      });
      if (!res.ok) throw new Error();
      const cart = await fetch('/cart.js', { headers: { 'X-Requested-With': 'XMLHttpRequest' } }).then(r => r.json());
      btn.dataset.state = 'added';
      document.dispatchEvent(new CustomEvent('cart:update', { bubbles: true, detail: { cart, resource: cart } }));
      setTimeout(() => { delete btn.dataset.state; btn.disabled = false; }, 1500);
    } catch { delete btn.dataset.state; btn.disabled = false; }
  }

  if (!customElements.get('vcd-cart-rec')) {
    customElements.define('vcd-cart-rec', class extends HTMLElement {
      connectedCallback() {
        const { productId, currency = 'USD' } = this.dataset;
        const self = this;
        const fetchRec = productId
          ? fetch(`/recommendations/products.json?product_id=${productId}&limit=15`)
              .then(r => r.ok ? r.json() : Promise.reject())
              .then(({ products = [] }) => products)
          : Promise.resolve([]);
        // /collections API returns available: undefined (only variants have it); check both.
        const _avail = p => p.available === true || (Array.isArray(p.variants) && p.variants.some(v => v.available));

        /*
        // ── Original recommendation logic (contextual, based on last cart product) ──
        fetchRec
          .then(products => {
            if (products.length >= 15) return products;
            // Pad with recently viewed products
            let viewedIds = [];
            try { viewedIds = JSON.parse(localStorage.getItem('viewedProducts') || '[]'); } catch {}
            if (productId) viewedIds = viewedIds.filter(id => id.toString() !== productId.toString());
            const seen = new Set(products.map(p => p.id.toString()));
            const needed = viewedIds.filter(id => !seen.has(id.toString())).slice(0, 15 - products.length);
            if (!needed.length) return products;
            return fetch(`/search/suggest.json?q=${encodeURIComponent(needed.map(id => 'id:' + id).join(' OR '))}&resources[type]=product&resources[limit]=15`)
              .then(r => r.ok ? r.json() : { resources: {} })
              .then(data => {
                const found = data.resources?.results?.products ?? [];
                const ordered = needed.map(id => found.find(p => p.id.toString() === id.toString())).filter(p => p && _avail(p));
                return [...products, ...ordered];
              });
          })
        // ── End original recommendation logic ──
        */

        // Pick 3 guaranteed non-overlapping random pages from top 1500 best-sellers (50 pages × 30)
        const _pages = new Set();
        while (_pages.size < 3) _pages.add(Math.floor(Math.random() * 50) + 1);
        const [page1, page2, page3] = [..._pages];
        Promise.all([
          fetch(`/collections/all/products.json?limit=30&page=${page1}&sort_by=best-selling`).then(r => r.ok ? r.json() : { products: [] }),
          fetch(`/collections/all/products.json?limit=30&page=${page2}&sort_by=best-selling`).then(r => r.ok ? r.json() : { products: [] }),
          fetch(`/collections/all/products.json?limit=30&page=${page3}&sort_by=best-selling`).then(r => r.ok ? r.json() : { products: [] }),
        ])
          .then(([r1, r2, r3]) => {
            const seen = new Set();
            const unique = [];
            for (const p of [...(r1.products || []), ...(r2.products || []), ...(r3.products || [])]) {
              const id = p.id.toString();
              if (!seen.has(id) && _avail(p)) { seen.add(id); unique.push(p); }
            }
            return unique;
          })
          .then(products => {
            // Shuffle for random presentation
            for (let i = products.length - 1; i > 0; i--) {
              const j = Math.floor(Math.random() * (i + 1));
              [products[i], products[j]] = [products[j], products[i]];
            }
            if (!products.length) { self.closest('.vcd-rec')?.remove(); return; }
            self.innerHTML = products.map(p => _recBuildCard(p, currency)).join('');
          })
          .catch(() => self.closest('.vcd-rec')?.remove());
        this.addEventListener('click', e => {
          const btn = e.target.closest('[data-rec-add]');
          if (btn) { e.preventDefault(); _recAddVariant(btn.dataset.variantId, btn); }
        });
      }
    });
  }

  if (!customElements.get('vcd-cart-recent')) {
    customElements.define('vcd-cart-recent', class extends HTMLElement {
      connectedCallback() {
        const { excludeId, currency = 'USD' } = this.dataset;
        let ids = [];
        try { ids = JSON.parse(localStorage.getItem('viewedProducts') || '[]'); } catch {}
        if (excludeId) ids = ids.filter(id => id.toString() !== excludeId);
        if (!ids.length) { this._hideTab(); return; }
        ids = ids.slice(0, 15);
        fetch(`/search/suggest.json?q=${encodeURIComponent(ids.map(id => 'id:' + id).join(' OR '))}&resources[type]=product`)
          .then(r => r.ok ? r.json() : Promise.reject())
          .then(data => {
            const found = data.resources?.results?.products ?? [];
            const ordered = ids.map(id => found.find(p => p.id.toString() === id.toString())).filter(p => p && p.available !== false);
            if (!ordered.length) { this._hideTab(); return; }
            this.innerHTML = ordered.map(p => {
              const url = p.url;
              const imgSrc = p.image ? (p.image + (p.image.includes('?') ? '&' : '?') + 'width=220') : '';
              const title = p.title.replace(/"/g, '&quot;');
              const isMulti = (Number(p.variants_count) || 1) > 1;
              const addBtn = isMulti
                ? `<a href="${url}" class="vcd-rec-card__add" aria-label="View options">${_bagSvg}</a>`
                : `<button class="vcd-rec-card__add" data-rec-add-handle data-handle="${p.handle}" aria-label="Add to cart" type="button">${_bagSvg}</button>`;
              return `<div class="vcd-rec-card">
                <div class="vcd-rec-card__media">
                  <a href="${url}" class="vcd-rec-card__img">
                    ${imgSrc ? `<img src="${imgSrc}" alt="${title}" loading="lazy" width="110" height="110">` : ''}
                  </a>${addBtn}
                </div>
                <div class="vcd-rec-card__info">
                  <a href="${url}" style="text-decoration:none"><p class="vcd-rec-card__title">${p.title}</p></a>
                  <p class="vcd-rec-card__price">${p.price || ''}</p>
                </div>
              </div>`;
            }).join('');
          })
          .catch(() => this._hideTab());
        this.addEventListener('click', async e => {
          const btn = e.target.closest('[data-rec-add-handle]');
          if (!btn || btn.disabled) return;
          e.preventDefault();
          btn.disabled = true; btn.dataset.state = 'loading';
          try {
            const prod = await fetch(`/products/${btn.dataset.handle}.js`).then(r => r.json());
            const v = prod.variants?.[0];
            if (!v?.id || !v?.available) { window.location.href = `/products/${btn.dataset.handle}`; return; }
            btn.disabled = false;
            await _recAddVariant(String(v.id), btn);
          } catch { delete btn.dataset.state; btn.disabled = false; }
        });
      }
      _hideTab() {
        const tabBtn = document.getElementById('vcd-tab-btn-recent');
        const panel  = document.getElementById('vcd-tab-recent');
        if (tabBtn) {
          tabBtn.hidden = true;
          if (tabBtn.getAttribute('aria-selected') === 'true') document.getElementById('vcd-tab-btn-relate')?.click();
        }
        if (panel) { panel.hidden = true; panel.classList.remove('vcd-rec-panel--active'); }
      }
    });
  }

  if (!customElements.get('vcd-rec-tabs')) {
    customElements.define('vcd-rec-tabs', class extends HTMLElement {
      connectedCallback() {
        this.querySelectorAll('[role="tab"]').forEach(btn => {
          btn.addEventListener('click', () => {
            if (btn.getAttribute('aria-selected') === 'true') return;
            this.querySelectorAll('[role="tab"]').forEach(b => {
              b.setAttribute('aria-selected', 'false');
              b.classList.remove('is-active');
              const p = document.getElementById(b.getAttribute('aria-controls') ?? '');
              if (p) { p.hidden = true; p.classList.remove('vcd-rec-panel--active'); }
            });
            btn.setAttribute('aria-selected', 'true');
            btn.classList.add('is-active');
            const target = document.getElementById(btn.getAttribute('aria-controls') ?? '');
            if (target) { target.hidden = false; target.classList.add('vcd-rec-panel--active'); }
          });
        });
      }
    });
  }

  // Track quick view opens as recently viewed products
  document.addEventListener('click', function(e) {
    const btn = e.target.closest('[data-quick-view-url]');
    if (!btn) return;
    const match = (btn.dataset.quickViewUrl || '').match(/\/products\/([^/?#]+)/);
    if (!match) return;
    fetch(`/products/${match[1]}.js`)
      .then(r => r.ok ? r.json() : null)
      .then(p => {
        if (!p?.id) return;
        try {
          const id = p.id.toString();
          let ids = JSON.parse(localStorage.getItem('viewedProducts') || '[]');
          ids = ids.filter(i => i !== id);
          ids.unshift(id);
          localStorage.setItem('viewedProducts', JSON.stringify(ids.slice(0, 16)));
        } catch {}
      });
  }, { capture: true });
})();
