
{%- doc -%}
  Renders a grid of manually-selected collections as image cards in the mega menu.
  @param {object} block - The matched mega_menu_collection_list section block.
{%- enddoc -%}

{% liquid
  assign b = block.settings
  assign block_id = block.id
%}

{% style %}
  .mcl-grid--{{ block_id }} {
    grid-template-columns: repeat(auto-fit, minmax({{ b.col_min_width | default: 120 }}px, {{ b.col_max_width | default: 400 }}px));
    --mcl-gap: {{ b.gap }}px;
    --mcl-radius: {{ b.border_radius }}px;
    --mcl-aspect: {{ b.aspect_ratio }};
  }
{% endstyle %}

<div class="mcl-grid mcl-grid--{{ block_id }}">
  {%- for col in b.collections -%}
    {%- assign col_title = col.title | split: ' > ' | last -%}
      <a href="{{ col.url }}" class="mcl-item">
        <div class="mcl-item__image-wrap">
          {%- if col.featured_image != blank -%}
            <img
              src="{{ col.featured_image | image_url: width: 400 }}"
              srcset="
                {{ col.featured_image | image_url: width: 200 }} 200w,
                {{ col.featured_image | image_url: width: 400 }} 400w
              "
              sizes="(min-width: 990px) 10vw, 25vw"
              class="mcl-item__image"
              alt="{{ col_title | escape }}"
              loading="lazy"
              width="{{ col.featured_image.width }}"
              height="{{ col.featured_image.height }}"
            >
          {%- else -%}
            <div class="mcl-item__placeholder">
              {{- 'collection-1' | placeholder_svg_tag -}}
            </div>
          {%- endif -%}
        </div>
        {%- if b.show_title -%}
          <p class="mcl-item__title">{{ col_title }}</p>
        {%- endif -%}
        {%- if b.show_count -%}
          <p class="mcl-item__count">{{ col.products_count }} products</p>
        {%- endif -%}
      </a>
  {%- endfor -%}
</div>

{% stylesheet %}
  .mcl-grid {
    display: grid;
    gap: var(--mcl-gap, 12px);
    padding: 20px 0;
    width: 100%;
    margin-inline: auto;
    justify-content: center;
  }

  .mcl-item {
    display: flex;
    flex-direction: column;
    gap: 8px;
    text-decoration: none;
    color: inherit;
  }

  .mcl-item__image-wrap {
    aspect-ratio: var(--mcl-aspect, 1 / 1);
    overflow: hidden;
    border-radius: var(--mcl-radius, 8px);
    background: rgba(0, 0, 0, 0.06);
  }

  .mcl-item__image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 0.3s ease;
  }

  .mcl-item:hover .mcl-item__image {
    transform: scale(1.03);
  }

  .mcl-item__placeholder {
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .mcl-item__placeholder svg {
    width: 48%;
    height: 48%;
    opacity: 0.2;
  }

  .mcl-item__title {
    margin: 0;
    font-size: 13px;
    font-weight: 600;
    text-align: center;
    line-height: 1.3;
  }

  .mcl-item__count {
    margin: 0;
    font-size: 12px;
    opacity: 0.6;
    text-align: center;
  }
{% endstylesheet %}
