{% liquid
  assign accent_color = section.settings.accent_color | default: '#c54448'
  assign heading_bold_highlight_color = section.settings.heading_bold_highlight_color | default: accent_color
  assign heading_italic_highlight_color = section.settings.heading_italic_highlight_color | default: accent_color
  assign heading_bold_highlight_bold = section.settings.heading_bold_highlight_bold | append: '' | downcase
  assign heading_italic_highlight_italic = section.settings.heading_italic_highlight_italic | append: '' | downcase
  assign heading_bold_highlight_font_weight = 'bolder'
  assign heading_italic_highlight_font_style = 'italic'

  if section.settings.heading_bold_highlight_bold == false
    assign heading_bold_highlight_font_weight = 'normal'
  elsif heading_bold_highlight_bold == 'false' or heading_bold_highlight_bold == '0' or heading_bold_highlight_bold == 'off'
    assign heading_bold_highlight_font_weight = 'normal'
  endif

  if section.settings.heading_italic_highlight_italic == false
    assign heading_italic_highlight_font_style = 'normal'
  elsif heading_italic_highlight_italic == 'false' or heading_italic_highlight_italic == '0' or heading_italic_highlight_italic == 'off'
    assign heading_italic_highlight_font_style = 'normal'
  endif

  assign primary_url = section.settings.primary_link
  if primary_url == blank
    assign primary_url = routes.account_register_url | default: routes.root_url
  endif
  assign secondary_url = section.settings.secondary_link
  if secondary_url == blank
    assign secondary_url = routes.root_url | append: 'pages/contact'
  endif
%}

{% style %}
  .valor-about-core {
    --valor-navy: #2b3a55;
    --valor-navy-deep: #1d2636;
    --valor-crimson: {{ accent_color }};
    --valor-chalk: var(--color-background, #f4f5f2);
    --valor-parchment: #eeede7;
    --valor-steel: #66717e;
    --valor-steel-light: #a8b0b8;
    --valor-ink: #121820;
    --valor-white: #ffffff;
    --valor-border: rgba(29, 38, 54, 0.08);
    --valor-border-strong: rgba(29, 38, 54, 0.14);
    --heading-bold-highlight-color: {{ heading_bold_highlight_color }};
    --heading-italic-highlight-color: {{ heading_italic_highlight_color }};
    --heading-bold-highlight-font-weight: {{ heading_bold_highlight_font_weight }};
    --heading-italic-highlight-font-style: {{ heading_italic_highlight_font_style }};

    background: var(--valor-chalk);
    color: var(--valor-ink);
    font-family: var(--font-body--family), Inter, Arial, sans-serif;
  }

  .valor-about-core__page,
  .valor-about-core__wide {
    margin: 0 auto;
    padding: 0 32px;
  }

  .valor-about-core__page {
    max-width: 1280px;
  }

  .valor-about-core__wide {
  	max-width: var(--content-max-width);
  }

  .valor-about-core__crumb {
    padding: 24px 0 0;
    color: var(--valor-steel);
    font-size: 12px;
    letter-spacing: 0.04em;
  }

  .valor-about-core__crumb a {
    color: inherit;
    text-decoration: none;
  }

  .valor-about-core__crumb a:hover,
  .valor-about-core__crumb-current {
    color: var(--valor-navy-deep);
  }

  .valor-about-core__crumb-separator {
    margin: 0 8px;
    opacity: 0.5;
  }

  .valor-about-core__hero {
    padding: 80px 0 0;
    border-bottom: 1px solid var(--valor-border);
  }

  .valor-about-core__eyebrow,
  .valor-about-core__closing-eyebrow,
  .valor-about-core__mission-label,
  .valor-about-core__label {
    color: var(--valor-crimson);
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 0.18em;
    line-height: 1.2;
    text-transform: uppercase;
  }

  .valor-about-core__eyebrow {
    display: flex;
    align-items: center;
    gap: 14px;
    margin-bottom: 32px;
  }

  .valor-about-core__eyebrow::before {
    content: '';
    width: 32px;
    height: 1px;
    background: currentColor;
  }

  .valor-about-core__hero-title,
  .valor-about-core__section-title,
  .valor-about-core__section-num,
  .valor-about-core__metric-value,
  .valor-about-core__story-year,
  .valor-about-core__pullquote,
  .valor-about-core__mission-copy,
  .valor-about-core__value-num,
  .valor-about-core__value-name,
  .valor-about-core__value-sub,
  .valor-about-core__channel-title,
  .valor-about-core__cap-num,
  .valor-about-core__channel-kicker,
  .valor-about-core__closing-title,
  .valor-about-core__placeholder {
    font-family: var(--font-heading--family), Georgia, serif;
    font-weight: 400;
    letter-spacing: 0;
  }

  .valor-about-core__hero-title {
    max-width: 1100px;
    margin: 0 0 36px;
    color: var(--valor-navy-deep);
    font-size: clamp(56px, 9vw, 124px);
    line-height: 0.95;
    letter-spacing: -0.025em;
  }

  .valor-about-core__hero-title em {
    display: block;
  }

  .valor-about-core em {
    color: var(--heading-italic-highlight-color) !important;
    font-style: var(--heading-italic-highlight-font-style) !important;
  }

  .valor-about-core :is(
    .valor-about-core__hero-title,
    .valor-about-core__section-title,
    .valor-about-core__mission-copy,
    .valor-about-core__channel-kicker,
    .valor-about-core__closing-title
  ) :is(strong, b) {
    color: var(--heading-bold-highlight-color) !important;
    font-weight: var(--heading-bold-highlight-font-weight) !important;
  }

  .valor-about-core__hero-meta {
    display: grid;
    grid-template-columns: repeat(5, minmax(0, 1fr));
    gap: 32px 40px;
    max-width: 1100px;
    padding: 32px 0 64px;
    border-top: 1px solid var(--valor-border-strong);
  }

  .valor-about-core__metric--statement {
    grid-column: 1 / -1;
    padding-top: 12px;
    border-top: 1px solid var(--valor-border);
  }

  .valor-about-core__metric-label,
  .valor-about-core__story-label {
    margin-bottom: 8px;
    color: var(--valor-steel);
    font-size: 10px;
    font-weight: 500;
    letter-spacing: 0.12em;
    text-transform: uppercase;
  }

  .valor-about-core__metric-value {
    color: var(--valor-navy-deep);
    font-size: 28px;
    line-height: 1.1;
    letter-spacing: -0.01em;
  }

  .valor-about-core__metric-unit {
    margin-left: 4px;
    color: var(--valor-steel);
    font-family: var(--font-body--family), Inter, Arial, sans-serif;
    font-size: 12px;
    letter-spacing: 0.04em;
  }

  .valor-about-core__metric--statement .valor-about-core__metric-value {
    color: var(--valor-navy);
    font-family: var(--font-body--family), Inter, Arial, sans-serif;
    font-size: 16px;
    line-height: 1.5;
    letter-spacing: 0;
  }

  .valor-about-core__image {
    position: relative;
    width: 100%;
    overflow: hidden;
    background: linear-gradient(135deg, var(--valor-parchment) 0%, var(--valor-chalk) 60%, var(--valor-parchment) 100%);
    border: 1px solid var(--valor-border-strong);
  }

  .valor-about-core__image::before {
    content: '';
    position: absolute;
    inset: 0;
    background: repeating-linear-gradient(45deg, transparent 0, transparent 24px, rgba(29, 38, 54, 0.025) 24px, rgba(29, 38, 54, 0.025) 25px);
    pointer-events: none;
  }

  .valor-about-core__image img {
    position: relative;
    z-index: 1;
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .valor-about-core__image--hero {
    aspect-ratio: 21 / 9;
  }

  .valor-about-core__image--story {
    aspect-ratio: 3 / 4;
  }

  .valor-about-core__image--interstitial {
    aspect-ratio: 21 / 7;
  }

  .valor-about-core__image--channel {
    aspect-ratio: 21 / 9;
    margin-bottom: 80px;
  }

  .valor-about-core__image--closing {
    aspect-ratio: 21 / 8;
  }

  .valor-about-core__placeholder {
    position: absolute;
    inset: 0;
    z-index: 1;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 20px;
    color: var(--valor-navy-deep);
    font-size: 18px;
    font-style: italic;
    line-height: 1.3;
    text-align: center;
  }

  .valor-about-core__placeholder-tag,
  .valor-about-core__placeholder-spec {
    display: block;
    font-family: var(--font-body--family), Inter, Arial, sans-serif;
    font-style: normal;
  }

  .valor-about-core__placeholder-tag {
    margin-bottom: 10px;
    color: var(--valor-crimson);
    font-size: 9px;
    font-weight: 600;
    letter-spacing: 0.18em;
    text-transform: uppercase;
  }

  .valor-about-core__placeholder-spec {
    margin-top: 12px;
    color: var(--valor-steel);
    font-size: 10px;
    letter-spacing: 0.04em;
  }

  .valor-about-core__section,
  .valor-about-core__interstitial {
    border-bottom: 1px solid var(--valor-border);
  }

  .valor-about-core__section {
    padding: 120px 0;
  }

  .valor-about-core__section-head {
    display: grid;
    grid-template-columns: 200px 1fr;
    gap: 64px;
    align-items: baseline;
    margin-bottom: 80px;
  }

  .valor-about-core__section-num {
    color: var(--valor-crimson);
    font-size: 22px;
    font-style: italic;
  }

  .valor-about-core__section-title {
    max-width: 880px;
    margin: 0;
    color: var(--valor-navy-deep);
    font-size: clamp(40px, 5vw, 64px);
    line-height: 1.05;
    letter-spacing: -0.02em;
  }

  .valor-about-core__story-grid {
    display: grid;
    grid-template-columns: 280px 1fr;
    gap: 80px;
    align-items: start;
  }

  .valor-about-core__story-aside {
    position: sticky;
    top: 96px;
  }

  .valor-about-core__story-year {
    margin-bottom: 12px;
    color: var(--valor-navy-deep);
    font-size: 96px;
    line-height: 1;
    letter-spacing: -0.03em;
  }

  .valor-about-core__story-place {
    margin-bottom: 32px;
    color: var(--valor-steel);
    font-size: 13px;
    font-style: italic;
    line-height: 1.5;
  }

  .valor-about-core__story-body {
    max-width: 720px;
    color: var(--valor-ink);
    font-size: 17px;
    line-height: 1.65;
  }

  .valor-about-core__story-body p {
    margin: 0 0 28px;
  }

  .valor-about-core__story-body p:first-child::first-letter {
    float: left;
    margin: 8px 14px 0 -2px;
    color: var(--valor-crimson);
    font-family: var(--font-heading--family), Georgia, serif;
    font-size: 80px;
    line-height: 0.85;
  }

  .valor-about-core__story-body strong,
  .valor-about-core__closing-sub strong,
  .valor-about-core__channel-lead strong {
    color: var(--valor-navy-deep);
    font-weight: 600;
  }

  .valor-about-core__pullquote {
    margin: 36px 0;
    padding: 36px 0;
    border-top: 1px solid var(--valor-border-strong);
    border-bottom: 1px solid var(--valor-border-strong);
    color: var(--valor-navy);
    font-size: 28px;
    font-style: italic;
    line-height: 1.35;
    letter-spacing: -0.01em;
  }

  .valor-about-core__pullquote::before {
    content: '"';
    margin-right: 6px;
    color: var(--valor-crimson);
    font-size: 56px;
    line-height: 0;
    vertical-align: -16px;
  }

  .valor-about-core__mission {
    margin-bottom: 96px;
    padding: 48px 0;
    border-top: 1px solid var(--valor-border-strong);
    border-bottom: 1px solid var(--valor-border-strong);
    text-align: center;
  }

  .valor-about-core__mission-label {
    margin-bottom: 24px;
  }

  .valor-about-core__mission-copy {
    max-width: 920px;
    margin: 0 auto;
    color: var(--valor-navy-deep);
    font-size: clamp(28px, 3.4vw, 44px);
    line-height: 1.25;
    letter-spacing: -0.015em;
  }

  .valor-about-core__mission-copy p,
  .valor-about-core__channel-kicker p,
  .valor-about-core__closing-sub p {
    margin: 0;
  }

  .valor-about-core__values,
  .valor-about-core__capabilities {
    display: grid;
  }

  .valor-about-core__values {
    grid-template-columns: repeat(4, minmax(0, 1fr));
    gap: 40px;
  }

  .valor-about-core__value {
    padding-top: 28px;
    border-top: 1px solid var(--valor-navy-deep);
  }

  .valor-about-core__value-num {
    margin-bottom: 16px;
    color: var(--valor-steel);
    font-size: 18px;
    font-style: italic;
  }

  .valor-about-core__value-name {
    margin-bottom: 8px;
    color: var(--valor-navy-deep);
    font-size: 28px;
    line-height: 1.1;
    letter-spacing: -0.015em;
  }

  .valor-about-core__value-sub {
    margin-bottom: 18px;
    color: var(--valor-crimson);
    font-size: 18px;
    font-style: italic;
    line-height: 1.25;
  }

  .valor-about-core__value-desc,
  .valor-about-core__channel-text,
  .valor-about-core__cap-desc {
    color: var(--valor-steel);
  }

  .valor-about-core__value-desc {
    font-size: 14px;
    line-height: 1.6;
  }

  .valor-about-core__channel-lead {
    max-width: 820px;
    margin-bottom: 56px;
    color: var(--valor-ink);
    font-size: 17px;
    line-height: 1.6;
  }

  .valor-about-core__channel-lead p {
    margin: 0 0 18px;
  }

  .valor-about-core__channel-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 64px 80px;
    margin-bottom: 96px;
  }

  .valor-about-core__channel {
    padding-top: 24px;
    border-top: 1px solid var(--valor-border-strong);
  }

  .valor-about-core__label {
    margin-bottom: 14px;
  }

  .valor-about-core__channel-title {
    margin: 0 0 16px;
    color: var(--valor-navy-deep);
    font-size: 28px;
    line-height: 1.15;
    letter-spacing: -0.015em;
  }

  .valor-about-core__channel-text {
    margin: 0 0 16px;
    font-size: 14px;
    line-height: 1.6;
  }

  .valor-about-core__pills {
    display: flex;
    flex-wrap: wrap;
    gap: 6px 8px;
    margin-top: 18px;
  }

  .valor-about-core__pill {
    padding: 5px 10px;
    border: 1px solid var(--valor-border-strong);
    border-radius: 999px;
    background: var(--valor-white);
    color: var(--valor-navy);
    font-size: 10px;
    font-weight: 500;
    letter-spacing: 0.06em;
    text-transform: uppercase;
  }

  .valor-about-core__capabilities {
    grid-template-columns: repeat(4, minmax(0, 1fr));
    border-top: 1px solid var(--valor-navy-deep);
  }

  .valor-about-core__cap {
    padding: 36px 24px 36px 0;
    border-right: 1px solid var(--valor-border);
  }

  .valor-about-core__cap:last-child {
    border-right: none;
    padding-right: 0;
  }

  .valor-about-core__cap-num {
    margin-bottom: 12px;
    color: var(--valor-crimson);
    font-size: 14px;
    font-style: italic;
  }

  .valor-about-core__cap-name {
    margin-bottom: 8px;
    color: var(--valor-navy-deep);
    font-size: 14px;
    font-weight: 600;
  }

  .valor-about-core__cap-desc {
    font-size: 12px;
    line-height: 1.55;
  }

  .valor-about-core__channel-kicker {
    max-width: 820px;
    margin: 64px 0 0;
    padding-top: 36px;
    border-top: 1px solid var(--valor-border-strong);
    color: var(--valor-navy-deep);
    font-size: clamp(22px, 2.4vw, 30px);
    line-height: 1.3;
    letter-spacing: -0.01em;
  }

  .valor-about-core__closing {
    padding: 120px 0 140px;
    text-align: center;
  }

  .valor-about-core__closing-eyebrow {
    margin-bottom: 28px;
  }

  .valor-about-core__closing-title {
    max-width: 880px;
    margin: 0 auto 24px;
    color: var(--valor-navy-deep);
    font-size: clamp(40px, 5.5vw, 72px);
    line-height: 1.05;
    letter-spacing: -0.02em;
  }

  .valor-about-core__closing-sub {
    max-width: 620px;
    margin: 0 auto 40px;
    color: var(--valor-steel);
    font-size: 16px;
    line-height: 1.6;
  }

  .valor-about-core__ctas {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 12px;
  }

  .valor-about-core__btn {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    border-radius: 999px;
    font-size: 13px;
    font-weight: 500;
    letter-spacing: 0.02em;
    text-decoration: none;
    transition: background 160ms ease, border-color 160ms ease, color 160ms ease;
  }

  .valor-about-core__btn--primary {
    padding: 14px 28px;
    background: var(--valor-navy-deep);
    color: var(--valor-chalk);
  }

  .valor-about-core__btn--primary:hover {
    background: var(--valor-crimson);
  }

  .valor-about-core__btn--secondary {
    padding: 13px 26px;
    border: 1px solid var(--valor-border-strong);
    background: var(--valor-white);
    color: var(--valor-navy);
  }

  .valor-about-core__btn--secondary:hover {
    border-color: var(--valor-navy);
    color: var(--valor-navy-deep);
  }

  @media (max-width: 1100px) {
    .valor-about-core__hero-meta {
      grid-template-columns: repeat(3, minmax(0, 1fr));
    }

    .valor-about-core__values {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }

  @media (max-width: 960px) {
    .valor-about-core__hero-meta {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }

    .valor-about-core__section-head,
    .valor-about-core__story-grid,
    .valor-about-core__channel-grid {
      grid-template-columns: 1fr;
      gap: 40px;
    }

    .valor-about-core__story-aside {
      position: static;
    }

    .valor-about-core__story-year {
      font-size: 64px;
    }

    .valor-about-core__image--story {
      max-width: 480px;
      aspect-ratio: 16 / 10;
    }

    .valor-about-core__capabilities {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }

    .valor-about-core__cap {
      border-bottom: 1px solid var(--valor-border);
      border-right: none;
    }

    .valor-about-core__cap:nth-child(odd) {
      border-right: 1px solid var(--valor-border);
      padding-right: 16px;
    }
  }

  @media (max-width: 600px) {
    .valor-about-core__page,
    .valor-about-core__wide {
      padding: 0 20px;
    }

    .valor-about-core__hero {
      padding-top: 56px;
    }

    .valor-about-core__section {
      padding: 80px 0;
    }

    .valor-about-core__hero-meta,
    .valor-about-core__values,
    .valor-about-core__capabilities {
      grid-template-columns: 1fr;
    }

    .valor-about-core__cap,
    .valor-about-core__cap:nth-child(odd) {
      border-right: none;
      padding-right: 0;
    }

    .valor-about-core__closing {
      padding: 80px 0 96px;
    }
  }
{% endstyle %}

<section class="valor-about-core color-{{ section.settings.color_scheme }}" {{ section.shopify_attributes }}>
  <div class="valor-about-core__page">
    {% if section.settings.show_breadcrumb %}
      <nav class="valor-about-core__crumb" aria-label="Breadcrumb">
        <a href="{{ routes.root_url }}">Home</a>
        <span class="valor-about-core__crumb-separator">/</span>
        <span class="valor-about-core__crumb-current">{{ section.settings.breadcrumb_label | escape }}</span>
      </nav>
    {% endif %}

    <div class="valor-about-core__hero">
      {% if section.settings.hero_eyebrow != blank %}
        <div class="valor-about-core__eyebrow">{{ section.settings.hero_eyebrow | escape }}</div>
      {% endif %}
      <h1 class="valor-about-core__hero-title">{{ section.settings.hero_title }}</h1>

      <div class="valor-about-core__hero-meta">
        {% for block in section.blocks %}
          {% if block.type == 'hero_metric' %}
            <div class="valor-about-core__metric{% if block.settings.full_width %} valor-about-core__metric--statement{% endif %}" {{ block.shopify_attributes }}>
              {% if block.settings.label != blank %}
                <div class="valor-about-core__metric-label">{{ block.settings.label | escape }}</div>
              {% endif %}
              <div class="valor-about-core__metric-value">
                {{ block.settings.value }}
                {% if block.settings.unit != blank %}
                  <span class="valor-about-core__metric-unit">{{ block.settings.unit | escape }}</span>
                {% endif %}
              </div>
            </div>
          {% endif %}
        {% endfor %}
      </div>
    </div>
  </div>

  <div class="valor-about-core__wide">
    <div class="valor-about-core__image valor-about-core__image--hero">
      {% if section.settings.hero_image != blank %}
        {{ section.settings.hero_image | image_url: width: 2200 | image_tag: loading: 'eager', widths: '750, 1100, 1500, 2200', sizes: '(max-width: 1440px) 100vw, 1440px', alt: section.settings.hero_image_alt }}
      {% else %}
        <div class="valor-about-core__placeholder">
          <span>
            <span class="valor-about-core__placeholder-tag">Image - Hero</span>
            {{ section.settings.hero_image_placeholder | escape }}
            <span class="valor-about-core__placeholder-spec">21 : 9 recommended</span>
          </span>
        </div>
