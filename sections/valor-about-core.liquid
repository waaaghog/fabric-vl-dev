    </div>
  </div>

  <div class="valor-about-core__page">
    <div class="valor-about-core__section">
      <div class="valor-about-core__section-head">
        <div class="valor-about-core__section-num">{{ section.settings.story_num | escape }}</div>
        <h2 class="valor-about-core__section-title">{{ section.settings.story_title }}</h2>
      </div>

      <div class="valor-about-core__story-grid">
        <aside class="valor-about-core__story-aside">
          <div class="valor-about-core__story-label">{{ section.settings.story_label | escape }}</div>
          <div class="valor-about-core__story-year">{{ section.settings.story_year | escape }}</div>
          <div class="valor-about-core__story-place">{{ section.settings.story_place | escape }}</div>
          <div class="valor-about-core__image valor-about-core__image--story">
            {% if section.settings.story_image != blank %}
              {{ section.settings.story_image | image_url: width: 900 | image_tag: loading: 'lazy', widths: '360, 540, 720, 900', sizes: '(max-width: 960px) 480px, 280px', alt: section.settings.story_image_alt }}
            {% else %}
              <div class="valor-about-core__placeholder">
                <span>
                  <span class="valor-about-core__placeholder-tag">Image - Story</span>
                  {{ section.settings.story_image_placeholder | escape }}
                  <span class="valor-about-core__placeholder-spec">3 : 4 recommended</span>
                </span>
              </div>
            {% endif %}
          </div>
        </aside>

        <div class="valor-about-core__story-body">
          {{ section.settings.story_body }}
          {% if section.settings.story_quote != blank %}
            <div class="valor-about-core__pullquote">{{ section.settings.story_quote | escape }}</div>
          {% endif %}
          {{ section.settings.story_body_after_quote }}
        </div>
      </div>
    </div>
  </div>

  <div class="valor-about-core__wide valor-about-core__interstitial">
    <div class="valor-about-core__image valor-about-core__image--interstitial">
      {% if section.settings.interstitial_image != blank %}
        {{ section.settings.interstitial_image | image_url: width: 2200 | image_tag: loading: 'lazy', widths: '750, 1100, 1500, 2200', sizes: '(max-width: 1440px) 100vw, 1440px', alt: section.settings.interstitial_image_alt }}
      {% else %}
        <div class="valor-about-core__placeholder">
          <span>
            <span class="valor-about-core__placeholder-tag">Image - Interstitial</span>
            {{ section.settings.interstitial_image_placeholder | escape }}
            <span class="valor-about-core__placeholder-spec">21 : 7 recommended</span>
          </span>
        </div>
      {% endif %}
    </div>
  </div>

  <div class="valor-about-core__page">
    <div class="valor-about-core__section">
      <div class="valor-about-core__section-head">
        <div class="valor-about-core__section-num">{{ section.settings.values_num | escape }}</div>
        <h2 class="valor-about-core__section-title">{{ section.settings.values_title }}</h2>
      </div>

      <div class="valor-about-core__mission">
        <div class="valor-about-core__mission-label">{{ section.settings.mission_label | escape }}</div>
        <div class="valor-about-core__mission-copy">{{ section.settings.mission_copy }}</div>
      </div>

      <div class="valor-about-core__values">
        {% for block in section.blocks %}
          {% if block.type == 'value' %}
            <article class="valor-about-core__value" {{ block.shopify_attributes }}>
              <div class="valor-about-core__value-num">{{ block.settings.number | escape }}</div>
              <h3 class="valor-about-core__value-name">{{ block.settings.title | escape }}</h3>
              <div class="valor-about-core__value-sub">{{ block.settings.subtitle | escape }}</div>
              <div class="valor-about-core__value-desc">{{ block.settings.description }}</div>
            </article>
          {% endif %}
        {% endfor %}
      </div>
    </div>
  </div>

  <div class="valor-about-core__page">
    <div class="valor-about-core__section">
      <div class="valor-about-core__section-head">
        <div class="valor-about-core__section-num">{{ section.settings.channel_num | escape }}</div>
        <h2 class="valor-about-core__section-title">{{ section.settings.channel_title }}</h2>
      </div>

      <div class="valor-about-core__image valor-about-core__image--channel">
        {% if section.settings.channel_image != blank %}
          {{ section.settings.channel_image | image_url: width: 1800 | image_tag: loading: 'lazy', widths: '750, 1100, 1500, 1800', sizes: '(max-width: 1280px) 100vw, 1280px', alt: section.settings.channel_image_alt }}
        {% else %}
          <div class="valor-about-core__placeholder">
            <span>
              <span class="valor-about-core__placeholder-tag">Image - Channel</span>
              {{ section.settings.channel_image_placeholder | escape }}
              <span class="valor-about-core__placeholder-spec">21 : 9 recommended</span>
            </span>
          </div>
        {% endif %}
      </div>

      <div class="valor-about-core__channel-lead">{{ section.settings.channel_lead }}</div>

      <div class="valor-about-core__channel-grid">
        {% for block in section.blocks %}
          {% if block.type == 'channel' %}
            <article class="valor-about-core__channel" {{ block.shopify_attributes }}>
              <div class="valor-about-core__label">{{ block.settings.label | escape }}</div>
              <h3 class="valor-about-core__channel-title">{{ block.settings.title | escape }}</h3>
              <div class="valor-about-core__channel-text">{{ block.settings.description }}</div>
              {% assign pills = block.settings.pills | newline_to_br | split: '<br />' %}
              {% if pills.size > 0 %}
                <div class="valor-about-core__pills">
                  {% for pill in pills %}
                    {% assign pill_text = pill | strip %}
                    {% if pill_text != blank %}
                      <span class="valor-about-core__pill">{{ pill_text | escape }}</span>
                    {% endif %}
                  {% endfor %}
                </div>
              {% endif %}
            </article>
          {% endif %}
        {% endfor %}
      </div>

      <div class="valor-about-core__capabilities">
        {% for block in section.blocks %}
          {% if block.type == 'capability' %}
            <article class="valor-about-core__cap" {{ block.shopify_attributes }}>
              <div class="valor-about-core__cap-num">{{ block.settings.number | escape }}</div>
              <div class="valor-about-core__cap-name">{{ block.settings.title | escape }}</div>
              <div class="valor-about-core__cap-desc">{{ block.settings.description | escape }}</div>
            </article>
          {% endif %}
        {% endfor %}
      </div>

      {% if section.settings.channel_kicker != blank %}
        <div class="valor-about-core__channel-kicker">{{ section.settings.channel_kicker }}</div>
      {% endif %}
    </div>
  </div>

  <div class="valor-about-core__wide">
    <div class="valor-about-core__image valor-about-core__image--closing">
      {% if section.settings.closing_image != blank %}
        {{ section.settings.closing_image | image_url: width: 2200 | image_tag: loading: 'lazy', widths: '750, 1100, 1500, 2200', sizes: '(max-width: 1440px) 100vw, 1440px', alt: section.settings.closing_image_alt }}
      {% else %}
        <div class="valor-about-core__placeholder">
          <span>
            <span class="valor-about-core__placeholder-tag">Image - Closing</span>
            {{ section.settings.closing_image_placeholder | escape }}
            <span class="valor-about-core__placeholder-spec">21 : 8 recommended</span>
          </span>
        </div>
      {% endif %}
    </div>
  </div>

  <div class="valor-about-core__page">
    <div class="valor-about-core__closing">
      <div class="valor-about-core__closing-eyebrow">{{ section.settings.closing_eyebrow | escape }}</div>
      <h2 class="valor-about-core__closing-title">{{ section.settings.closing_title }}</h2>
      <div class="valor-about-core__closing-sub">{{ section.settings.closing_copy }}</div>
      <div class="valor-about-core__ctas">
        {% if section.settings.primary_label != blank %}
          <a href="{{ primary_url }}" class="valor-about-core__btn valor-about-core__btn--primary">
            {{ section.settings.primary_label | escape }}
            <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
              <path d="M5 12h14"></path>
              <path d="M13 5l7 7-7 7"></path>
            </svg>
          </a>
        {% endif %}
        {% if section.settings.secondary_label != blank %}
          <a href="{{ secondary_url }}" class="valor-about-core__btn valor-about-core__btn--secondary">{{ section.settings.secondary_label | escape }}</a>
        {% endif %}
      </div>
    </div>
  </div>
</section>

