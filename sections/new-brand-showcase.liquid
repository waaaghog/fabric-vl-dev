
<div class="section-background color-{{ section.settings.color_scheme }}"></div>
<div
  class="section section--{{ section.settings.section_width }} color-{{ section.settings.color_scheme }} spacing-style"
  style="{% render 'spacing-style', settings: section.settings %}"
>

<brand-showcase
  id="brand-showcase-{{ section.id }}"
  class="brand-showcase{% if section.settings.image_fit == 'same_height' %} brand-showcase--same-height{% endif %}"
  data-autoplay="{{ section.settings.autoplay }}"
  data-autoplay-speed="{{ section.settings.autoplay_speed }}"
  data-init-desk="{{ section.settings.items_per_view }}"
  data-init-mobile="{{ section.settings.items_per_view_mobile }}"
  {{ section.shopify_attributes }}
>
  {% if section.settings.title != blank or section.settings.subtitle != blank %}
    <div class="brand-showcase__header">
      {% if section.settings.title != blank %}
        <h2 class="brand-showcase__title">{{ section.settings.title }}</h2>
      {% endif %}
      {% if section.settings.subtitle != blank %}
        <p class="brand-showcase__subtitle">{{ section.settings.subtitle }}</p>
      {% endif %}
    </div>
  {% endif %}

  <div class="brand-showcase__carousel">
    <div class="brand-showcase__track">
      {% for block in section.blocks %}
        {% if block.settings.item_title != blank or block.settings.item_description != blank or block.settings.item_image_1 != blank %}
          <div class="brand-showcase__item" data-item="{{ forloop.index0 }}" {{ block.shopify_attributes }}>
            {% if block.settings.item_image_1 %}
              <div class="brand-showcase__image-wrapper">
                <img
                  src="{{ block.settings.item_image_1 | image_url: width: 400 }}"
                  alt="{{ block.settings.item_image_1.alt | escape }}"
                  class="brand-showcase__image"
                  loading="lazy"
                  width="400"
                  height="{{ section.settings.image_height }}"
                >
              </div>
            {% endif %}
            <div class="brand-showcase__content">
              {% if block.settings.item_title != blank %}
                <h3 class="brand-showcase__item-title">{{ block.settings.item_title }}</h3>
              {% endif %}
              {% if block.settings.item_description != blank %}
                <p class="brand-showcase__item-description">{{ block.settings.item_description }}</p>
              {% endif %}
            </div>
            {% if block.settings.item_image_2 %}
              <div class="brand-showcase__image-wrapper">
                <img
                  src="{{ block.settings.item_image_2 | image_url: width: 400 }}"
                  alt="{{ block.settings.item_image_2.alt | escape }}"
                  class="brand-showcase__image"
                  loading="lazy"
                  width="400"
                  height="{{ section.settings.image_height }}"
                >
              </div>
            {% endif %}
          </div>
        {% endif %}
      {% endfor %}
    </div>
  </div>

  <div class="brand-showcase__controls">
    <button class="brand-showcase__nav-button brand-showcase__prev" aria-label="Previous slide">
      <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
        <path d="M15 18l-6-6 6-6"/>
      </svg>
    </button>
    <div class="brand-showcase__dots"></div>
    <button class="brand-showcase__nav-button brand-showcase__next" aria-label="Next slide">
      <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
        <path d="M9 18l6-6-6-6"/>
      </svg>
    </button>
  </div>
</brand-showcase>

</div>

<style>
  #shopify-section-{{ section.id }} .brand-showcase__title {
    color: {{ section.settings.text_color }};
    font-size: {{ section.settings.title_size }}px;
  }
  #shopify-section-{{ section.id }} .brand-showcase__subtitle {
    color: {{ section.settings.text_color }};
    font-size: {{ section.settings.subtitle_size }}px;
  }
  #shopify-section-{{ section.id }} .brand-showcase__item {
    flex: 0 0 calc(100% / {{ section.settings.items_per_view }});
    padding-right: {{ section.settings.item_spacing }}px;
  }
  #shopify-section-{{ section.id }} .brand-showcase__image-wrapper {
    height: {{ section.settings.image_height }}px;
    border-radius: {{ section.settings.image_border_radius }}px;
  }
  #shopify-section-{{ section.id }} .brand-showcase__content {
    color: {{ section.settings.item_text_color }};
  }
  #shopify-section-{{ section.id }} .brand-showcase__item-title {
    font-size: {{ section.settings.item_title_size }}px;
  }
  #shopify-section-{{ section.id }} .brand-showcase__item-description {
    font-size: {{ section.settings.item_description_size }}px;
  }
  #shopify-section-{{ section.id }} .brand-showcase__nav-button {
    background-color: {{ section.settings.nav_button_color }};
    color: {{ section.settings.nav_button_text_color }};
  }
  #shopify-section-{{ section.id }} .brand-showcase__nav-button:hover {
    background-color: {{ section.settings.nav_button_hover_color }};
  }
  #shopify-section-{{ section.id }} .brand-showcase__dot {
    background-color: {{ section.settings.dot_color }};
  }
  #shopify-section-{{ section.id }} .brand-showcase__dot.active {
    background-color: {{ section.settings.dot_active_color }};
  }
  @media screen and (max-width: 768px) {
    #shopify-section-{{ section.id }} .brand-showcase__item {
      flex: 0 0 calc(100% / {{ section.settings.items_per_view_mobile }});
    }
    #shopify-section-{{ section.id }} .brand-showcase__title {
      font-size: {{ section.settings.title_size | times: 0.8 }}px;
    }
    #shopify-section-{{ section.id }} .brand-showcase__subtitle {
      font-size: {{ section.settings.subtitle_size | times: 0.9 }}px;
    }
  }
  @media screen and (max-width: 340px) {
    #shopify-section-{{ section.id }} .brand-showcase__item {
      flex: 0 0 100%;
    }
  }
</style>

{% stylesheet %}
  .brand-showcase__header {
    text-align: center;
    margin-bottom: 40px;
  }

  .brand-showcase__title {
    margin: 0 0 16px;
  }

  .brand-showcase__subtitle {
    opacity: 0.8;
    margin: 0;
  }

  .brand-showcase__carousel {
    position: relative;
    overflow: hidden;
  }

  .brand-showcase__track {
    display: flex;
    transition: transform 0.5s ease;
  }

  .brand-showcase__item {
    text-align: center;
    transition: transform 0.3s ease, box-shadow 0.3s ease;
  }

  .brand-showcase__item:hover .brand-showcase__image-wrapper {
    transform: translateY(-3px);
    box-shadow: 0 4px 16px rgba(0, 0, 0, 0.15);
  }

  .brand-showcase__image-wrapper {
    width: 100%;
    margin-bottom: 16px;
    overflow: hidden;
    background-color: #f5f5f5;
    position: relative;
    transition: transform 0.5s ease, box-shadow 0.5s ease;
  }

  .brand-showcase__image {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .brand-showcase--same-height .brand-showcase__image-wrapper {
    background: none;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .brand-showcase--same-height .brand-showcase__image {
    width: auto;
    max-width: 100%;
    height: 100%;
    object-fit: contain;
  }

  .brand-showcase__item-title {
    font-weight: 600;
    margin: 0 0 8px;
  }

  .brand-showcase__item-description {
    line-height: 1.4;
    margin: 0;
    opacity: 0.9;
  }

  .brand-showcase__controls {
    display: flex;
    justify-content: center;
    align-items: center;
    gap: 16px;
    height: 48px;
    margin-top: 26px;
  }

  .brand-showcase__nav-button {
    width: 44px;
    height: 44px;
    border-radius: 50%;
    border: none;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: all 0.3s ease;
  }

  .brand-showcase__nav-button:hover {
    transform: scale(1.1);
  }

  .brand-showcase__nav-button:disabled {
    opacity: 0.5;
    cursor: not-allowed;
    transform: none;
  }

  .brand-showcase__dots {
    display: flex;
    gap: 8px;
  }

  .brand-showcase__dot {
    width: 12px;
    height: 12px;
    border-radius: 50%;
    border: none;
    cursor: pointer;
    transition: all 0.3s ease;
    opacity: 0.5;
  }

  .brand-showcase__dot.active {
    opacity: 1;
    transform: scale(1.2);
  }
{% endstylesheet %}

<script>
  (function () {
    class BrandShowcase extends HTMLElement {
      constructor() {
        super();
        this.currentSlide = 0;
        this.autoplayInterval = null;
      }

      connectedCallback() {
        this.track = this.querySelector('.brand-showcase__track');
        this.items = this.querySelectorAll('.brand-showcase__item');
        this.prevButton = this.querySelector('.brand-showcase__prev');
        this.nextButton = this.querySelector('.brand-showcase__next');
        this.dotsContainer = this.querySelector('.brand-showcase__dots');

        this.autoplay = this.dataset.autoplay === 'true';
        this.autoplaySpeed = parseInt(this.dataset.autoplaySpeed) * 1000;
        this.init();
      }

      init() {
        if (this.items.length === 0) return;

        this.updateItemsPerView();
        this.createDots();
        this.setupEventListeners();
        this.updateSlide();

        if (this.autoplay) {
          this.startAutoplay();
        }

        window.addEventListener('resize', () => {
          this.updateItemsPerView();
          this.updateSlide();
        });
      }

      updateItemsPerView() {
        this.itemsPerView = window.innerWidth <= 768
          ? this.dataset.initMobile * 1
          : this.dataset.initDesk * 1;
        if (window.innerWidth <= 340)
          this.itemsPerView = 1;

        this.lastSlides = Math.max(1, this.items.length - this.itemsPerView);
        if (this.currentSlide > this.lastSlides)
          this.currentSlide = this.lastSlides;
      }

      createDots() {
        this.dotsContainer.innerHTML = '';
        for (let i = 0; i < this.items.length; i++) {
          const dot = document.createElement('button');
          dot.className = 'brand-showcase__dot';
          dot.setAttribute('aria-label', `Go to slide ${i + 1}`);
          dot.addEventListener('click', () => this.goToSlide(i));
          this.dotsContainer.appendChild(dot);
        }
      }

      setupEventListeners() {
        this.prevButton.addEventListener('click', () => this.prevSlide());
        this.nextButton.addEventListener('click', () => this.nextSlide());

        this.addEventListener('mouseenter', () => this.stopAutoplay());
        this.addEventListener('mouseleave', () => {
          if (this.autoplay) this.startAutoplay();
        });
      }

      updateSlide() {
        const translateX = this.currentSlide * 100 / this.itemsPerView;
        this.track.style.transform = `translateX(-${translateX}%)`;

        this.prevButton.disabled = this.currentSlide === 0;
        this.nextButton.disabled = this.currentSlide >= this.lastSlides;

        const dots = this.querySelectorAll('.brand-showcase__dot');
        dots.forEach((dot, index) => {
          dot.classList.toggle('active', index === this.currentSlide);
        });
      }

      goToSlide(index) {
        this.currentSlide = Math.max(0, Math.min(index, this.lastSlides));
        this.updateSlide();
      }

      nextSlide() {
        if (this.currentSlide < this.lastSlides)
          this.currentSlide++;
        else
          this.currentSlide = 0;
        this.updateSlide();
      }

      prevSlide() {
        if (this.currentSlide > 0)
          this.currentSlide--;
        else
          this.currentSlide = this.lastSlides;
        this.updateSlide();
      }

      startAutoplay() {
        this.stopAutoplay();
        this.autoplayInterval = setInterval(() => {
          this.nextSlide();
        }, this.autoplaySpeed);
      }

      stopAutoplay() {
        if (this.autoplayInterval) {
          clearInterval(this.autoplayInterval);
          this.autoplayInterval = null;
        }
      }
    }

    if (!customElements.get('brand-showcase')) {
      customElements.define('brand-showcase', BrandShowcase);
    }
  })();
</script>

