
{%- liquid
  assign mf_input = section.settings.images_metafield | strip
  assign img_count = 0
  case request.page_type
    when 'collection'
      assign mf_owner = collection
    when 'product'
      assign mf_owner = product
    when 'page'
      assign mf_owner = page
    when 'blog'
      assign mf_owner = blog
    when 'article'
      assign mf_owner = article
  endcase

  if mf_input != blank and mf_owner != nil
    assign mf_parts = mf_input | split: '.'
    assign mf_ns    = mf_parts[0]
    assign mf_key   = mf_parts[1]
    assign banner_images = mf_owner.metafields[mf_ns][mf_key].value
    if banner_images != blank
      assign img_count = banner_images.size
    endif
  endif
  assign display_count = img_count | at_most: 2
-%}

<div class="section-background color-{{ section.settings.color_scheme }}"></div>
<div
  class="section section--{{ section.settings.section_width }} color-{{ section.settings.color_scheme }} spacing-style"
  style="{% if img_count > 0 %}{% render 'spacing-style', settings: section.settings %}{% endif %}"
  {{ section.shopify_attributes }}
>
  {%- if img_count > 0 -%}
    <div
      class="imb imb--count-{{ display_count }}"
      style="--imb-gap: {{ section.settings.gap }}px; --imb-mobile-height: {{ section.settings.max_height }}; --imb-overlay-color: {{ section.settings.overlay_color }}; --imb-overlay-opacity: {{ section.settings.overlay_opacity | divided_by: 100.0 }};"
    >
      <div class="imb__row">

        {%- comment -%} Image 1 {%- endcomment -%}
        {%- for f in banner_images limit: 1 -%}
          <div
            class="imb__img"
            {% if display_count == 2 %}style="flex: {{ f.preview_image.aspect_ratio | default: 1 | times: 100 | round }}"{% endif %}
          >
            <img
              src="{{ f | image_url: width: 1600 }}"
              srcset="
                {{ f | image_url: width: 750 }} 750w,
                {{ f | image_url: width: 1100 }} 1100w,
                {{ f | image_url: width: 1600 }} 1600w
              "
              sizes="{% if display_count == 2 %}(max-width: 749px) 100vw, 50vw{% else %}100vw{% endif %}"
              alt="{{ f.alt | default: '' | escape }}"
              loading="lazy"
              width="{{ f.preview_image.width }}"
              height="{{ f.preview_image.height }}"
            >
            <div class="imb__overlay"></div>
          </div>
        {%- endfor -%}

        {%- comment -%} Image 2 {%- endcomment -%}
        {%- if display_count == 2 -%}
          {%- for f in banner_images limit: 1 offset: 1 -%}
            <div
              class="imb__img"
              style="flex: {{ f.preview_image.aspect_ratio | default: 1 | times: 100 | round }}"
            >
              <img
                src="{{ f | image_url: width: 1600 }}"
                srcset="
                  {{ f | image_url: width: 750 }} 750w,
                  {{ f | image_url: width: 1100 }} 1100w,
                  {{ f | image_url: width: 1600 }} 1600w
                "
                sizes="(max-width: 749px) 100vw, 50vw"
                alt="{{ f.alt | default: '' | escape }}"
                loading="lazy"
                width="{{ f.preview_image.width }}"
                height="{{ f.preview_image.height }}"
              >
              <div class="imb__overlay"></div>
            </div>
          {%- endfor -%}
        {%- endif -%}

      </div>

      {%- comment -%} Blocks overlaid on top of images {%- endcomment -%}
      <div
        class="imb__blocks-overlay"
        style="
          --horizontal-alignment: {{ section.settings.blocks_horizontal }};
          --vertical-alignment: {{ section.settings.blocks_vertical }};
        "
      >
        {% content_for 'blocks' %}
      </div>
    </div>
  {%- endif -%}

</div>

{% stylesheet %}
  .imb {
    position: relative;
  }
  @media screen and (min-width: 750px) {
	.imb {
		max-width: 90%;
		margin: auto;
	}
  }

  .imb__row {
    display: flex;
    gap: var(--imb-gap, 8px);
  }

  .imb__img {
    overflow: hidden;
    min-width: 0;
    position: relative;
    max-height: var(--imb-mobile-height, auto);
  }

  .imb__overlay {
    position: absolute;
    inset: 0;
    background: var(--imb-overlay-color, #000);
    opacity: var(--imb-overlay-opacity, 0);
    pointer-events: none;
  }

  .imb__img img {
    display: block;
    width: 100%;
    height: auto;
  }

  /* Overlay container */
  .imb__blocks-overlay {
    position: absolute;
    inset: 0;
    display: flex;
    flex-direction: column;
    align-items: var(--horizontal-alignment, flex-start);
    justify-content: var(--vertical-alignment, flex-start);
    pointer-events: none;
  }

  .imb__blocks-overlay > * {
    pointer-events: auto;
  }

  .imb__placeholder {
    padding: 40px 20px;
    text-align: center;
    opacity: 0.5;
  }

  /* Mobile */
  @media screen and (max-width: 749px) {
    /* Single image: fixed-height crop to show center */
    .imb--count-1 .imb__img {
      max-height: var(--imb-mobile-height, auto);
    }

    .imb--count-1 .imb__img img {
      height: 100%;
      object-fit: cover;
      object-position: center;
    }

    /* Two images: stack vertically */
    .imb--count-2 .imb__row {
      flex-direction: column;
    }

    .imb--count-2 .imb__img {
      flex: none !important;
      width: 100%;
    }

    /* Blocks */
    .imb__block {
      max-width: 90%;
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "New: Image banner",
  "disabled_on": {
    "groups": ["header", "footer"]
  },
  "settings": [
    {
      "type": "header",
      "content": "Images"
    },
    {
      "type": "text",
      "id": "images_metafield",
      "label": "Images metafield key",
      "placeholder": "e.g. custom.banner_images",
      "info": "Use a list.file_reference metafield. Supports 1 image (full width) or 2 images (side by side)."
    },
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "select",
      "id": "section_width",
      "label": "t:settings.width",
      "options": [
        { "value": "page-width", "label": "t:options.page" },
        { "value": "full-width", "label": "t:options.full" }
      ],
      "default": "full-width"
    },
    {
      "type": "range",
      "id": "gap",
      "label": "Gap between images",
      "min": 0,
      "max": 40,
      "step": 4,
      "unit": "px",
      "default": 8
    },
    {
      "type": "text",
      "id": "max_height",
      "label": "Max image height"
    },
    {
      "type": "header",
      "content": "Blocks alignment"
    },
    {
      "type": "select",
      "id": "blocks_horizontal",
      "label": "Horizontal",
      "options": [
        { "value": "flex-start", "label": "Left" },
        { "value": "center",     "label": "Center" },
        { "value": "flex-end",   "label": "Right" }
      ],
      "default": "flex-start"
    },
    {
      "type": "select",
      "id": "blocks_vertical",
      "label": "Vertical",
      "options": [
        { "value": "flex-start", "label": "Top" },
        { "value": "center",     "label": "Middle" },
        { "value": "flex-end",   "label": "Bottom" }
      ],
      "default": "flex-start"
    },
    {
      "type": "header",
      "content": "Overlay"
    },
    {
      "type": "color",
      "id": "overlay_color",
      "label": "Overlay color",
      "default": "#000000"
    },
    {
      "type": "range",
      "id": "overlay_opacity",
      "label": "Overlay opacity",
      "min": 0,
      "max": 100,
      "step": 5,
      "unit": "%",
      "default": 0
    },
    {
      "type": "header",
      "content": "Color"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "t:settings.color_scheme",
      "default": "scheme-1"
    },
    {
      "type": "header",
      "content": "t:content.padding"
    },
    {
      "type": "range",
      "id": "padding-block-start",
      "label": "t:settings.top",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 0
    },
    {
      "type": "range",
      "id": "padding-block-end",
      "label": "t:settings.bottom",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 0
    }
  ],
  "blocks": [
    {
      "type": "@theme"
    }
  ],
  "presets": [
    {
      "name": "New: Image banner"
    }
  ]
}
{% endschema %}
