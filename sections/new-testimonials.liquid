        },
        {
          "type": "text",
          "id": "author_detail",
          "label": "Author detail",
          "default": "Company or location"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "New: Testimonials",
      "blocks": [
        { "type": "testimonial" },
        { "type": "testimonial" },
        { "type": "testimonial" },
        { "type": "testimonial" },
        { "type": "testimonial" }
      ]
    }
  ]
}
