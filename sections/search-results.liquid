{% render 'rapid-search-results-template-v2' %}
{% javascript %}
  const url = new URL(window.location.href);
  if (url.hash) {
    document.addEventListener(
      'DOMContentLoaded',
      () => {
        const card = document.getElementById(url.hash.slice(1));
        if (card) {
          card.scrollIntoView({ behavior: 'instant' });
        }
      },
      { once: true }
    );
  }
{% endjavascript %}

<script
  src="{{ 'results-list.js' | asset_url }}"
  type="module"
  fetchpriority="low"
></script>

<div class="section-background color-{{ section.settings.color_scheme }}"></div>

<results-list
  class="section product-grid-container color-{{ section.settings.color_scheme }}"
  style="--padding-block-start: {{ section.settings.padding-block-start }}px; --padding-block-end: {{ section.settings.padding-block-end }}px;"
  section-id="{{ section.id }}"
  infinite-scroll="{{ section.settings.enable_infinite_scroll }}"
>
  {% render 'skip-to-content-link', href: '#ResultsList', text: 'accessibility.skip_to_results_list' %}

  <div
    class="collection-wrapper grid gap-style{% if section.settings.product_grid_width == 'full-width' %} collection-wrapper--grid-full-width{% endif %}"
    style="
      --facets-vertical-col-width: {{ section.settings.facets_vertical_col_width }};
      --product-grid-gap-mobile: {{ section.settings.columns_gap_vertical | at_most: 12 }}px {{ section.settings.columns_gap_horizontal | at_most: 12 }}px;
      --product-grid-gap-desktop: {{ section.settings.columns_gap_vertical }}px {{ section.settings.columns_gap_horizontal }}px;
    "
  >
    {% assign products_per_page = 24 %}

    {% if section.settings.enable_infinite_scroll == false %}
      {% assign products_per_page = section.settings.products_per_page %}
    {% endif %}

    {% paginate search.results by products_per_page %}
      {% assign products = search.results | where: 'object_type', 'product' %}
      {% assign exact_sku_query = search.terms | strip | downcase %}
      {% assign exact_sku_match_count = 0 %}

      {% if exact_sku_query != blank and exact_sku_query != '*' %}
        {% for product in products %}
          {% for variant in product.variants %}
            {% assign variant_sku = variant.sku | strip | downcase %}
            {% if variant_sku != blank and variant_sku == exact_sku_query %}
              {% assign exact_sku_match_count = exact_sku_match_count | plus: 1 %}
              {% break %}
            {% endif %}
          {% endfor %}
        {% endfor %}
      {% endif %}

      {% assign results_size = search.results_count %}
      {% assign single_page_results = false %}

      {% if exact_sku_match_count > 0 %}
        {% assign results_size = exact_sku_match_count %}
        {% assign single_page_results = true %}
      {% endif %}

      {% if exact_sku_match_count > 0 %}
        <style>
          #shopify-section-{{ section.id }} > .rps-results,
          #shopify-section-{{ section.id }} > .rps-results-page-title {
            display: none !important;
          }

          #shopify-section-{{ section.id }} > results-list.section.product-grid-container {
            display: block !important;
          }

          @media screen and (min-width: 750px) {
            #shopify-section-{{ section.id }} > results-list.section.product-grid-container {
              display: grid !important;
            }
          }
        </style>
      {% endif %}

      {% content_for 'block', type: 'filters', id: 'filters', results: search, results_size: results_size %}

      {% capture children %}
        {% for product in products %}
          {% assign render_product = true %}

          {% if exact_sku_match_count > 0 %}
            {% assign render_product = false %}
            {% for variant in product.variants %}
              {% assign variant_sku = variant.sku | strip | downcase %}
              {% if variant_sku != blank and variant_sku == exact_sku_query %}
                {% assign render_product = true %}
                {% break %}
              {% endif %}
            {% endfor %}
          {% endif %}

          {% if render_product %}
            <li
              id="{{ section.id }}-{{ product.id }}"
              class="product-grid__item product-grid__item--{{ forloop.index0 }}"
              data-page="{{ paginate.current_page }}"
              data-product-id="{{ product.id }}"
              ref="cards[]"
            >
              {% # theme-check-disable %}
              {% content_for 'block', type: '_product-card', id: 'product-card', closest.product: product %}
              {% # theme-check-enable %}
            </li>
          {% endif %}
        {% endfor %}
      {% endcapture %}

      {% render 'product-grid',
        section: section,
        children: children,
        products: products,
        paginate: paginate,
        enable_infinite_scroll: section.settings.enable_infinite_scroll,
        single_page_results: single_page_results
      %}
    {% endpaginate %}
  </div>
</results-list>

{% schema %}
{
  "name": "t:names.search_results",
  "enabled_on": {
    "templates": ["search"]
  },
  "settings": [
    {
      "type": "header",
      "content": "t:content.layout"
    },
    {
      "type": "select",
      "id": "product_grid_width",
      "label": "t:settings.width",
      "options": [
        {
          "value": "centered",
          "label": "t:options.page"
        },
        {
          "value": "full-width",
          "label": "t:options.full"
        }
      ],
      "default": "centered"
    },
    {
      "type": "checkbox",
      "id": "full_width_on_mobile",
      "label": "t:settings.full_width_on_mobile",
      "default": true,
      "visible_if": "{{ section.settings.product_grid_width != 'full-width' }}"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "t:settings.color_scheme",
      "default": "scheme-1"
    },
    {
      "type": "paragraph",
      "content": "t:content.edit_empty_state_collection_in_theme_settings"
    },
    {
      "type": "select",
      "id": "layout_type",
      "label": "t:settings.type",
      "options": [
        {
          "value": "grid",
          "label": "t:options.grid"
        },
        {
          "value": "organic",
          "label": "t:options.editorial"
        }
      ],
      "default": "grid"
    },
    {
      "type": "range",
      "id": "product_card_size",
      "label": "t:settings.card_size",
      "min": 100,
      "max": 600,
      "step": 10,
      "unit": "px",
      "default": 230,
      "visible_if": "{{ section.settings.layout_type == 'grid' }}"
    },
    {
      "type": "select",
      "id": "mobile_product_card_size",
      "label": "t:settings.mobile_card_size",
      "options": [
        {
          "value": "small",
          "label": "t:options.small"
        },
        {
          "value": "large",
          "label": "t:options.large"
        }
      ],
      "default": "small"
    },
    {
      "type": "checkbox",
      "id": "enable_infinite_scroll",
      "label": "t:settings.auto_load_products",
      "default": true
    },
    {
      "type": "range",
      "id": "products_per_page",
      "label": "t:settings.products_per_page",
      "min": 8,
      "max": 36,
      "step": 4,
      "default": 24,
      "visible_if": "{{ section.settings.enable_infinite_scroll == false }}"
    },
    {
      "type": "range",
      "id": "columns_gap_horizontal",
      "label": "t:settings.horizontal_gap",
      "min": 0,
      "max": 50,
      "step": 1,
      "unit": "px",
      "default": 16
    },
    {
      "type": "range",
      "id": "columns_gap_vertical",
      "label": "t:settings.vertical_gap",
      "min": 0,
      "max": 50,
      "step": 1,
      "unit": "px",
      "default": 16
    },
    {
      "type": "range",
      "id": "facets_vertical_col_width",
      "label": "t:settings.vertical_filter_width",
      "min": 2,
      "max": 7,
      "step": 1,
      "default": 5
    },
    {
      "type": "range",
      "id": "padding-block-start",
      "label": "t:settings.top_padding",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 8
    },
    {
      "type": "range",
      "id": "padding-block-end",
      "label": "t:settings.bottom_padding",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 8
    }
  ],
  "presets": []
}
{% endschema %}
