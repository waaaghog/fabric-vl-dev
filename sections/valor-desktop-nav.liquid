{% javascript %}
(function () {
  var items = document.querySelectorAll('.vdn__item--dd');

  items.forEach(function (item) {
    var trigger = item.querySelector('.vdn__trigger');
    if (!trigger) return;

    // Keep aria-expanded in sync with CSS hover state
    item.addEventListener('mouseenter', function () {
      trigger.setAttribute('aria-expanded', 'true');
    });
    item.addEventListener('mouseleave', function () {
      trigger.setAttribute('aria-expanded', 'false');
    });

    // Click: close others, toggle this (keyboard / touch support)
    trigger.addEventListener('click', function () {
      var isOpen = trigger.getAttribute('aria-expanded') === 'true';
      items.forEach(function (other) {
        if (other !== item) {
          var t = other.querySelector('.vdn__trigger');
          if (t) t.setAttribute('aria-expanded', 'false');
        }
      });
      trigger.setAttribute('aria-expanded', isOpen ? 'false' : 'true');
    });
  });

  // Escape closes all
  document.addEventListener('keydown', function (e) {
    if (e.key !== 'Escape') return;
    items.forEach(function (item) {
      var t = item.querySelector('.vdn__trigger');
      if (t) t.setAttribute('aria-expanded', 'false');
    });
  });

  // Click outside closes all
  document.addEventListener('click', function (e) {
    if (e.target.closest('.vdn__item--dd')) return;
    items.forEach(function (item) {
      var t = item.querySelector('.vdn__trigger');
      if (t) t.setAttribute('aria-expanded', 'false');
    });
  });

  document.querySelectorAll('.vdn__mega--designlab').forEach(function (menu) {
    var railItems = menu.querySelectorAll('.vdn__dl-rail-item');
    var panels = menu.querySelectorAll('.vdn__dl-panel');

    function activate(category) {
      railItems.forEach(function (button) {
        var active = button.getAttribute('data-vdn-dlcat') === category;
        button.classList.toggle('is-active', active);
        button.setAttribute('aria-selected', active ? 'true' : 'false');
      });

      panels.forEach(function (panel) {
        var active = panel.getAttribute('data-vdn-dlpanel') === category;
        panel.classList.toggle('is-active', active);
        panel.hidden = !active;
      });
    }

    railItems.forEach(function (button) {
      var category = button.getAttribute('data-vdn-dlcat');
      button.addEventListener('mouseenter', function () { activate(category); });
      button.addEventListener('focus', function () { activate(category); });
      button.addEventListener('click', function (event) {
        event.preventDefault();
        activate(category);
      });
    });
  });

})();
{% endjavascript %}

