{%- comment -%}
  valor-desktop-nav.liquid
  Desktop mega-menu navigation bar. Hidden on mobile (≤ 900px).
  Add to the Header group in the theme editor — it renders as a sticky
  secondary nav bar below the logo/search row.

  Four block types:
    link              — simple link, no dropdown
    dropdown-simple   — plain list dropdown (e.g. About)
    dropdown-categories — image-card columns mega menu
    dropdown-devices  — hero banner + brand/device grid
    dropdown-brands   — brand tile grid
    dropdown-designlab - Design Lab rail mega menu
{%- endcomment -%}

{%- if section.blocks.size > 0 -%}
<nav class="vdn{% if section.settings.dropdown_align == 'center' %} vdn--center{% endif %}" aria-label="{{ section.settings.aria_label | default: 'Primary navigation' | escape }}">
  <div class="vdn__inner">
    <ul class="vdn__list" role="menubar">

      {%- for block in section.blocks -%}
        {%- assign has_dd = false -%}
        {%- unless block.type == 'link' -%}
          {%- assign has_dd = true -%}
        {%- endunless -%}
        {%- liquid
          assign block_label_key = block.settings.label | default: '' | downcase | strip | replace: ' ', '' | replace: '-', ''
          assign is_design_lab_dropdown = false
          if block.type == 'dropdown-designlab' or block_label_key == 'designlab'
            assign is_design_lab_dropdown = true
          endif
        -%}

        <li
          class="vdn__item{% if has_dd %} vdn__item--dd{% endif %}"
          role="none"
          {{ block.shopify_attributes }}
        >

          {%- if block.type == 'link' -%}
            <a class="vdn__trigger vdn__link" href="{{ block.settings.url }}" role="menuitem">
              {{- block.settings.label | escape -}}
            </a>

          {%- else -%}
            <button
              class="vdn__trigger"
              role="menuitem"
              aria-haspopup="true"
              aria-expanded="false"
              type="button"
            >
              {{- block.settings.label | escape -}}
              <svg class="vdn__chev" width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" aria-hidden="true"><path d="M6 9l6 6 6-6"/></svg>
            </button>

            {%- case block.type -%}

              {%- when 'dropdown-categories' -%}
                {%- assign dd_menu_handle = block.settings.menu | default: 'desknav-categories' -%}
                {%- assign dd_menu = linklists[dd_menu_handle] -%}
                <div class="vdn__mega vdn__mega--cats" role="menu">
                  {%- assign _palette = '#2B3A55,#C54448,#63B9DE,#B07E1A,#2d7a3f,#66717E' | split: ',' -%}
                  <div class="vdn__cats-grid">
                    {%- for link in dd_menu.links -%}
                      {%- assign ci = forloop.index -%}
                      {%- assign _pi = ci | minus: 1 -%}
                      {%- assign col_bg = _palette[_pi] | default: '#2B3A55' -%}
                      {%- assign img_key = 'col_' | append: ci | append: '_image' -%}
                      {%- assign col_img = block.settings[img_key] -%}
                      {%- assign col_fallback_file = blank -%}
                      {%- case ci -%}
                        {%- when 1 -%}{%- assign col_fallback_file = 'Protection.png' -%}
                        {%- when 2 -%}{%- assign col_fallback_file = 'Power.png' -%}
                        {%- when 3 -%}{%- assign col_fallback_file = 'Audio.png' -%}
                        {%- when 4 -%}{%- assign col_fallback_file = 'Attachables.png' -%}
                        {%- when 5 -%}{%- assign col_fallback_file = 'Wearables.png' -%}
                        {%- when 6 -%}{%- assign col_fallback_file = 'Everything-Else.png' -%}
                      {%- endcase -%}
                      {%- assign col_fallback_img = blank -%}
                      {%- if col_fallback_file != blank -%}
                        {%- assign col_fallback_img = images[col_fallback_file] -%}
                      {%- endif -%}
                      <div class="vdn__col" role="none">
                        <a
                          href="{{ link.url }}"
                          class="vdn__col-img"
                          style="
                            background: linear-gradient(135deg, {{ col_bg }} 0%, #1D2636 100%);
                            aspect-ratio: {{ block.settings.column_image_ratio }};
                          "
                          aria-hidden="true"
                          tabindex="-1"
                        >
                          {%- if col_img != blank -%}
                            {{ col_img | image_url: width: 320 | image_tag: loading: 'lazy', class: 'vdn__col-img-src' }}
                          {%- elsif col_fallback_img != blank -%}
                            {{ col_fallback_img | image_url: width: 320 | image_tag: loading: 'lazy', class: 'vdn__col-img-src' }}
                          {%- endif -%}
                        </a>
                        <a href="{{ link.url }}" class="vdn__col-title-link" role="none">
                          <div class="vdn__col-title" role="menuitem">{{ link.title }}</div>
                        </a>
                        {%- if link.links.size > 0 -%}
                          <ul class="vdn__col-links" role="menu">
                            {%- for child in link.links -%}
                              <li role="none"><a href="{{ child.url }}" role="menuitem">{{ child.title }}</a></li>
                            {%- endfor -%}
                          </ul>
                        {%- endif -%}
                      </div>
                    {%- endfor -%}
                  </div>
                </div>

              {%- when 'dropdown-devices' -%}
                {%- assign dd_menu_handle = block.settings.menu | default: 'desknav-devices' -%}
                {%- assign dd_menu = linklists[dd_menu_handle] -%}
                <div class="vdn__mega vdn__mega--devices" role="menu">
                  {%- if block.settings.hero_title != blank -%}
                    <a href="{{ block.settings.hero_url | default: '#' }}" class="vdn__dev-hero">
                      <div class="vdn__hero-graphic" aria-hidden="true">
                        {%- if block.settings.hero_image != blank -%}
                          <div class="vdn__hero-device">
                            {{ block.settings.hero_image | image_url: width: 480 | image_tag: loading: 'lazy', style: 'height: 130px; width: auto; object-fit: contain; display: block;' }}
                          </div>
                        {%- else -%}
                          <div class="vdn__hero-device">
                            <svg viewBox="0 0 220 360" fill="none" xmlns="http://www.w3.org/2000/svg" style="height:100%;width:auto;">
                              <rect x="20" y="10" width="180" height="340" rx="32" fill="#2B3A55" stroke="rgba(255,255,255,0.18)" stroke-width="1"/>
                              <rect x="28" y="18" width="164" height="324" rx="26" fill="#111"/>
                              <rect x="92" y="26" width="36" height="8" rx="4" fill="#000"/>
                              <circle cx="120" cy="30" r="2" fill="#1a3a4a"/>
                            </svg>
                          </div>
                        {%- endif -%}
                        <div class="vdn__hero-glow"></div>
                      </div>
                      <div class="vdn__hero-text">
                        {%- if block.settings.hero_eyebrow != blank -%}
                          <div class="vdn__hero-eyebrow">{{ block.settings.hero_eyebrow | escape }}</div>
                        {%- endif -%}
                        <div class="vdn__hero-title">{{ block.settings.hero_title | escape }}</div>
                        {%- if block.settings.hero_cta != blank -%}
                          <span class="vdn__hero-cta">
                            {{ block.settings.hero_cta | escape }}
                            <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" aria-hidden="true"><path d="M5 12h14M13 5l7 7-7 7"/></svg>
                          </span>
                        {%- endif -%}
                      </div>
                    </a>
                  {%- endif -%}
                  {%- if dd_menu.links.size > 0 -%}
                    <div class="vdn__dev-grid">
                      {%- for link in dd_menu.links -%}
                        <div class="vdn__col" role="none">
                          <div class="vdn__col-title">{{ link.title }}</div>
                          {%- if link.links.size > 0 -%}
                            <ul class="vdn__col-links" role="menu">
                              {%- for child in link.links -%}
                                <li role="none">
                                  <a href="{{ child.url }}" role="menuitem">
                                    {% render 'valor-menu-title-with-new-badge', title: child.title, badge_class: 'vdn__dl-new' %}
                                  </a>
                                </li>
                              {%- endfor -%}
                            </ul>
                          {%- endif -%}
                          {%- if link.url != blank and link.url != '#' -%}
                            {%- assign _words = link.title | split: ' ' -%}
                            <a href="{{ link.url }}" class="vdn__col-viewall" role="menuitem">View all {{ _words | last }} →</a>
                          {%- endif -%}
                        </div>
                      {%- endfor -%}
                    </div>
                  {%- endif -%}
                </div>

              {%- when 'dropdown-brands' -%}
                {%- assign dd_menu_handle = block.settings.menu | default: 'navmenu-brands' -%}
                {%- assign dd_menu = linklists[dd_menu_handle] -%}
                <div class="vdn__mega vdn__mega--brands" role="menu">
                  {%- if block.settings.eyebrow != blank -%}
                    <div class="vdn__brands-eyebrow">{{ block.settings.eyebrow | escape }}</div>
                  {%- endif -%}

                  {%- comment -%} Per-brand tiles: upload a logo image OR fall back to text, set in the theme editor {%- endcomment -%}
                  {%- assign brand_max = 20 -%}
                  {%- assign brand_rendered = 0 -%}
                  {%- capture brand_tiles -%}
                    {%- for i in (1..brand_max) -%}
                      {%- assign url_key  = 'brand_' | append: i | append: '_url' -%}
                      {%- assign img_key  = 'brand_' | append: i | append: '_image' -%}
                      {%- assign name_key = 'brand_' | append: i | append: '_name' -%}
                      {%- assign b_url  = block.settings[url_key] -%}
                      {%- assign b_img  = block.settings[img_key] -%}
                      {%- assign b_name = block.settings[name_key] -%}
                      {%- assign b_fallback_file = blank -%}
                      {%- case i -%}
                        {%- when 1 -%}{%- assign b_fallback_file = 'mybatpro-dropdown_fa2c8e6a-5f6c-4ce6-acd7-f6dc4bb2538a.png' -%}
                        {%- when 2 -%}{%- assign b_fallback_file = 'mybat-dropdown_ff10186c-dcf8-4fd1-a4c2-2aa5b7b76bc3.png' -%}
                        {%- when 3 -%}{%- assign b_fallback_file = 'echelon-dropdown_275aeb52-2f1f-4e89-9f3c-6009af5f173c.png' -%}
                        {%- when 4 -%}{%- assign b_fallback_file = 'ampnergy-dropdown_d1bd5268-9745-4d1c-9cef-abe4a5ca1ac3.png' -%}
                        {%- when 5 -%}{%- assign b_fallback_file = 'baseline-dropdown_886171a7-48f3-45a7-a28c-22258f9d8cce.png' -%}
                        {%- when 6 -%}{%- assign b_fallback_file = 'ecoblvd-dropdown_cd89d25d-d588-4860-b96a-d0631d4ba72d.png' -%}
                        {%- when 7 -%}{%- assign b_fallback_file = 'ondigo-dropdown_8ac29982-58f3-4e3e-98d7-ac9d32d61cf0.png' -%}
                        {%- when 8 -%}{%- assign b_fallback_file = 'adata-dropdown_908142ec-696d-4d7d-8f79-ada55995017d.png' -%}
                        {%- when 9 -%}{%- assign b_fallback_file = 'beats-dropdown.png' -%}
                        {%- when 12 -%}{%- assign b_fallback_file = 'deejays-dropdown.png' -%}
                        {%- when 14 -%}{%- assign b_fallback_file = 'luxmo-dropdown.png' -%}
                        {%- when 15 -%}{%- assign b_fallback_file = 'maxpower-dropdown.png' -%}
                        {%- when 16 -%}{%- assign b_fallback_file = 'mlb-dropdown_a615b1c1-6087-4116-99d3-5504d6fd5f87.png' -%}
                        {%- when 17 -%}{%- assign b_fallback_file = 'scosche-dropdown.png' -%}
                        {%- when 18 -%}{%- assign b_fallback_file = 'sentry-dropdown.png' -%}
                        {%- when 19 -%}{%- assign b_fallback_file = 'RWAN-logo_1.png' -%}
                      {%- endcase -%}
                      {%- assign b_fallback_img = blank -%}
                      {%- if b_fallback_file != blank -%}
                        {%- assign b_fallback_img = images[b_fallback_file] -%}
                      {%- endif -%}
                      {%- assign b_use_fallback_img = false -%}
                      {%- if b_fallback_img != blank -%}
                        {%- if b_url != blank or b_name != blank -%}
                          {%- assign b_use_fallback_img = true -%}
                        {%- endif -%}
                      {%- endif -%}
                      {%- comment -%} Pull the collection's image when the link points to a collection {%- endcomment -%}
                      {%- assign b_coll_img = nil -%}
                      {%- if b_url contains '/collections/' -%}
                        {%- assign b_coll_handle = b_url | split: '/collections/' | last | split: '/' | first | split: '?' | first | split: '#' | first -%}
                        {%- assign b_coll_img = collections[b_coll_handle].image -%}
                        {%- comment -%} Ignore Shopify's blank placeholder image so it falls back to text {%- endcomment -%}
                        {%- if b_coll_img != blank -%}
                          {%- assign _coll_img_src = b_coll_img | image_url: width: 320 | downcase -%}
                          {%- if _coll_img_src contains 'placeholder' -%}
                            {%- assign b_coll_img = nil -%}
                          {%- endif -%}
                        {%- endif -%}
                      {%- endif -%}
                      {%- if b_img != blank or b_coll_img != blank or b_use_fallback_img or b_name != blank -%}
                        {%- assign brand_rendered = brand_rendered | plus: 1 -%}
                        {%- assign b_alt = b_name | strip_html | strip | escape -%}
                        <a href="{{ b_url | default: '#' }}" class="vdn__brand-pill" role="menuitem">
                          {%- if b_img != blank -%}
                            {{ b_img | image_url: width: 320 | image_tag: loading: 'lazy', class: 'vdn__brand-pill__img', alt: b_alt }}
                          {%- elsif b_coll_img != blank -%}
                            {{ b_coll_img | image_url: width: 320 | image_tag: loading: 'lazy', class: 'vdn__brand-pill__img', alt: b_alt }}
                          {%- elsif b_use_fallback_img -%}
                            {{ b_fallback_img | image_url: width: 320 | image_tag: loading: 'lazy', class: 'vdn__brand-pill__img', alt: b_alt }}
                          {%- else -%}
                            {{ b_name }}
                          {%- endif -%}
                        </a>
                      {%- endif -%}
                    {%- endfor -%}
                  {%- endcapture -%}

                  {%- if brand_rendered > 0 -%}
                    <div class="vdn__brands-grid">{{ brand_tiles }}</div>
                  {%- elsif block.settings.brands_html != blank -%}
                    <div class="vdn__brands-grid">{{ block.settings.brands_html }}</div>
                  {%- elsif dd_menu.links.size > 0 -%}
                    <div class="vdn__brands-grid">
                      {%- for link in dd_menu.links -%}
                        <a href="{{ link.url }}" class="vdn__brand-tile" role="menuitem">
                          <span class="vdn__brand-name">{{ link.title }}</span>
                        </a>
                      {%- endfor -%}
                    </div>
                  {%- endif -%}
                </div>

              {%- when 'dropdown-designlab' -%}
                <div class="vdn__mega vdn__mega--designlab" role="menu">
                  {% render 'valor-design-lab-nav',
                    variant: 'desktop',
                    block_settings: block.settings,
                    block_id: block.id
                  %}
                </div>

              {%- when 'dropdown-simple' -%}
                {%- if is_design_lab_dropdown -%}
                  <div class="vdn__mega vdn__mega--designlab" role="menu">
                    {% render 'valor-design-lab-nav',
                      variant: 'desktop',
                      block_settings: block.settings,
                      block_id: block.id
                    %}
                  </div>
                {%- else -%}
                  {%- assign dd_menu = linklists[block.settings.menu] -%}
                  <div class="vdn__mega vdn__mega--simple{% if block.settings.side_image != blank %} vdn__mega--simple-img{% endif %}" role="menu">
                    {%- if block.settings.side_image != blank -%}
                      <div class="vdn__simple-side">
                        {{ block.settings.side_image | image_url: width: 640 | image_tag }}
                      </div>
                    {%- endif -%}
                    <ul class="vdn__simple-list">
                      {%- for link in dd_menu.links -%}
                        <li role="none"><a href="{{ link.url }}" role="menuitem">{{ link.title }}</a></li>
                      {%- endfor -%}
                    </ul>
                  </div>
                {%- endif -%}

            {%- endcase -%}
          {%- endif -%}

        </li>
      {%- endfor -%}

    </ul>
  </div>
</nav>
<script>
  (function () {
    var section = document.currentScript.closest('.vdn-section');
    var vdn = section && section.querySelector('.vdn');
    var left = document.querySelector('.vhr__left');
    if (vdn && left) {
      left.appendChild(vdn);
      section.style.display = 'none';
    }
  })();
</script>
{%- endif -%}

{% stylesheet %}
/* ── Valor Desktop Nav ─────────────────────────────────────── */
.vdn {
  /*border-bottom: 1px solid rgba(29, 38, 54, 0.08);*/
  /*font-family: var(--font-body--family, inherit);*/
  /*font-size: 13px;*/
}

.vdn__inner {
  max-width: 1440px;
  margin: 0 auto;
  padding: 0 20px;
}

.vdn__list {
  display: flex;
  list-style: none;
  margin: 0;
  padding: 0;
  gap: 2px;
}

/* ── Item ─── */
.vdn__item { position: relative; }

/* ── Trigger (button or <a>) ─── */
.vdn__trigger {
  display: inline-flex;
  align-items: center;
  gap: 5px;
  padding: 0 14px;
  height: 52px;
  font-size: 13px;
  font-weight: 500;
  color: #1D2636;
  background: transparent;
  border: none;
  cursor: pointer;
  text-decoration: none;
  font-family: inherit;
  letter-spacing: 0.005em;
  transition: color 0.15s ease;
  position: relative;
  line-height: 1;
  white-space: nowrap;
}

/* Underline bar */
.vdn__trigger::after {
  content: '';
  position: absolute;
  bottom: 12px;
  left: 14px;
  right: 14px;
  height: 2px;
  background: #C54448;
  transform: scaleX(0);
  transform-origin: left center;
  transition: transform 0.18s ease;
}

/* Active/hover states */
.vdn__item--dd:hover .vdn__trigger,
.vdn__trigger[aria-expanded="true"],
.vdn__trigger:focus-visible {
  color: #C54448;
  outline: none;
}

.vdn__item--dd:hover .vdn__trigger::after,
.vdn__trigger[aria-expanded="true"]::after,
.vdn__link:hover::after,
.vdn__link:focus-visible::after {
  transform: scaleX(1);
}

/* Chevron */
.vdn__chev {
  flex-shrink: 0;
  margin-top: 1px;
  transition: transform 0.18s ease;
}

.vdn__item--dd:hover .vdn__chev,
.vdn__trigger[aria-expanded="true"] .vdn__chev {
  transform: rotate(180deg);
}

/* ── Mega panel (shared base) ─── */
.vdn__mega {
  position: absolute;
  top: calc(100% - 1px);
  left: 0;
  background: #FFFFFF;
  border: 1px solid rgba(29, 38, 54, 0.08);
  box-shadow: 0 14px 40px -10px rgba(29, 38, 54, 0.15), 0 4px 12px -4px rgba(0, 0, 0, 0.08);
  border-radius: 8px;
  opacity: 0;
  visibility: hidden;
  transform: translateY(-6px);
  transition: opacity 0.18s ease, transform 0.18s ease, visibility 0s linear 0.18s;
  z-index: 1000;
  max-width: 100%;
}

.vdn__item--dd:hover .vdn__mega {
  opacity: 1;
  visibility: visible;
  transform: translateY(0);
  transition: opacity 0.18s ease, transform 0.18s ease, visibility 0s linear 0s;
}

/* ── Center alignment mode ─── */
.vdn--center .vdn__mega {
  position: fixed;
  left: 50%;
  top: calc(100% - 3px);
  transform: translateX(-50%) translateY(-6px);
}

.vdn--center .vdn__item--dd:hover .vdn__mega {
  transform: translateX(-50%) translateY(0);
}

/* ── Categories mega ─── */
.vdn__mega--cats {
  padding: 24px 24px 20px;
  min-width: 880px;
}

.vdn__cats-grid {
  display: grid;
  grid-template-columns: repeat(6, minmax(120px, 1fr));
  gap: 20px 14px;
}

/* Column image card */
.vdn__col-img {
  display: block;
  width: 100%;
  /*aspect-ratio: 5 / 3;*/
  border-radius: 6px;
  background:none !important;
  overflow: hidden;
  margin-bottom: 10px;
  text-decoration: none;
  transition: transform 0.2s ease, box-shadow 0.2s ease;
  box-shadow: 0 2px 8px -2px rgba(29, 38, 54, 0.12);
}

.vdn__col-img:hover {
  transform: translateY(-2px);
  box-shadow: 0 6px 16px -4px rgba(29, 38, 54, 0.2);
}

.vdn__col-img-src {
  width: 100%;
  height: 100%;
  object-fit: cover;
  display: block;
}

/* Column title */
.vdn__col-title-link {
  display: block;
  text-decoration: none;
  color: inherit;
}

.vdn__col-title-link:hover .vdn__col-title { color: #C54448; }

.vdn__col-title {
  font-size: 11px;
  font-weight: 700;
  letter-spacing: 0.1em;
  text-transform: uppercase;
  color: #1D2636;
  margin-bottom: 8px;
  transition: color 0.15s ease;
}

/* Column link list */
.vdn__col-links {
  list-style: none;
  margin: 0;
  padding: 0;
  display: flex;
  flex-direction: column;
  gap: 5px;
}

.vdn__col-links li a {
  display: block;
  font-size: 12px;
  color: #66717E;
  text-decoration: none;
  padding: 2px 0;
  transition: color 0.12s ease, transform 0.12s ease;
  font-weight: 400;
}

.vdn__col-links li a:hover {
  color: #C54448;
  transform: translateX(2px);
}

/* ── Devices mega ─── */
.vdn__mega--devices {
  padding: 0 0 20px;
  width: max-content;
}

.vdn__dev-hero {
  display: flex;
  align-items: stretch;
  background: linear-gradient(135deg, #1D2636 0%, #2B3A55 70%, #0a1220 100%);
  color: #F4F5F2;
  border-radius: 8px 8px 0 0;
  text-decoration: none;
  position: relative;
  overflow: hidden;
  transition: filter 0.2s ease;
  min-height: 160px;
}

.vdn__dev-hero:hover { filter: brightness(1.1); }

.vdn__hero-graphic {
  flex: 0 0 28%;
  position: relative;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 16px;
  overflow: hidden;
}

.vdn__hero-device {
  position: relative;
  z-index: 2;
  height: 130px;
  display: flex;
  align-items: center;
  justify-content: center;
  transform: rotate(-8deg);
  filter: drop-shadow(0 10px 20px rgba(0, 0, 0, 0.4));
}

.vdn__hero-glow {
  position: absolute;
  inset: 0;
  background: radial-gradient(circle at 50% 50%, rgba(99, 185, 222, 0.35) 0%, transparent 60%);
  z-index: 1;
  pointer-events: none;
}

.vdn__hero-text {
  flex: 1;
  padding: 22px 26px 18px;
  display: flex;
  flex-direction: column;
  justify-content: center;
  position: relative;
  z-index: 2;
}

.vdn__hero-eyebrow {
  font-size: 10px;
  font-weight: 700;
  letter-spacing: 0.16em;
  text-transform: uppercase;
  color: #63B9DE;
  margin-bottom: 8px;
}

.vdn__hero-title {
  font-size: 24px;
  font-weight: 400;
  color: #F4F5F2;
  line-height: 1.05;
  letter-spacing: -0.01em;
  margin-bottom: 12px;
