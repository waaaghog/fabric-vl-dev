

<div
  class="vab vab--{{ section.settings.type }}{% if section.settings.collapsed_default %} vab--collapsed{% endif %}"
  role="status"
  aria-live="polite"
>
  <div class="vab__inner">
    <div class="vab__icon" aria-hidden="true">
      {%- if section.settings.type == 'warning' -%}
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M10.29 3.86L1.82 18a2 2 0 001.71 3h16.94a2 2 0 001.71-3L13.71 3.86a2 2 0 00-3.42 0z"/><line x1="12" y1="9" x2="12" y2="13"/><line x1="12" y1="17" x2="12.01" y2="17"/></svg>
      {%- elsif section.settings.type == 'error' -%}
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><line x1="15" y1="9" x2="9" y2="15"/><line x1="9" y1="9" x2="15" y2="15"/></svg>
      {%- elsif section.settings.type == 'success' -%}
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
      {%- else -%}
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
      {%- endif -%}
      <span class="vab__pulse" aria-hidden="true"></span>
    </div>

    <div class="vab__content">
      {%- if section.settings.title != blank -%}
        <div class="vab__title">{{ section.settings.title }}</div>
      {%- endif -%}
      {%- if section.settings.body != blank -%}
        <div class="vab__body">{{ section.settings.body }}</div>
      {%- endif -%}
    </div>

    <button class="vab__collapse" type="button" aria-label="Collapse alert" title="Collapse this notice">
      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><polyline points="18 15 12 9 6 15"/></svg>
    </button>
  </div>
</div>


{% stylesheet %}
.vab {
  border-bottom: 1px solid transparent;
  font-family: var(--font-body--family, inherit);
}

/* ── Type: warning (amber) ── */
.vab--warning {
  background: #FBF1DA;
  border-color: rgba(176, 126, 26, 0.25);
  color: #5C4416;
}
.vab--warning .vab__icon   { color: #B07E1A; }
.vab--warning .vab__pulse  { border-color: #B07E1A; }
.vab--warning .vab__title  { color: #5C4416; }
.vab--warning .vab__body   { color: #6C5520; }
.vab--warning .vab__body a { color: #5C4416; }
.vab--warning .vab__collapse:hover { background: rgba(176, 126, 26, 0.12); color: #5C4416; }

/* ── Type: error (red) ── */
.vab--error {
  background: #FDF2F2;
  border-color: rgba(197, 68, 72, 0.25);
  color: #7A1F22;
}
.vab--error .vab__icon   { color: #C54448; }
.vab--error .vab__pulse  { border-color: #C54448; }
.vab--error .vab__title  { color: #7A1F22; }
.vab--error .vab__body   { color: #8C3033; }
.vab--error .vab__body a { color: #7A1F22; }
.vab--error .vab__collapse:hover { background: rgba(197, 68, 72, 0.1); color: #7A1F22; }

/* ── Type: success (green) ── */
.vab--success {
  background: #E1F0E3;
  border-color: rgba(45, 122, 63, 0.25);
  color: #1B4F28;
}
.vab--success .vab__icon   { color: #2d7a3f; }
.vab--success .vab__pulse  { border-color: #2d7a3f; }
.vab--success .vab__title  { color: #1B4F28; }
.vab--success .vab__body   { color: #255C31; }
.vab--success .vab__body a { color: #1B4F28; }
.vab--success .vab__collapse:hover { background: rgba(45, 122, 63, 0.1); color: #1B4F28; }

/* ── Type: info (blue) ── */
.vab--info {
  background: #E8F4FB;
  border-color: rgba(29, 38, 54, 0.15);
  color: #1D2E45;
}
.vab--info .vab__icon   { color: #2B5C8A; }
.vab--info .vab__pulse  { border-color: #2B5C8A; }
.vab--info .vab__title  { color: #1D2E45; }
.vab--info .vab__body   { color: #2A3F5A; }
.vab--info .vab__body a { color: #1D2E45; }
.vab--info .vab__collapse:hover { background: rgba(29, 38, 54, 0.08); color: #1D2636; }

/* ── Layout ── */
.vab__inner {
  max-width: 1440px;
  margin: 0 auto;
  padding: 12px 32px;
  display: flex;
  align-items: flex-start;
  gap: 14px;
}

.vab__icon {
  position: relative;
  flex-shrink: 0;
  width: 28px;
  height: 28px;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-top: -1px;
}

.vab__pulse {
  position: absolute;
  inset: 4px;
  border-radius: 999px;
  border: 1.5px solid;
  opacity: 0;
  animation: vab-pulse 2.2s ease-out infinite;
}

@keyframes vab-pulse {
  0%   { transform: scale(1);    opacity: 0.6; }
  70%  { transform: scale(1.45); opacity: 0; }
  100% { transform: scale(1.45); opacity: 0; }
}

.vab__content {
  flex: 1;
  min-width: 0;
  line-height: 1.45;
}

.vab__title {
  font-size: 13px;
  font-weight: 600;
  letter-spacing: 0.005em;
  margin-bottom: 2px;
}

.vab__body {
  font-size: 12.5px;
}

.vab__body a {
  text-decoration: underline;
  text-underline-offset: 2px;
  font-weight: 500;
  transition: color 0.15s;
}

.vab__body a:hover { color: #1D2636; }

.vab__body p { margin: 0; }

.vab__collapse {
  flex-shrink: 0;
  background: transparent;
  border: none;
  cursor: pointer;
  border-radius: 6px;
  width: 28px;
  height: 28px;
  display: flex;
  align-items: center;
  justify-content: center;
  color: inherit;
  opacity: 0.55;
  transition: background 0.15s, color 0.15s, transform 0.2s;
  margin-top: -2px;
}

.vab__collapse:hover { opacity: 1; }

/* Collapsed state */
.vab--collapsed .vab__body    { display: none; }
.vab--collapsed .vab__pulse   { display: none; }
.vab--collapsed .vab__inner   { padding: 8px 32px; align-items: center; }
.vab--collapsed .vab__collapse svg { transform: rotate(180deg); }

@media (max-width: 749px) {
  .vab__inner { padding: 12px 20px; gap: 10px; }
  .vab__title { font-size: 12.5px; }
  .vab__body  { font-size: 12px; }
  .vab--collapsed .vab__inner { padding: 8px 20px; }
}
{% endstylesheet %}

{% javascript %}
document.addEventListener('click', function (e) {
  var btn = e.target.closest('.vab__collapse');
  if (!btn) return;
  var banner = btn.closest('.vab');
  if (!banner) return;
  var collapsed = banner.classList.toggle('vab--collapsed');
  btn.setAttribute('aria-label', collapsed ? 'Expand alert' : 'Collapse alert');
  btn.setAttribute('title',      collapsed ? 'Expand this notice' : 'Collapse this notice');
});
{% endjavascript %}

{% schema %}
{
  "name": "Alert banner",
  "tag": "div",
  "class": "vab-section",
  "settings": [
    {
      "type": "select",
      "id": "type",
      "label": "Type",
      "options": [
        { "value": "warning", "label": "Warning (amber)" },
        { "value": "error",   "label": "Error (red)" },
        { "value": "success", "label": "Success (green)" },
        { "value": "info",    "label": "Info (blue)" }
      ],
      "default": "warning"
    },
    {
      "type": "text",
      "id": "title",
      "label": "Title",
      "default": "Active notice"
    },
    {
      "type": "richtext",
      "id": "body",
      "label": "Body",
      "default": "<p>Add your message here. You can include <a href=\"#\">links</a>.</p>"
    },
    {
      "type": "checkbox",
      "id": "collapsed_default",
      "label": "Collapsed by default",
      "default": false
    }
  ],
  "presets": [
    {
      "name": "Alert banner"
    }
  ]
}
{% endschema %}
