{% doc %}
  Valor Partner Portal – B2B account dashboard.
  Fully self-contained CSS (--va-* variables, no dependency on theme CSS vars).
  Tabs: dashboard, orders, addresses, profile.
  Order detail supports two modes: multiship (from _order attribute) and simple.
{% enddoc %}

<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&family=Instrument+Serif:ital@0;1&display=swap" rel="stylesheet">

{{ 'valor-account.css' | asset_url | stylesheet_tag }}

{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }
  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }
{%- endstyle -%}

{%- if customer == nil -%}
  <p style="padding:2rem;text-align:center;">
    Please <a class="js-shopify-login-trigger">sign in</a> to view your account.
  </p>
{%- else -%}

{%- comment -%} ── Proxy auth ── {%- endcomment -%}
{%- liquid
  assign _va_ts    	= 'now' | date: '%s'
  assign _va_secret = shop.metafields.valor.connect.value[0]
  assign _va_token  = customer.id | append: '|' | append: _va_ts | hmac_sha256: _va_secret
-%}
<script>
	window.__vaAuth = {
		customer_id: {{ customer.id | json }},
		customer_email: {{ customer.email | json }},
		ts: {{ _va_ts | json }},
		token: {{ _va_token | json }},
		proxy: window.__vaProxy
	};
</script>

{%- comment -%} ── Pre-compute dashboard metrics ── {%- endcomment -%}
{%- assign _va_year  = 'now' | date: '%Y' -%}
{%- assign _va_fi       = customer.first_name | slice: 0 | upcase -%}
{%- assign _va_li       = customer.last_name  | slice: 0 | upcase -%}
{%- assign _va_initials = _va_fi | append: _va_li -%}
{%- assign _va_company  = customer.default_address.company | default: '' -%}
{%- assign _va_tier     = customer.metafields.custom.tier.value | default: '' -%}
{%- assign _va_addrs_count  = customer.addresses.size -%}

<div class="section section--{{ section.settings.section_width }}">
<div class="va section-{{ section.id }}-padding">
  <div class="va-shell">

    <!-- ═══ SIDEBAR ═══════════════════════════════════════ -->
    <aside class="va-sidebar">
      <div class="va-side-head">
        <div class="va-side-account">
          <div class="va-side-av">{{ _va_initials }}</div>
          <div class="va-side-info">
            <div class="va-side-name">{{ customer.name }}</div>
            {%- if _va_company != blank -%}
            <div class="va-side-company">{{ _va_company }}</div>
            {%- endif -%}
            <div class="va-side-role">{{ customer.email }}</div>
            <div class="va-side-role" id="va-side-customer-no" hidden></div>
          </div>
        </div>
        {%- if _va_tier != blank -%}
        <div class="va-side-tier">
          <div>
            <div class="va-side-tier-label">Account tier</div>
            <div class="va-side-tier-value">{{ _va_tier }}</div>
          </div>
        </div>
        {%- endif -%}
      </div>

      <nav class="va-side-nav">
        <div class="va-side-section">Overview</div>
        <a href="#dashboard" class="va-side-link" data-tab="dashboard">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7"><rect x="3" y="3" width="7" height="9" rx="1"/><rect x="14" y="3" width="7" height="5" rx="1"/><rect x="14" y="12" width="7" height="9" rx="1"/><rect x="3" y="16" width="7" height="5" rx="1"/></svg>
          Dashboard
        </a>

        <div class="va-side-section">Operations</div>
        <a href="#orders" class="va-side-link" data-tab="orders">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7"><path d="M6 2 3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4Z"/><path d="M3 6h18M16 10a4 4 0 0 1-8 0"/></svg>
          Orders
        </a>
        <a href="#invoices" class="va-side-link" data-tab="invoices">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8zM14 2v6h6M9 13h6M9 17h4"/></svg>
          Invoices
        </a>
        <a href="#rma" class="va-side-link" data-tab="rma">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7"><path d="M3 3v5h5M22 12a10 10 0 1 1-3-7.3L22 8"/></svg>
          Returns &amp; RMA
        </a>
        <a href="#bulk" class="va-side-link" data-tab="bulk" hidden>
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4M7 10l5 5 5-5M12 15V3"/></svg>
          Bulk upload
        </a>

        <div class="va-side-section" style="display: none;">Shortcuts</div>
        <a href="#favorites" class="va-side-link" data-tab="favorites">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7"><path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/></svg>
          Favorites
        </a>
        <a href="#lists" class="va-side-link" data-tab="lists" style="display:none">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7"><path d="M6 2 3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4Z"/><path d="M3 6h18M16 10a4 4 0 0 1-8 0"/></svg>
          Saved carts
        </a>

        <div class="va-side-section">Account</div>
        <a href="#addresses" class="va-side-link" data-tab="addresses">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>
          Address book
        </a>
        <a href="#payment" class="va-side-link" data-tab="payment">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7"><rect x="2" y="5" width="20" height="14" rx="2"/><path d="M2 10h20"/></svg>
          Payment &amp; terms
        </a>
        <a href="#team" class="va-side-link" data-tab="team" style="display: none;">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87M16 3.13a4 4 0 0 1 0 7.75"/></svg>
          Team permissions
        </a>
        <a href="#profile" class="va-side-link" data-tab="profile">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
          Profile &amp; security
        </a>
      </nav>

      <div class="va-side-foot">
        <a href="#" class="va-side-foot-link">
          Contact your rep
          <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7"><path d="M7 17 17 7M7 7h10v10"/></svg>
        </a>
        <a href="#" class="va-side-foot-link">
          Help center
          <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7"><path d="M7 17 17 7M7 7h10v10"/></svg>
        </a>
      </div>

		<a href="/account/logout" class="va-side-link va-side-signout">
			<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7"><path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4M16 17l5-5-5-5M21 12H9"/></svg>
			Sign out
		</a>
    </aside>

    <!-- ═══ MAIN ═══════════════════════════════════════════ -->
    <main class="va-main">

      <!-- ── TAB: DASHBOARD ───────────────────────────────── -->
      <div class="va-tab" id="va-tab-dashboard">

        <div class="va-page-head">
          <div class="va-page-head-left">
            <h1>Welcome back, <em>{{ customer.first_name }}.</em></h1>
            <div class="va-page-head-sub" id="va-dash-head-sub">Loading orders…</div>
          </div>
          <div class="va-page-head-actions">
            <a href="{{ routes.root_url }}" class="va-btn-primary">
              Start new order
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14M13 5l7 7-7 7"/></svg>
            </a>
          </div>
        </div>

        <!-- Metric row -->
        <div class="va-metric-row">
          <div class="va-metric">
            <div class="va-metric-head">
              <div class="va-metric-label">Open orders</div>
              <div class="va-metric-icon"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7"><path d="M6 2 3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4Z"/><path d="M3 6h18"/></svg></div>
            </div>
            <div class="va-metric-value"></div>
            <div class="va-metric-delta neutral">active orders</div>
          </div>
          <div class="va-metric">
            <div class="va-metric-head">
              <div class="va-metric-label">YTD volume</div>
              <div class="va-metric-icon"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7"><polyline points="22 12 18 12 15 21 9 3 6 12 2 12"/></svg></div>
            </div>
            <div class="va-metric-value"></div>
            <div class="va-metric-delta neutral">{{ _va_year }}</div>
          </div>
          <div class="va-metric">
            <div class="va-metric-head">
              <div class="va-metric-label">Total orders</div>
              <div class="va-metric-icon"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8zM14 2v6h6"/></svg></div>
            </div>
            <div class="va-metric-value" id="va-metric-total-orders"></div>
            <div class="va-metric-delta neutral">all time</div>
          </div>
          <div class="va-metric">
            <div class="va-metric-head">
              <div class="va-metric-label">Addresses</div>
              <div class="va-metric-icon"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg></div>
            </div>
            <div class="va-metric-value" id="va-metric-addr-count"></div>
            <div class="va-metric-delta neutral">ship-to locations</div>
          </div>
        </div>

        <!-- Dash grid -->
        <div class="va-dash-grid">

          <!-- Left col: chart + recent orders -->
          <div class="va-dash-col">

            <!-- Order volume chart (illustrative) -->
            <div class="va-panel">
              <div class="va-panel-head">
                <div>
                  <h3>Order volume</h3>
                  <div class="va-panel-head-sub">Last 12 months · order totals</div>
                </div>
              </div>
              <div class="va-chart-wrap">
                <div class="va-chart-area">
                  <svg viewBox="0 0 600 180" preserveAspectRatio="none" style="width:100%;height:100%;">
                    <defs>
                      <linearGradient id="va-g1" x1="0" y1="0" x2="0" y2="1">
                        <stop offset="0%" stop-color="#2B3A55" stop-opacity="0.15"/>
                        <stop offset="100%" stop-color="#2B3A55" stop-opacity="0"/>
                      </linearGradient>
                    </defs>
                    <line x1="0" y1="30" x2="600" y2="30" stroke="#EEEDE7" stroke-width="1"/>
                    <line x1="0" y1="80" x2="600" y2="80" stroke="#EEEDE7" stroke-width="1"/>
                    <line x1="0" y1="130" x2="600" y2="130" stroke="#EEEDE7" stroke-width="1"/>
                    <path d="M 0 120 T 60 100 T 120 90 T 180 95 T 240 70 T 300 75 T 360 55 T 420 60 T 480 40 T 540 45 T 600 30"
                          stroke="#2B3A55" stroke-width="2" fill="none"/>
                    <path d="M 0 120 T 60 100 T 120 90 T 180 95 T 240 70 T 300 75 T 360 55 T 420 60 T 480 40 T 540 45 T 600 30 L 600 180 L 0 180 Z"
                          fill="url(#va-g1)"/>
                    <circle cx="600" cy="30" r="4" fill="#C54448"/>
                    <circle cx="600" cy="30" r="8" fill="#C54448" opacity="0.2"/>
                  </svg>
                </div>
                <div class="va-chart-legend">
                  <div class="va-chart-legend-item">
                    <div class="va-legend-dot" style="background:#2B3A55;"></div>
                    Order volume
                  </div>
                  <div class="va-chart-legend-item">
                    <div class="va-legend-dot" style="background:#C54448;"></div>
                    Today
                  </div>
                </div>
              </div>
            </div>

            <!-- Recent orders panel -->
            <div class="va-panel">
              <div class="va-panel-head">
                <div>
                  <h3>Recent orders</h3>
                  <div class="va-panel-head-sub" id="va-dash-order-sub">Last 30 days</div>
                </div>
                <a href="#orders" class="va-panel-head-link va-side-link-trigger" data-tab="orders">All orders →</a>
              </div>
              <div class="va-order-list">
                <div class="va-order-row va-order-row-head">
                  <div>Order</div><div>Date</div><div>Total</div><div>Status</div><div></div>
                </div>
                <div id="va-dash-order-list">
                  <div class="va-empty">Loading orders…</div>
                </div>
              </div>
            </div>

          </div><!-- /left col -->

          <!-- Right col: locations + returns -->
          <div class="va-dash-col">

            <!-- Active locations -->
            <div class="va-panel">
              <div class="va-panel-head">
                <div>
                  <h3>Addresses</h3>
                  <div class="va-panel-head-sub" id="va-dash-addr-sub">Loading…</div>
                </div>
                <a href="#addresses" class="va-panel-head-link va-side-link-trigger" data-tab="addresses">Manage →</a>
              </div>
              <div id="va-dash-addr-list"><div class="va-empty">Loading…</div></div>
            </div>

          </div><!-- /right col -->

        </div><!-- /dash-grid -->
      </div><!-- /tab-dashboard -->


      <!-- ── TAB: ORDERS ──────────────────────────────────── -->
      <div class="va-tab" id="va-tab-orders">

        <div class="va-page-head" id="va-orders-page-head">
          <div class="va-page-head-left">
            <h1>Orders <em>history.</em></h1>
            <div class="va-page-head-sub" id="va-orders-page-sub">Loading orders…</div>
          </div>
        </div>

        <div class="va-panel" id="va-orders-list-panel">
          <div class="va-inv-filter-bar">
            <div class="va-inv-search-wrap">
              <input type="text" id="va-orders-search" class="va-inv-search-input" placeholder="Filter in this page..." autocomplete="off">
              <button class="va-inv-search-clear" id="va-orders-search-clear" tabindex="-1" aria-label="Clear search">&#x2715;</button>
            </div>
            <div class="va-pager-top" id="va-orders-pager-top" hidden></div>
          </div>
          <div class="va-order-list">
            <div class="va-order-row va-order-row-head">
              <div>Order</div><div>Date</div><div>Total</div><div>Status</div><div></div>
            </div>

            <div id="va-orders-list">
              <div class="va-empty">Loading orders…</div>
            </div>
            <div class="va-inv-pager" id="va-orders-pager" hidden></div>

          </div>
        </div>
      </div><!-- /tab-orders -->


      <!-- ── TAB: ADDRESSES ───────────────────────────────── -->
      <div class="va-tab" id="va-tab-addresses">

        <div class="va-page-head"><div class="va-page-head-left"><h1>Address <em>book.</em></h1></div></div>

        <!-- ERP ship-to addresses -->
        <div class="va-panel" style="margin-bottom:20px;">
          <div class="va-pay-content">
            <div class="va-panel-title">Ship-to locations</div>
            <p class="va-pay-desc">Company ship-to addresses.</p>
            <div class="va-erp-addr-actions"></div>
            <div class="va-erp-addr-list"></div>
          </div>
        </div>
      </div><!-- /tab-addresses -->


      <!-- ── TAB: PROFILE ─────────────────────────────────── -->
      <div class="va-tab" id="va-tab-profile">

        <div class="va-page-head">
          <div class="va-page-head-left">
            <h1>Profile <em>&amp; security.</em></h1>
          </div>
        </div>

        <div class="va-profile-panel">
          <h3>Account information</h3>
          <div class="va-profile-field">
            <div class="va-profile-label">Name</div>
            <div class="va-profile-value">{{ customer.name }}</div>
          </div>
          <div class="va-profile-field">
            <div class="va-profile-label">Email</div>
            <div class="va-profile-value">{{ customer.email }}</div>
          </div>
          {%- if customer.default_address.phone != blank -%}
          <div class="va-profile-field">
            <div class="va-profile-label">Phone</div>
            <div class="va-profile-value">{{ customer.default_address.phone }}</div>
          </div>
          {%- endif -%}
          {%- if _va_tier != blank -%}
          <div class="va-profile-field">
            <div class="va-profile-label">Account tier</div>
            <div class="va-profile-value">{{ _va_tier }}</div>
          </div>
          {%- endif -%}
          <div class="va-profile-actions">
            <a href="/account" class="va-btn-outline">Edit profile</a>
            <a href="/account/logout" class="va-btn-outline">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7"><path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4M16 17l5-5-5-5M21 12H9"/></svg>
              Sign out
            </a>
          </div>
        </div>

        <div class="va-profile-panel" id="va-profile-company-panel" hidden>
          <h3>Company</h3>
          <div class="va-profile-field">
            <div class="va-profile-label">Name</div>
            <div class="va-profile-value" id="va-profile-company-name"></div>
          </div>
          <div class="va-profile-field" id="va-profile-company-no-row" hidden>
            <div class="va-profile-label">Customer #</div>
            <div class="va-profile-value" id="va-profile-company-no"></div>
          </div>
          <div class="va-profile-field" id="va-profile-company-market-row" hidden>
            <div class="va-profile-label">Market</div>
            <div class="va-profile-value" id="va-profile-company-market"></div>
          </div>
          <div class="va-profile-field" id="va-profile-company-addr-row" hidden>
            <div class="va-profile-label">Address</div>
            <div class="va-profile-value va-profile-addr" id="va-profile-company-addr"></div>
          </div>
          <div class="va-profile-field" id="va-profile-company-phone-row" hidden>
            <div class="va-profile-label">Phone</div>
            <div class="va-profile-value" id="va-profile-company-phone"></div>
          </div>
        </div>

      </div><!-- /tab-profile -->

      <!-- ── TAB: INVOICES ────────────────────────────────── -->
      <div class="va-tab" id="va-tab-invoices">
        <div class="va-page-head"><div class="va-page-head-left"><h1>Invoices <em>&amp; statements.</em></h1>
			<div class="va-page-head-sub" id="va-invoices-page-sub">Loading invoices&hellip;</div></div>
		</div>
        <div class="va-panel">
          <div class="va-inv-filter-bar">
            <div class="va-inv-search-wrap">
              <input type="text" id="va-inv-search" class="va-inv-search-input" placeholder="Filter in this page..." autocomplete="off">
              <button class="va-inv-search-clear" id="va-inv-search-clear" tabindex="-1" aria-label="Clear search">&#x2715;</button>
            </div>
            <div class="va-inv-filter-amt" style="display:none">
              <span class="va-inv-filter-currency">$</span>
              <input type="number" id="va-inv-min" class="va-inv-filter-num" placeholder="min" min="0" step="0.01">
              <span class="va-inv-filter-dash">&#x2500;&#x2500;</span>
              <span class="va-inv-filter-currency">$</span>
              <input type="number" id="va-inv-max" class="va-inv-filter-num" placeholder="max" min="0" step="0.01">
            </div>
            <div class="va-pager-top" id="va-inv-pager-top" hidden></div>
          </div>
          <div id="va-inv-list"></div>
        </div>
      </div><!-- /tab-invoices -->

      <!-- ── TAB: RETURNS & RMA ────────────────────────────── -->
      <div class="va-tab" id="va-tab-rma">
        <div class="va-page-head"><div class="va-page-head-left"><h1>Returns <em>&amp; RMA.</em></h1></div></div>
        <div class="va-panel"><div class="va-empty">
          <svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M3 3v5h5M22 12a10 10 0 1 1-3-7.3L22 8"/></svg>
          Returns &amp; RMA coming soon.
        </div></div>
      </div><!-- /tab-rma -->

      <!-- ── TAB: BULK UPLOAD ──────────────────────────────── -->
      <div class="va-tab" id="va-tab-bulk" hidden>
        <div class="va-page-head"><div class="va-page-head-left"><h1>Bulk <em>upload.</em></h1></div></div>
        <div class="va-panel va-bulk-panel" data-api-base="{{ section.settings.bulk_order_api_url | escape }}">
          <div class="va-bulk-content">
            <div>
              <div class="va-panel-title">Bulk upload draft</div>
              <p class="va-bulk-intro">Upload a CSV with <strong>SFID or BC Customer Location ID, SKU, Quantity</strong>. <a href="#" class="va-bulk-download-link va-bulk-template-download" aria-disabled="true">Download your customer CSV template</a>. Data and SKU errors block the entire submission. Inventory issues stay actionable and do not block valid locations from being submitted. Contact our customer support if you need any assistance. Review your address records <a href="#" class="va-bulk-download-link va-bulk-address-download" aria-disabled="true">here</a>.</p>
            </div>

            <div class="va-bulk-grid">
              <label class="va-bulk-field">
                Order CSV
                <input type="file" class="va-bulk-file" accept=".csv,text/csv">
                <span class="va-bulk-hint">Maximum 25 MB. Header: Location ID / SFID, SKU, Quantity.</span>
              </label>
              <label class="va-bulk-field">
                ACH payment method
                <select class="va-bulk-ach" disabled>
                  <option value="">Loading ACH accounts…</option>
                </select>
                <span class="va-bulk-hint">Accounts are read from Payment &amp; terms and verified again by the API.</span>
              </label>
            </div>

            <div class="va-bulk-status" role="status">Loading your customer and payment information…</div>
            <div class="va-bulk-progress" hidden>
              <div class="va-bulk-progress-head"><strong class="va-bulk-progress-label">Queued</strong><span class="va-bulk-progress-count">0 / 0 locations</span></div>
              <div class="va-bulk-progress-track"><div class="va-bulk-progress-bar"></div></div>
            </div>
            <div class="va-bulk-summary-cards" hidden></div>
            <div class="va-bulk-preview" hidden></div>
            <div class="va-bulk-results" hidden></div>
            <div class="va-bulk-actions">
              <button type="button" class="va-bulk-footer-btn va-bulk-footer-btn--outline va-bulk-rules">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" aria-hidden="true"><path d="M12 20h9M16.5 3.5a2.121 2.121 0 0 1 3 3L7 19l-4 1 1-4L16.5 3.5z"></path></svg>
                Edit Substitution Rule Profiles
              </button>
              <div class="va-bulk-actions-right">
                <button type="button" class="va-bulk-footer-btn va-bulk-footer-btn--reset va-bulk-reset" disabled>Reset Draft Workspace</button>
                <button type="button" class="va-bulk-footer-btn va-bulk-footer-btn--primary va-bulk-import" disabled>
                  <span>Submit Multi-Location Orders (<span class="va-bulk-import-count">0</span>)</span>
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M5 12h14M13 5l7 7-7 7"></path></svg>
                </button>
              </div>
            </div>
            <dialog class="va-bulk-rules-dialog">
              <div class="va-bulk-rules-body">
                <div class="va-panel-title">Customer-group substitution rules</div>
                <p class="va-bulk-intro">One group per line: Device, Product, then SKUs in priority order. Rules apply to this customer group across all locations.</p>
                <textarea class="va-bulk-rules-text" spellcheck="false" placeholder="Device,Product,Priority 1 SKU,Priority 2 SKU"></textarea>
                <div class="va-bulk-rules-actions">
                  <button type="button" class="va-btn va-btn--outline va-bulk-rules-cancel">Cancel</button>
                  <button type="button" class="va-btn va-btn--primary va-bulk-rules-save">Save rules</button>
                </div>
              </div>
            </dialog>
          </div>
          <div class="va-bulk-busy-overlay" hidden role="status" aria-live="assertive" aria-label="Bulk order processing in progress">
            <div class="va-bulk-busy-card">
              <span class="va-bulk-busy-spinner" aria-hidden="true"></span>
              <strong class="va-bulk-busy-title">Validating CSV…</strong>
              <span class="va-bulk-busy-detail">Please keep this page open until processing completes.</span>
            </div>
          </div>
        </div>
      </div><!-- /tab-bulk -->

      <!-- ── TAB: FAVORITES ────────────────────────────────── -->
      <div class="va-tab" id="va-tab-favorites">
        <div class="va-page-head"><div class="va-page-head-left"><h1>Favorites <em>&amp; quick reorder.</em></h1></div></div>
        <div class="va-panel"><div class="va-empty">
          <svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/></svg>
          Favorites coming soon.
        </div></div>
      </div><!-- /tab-favorites -->

      <!-- ── TAB: SAVED CARTS ──────────────────────────────── -->
      <div class="va-tab" id="va-tab-lists">
        <div class="va-page-head"><div class="va-page-head-left"><h1>Saved <em>carts.</em></h1></div></div>
        <div class="va-panel">
          <div class="va-inv-filter-bar">
            <div class="va-inv-search-wrap">
              <input type="text" id="va-sc-search" class="va-inv-search-input" placeholder="Filter in this page..." autocomplete="off">
              <button class="va-inv-search-clear" id="va-sc-search-clear" tabindex="-1" aria-label="Clear search">&#x2715;</button>
            </div>
            <div class="va-sc-scope" id="va-sc-scope" style="margin: 0 auto;">
              <button class="va-sc-scope-btn va-sc-scope-btn--active" data-scope="mine">My company</button>
              <button class="va-sc-scope-btn" data-scope="org">Whole orgnization</button>
            </div>
            <div class="va-pager-top" id="va-sc-pager-top" hidden></div>
          </div>
          <div id="va-sc-list">
            <div class="va-empty" style="padding: 28px;">Loading…</div>
          </div>
          <div class="va-inv-pager" id="va-sc-pager" hidden></div>
        </div>
      </div><!-- /tab-lists -->

      <!-- ── TAB: PAYMENT & TERMS ──────────────────────────── -->
      <div class="va-tab" id="va-tab-payment">
        <div class="va-page-head"><div class="va-page-head-left"><h1>Payment <em>&amp; terms.</em></h1></div></div>
        <!-- Credit cards — shown only for CRICKET-WIRELESS by JS -->
        <div class="va-panel va-cc-panel" hidden>
          <div class="va-pay-content">
            <div class="va-panel-title">Credit cards</div>
            <p class="va-pay-desc">Select a default card for automatic payments on orders.</p>
            <div class="va-cc-add-form" hidden>
              <h3>Add credit card</h3>
              <div class="va-cc-form-layout">
                <div class="va-cc-consent">
                  <p>By saving your credit card on <strong>www.valorcomm.com</strong>, you authorize <strong>Valor Communication, Inc.</strong> to securely store your payment information and automatically process credit card authorizations for purchase orders submitted through the <strong>Cricket ABO system</strong> or any integrated ordering system that transmits purchase orders to our website.</p>
                  <p>You agree that your card may be used to <strong>authorize and hold funds</strong> for such orders at the time they are placed. You acknowledge that this authorization applies to all future purchase orders submitted through the integrated systems until you remove or update your stored payment information. You may remove your saved card at any time by accessing your account settings on <strong>www.valorcomm.com</strong>.</p>
                  <p>Valor Communication, Inc. will not disclose your payment information to any third party, except as required to process transactions securely in compliance with applicable laws and PCI-DSS standards. By checking the box, you confirm that you have read, understood, and agree to this Credit Card Authorization Agreement.</p>
                  <label class="va-cc-consent-label"><input type="checkbox" name="cc_consent">&nbsp;I understand and agree</label>
                </div>
                <div class="va-pay-fields">
                  <div class="va-pay-row">
                    <label class="va-field">Card number<input type="text" name="cc_number" placeholder="•••• •••• •••• ••••" inputmode="numeric" maxlength="19" autocomplete="cc-number"></label>
                    <label class="va-field">Cardholder name<input type="text" name="cc_holder" placeholder="Name on card" autocomplete="cc-name"></label>
                  </div>
                  <div class="va-pay-row">
                    <label class="va-field">Expiry<input type="text" name="cc_expiry" placeholder="MM/YY" maxlength="5" autocomplete="cc-exp"></label>
                    <label class="va-field">CVV<input type="text" name="cc_cvv" placeholder="•••" maxlength="4" inputmode="numeric" autocomplete="cc-csc"></label>
                  </div>
                  <div class="va-pay-row">
                    <label class="va-field">Billing address<input type="text" name="cc_street" placeholder="Street address" autocomplete="street-address"></label>
                    <label class="va-field">Billing city<input type="text" name="cc_city" placeholder="City" autocomplete="address-level2"></label>
                  </div>
                  <div class="va-pay-row">
                    <label class="va-field">Billing state<input type="text" name="cc_state" placeholder="State" autocomplete="address-level1"></label>
                    <label class="va-field">Billing ZIP<input type="text" name="cc_zip" placeholder="ZIP code" inputmode="numeric" maxlength="10" autocomplete="postal-code"></label>
                  </div>
                  <div class="va-cc-form-err va-pay-error" hidden></div>
                  <div class="va-pay-actions">
                    <button class="va-btn va-btn--primary va-cc-save">Save card</button>
                    <button class="va-btn va-cc-cancel-add">Cancel</button>
                  </div>
                </div>
              </div>
            </div>
            <button class="va-btn va-cc-open-add">+ Add credit card</button>
            <div class="va-cc-accounts"></div>
          </div>
        </div>
        <div class="va-panel">
          <div class="va-pay-content">
            <div class="va-panel-title">ACH bank accounts</div>
            <p class="va-pay-desc">Saved bank accounts used for ACH payments at checkout.</p>
            <div class="va-ach-add-form" hidden>
              <h3>Add bank account</h3>
              <div class="va-pay-fields">
                <div class="va-pay-row">
                  <label class="va-field">Account holder name<input type="text" name="holder" placeholder="Full name" autocomplete="name"></label>
                  <label class="va-field">Nickname<input type="text" name="nickName" placeholder="Optional"></label>
                </div>
                <div class="va-pay-row">
                  <label class="va-field">Routing number<input type="text" name="routing" placeholder="9 digits" maxlength="9" inputmode="numeric"></label>
                  <label class="va-field">Account number<input type="text" name="account" placeholder="Account number" inputmode="numeric"></label>
                </div>
                <div class="va-ach-form-err va-pay-error" hidden></div>
                <div class="va-pay-actions">
                  <button class="va-btn va-btn--primary va-ach-save">Save bank account</button>
                  <button class="va-btn va-ach-cancel">Cancel</button>
                </div>
              </div>
            </div>
            <button class="va-btn va-ach-open">+ Add bank account</button>
            <div class="va-ach-accounts"></div>
          </div>
        </div>
        <!-- Permission modal (shared, dynamically populated) -->
        <div class="va-perm-modal" id="va-perm-modal" hidden>
          <div class="va-perm-dialog">
            <div class="va-perm-head">
              <div class="va-perm-head-row">
                <div>
                  <div class="va-perm-title">Set permissions  -  <span class="va-perm-sub"></span></div>
                  <p class="va-perm-desc">Select which child companies can use this payment account at checkout.</p>
                </div>
                <button class="va-perm-close" aria-label="Close">&times;</button>
              </div>
              <div class="va-perm-toolbar">
                <div class="va-perm-search-wrap">
                  <input type="text" class="va-perm-search" placeholder="Filter locations…" autocomplete="off">
                  <button class="va-perm-search-clear" tabindex="-1" aria-label="Clear filter">&#x2715;</button>
                </div>
                <button class="va-perm-select-all-btn">Select all</button>
				<div class="va-team-access-note va-perm-default-note" hidden>Default: available to all locations</div>
              </div>
            </div>
            <div class="va-perm-body">
              <div class="va-perm-list"></div>
            </div>
            <div class="va-perm-foot">
              <div class="va-perm-error va-pay-error" hidden></div>
              <div class="va-pay-actions">
                <button class="va-perm-save va-btn va-btn--primary">Save</button>
                <button class="va-perm-cancel va-btn">Cancel</button>
              </div>
            </div>
          </div>
        </div>
      </div><!-- /tab-payment -->

      <!-- ── TAB: TEAM & PERMISSIONS ───────────────────────── -->
      <div class="va-tab" id="va-tab-team">
        <div class="va-page-head">
          <div class="va-page-head-left">
            <h1>Team <em>&amp; permissions.</em></h1>
            <div class="va-page-head-sub" id="va-team-sub">Loading…</div>
          </div>
        </div>
        <div class="va-panel" id="va-team-panel">
          <div class="va-perm-head">
            <div class="va-perm-head-row">
              <div>
                <div class="va-perm-title">Location access</div>
                <p class="va-perm-desc">Select which locations you can access. Uncheck locations to restrict your view. By default you have access to all locations.</p>
              </div>
            </div>
            <div class="va-perm-toolbar">
              <select class="va-team-user-select" id="va-team-user-select">
                <option value="">Loading users…</option>
              </select>
              <div class="va-perm-search-wrap">
                <input type="text" class="va-perm-search" id="va-team-search" placeholder="Filter locations…" autocomplete="off">
                <button class="va-perm-search-clear" id="va-team-search-clear" tabindex="-1" aria-label="Clear filter">&#x2715;</button>
              </div>
              <button class="va-perm-select-all-btn" id="va-team-select-all">Select all</button>
            </div>
          </div>
          <div class="va-perm-body">
            <div class="va-perm-list" id="va-team-list">
              <div class="va-empty">Loading…</div>
            </div>
          </div>
          <div class="va-perm-foot">
            <div class="va-team-access-note" id="va-team-access-note" hidden></div>
            <div class="va-pay-error" id="va-team-error" hidden></div>
            <div class="va-pay-actions">
              <button class="va-btn va-btn--primary" id="va-team-save">Save</button>
              <button class="va-btn" id="va-team-reset">Reset to full access</button>
            </div>
          </div>
        </div>
      </div><!-- /tab-team -->

      <!-- Order detail panel — overlays any tab when a row is clicked -->
      <div id="va-od-panel" hidden>
        <div class="va-od-topbar">
          <button class="va-od-back" id="va-od-back">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M19 12H5M12 19l-7-7 7-7"/></svg>
            Orders
          </button>
          <span class="va-od-topbar-name" id="va-od-topbar-name"></span>
          <span class="va-od-topbar-num" id="va-od-topbar-num" hidden></span>
          <span class="va-od-topbar-num" id="va-od-topbar-ext" hidden></span>
        </div>
        <div id="va-od-content">
          <div class="va-od-skeleton">
            <div class="va-od-skel va-od-skel--short"></div>
            <div class="va-od-skel"></div>
            <div class="va-od-skel va-od-skel--wide"></div>
            <div class="va-od-skel va-od-skel--short"></div>
          </div>
        </div>
      </div>

    </main>
  </div>
</div>
</div>

<!-- Image zoom lightbox -->
<div class="va-lightbox" id="va-lightbox" aria-hidden="true" role="dialog" aria-modal="true" aria-label="Product image">
  <button class="va-lightbox-close" aria-label="Close">&times;</button>
  <img class="va-lightbox-img" src="" alt="">
</div>

<dialog class="va-confirm-dialog" id="va-confirm-dialog">
  <div class="va-confirm-body">
    <div class="va-confirm-msg" id="va-confirm-msg"></div>
  </div>
  <div class="va-confirm-actions">
    <button class="va-confirm-cancel" id="va-confirm-cancel">Cancel</button>
    <button class="va-confirm-ok danger" id="va-confirm-ok">Delete</button>
  </div>
</dialog>

{%- endif -%}

<script src="{{ 'valor-account.js' | asset_url }}&feature=bulk-page-busy-lock-20260723"></script>

{% schema %}
{
  "name": "Valor account",
  //"tag": "section",
  //"class": "valor-account-section",
  "settings": [
    {
      "type": "select",
      "id": "section_width",
      "label": "Width",
      "options": [
        { "value": "page-width", "label": "Page" },
        { "value": "full-width", "label": "Full" }
      ],
      "default": "page-width"
    },
    {
      "type": "text",
      "id": "bulk_order_api_url",
      "label": "Bulk order API URL",
      "default": "https://valor-middleplatform-dev.azurewebsites.net/api/shopify/bulk-orders"
    },
    {
      "type": "header",
      "content": "Padding"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Top",
      "default": 0
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Bottom",
      "default": 0
    }
  ],
  "presets": [
  	{
		"name": "Valor account",
  	}
  ]
}
{% endschema %}
