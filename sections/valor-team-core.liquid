{% liquid
  assign contact_url = routes.root_url | append: 'pages/contact'
  if section.settings.contact_link != blank
    assign contact_url = section.settings.contact_link
  endif

  assign contact_label = section.settings.contact_label
  if contact_label == blank
    assign contact_label = 'Contact us'
  endif

  assign founder_count = 0
  assign leadership_count = 0

  for block in section.blocks
    if block.type == 'member'
      if block.settings.featured_founder
        assign founder_count = founder_count | plus: 1
      else
        assign leadership_count = leadership_count | plus: 1
      endif
    endif
  endfor
%}

{% style %}
  .valor-team-core {
    --valor-navy: var(--color-foreground-heading, #2b3a55);
    --valor-navy-deep: var(--color-foreground, #1d2636);
    --valor-crimson: {{ section.settings.accent_color | default: '#c54448' }};
    --valor-crimson-deep: color-mix(in srgb, var(--valor-crimson) 80%, #000000);
    --valor-chalk: var(--color-background, #f4f5f2);
    --valor-parchment: color-mix(in srgb, var(--color-background, #f4f5f2) 92%, var(--color-foreground, #1d2636) 8%);
    --valor-steel: rgb(var(--color-foreground-rgb, 29 38 54) / 0.68);
    --valor-border: rgb(var(--color-border-rgb, 29 38 54) / 0.18);
    --valor-border-strong: rgb(var(--color-border-rgb, 29 38 54) / 0.32);

    background: var(--color-background);
    color: var(--color-foreground);
    font-family: var(--font-body--family), Inter, Arial, sans-serif;
  }

  .valor-team-core__page {
    max-width: 1280px;
    margin: 0 auto;
    padding: 0 32px;
  }

  .valor-team-core__crumb {
    padding-top: 24px;
    color: var(--valor-steel);
    font-size: 12px;
    letter-spacing: 0.04em;
  }

  .valor-team-core__crumb a {
    color: inherit;
    text-decoration: none;
    transition: color 160ms ease;
  }

  .valor-team-core__crumb a:hover {
    color: var(--valor-navy-deep);
  }

  .valor-team-core__crumb-separator {
    margin: 0 8px;
    opacity: 0.5;
  }

  .valor-team-core__crumb-current {
    color: var(--valor-navy-deep);
  }

  .valor-team-core__hero {
    padding: 80px 0 56px;
  }

  .valor-team-core__eyebrow {
    display: flex;
    align-items: center;
    gap: 14px;
    margin-bottom: 32px;
    color: var(--valor-crimson);
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.18em;
    line-height: 1.2;
    text-transform: uppercase;
  }

  .valor-team-core__eyebrow::before {
    content: '';
    display: block;
    width: 32px;
    height: 1px;
    background: currentColor;
  }

  .valor-team-core__hero-title,
  .valor-team-core__join-title,
  .valor-team-core__initials {
    font-family: var(--font-heading--family), Georgia, serif;
    font-weight: 400;
    letter-spacing: 0;
  }

  .valor-team-core__hero-title {
    max-width: 1100px;
    margin: 0 0 36px;
    color: var(--valor-navy-deep);
    font-size: 96px;
    line-height: 0.95;
  }

  .valor-team-core__hero-title em,
  .valor-team-core__join-title em {
    color: var(--valor-crimson);
    font-style: italic;
  }

  .valor-team-core__hero-copy {
    max-width: 640px;
    margin: 0;
    color: var(--valor-steel);
    font-size: 17px;
    line-height: 1.55;
  }

  .valor-team-core__hero-copy strong {
    color: var(--valor-navy-deep);
    font-weight: 600;
  }

  .valor-team-core__founder-row {
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    margin-top: 24px;
    border-top: 1px solid var(--valor-navy-deep);
  }

  .valor-team-core__founder-row .valor-team-core__person {
    grid-column: 2 / span 2;
    justify-self: center;
    width: calc(50% - 20px);
    padding: 28px 0;
    border-right: 0;
  }

  .valor-team-core__founder-row--multiple .valor-team-core__person {
    grid-column: auto;
    width: auto;
    padding: 28px 20px 28px 0;
    border-right: 1px solid var(--valor-border);
  }

  .valor-team-core__founder-row--multiple .valor-team-core__person:nth-child(4n) {
    border-right: 0;
  }

  .valor-team-core__grid {
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    border-top: 1px solid var(--valor-border);
  }

  .valor-team-core__person {
    position: relative;
    min-width: 0;
    padding: 28px 20px 28px 0;
    border-right: 1px solid var(--valor-border);
    border-bottom: 1px solid var(--valor-border);
    transition: background-color 180ms ease;
  }

  .valor-team-core__grid .valor-team-core__person:nth-child(4n) {
    border-right: 0;
  }

  .valor-team-core__person:hover {
    background: color-mix(in srgb, var(--color-background) 70%, #ffffff 30%);
  }

  .valor-team-core__person--empty {
    display: none;
  }

  .valor-team-core__thumb {
    position: relative;
    display: flex;
    align-items: center;
    justify-content: center;
    width: 100%;
    aspect-ratio: 1 / 1;
    margin-bottom: 18px;
    overflow: hidden;
    border: 1px solid var(--valor-border-strong);
    background:
      repeating-linear-gradient(
        45deg,
        transparent 0,
        transparent 18px,
        rgba(29, 38, 54, 0.025) 18px,
        rgba(29, 38, 54, 0.025) 19px
      ),
      linear-gradient(135deg, var(--valor-parchment) 0%, var(--valor-chalk) 60%, var(--valor-parchment) 100%);
  }

  .valor-team-core__image {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .valor-team-core__initials {
    color: var(--valor-navy-deep);
    font-size: 56px;
    font-style: italic;
    line-height: 1;
    opacity: 0.42;
  }

  .valor-team-core__accent {
    position: absolute;
    top: 10px;
    right: 10px;
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: var(--valor-crimson);
    opacity: 0;
    transition: opacity 200ms ease;
  }

  .valor-team-core__person:hover .valor-team-core__accent {
    opacity: 1;
  }

  .valor-team-core__name {
    margin: 0 0 4px;
    color: var(--valor-navy-deep);
    font-size: 14px;
    font-weight: 700;
    line-height: 1.25;
  }

  .valor-team-core__role {
    color: var(--valor-steel);
    font-size: 12px;
    line-height: 1.4;
  }

  .valor-team-core__join {
    margin-top: 80px;
    padding: 120px 0 140px;
    border-top: 1px solid var(--valor-border);
    text-align: center;
  }

  .valor-team-core__join-eyebrow {
    margin-bottom: 28px;
    color: var(--valor-crimson);
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.18em;
    line-height: 1.2;
    text-transform: uppercase;
  }

  .valor-team-core__join-title {
    max-width: 820px;
    margin: 0 auto 24px;
    color: var(--valor-navy-deep);
    font-size: 56px;
    line-height: 1.05;
  }

  .valor-team-core__join-copy {
    max-width: 560px;
    margin: 0 auto 40px;
    color: var(--valor-steel);
    font-size: 16px;
    line-height: 1.6;
  }

  .valor-team-core__actions {
    display: flex;
    justify-content: center;
  }

  .valor-team-core__button {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 8px;
    min-height: 48px;
    padding: 0 28px;
    border-radius: 999px;
    background: var(--color-primary-button-background);
    color: var(--color-primary-button-text);
    font-size: 13px;
    font-weight: 600;
    letter-spacing: 0.02em;
    text-decoration: none;
    transition: background-color 160ms ease;
  }

  .valor-team-core__button:hover {
    background: var(--valor-crimson-deep);
    color: var(--color-primary-button-text);
  }

  .valor-team-core__button svg {
    width: 13px;
    height: 13px;
    flex: 0 0 auto;
  }

  @media screen and (max-width: 1100px) {
    .valor-team-core__hero-title {
      font-size: 80px;
    }
  }

  @media screen and (max-width: 880px) {
    .valor-team-core__grid {
      grid-template-columns: repeat(3, minmax(0, 1fr));
    }

    .valor-team-core__grid .valor-team-core__person:nth-child(4n) {
      border-right: 1px solid var(--valor-border);
    }

    .valor-team-core__grid .valor-team-core__person:nth-child(3n) {
      border-right: 0;
    }

    .valor-team-core__founder-row {
      grid-template-columns: repeat(3, minmax(0, 1fr));
    }

    .valor-team-core__founder-row .valor-team-core__person {
      grid-column: 2 / span 1;
      width: 100%;
      max-width: 100%;
    }

    .valor-team-core__founder-row--multiple .valor-team-core__person:nth-child(4n) {
      border-right: 1px solid var(--valor-border);
    }

    .valor-team-core__founder-row--multiple .valor-team-core__person:nth-child(3n) {
      border-right: 0;
    }
  }

  @media screen and (max-width: 760px) {
    .valor-team-core__hero {
      padding: 64px 0 52px;
    }

    .valor-team-core__hero-title {
      font-size: 58px;
      line-height: 1;
    }

    .valor-team-core__hero-copy {
      font-size: 16px;
    }

    .valor-team-core__grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }

    .valor-team-core__grid .valor-team-core__person:nth-child(n) {
      border-right: 1px solid var(--valor-border);
    }

    .valor-team-core__grid .valor-team-core__person:nth-child(2n) {
      border-right: 0;
    }

    .valor-team-core__founder-row {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }

    .valor-team-core__founder-row .valor-team-core__person {
      grid-column: 1 / span 2;
      justify-self: center;
      width: 50%;
      padding: 20px 16px 20px 0;
    }

    .valor-team-core__founder-row--multiple .valor-team-core__person {
      grid-column: auto;
      width: auto;
    }

    .valor-team-core__founder-row--multiple .valor-team-core__person:nth-child(n) {
      border-right: 1px solid var(--valor-border);
    }

    .valor-team-core__founder-row--multiple .valor-team-core__person:nth-child(2n) {
      border-right: 0;
    }

    .valor-team-core__person {
      padding: 20px 16px 20px 0;
    }

    .valor-team-core__join {
      margin-top: 64px;
      padding: 88px 0 104px;
    }

    .valor-team-core__join-title {
      font-size: 44px;
    }
  }

  @media screen and (max-width: 480px) {
    .valor-team-core__page {
      padding: 0 20px;
    }

    .valor-team-core__hero {
      padding: 56px 0 48px;
    }

    .valor-team-core__hero-title {
      font-size: 48px;
    }

    .valor-team-core__founder-row:not(.valor-team-core__founder-row--multiple) .valor-team-core__person {
      width: 80%;
    }

    .valor-team-core__initials {
      font-size: 44px;
    }

    .valor-team-core__join-title {
      font-size: 38px;
    }
  }
{% endstyle %}

<section class="valor-team-core color-{{ section.settings.color_scheme }}" {{ section.shopify_attributes }}>
  <div class="valor-team-core__page">
    <nav class="valor-team-core__crumb" aria-label="Breadcrumb">
      <a href="{{ routes.root_url }}">Home</a>
      <span class="valor-team-core__crumb-separator">/</span>
      <span class="valor-team-core__crumb-current">Our Team</span>
    </nav>

    <div class="valor-team-core__hero">
      {% if section.settings.hero_eyebrow != blank %}
        <div class="valor-team-core__eyebrow">{{ section.settings.hero_eyebrow | escape }}</div>
      {% endif %}
      {% if section.settings.hero_title != blank %}
        <h1 class="valor-team-core__hero-title">{{ section.settings.hero_title }}</h1>
      {% endif %}
      {% if section.settings.hero_copy != blank %}
        <div class="valor-team-core__hero-copy">{{ section.settings.hero_copy }}</div>
      {% endif %}
    </div>

    {% if founder_count > 0 %}
      <div class="valor-team-core__founder-row{% if founder_count > 1 %} valor-team-core__founder-row--multiple{% endif %}">
        {% for block in section.blocks %}
          {% if block.type == 'member' and block.settings.featured_founder %}
            {% liquid
              assign member_name = block.settings.name
              assign member_role = block.settings.role
              assign member_initials = block.settings.initials | default: 'VC'
              assign member_image = block.settings.image
            %}
            <article class="valor-team-core__person{% if member_name == blank and member_role == blank and member_image == blank %} valor-team-core__person--empty{% endif %}" {{ block.shopify_attributes }}>
              <div class="valor-team-core__thumb" {% if member_image != blank %}aria-label="{{ member_name | escape }}"{% else %}aria-hidden="true"{% endif %}>
                {% if member_image != blank %}
                  <img
                    src="{{ member_image | image_url: width: 700 }}"
                    srcset="
                      {{ member_image | image_url: width: 360 }} 360w,
                      {{ member_image | image_url: width: 520 }} 520w,
                      {{ member_image | image_url: width: 700 }} 700w
                    "
                    sizes="(max-width: 760px) 50vw, (max-width: 880px) 33vw, 300px"
                    alt="{{ member_name | escape }}"
                    width="{{ member_image.width }}"
                    height="{{ member_image.height }}"
                    loading="lazy"
                    class="valor-team-core__image"
                  >
                {% else %}
                  <span class="valor-team-core__initials">{{ member_initials | escape }}</span>
                {% endif %}
                <span class="valor-team-core__accent"></span>
              </div>
              {% if member_name != blank %}
                <h2 class="valor-team-core__name">{{ member_name | escape }}</h2>
              {% endif %}
              {% if member_role != blank %}
                <div class="valor-team-core__role">{{ member_role | escape }}</div>
              {% endif %}
            </article>
          {% endif %}
        {% endfor %}
      </div>
    {% endif %}

    {% if leadership_count > 0 %}
      <div class="valor-team-core__grid">
        {% for block in section.blocks %}
          {% if block.type == 'member' and block.settings.featured_founder != true %}
            {% liquid
              assign member_name = block.settings.name
              assign member_role = block.settings.role
              assign member_initials = block.settings.initials | default: 'VC'
              assign member_image = block.settings.image
            %}
            <article class="valor-team-core__person{% if member_name == blank and member_role == blank and member_image == blank %} valor-team-core__person--empty{% endif %}" {{ block.shopify_attributes }}>
              <div class="valor-team-core__thumb" {% if member_image != blank %}aria-label="{{ member_name | escape }}"{% else %}aria-hidden="true"{% endif %}>
                {% if member_image != blank %}
                  <img
                    src="{{ member_image | image_url: width: 700 }}"
                    srcset="
                      {{ member_image | image_url: width: 360 }} 360w,
                      {{ member_image | image_url: width: 520 }} 520w,
                      {{ member_image | image_url: width: 700 }} 700w
                    "
                    sizes="(max-width: 760px) 50vw, (max-width: 880px) 33vw, 300px"
                    alt="{{ member_name | escape }}"
                    width="{{ member_image.width }}"
                    height="{{ member_image.height }}"
                    loading="lazy"
                    class="valor-team-core__image"
                  >
                {% else %}
                  <span class="valor-team-core__initials">{{ member_initials | escape }}</span>
                {% endif %}
                <span class="valor-team-core__accent"></span>
              </div>
              {% if member_name != blank %}
                <h2 class="valor-team-core__name">{{ member_name | escape }}</h2>
              {% endif %}
              {% if member_role != blank %}
                <div class="valor-team-core__role">{{ member_role | escape }}</div>
              {% endif %}
            </article>
          {% endif %}
        {% endfor %}
      </div>
    {% endif %}

    <div class="valor-team-core__join">
      <div class="valor-team-core__join-eyebrow">Open roles</div>
      <h2 class="valor-team-core__join-title">There aren't any.<br><em>Send a note anyway.</em></h2>
      <p class="valor-team-core__join-copy">We hire quietly and infrequently. The right introduction tends to land before a role is posted.</p>
      <div class="valor-team-core__actions">
        <a href="{{ contact_url }}" class="valor-team-core__button">
          {{ contact_label | escape }}
          <svg aria-hidden="true" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M5 12h14"></path>
            <path d="m13 5 7 7-7 7"></path>
          </svg>
        </a>
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Valor team core",
  "settings": [
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "scheme-1"
    },
    {
      "type": "color",
      "id": "accent_color",
      "label": "Accent color",
      "default": "#c54448"
    },
    {
      "type": "header",
      "content": "Hero"
    },
    {
      "type": "text",
      "id": "hero_eyebrow",
      "label": "Eyebrow",
      "default": "Our Team"
    },
    {
      "type": "inline_richtext",
      "id": "hero_title",
      "label": "Heading",
      "default": "The people behind <em>Valor.</em>"
    },
    {
      "type": "richtext",
      "id": "hero_copy",
      "label": "Text",
      "default": "<p>Decades of combined experience across the wireless industry, run by a leadership group that's been at this a long time, knows the work from every angle, and is allergic to the status quo. <strong>They're the ones who get the job done.</strong></p>"
    },
    {
      "type": "header",
      "content": "Contact"
    },
    {
      "type": "url",
      "id": "contact_link",
      "label": "Contact link"
    },
    {
      "type": "text",
      "id": "contact_label",
      "label": "Contact label",
      "default": "Contact us"
    }
  ],
  "blocks": [
    {
      "type": "member",
      "name": "Team member",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Photo"
        },
        {
          "type": "checkbox",
          "id": "featured_founder",
          "label": "Show in founder row",
          "default": false
        },
        {
          "type": "text",
          "id": "name",
          "label": "Name",
          "default": "Team member"
        },
        {
          "type": "text",
          "id": "role",
          "label": "Role",
          "default": "Role"
        },
        {
          "type": "text",
          "id": "initials",
          "label": "Initials fallback",
          "default": "TM"
        }
      ]
    }
  ],
  "max_blocks": 30,
  "presets": [
    {
      "name": "Valor team core"
    }
  ]
}
{% endschema %}
