{% stylesheet %}
/* ═══════════════════════════════════════════════════════════════════
   VALOR REGISTER — sections/valor-register.liquid
   Isolated styles; uses --vr- CSS custom properties.
   ═══════════════════════════════════════════════════════════════════ */

/* ── Color tokens ─────────────────────────────────────────────────── */
:root {
  --vr-navy:        #2B3A55;
  --vr-navy-deep:   #1D2636;
  --vr-sky:         #63B9DE;
  --vr-sky-pale:    #D9EEF6;
  --vr-crimson:     #C54448;
  --vr-chalk:       #F4F5F2;
  --vr-parchment:   #EEEDE7;
  --vr-steel:       #66717E;
  --vr-steel-lt:    #A8B0B8;
  --vr-ink:         #121820;
  --vr-white:       #FFFFFF;
  --vr-green:       #2d7a3f;
  --vr-green-soft:  #E1F0E3;
  --vr-border:      #0002;
  --vr-border-str:  #0003;
  --vr-serif:       var(--font-heading--family, 'Georgia', serif);
  --vr-sans:        var(--font-body--family, -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif);
}

/* ── Page wrapper & layout ────────────────────────────────────────── */
.vr-page-wrap {
  width: 100%;
  display: flex;
  flex-direction: column;
  gap: var(--vr-sections-gap, 0px);
}
.vr-page-wrap.vr-layout--page_width {
  overflow: hidden;
}


/* ═══════════════════════════════════════════════════════════════════
   PAGE SECTIONS
   ═══════════════════════════════════════════════════════════════════ */

/* ── Shared ───────────────────────────────────────────────────────── */
.vr-eyebrow {
  display: inline-flex;
  align-items: center;
  gap: 10px;
  font-family: var(--vr-sans);
  font-size: 11px;
  letter-spacing: 0.2em;
  text-transform: uppercase;
  font-weight: 600;
  color: var(--vr-crimson);
  margin-bottom: 16px;
}
.vr-eyebrow::before {
  content: '';
  width: 20px;
  height: 1px;
  background: var(--vr-crimson);
}

/* ── Hero ─────────────────────────────────────────────────────────── */
.vr-hero {}
.vr-hero-grid {
  display: grid;
  grid-template-columns: 1.6fr 1fr;
  gap: 20px;
  height: 540px;
}
.vr-hero-main {
  background: var(--vr-navy-deep);
  border-radius: 20px;
  overflow: hidden;
  position: relative;
  color: var(--vr-chalk);
  padding: 56px;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
}
.vr-hero-main::before {
  content: '';
  position: absolute;
  top: 0; right: 0; bottom: 0;
  width: 55%;
  background: linear-gradient(135deg, #2B3A55 0%, #1D2636 100%);
  clip-path: polygon(20% 0, 100% 0, 100% 100%, 0% 100%);
}
.vr-hero-main::after {
  content: '';
  position: absolute;
  top: 50%; right: 8%;
  transform: translateY(-50%);
  width: 380px; height: 380px;
  background: radial-gradient(circle, rgba(99,185,222,0.22) 0%, transparent 65%);
  border-radius: 50%;
}
.vr-hero-eyebrow {
  font-family: var(--vr-sans);
  font-size: 11px;
  letter-spacing: 0.2em;
  text-transform: uppercase;
  color: var(--vr-sky);
  font-weight: 500;
  display: flex;
  align-items: center;
  gap: 10px;
  position: relative;
  z-index: 3;
}
.vr-hero-eyebrow::before { content: ''; width: 32px; height: 1px; background: var(--vr-sky); }
.vr-hero-title {
  font-family: var(--vr-serif);
  font-size: 68px;
  line-height: 0.98;
  letter-spacing: -0.03em;
  max-width: 70%;
  position: relative;
  z-index: 3;
  font-weight: 400;
  color: var(--vr-chalk);
  margin: 20px 0 14px;
}
.vr-hero-title em { color: var(--vr-sky) !important; font-style: italic; }
.vr-hero-sub {
  font-family: var(--vr-sans);
  font-size: 16px;
  line-height: 1.55;
  color: rgba(244, 245, 242, 0.78);
  max-width: 480px;
  margin: 0 0 28px;
  position: relative;
  z-index: 3;
}
.vr-hero-cta-row {
  display: flex;
  gap: 12px;
  align-items: center;
  position: relative;
  z-index: 3;
  flex-wrap: wrap;
}
.vr-hero-ghost {
  font-family: var(--vr-sans);
  color: var(--vr-chalk);
  padding: 14px 24px;
  border: 1px solid rgba(244,245,242,0.25);
  border-radius: 999px;
  font-size: 13px;
  font-weight: 500;
  transition: background 0.15s;
  display: inline-flex;
  align-items: center;
  text-decoration: none;
  cursor: pointer;
}
.vr-hero-ghost:hover { background: rgba(244,245,242,0.08); }
.vr-hero-device {
  position: absolute;
  right: 6%; top: 50%;
  transform: translateY(-50%) rotate(-8deg);
  width: 280px; height: 400px;
  background: linear-gradient(145deg, #2a2a2e 0%, #151517 100%);
  border-radius: 36px;
  border: 2px solid #3a3a40;
  z-index: 2;
  box-shadow: -30px 40px 80px rgba(0,0,0,0.5);
}
.vr-hero-device::before {
  content: '';
  position: absolute;
  inset: 8px;
  border-radius: 30px;
  background: linear-gradient(145deg, #C54448 0%, #8a2f33 100%);
}
.vr-hero-device::after {
  content: 'MyBat Pro';
  position: absolute;
  bottom: 24px; left: 0; right: 0;
  text-align: center;
  color: rgba(255,255,255,0.4);
  font-size: 11px;
  letter-spacing: 0.3em;
  text-transform: uppercase;
  font-weight: 500;
  z-index: 1;
  font-family: var(--vr-sans);
}
.vr-hero-side { display: grid; grid-template-rows: 1fr 1fr; gap: 20px; }
.vr-hero-card {
  border-radius: 20px;
  padding: 32px;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
  transition: transform 0.2s;
  text-decoration: none;
}
.vr-hero-card:hover { transform: translateY(-2px); }
.vr-hero-card--sky { background: var(--vr-sky-pale); color: var(--vr-navy-deep); }
.vr-hero-card--crimson { background: var(--vr-crimson); color: var(--vr-chalk); }
.vr-hcard-tag {
  font-family: var(--vr-sans);
  display: inline-flex;
  align-items: center;
  gap: 8px;
  font-size: 10px;
  letter-spacing: 0.16em;
  text-transform: uppercase;
  font-weight: 500;
  opacity: 0.9;
}
.vr-hcard-tag::before { content: '●'; color: var(--vr-crimson); font-size: 8px; }
.vr-hero-card--crimson .vr-hcard-tag::before { color: var(--vr-chalk); }
.vr-hcard-title {
  font-family: var(--vr-serif);
  font-size: 32px;
  line-height: 1;
  font-weight: 400;
  margin-top: 12px;
  letter-spacing: -0.01em;
}
.vr-hcard-sub { font-family: var(--vr-sans); font-size: 12px; opacity: 0.7; margin-top: 6px; }
.vr-hcard-foot { font-family: var(--vr-sans); display: flex; justify-content: space-between; align-items: flex-end; font-size: 12px; }
.vr-hcard-arrow {
  width: 36px; height: 36px;
  border-radius: 50%;
  background: rgba(0,0,0,0.08);
  display: flex; align-items: center; justify-content: center;
  transition: transform 0.15s;
}
.vr-hero-card--crimson .vr-hcard-arrow { background: rgba(255,255,255,0.18); }
.vr-hero-card:hover .vr-hcard-arrow { transform: translate(3px, -3px); }

/* ── Section shared head ──────────────────────────────────────────── */
.vr-section-head {
  display: flex;
  justify-content: space-between;
  align-items: flex-end;
  margin-bottom: 40px;
  gap: 40px;
}
.vr-section-eyebrow {
  font-family: var(--vr-sans);
  font-size: 11px;
  letter-spacing: 0.18em;
  text-transform: uppercase;
  color: var(--vr-crimson);
  font-weight: 500;
  margin-bottom: 12px;
}
.vr-section-title {
  font-family: var(--vr-serif);
  font-size: 56px;
  line-height: 1;
  color: var(--vr-navy-deep);
  letter-spacing: -0.02em;
  font-weight: 400;
}
.vr-section-title em { font-style: italic; color: var(--vr-steel) !important; }
.vr-view-all {
  font-family: var(--vr-sans);
  font-size: 13px;
  color: var(--vr-navy);
  font-weight: 500;
  display: inline-flex;
  align-items: center;
  gap: 6px;
  padding: 8px 14px;
  border-radius: 999px;
  transition: background 0.15s;
  text-decoration: none;
  white-space: nowrap;
}
.vr-view-all:hover { background: var(--vr-chalk); }

/* ── Category ─────────────────────────────────────────────────────── */
.vr-category {}
.vr-cat-grid {
  display: grid;
  grid-template-columns: repeat(6, 1fr);
  gap: 8px;
}
.vr-cat-card {
  aspect-ratio: 1 / 1.15;
  background: var(--vr-white);
  border-radius: 16px;
  padding: 22px 20px;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
  position: relative;
  overflow: hidden;
  transition: all 0.2s;
  border: 1px solid var(--vr-border);
  text-decoration: none;
}
.vr-cat-card:hover { transform: translateY(-3px); border-color: var(--vr-border-str); }
.vr-cat-card--feat { background: var(--vr-navy-deep); color: var(--vr-chalk); }
.vr-cat-icon {
  width: 44px; height: 44px;
  border-radius: 12px;
  background: var(--vr-chalk);
  color: var(--vr-navy);
  display: flex; align-items: center; justify-content: center;
}
.vr-cat-card--feat .vr-cat-icon { background: rgba(244,245,242,0.1); color: var(--vr-sky); }
.vr-cat-body { display: flex; flex-direction: column; gap: 4px; }
.vr-cat-name {
  font-family: var(--vr-serif);
  font-size: 24px;
  font-weight: 400;
  color: var(--vr-navy-deep);
  letter-spacing: -0.02em;
  line-height: 1.05;
}
.vr-cat-card--feat .vr-cat-name { color: var(--vr-chalk); }
.vr-cat-subs { font-family: var(--vr-sans); font-size: 11px; color: var(--vr-steel); line-height: 1.4; max-width: 90%; }
.vr-cat-card--feat .vr-cat-subs { color: rgba(244,245,242,0.6); }
.vr-cat-arrow {
  position: absolute;
  right: 16px; bottom: 16px;
  width: 28px; height: 28px;
  border-radius: 50%;
  background: var(--vr-chalk);
  color: var(--vr-navy-deep);
  display: flex; align-items: center; justify-content: center;
  opacity: 0;
  transform: translateX(-4px);
  transition: all 0.2s;
}
.vr-cat-card:hover .vr-cat-arrow { opacity: 1; transform: translateX(0); }

/* ── Brand portfolio ──────────────────────────────────────────────── */
.vr-bp {}
.vr-bp-head { max-width: 760px; margin-bottom: 32px; }
.vr-bp-title {
  font-family: var(--vr-serif);
  font-size: 56px;
  line-height: 1;
  letter-spacing: -0.02em;
  color: var(--vr-navy-deep);
  font-weight: 400;
  margin-bottom: 16px;
}
.vr-bp-title em { color: var(--vr-steel) !important; font-style: italic; }
.vr-bp-intro { font-family: var(--vr-sans); font-size: 14px; color: var(--vr-steel); line-height: 1.65; max-width: 640px; }
.vr-bp-grid {
  display: grid;
  grid-template-columns: repeat(6, 1fr);
  gap: 8px;
  background: var(--vr-white);
  border: 1px solid var(--vr-border);
  border-radius: 18px;
  padding: 12px;
}
.vr-bp-tile {
  aspect-ratio: 3 / 1;
  display: flex; align-items: center; justify-content: center;
  border-radius: 999px;
  background: var(--vr-chalk);
  transition: background 0.15s, transform 0.15s;
  text-decoration: none;
  padding: 8px 16px;
}
.vr-bp-tile:hover { background: var(--vr-parchment); transform: translateY(-2px); }
.vr-bp-wordmark { font-size: 20px; color: var(--vr-navy-deep); letter-spacing: -0.01em; text-align: center; line-height: 1; user-select: none; }
.vr-bp-sub { font-style: italic; color: var(--vr-crimson); margin-left: 4px; }

/* ── Design Lab ───────────────────────────────────────────────────── */
.vr-dl {}
.vr-dl-inner {
  display: grid;
  grid-template-columns: 1fr 1.05fr;
  border-radius: 24px;
  overflow: hidden;
  background: var(--vr-white);
  border: 1px solid var(--vr-border);
  min-height: 400px;
}
.vr-dl-visual {
  background: linear-gradient(135deg, #1D2636 0%, #2B3A55 60%, #C54448 130%);
  color: var(--vr-chalk);
  padding: 48px 44px;
  position: relative;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
  overflow: hidden;
}
.vr-dl-overlay {
  position: absolute;
  top: -10%; right: -20%;
  width: 70%; height: 80%;
  background: radial-gradient(circle, rgba(99,185,222,0.18) 0%, transparent 60%);
  pointer-events: none;
}
.vr-dl-tag-row { display: flex; gap: 6px; position: relative; z-index: 1; }
.vr-dl-tag {
  font-family: var(--vr-sans);
  font-size: 10px;
  letter-spacing: 0.14em;
  text-transform: uppercase;
  color: var(--vr-sky);
  background: rgba(99,185,222,0.12);
  border: 1px solid rgba(99,185,222,0.4);
  padding: 4px 10px;
  border-radius: 999px;
  font-weight: 600;
}
.vr-dl-visual-text { position: relative; z-index: 1; margin: auto 0; }
.vr-dl-eyebrow { font-family: var(--vr-serif); font-style: italic; font-size: 22px; color: var(--vr-sky); margin-bottom: 8px; }
.vr-dl-title { font-family: var(--vr-serif); font-size: 76px; line-height: 0.95; color: var(--vr-chalk); letter-spacing: -0.03em; font-weight: 400; }
.vr-dl-types {
  font-family: var(--vr-sans);
  position: relative; z-index: 1;
  border-top: 1px solid rgba(244,245,242,0.12);
  padding-top: 16px; margin-top: 24px;
  font-size: 12px; letter-spacing: 0.18em; text-transform: uppercase;
  color: rgba(244,245,242,0.85);
  display: flex; gap: 12px; align-items: center; flex-wrap: wrap;
  font-weight: 500;
}
.vr-dl-dim { color: rgba(244,245,242,0.3); }
.vr-dl-content { padding: 48px 52px; display: flex; flex-direction: column; justify-content: center; }
.vr-dl-content-eyebrow {
  font-family: var(--vr-sans);
  font-size: 11px; letter-spacing: 0.18em; text-transform: uppercase;
  color: var(--vr-crimson); font-weight: 500; margin-bottom: 18px;
  display: flex; align-items: center; gap: 10px;
}
.vr-dl-content-eyebrow::before { content: ''; width: 24px; height: 1px; background: var(--vr-crimson); }
.vr-dl-content-title { font-family: var(--vr-serif); font-size: 44px; line-height: 1.05; color: var(--vr-navy-deep); letter-spacing: -0.02em; font-weight: 400; margin-bottom: 18px; }
.vr-dl-content-title em { color: var(--vr-steel) !important; font-style: italic; }
.vr-dl-body { font-family: var(--vr-sans); font-size: 14px; color: var(--vr-steel); line-height: 1.65; margin-bottom: 18px; max-width: 480px; }
.vr-dl-stats {
  font-family: var(--vr-sans);
  display: flex; align-items: center; flex-wrap: wrap; gap: 8px 6px;
  padding: 14px 0; margin: 0 0 22px;
  border-top: 1px solid var(--vr-border); border-bottom: 1px solid var(--vr-border);
  font-size: 12px; color: var(--vr-steel);
}
.vr-dl-stats strong { color: var(--vr-navy-deep); font-weight: 600; }
.vr-dl-sep { color: var(--vr-steel-lt); }
.vr-dl-actions { display: flex; gap: 10px; flex-wrap: wrap; }

/* ── Dashboard teaser ─────────────────────────────────────────────── */
.vr-dash {}
.vr-dash-inner {
  background: var(--vr-white);
  border-radius: 24px;
  padding: 48px;
  border: 1px solid var(--vr-border);
  display: grid;
  grid-template-columns: 1fr 1.2fr;
  gap: 56px;
  align-items: center;
}
.vr-dash-left .vr-eyebrow { margin-bottom: 16px; }
.vr-dash-title { font-family: var(--vr-serif); font-size: 48px; line-height: 1.05; color: var(--vr-navy-deep); letter-spacing: -0.02em; font-weight: 400; margin-bottom: 20px; }
.vr-dash-title em { color: var(--vr-steel) !important; font-style: italic; }
.vr-dash-body { font-family: var(--vr-sans); color: var(--vr-steel); font-size: 15px; line-height: 1.65; margin-bottom: 28px; }
.vr-feat-list { list-style: none; padding: 0; margin: 0 0 28px; display: flex; flex-direction: column; gap: 14px; }
.vr-feat-list li { font-family: var(--vr-sans); display: flex; align-items: center; gap: 14px; font-size: 14px; color: var(--vr-navy-deep); font-weight: 500; }
.vr-feat-chk { width: 22px; height: 22px; border-radius: 50%; background: var(--vr-navy-deep); color: var(--vr-chalk); display: flex; align-items: center; justify-content: center; flex-shrink: 0; }
.vr-dash-ctas { display: flex; gap: 8px; flex-wrap: wrap; }
.vr-dash-mock { background: var(--vr-chalk); border-radius: 16px; padding: 24px; border: 1px solid var(--vr-border); }
.vr-dash-mock-head { display: flex; justify-content: space-between; align-items: center; margin-bottom: 20px; }
.vr-dash-mock-title { font-family: var(--vr-sans); font-size: 13px; font-weight: 600; color: var(--vr-navy-deep); }
.vr-dash-period { font-family: var(--vr-sans); font-size: 11px; color: var(--vr-steel); background: var(--vr-white); padding: 4px 10px; border-radius: 999px; border: 1px solid var(--vr-border); }
.vr-stat-row { display: grid; grid-template-columns: repeat(3, 1fr); gap: 8px; margin-bottom: 20px; }
.vr-stat-box { background: var(--vr-white); border-radius: 10px; padding: 14px; border: 1px solid var(--vr-border); }
.vr-stat-lbl { font-family: var(--vr-sans); font-size: 10px; letter-spacing: 0.08em; text-transform: uppercase; color: var(--vr-steel); font-weight: 500; }
.vr-stat-val { font-family: var(--vr-sans); font-size: 20px; font-weight: 600; color: var(--vr-navy-deep); margin-top: 6px; letter-spacing: -0.01em; }
.vr-stat-delta { font-family: var(--vr-sans); font-size: 11px; margin-top: 4px; display: flex; align-items: center; gap: 4px; color: var(--vr-steel); }
.vr-delta--up { color: #2d7a3f; }
.vr-chart-mock { background: var(--vr-white); border-radius: 10px; padding: 18px; border: 1px solid var(--vr-border); height: 140px; }
.vr-chart-mock svg { width: 100%; height: 100%; }

/* ── Perks strip ──────────────────────────────────────────────────── */
.vr-perks {
  background: var(--vr-white);
  border: 1px solid var(--vr-border);
  padding: 20px 32px;
  border-radius: 16px;
}
.vr-perks-inner {
  max-width: 1200px;
  margin: 0 auto;
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 24px;
}
.vr-perk {
  display: flex;
  align-items: flex-start;
  gap: 12px;
  font-family: var(--vr-sans);
  font-size: 12px;
  color: var(--vr-steel);
  line-height: 1.4;
}
.vr-perk svg { flex-shrink: 0; color: var(--vr-navy); margin-top: 2px; }
.vr-perk strong {
  display: block;
  color: var(--vr-navy-deep);
  font-size: 13px;
  font-weight: 600;
  margin-bottom: 2px;
}
.vr-perk span { display: block; }

/* ── Pillars ──────────────────────────────────────────────────────── */
.vr-pillars {
  background: var(--vr-chalk);
}
.vr-pillars-inner { margin: auto; }
.vr-pillars-head {
  max-width: 760px;
  margin-bottom: 28px;
}
.vr-pillars-title {
  font-family: var(--vr-serif);
  font-size: 56px;
  color: var(--vr-navy-deep);
  letter-spacing: -0.02em;
  line-height: 1;
  font-weight: 400;
  margin-bottom: 16px;
}
.vr-pillars-title em { color: var(--vr-steel) !important; font-style: italic; }
.vr-pillars-intro {
  font-family: var(--vr-sans);
  font-size: 15px;
  color: var(--vr-steel);
  line-height: 1.65;
}
.vr-pillars-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 20px;
}
.vr-pillar-num {
  font-family: var(--vr-serif);
  font-size: 36px;
  color: var(--vr-crimson);
  line-height: 1;
  letter-spacing: -0.02em;
  margin-bottom: 16px;
}
.vr-pillar {
  background: var(--vr-white);
  border: 1px solid var(--vr-border);
  border-radius: 18px;
  padding: 32px 28px;
}
.vr-pillar-title {
  font-family: var(--vr-serif);
  font-size: 26px;
  color: var(--vr-navy-deep);
  letter-spacing: -0.02em;
  font-weight: 400;
  margin-bottom: 12px;
  line-height: 1.1;
}
.vr-pillar p {
  font-family: var(--vr-sans);
  font-size: 13px;
  color: var(--vr-steel);
  line-height: 1.65;
}

/* ── Apply CTA ────────────────────────────────────────────────────── */
.vr-cta {}
.vr-cta-inner {
  background: var(--vr-navy-deep);
  border-radius: 24px;
  padding: 56px 60px;
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 60px;
  align-items: center;
  position: relative;
  overflow: hidden;
}
.vr-cta-inner::before {
  content: '';
  position: absolute;
  top: -50%; right: -10%;
  width: 60%; height: 200%;
  background: radial-gradient(ellipse, rgba(99, 185, 222, 0.08) 0%, transparent 60%);
  pointer-events: none;
}
.vr-cta-eyebrow {
  display: inline-flex;
  align-items: center;
  gap: 8px;
  font-family: var(--vr-sans);
  font-size: 11px;
  letter-spacing: 0.18em;
  text-transform: uppercase;
  font-weight: 600;
  color: var(--vr-sky);
  margin-bottom: 16px;
}
.vr-cta-eyebrow::before {
  content: '';
  width: 20px; height: 1px;
  background: var(--vr-sky);
}
.vr-cta-title {
  font-family: var(--vr-serif);
  font-size: 46px;
  color: var(--vr-chalk);
  letter-spacing: -0.02em;
  line-height: 1.05;
  font-weight: 400;
  margin-bottom: 18px;
}
.vr-cta-title em { color: var(--vr-sky); font-style: italic; }
.vr-cta-body {
  font-family: var(--vr-sans);
  font-size: 14px;
  color: rgba(244, 245, 242, 0.7);
  line-height: 1.65;
  margin-bottom: 28px;
  max-width: 420px;
}
.vr-cta-actions { display: flex; gap: 10px; flex-wrap: wrap; }
.vr-cta-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 16px;
}
.vr-cta-item {
  display: flex;
  align-items: flex-start;
  gap: 10px;
}
.vr-cta-star {
  width: 24px;
  height: 24px;
  border-radius: 6px;
  background: rgba(99, 185, 222, 0.15);
  color: var(--vr-sky);
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  margin-top: 2px;
}
.vr-cta-item-title {
  font-family: var(--vr-sans);
  font-size: 13px;
  font-weight: 600;
  color: var(--vr-chalk);
  margin-bottom: 3px;
  line-height: 1.3;
}
.vr-cta-item-sub {
  font-family: var(--vr-sans);
  font-size: 12px;
  color: rgba(244, 245, 242, 0.55);
  line-height: 1.4;
}

/* ── Responsive ───────────────────────────────────────────────────── */
@media (max-width: 1000px) {
  .vr-hero-grid { grid-template-columns: 1fr; height: auto; }
  .vr-hero-side { grid-template-rows: auto; grid-template-columns: 1fr 1fr; }
  .vr-hero-main { min-height: 420px; }
  .vr-cat-grid { grid-template-columns: repeat(3, 1fr); }
  .vr-bp-grid { grid-template-columns: repeat(4, 1fr); }
  .vr-bp-title { font-size: 36px; }
  .vr-dl-inner { grid-template-columns: 1fr; }
  .vr-dl-visual { padding: 36px 32px; min-height: 360px; }
  .vr-dl-title { font-size: 56px; }
  .vr-dl-content { padding: 36px 32px; }
  .vr-dl-content-title { font-size: 34px; }
  .vr-dash-inner { grid-template-columns: 1fr; gap: 32px; }
  .vr-dash-title { font-size: 36px; }
  .vr-section-title { font-size: 36px; }
}
@media (max-width: 749px) {
  .vr-page-wrap { padding-inline: 16px; }
  .vr-dialog-body { padding: 20px 20px 12px; }
  .vr-actions { padding: 14px 20px 18px; }
  .vr-row, .vr-row--three { grid-template-columns: 1fr; }
  .vr-hero-main { padding: 36px 28px; }
  .vr-hero-title { font-size: 40px; max-width: 100%; }
  .vr-hero-side { grid-template-columns: 1fr; }
  .vr-hero-device { display: none; }
  .vr-cat-grid { grid-template-columns: repeat(2, 1fr); }
  .vr-bp-grid { grid-template-columns: repeat(3, 1fr); }
  .vr-dash-inner { padding: 28px 24px; }
  .vr-stat-row { grid-template-columns: 1fr; }
  .vr-perks-inner { grid-template-columns: 1fr 1fr; gap: 16px; }
  .vr-pillars-title { font-size: 36px; }
  .vr-pillars-grid { grid-template-columns: 1fr; gap: 14px; }
  .vr-cta-inner { grid-template-columns: 1fr; padding: 36px 28px; gap: 32px; }
  .vr-cta-title { font-size: 34px; }
  .vr-cta-grid { grid-template-columns: 1fr; gap: 12px; }
  .vr-step-label { font-size: 10px; }
  .vr-step { padding: 0 6px; }
  .vr-section-head { flex-direction: column; align-items: flex-start; }
}
@media (max-width: 480px) {
  .vr-perks-inner { grid-template-columns: 1fr; }
  .vr-cat-grid { grid-template-columns: 1fr 1fr; }
  .vr-bp-grid { grid-template-columns: repeat(2, 1fr); }
  .vr-bp-wordmark { font-size: 16px; }
}
{% endstylesheet %}



