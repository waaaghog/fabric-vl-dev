      "step": 4,
      "unit": "px",
      "default": 12
    },
    {
      "type": "select",
      "id": "aspect_ratio",
      "label": "Media aspect ratio",
      "options": [
        { "value": "9/16", "label": "9:16 (Portrait)" },
        { "value": "4/5", "label": "4:5" },
        { "value": "1/1", "label": "1:1 (Square)" },
        { "value": "4/3", "label": "4:3" },
        { "value": "16/9", "label": "16:9 (Wide)" }
      ],
      "default": "9/16"
    },
    {
      "type": "range",
      "id": "border_radius",
      "label": "Border radius",
      "min": 0,
      "max": 40,
      "step": 4,
      "unit": "px",
      "default": 8
    },
    {
      "type": "header",
      "content": "Color"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "scheme-1"
    },
    {
      "type": "color",
      "id": "play_icon_bg",
      "label": "Play icon background",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "play_icon_color",
      "label": "Play icon color",
      "default": "#000000"
    },
    {
      "type": "header",
      "content": "Margin"
    },
    {
      "type": "range",
      "id": "padding-block-start",
      "label": "Top",
      "min": 0,
