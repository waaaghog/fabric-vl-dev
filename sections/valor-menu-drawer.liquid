// B2B account card: populate company name, market, and avatar initials from cached customer-info
(function () {
  var nameEl   = document.getElementById('vmd-account-card-name');
  var marketEl = document.getElementById('vmd-account-card-market');
  var avatarEl = document.getElementById('vmd-account-avatar');
  if (!nameEl && !marketEl) return;
  function applyInfo(d) {
    var company = d.name || d.Name || '';
    var handle  = d.shopifyMarketHandle || '';
    if (company && nameEl)  nameEl.textContent  = company;
    if (handle  && marketEl) marketEl.textContent = handle.toLowerCase().replace(/[-_]/g, ' ').replace(/\b\w/g, function (c) { return c.toUpperCase(); });
  }
  window.__vaCustomerInfo.then(function (d) { if (d) applyInfo(d); });
})();


