{% javascript %}
(function () {
  /* Shared overlay singleton */
  function _getValorOverlay() {
    if (window.__valorDrawerOverlay) return window.__valorDrawerOverlay;
    const el = document.createElement('div');
    el.className = 'valor-drawer-overlay';
    document.body.appendChild(el);
    const ov = {
      el,
      _handler: null,
      show(onClose) {
        el.classList.add('valor-open');
        if (this._handler) el.removeEventListener('click', this._handler);
        this._handler = () => { this.hide(); onClose && onClose(); };
        el.addEventListener('click', this._handler, { once: true });
      },
      hide() {
        el.classList.remove('valor-open');
        if (this._handler) { el.removeEventListener('click', this._handler); this._handler = null; }
      },
    };
    return (window.__valorDrawerOverlay = ov);
  }

  class ValorMenuDrawer extends HTMLElement {
    connectedCallback() {
      this._initTabs();
      this._initAccordions();
      this._initOpen();
    }

    _initOpen() {
      /* Trigger from header hamburger button */
      document.addEventListener('vmd:open-menu', () => this.open());

      /* Close button inside drawer */
      this.querySelector('[data-vmd-close]')?.addEventListener('click', () => this.close());

      /* Register link → open popup instead of redirecting */
      this.querySelector('.vmd-account-card__register')?.addEventListener('click', (e) => {
        e.preventDefault();
        this.close();
        setTimeout(() => document.dispatchEvent(new CustomEvent('vr:open-register')), 0);
      });

      /* Escape key */
      document.addEventListener('keydown', (e) => {
        if (e.key === 'Escape' && this.classList.contains('vmd-open')) this.close();
      });
    }

    open() {
      this.classList.add('vmd-open');
      document.body.classList.add('vcd-scroll-locked');
      _getValorOverlay().show(() => this.close());
    }

    close() {
      this.classList.remove('vmd-open');
      document.body.classList.remove('vcd-scroll-locked');
      _getValorOverlay().hide();
      const trigger = document.querySelector('[data-vmd-trigger]');
      trigger?.setAttribute('aria-expanded', 'false');
      trigger?.focus();
    }

    _initTabs() {
      const tabs = this.querySelectorAll('[data-vmd-tab]');
      const panels = this.querySelectorAll('[data-vmd-panel]');
      tabs.forEach((tab) => {
        tab.addEventListener('click', () => {
          const target = tab.dataset.vmdTab;
          tabs.forEach((t) => {
            t.classList.remove('vmd-tab--active');
            t.setAttribute('aria-selected', 'false');
          });
          panels.forEach((p) => {
            const active = p.dataset.vmdPanel === target;
            p.hidden = !active;
            p.classList.toggle('vmd-panel--active', active);
          });
          tab.classList.add('vmd-tab--active');
          tab.setAttribute('aria-selected', 'true');
          const body = this.querySelector('.vmd-body');
          if (body) body.scrollTop = 0;
        });
      });
    }

    _initAccordions() {
      this.addEventListener('click', (e) => {
        const btn = e.target.closest('[data-vmd-acc]');
        if (!btn) return;
        const item = btn.closest('[data-vmd-acc-item]');
        if (!item) return;
        const wasOpen = item.classList.contains('vmd-acc--open');
        const panel = btn.closest('[data-vmd-panel]');
        if (panel) {
          panel.querySelectorAll('[data-vmd-acc-item].vmd-acc--open').forEach((el) => {
            el.classList.remove('vmd-acc--open');
            const subs = el.querySelector('.vmd-acc-subs');
            if (subs) subs.style.maxHeight = '0';
            const b = el.querySelector('[data-vmd-acc]');
            if (b) b.setAttribute('aria-expanded', 'false');
          });
        }
        if (!wasOpen) {
          item.classList.add('vmd-acc--open');
          btn.setAttribute('aria-expanded', 'true');
          const subs = item.querySelector('.vmd-acc-subs');
          if (subs) subs.style.maxHeight = subs.scrollHeight + 'px';
        }
      });
    }
  }

  if (!customElements.get('valor-menu-drawer')) {
    customElements.define('valor-menu-drawer', ValorMenuDrawer);
  }
})();

// Drawer-close on shopify-account click disabled for testing — re-enable if dialog appears behind drawer
