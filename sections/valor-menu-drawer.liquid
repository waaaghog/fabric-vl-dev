{%- liquid
  assign s = section.settings
-%}

<valor-menu-drawer
  {{ section.shopify_attributes }}
>

  {%- comment -%} ── Drawer header ─────────────────────────────────── {%- endcomment -%}
  <div class="vmd-head">
    <button
      class="vmd-close"
      data-vmd-close
      aria-label="{{ 'accessibility.close' | t }}"
    >
      <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" aria-hidden="true">
        <path d="M18 6 6 18M6 6l12 12"/>
      </svg>
    </button>
    {%- if s.logo != blank -%}
      <a href="{{ routes.root_url }}" class="vmd-logo">
        {{- s.logo | image_url: height: 52 | image_tag:
          height: 26,
          loading: 'eager',
          alt: shop.name,
          class: 'vmd-logo__img'
        -}}
      </a>
    {%- else -%}
      <a href="{{ routes.root_url }}" class="vmd-logo vmd-logo--text">{{ shop.name }}</a>
    {%- endif -%}
  </div>

  {%- comment -%} ── Tab bar ───────────────────────────────────────── {%- endcomment -%}
  <div class="vmd-tabs" role="tablist">
    {%- for block in section.blocks -%}
      <button
        class="vmd-tab{% if forloop.first %} vmd-tab--active{% endif %}"
        data-vmd-tab="{{ block.id }}"
        role="tab"
        aria-selected="{% if forloop.first %}true{% else %}false{% endif %}"
        {{ block.shopify_attributes }}
      >{{- block.settings.tab_label | default: 'Tab' -}}</button>
    {%- endfor -%}
  </div>

  {%- comment -%} ── Search bar ────────────────────────────────────── {%- endcomment -%}
  <div class="vmd-search">
    <button
      type="button"
      class="vmd-search__btn"
      on:click="#search-modal/showDialog"
      aria-label="{{ 'content.search_input_label' | t }}"
      aria-haspopup="dialog"
    >
      <span class="vmd-search__icon">
        {{- 'icon-search.svg' | inline_asset_content -}}
      </span>
      <span class="vmd-search__placeholder">{{ 'content.search_input_placeholder' | t }}</span>
    </button>
  </div>

  {%- comment -%} ── Scrollable body ───────────────────────────────── {%- endcomment -%}
  <div class="vmd-body">

    {%- for block in section.blocks -%}
      {%- assign bs = block.settings -%}
      {%- assign tab_menu = bs.menu -%}
      {%- liquid
        assign tab_label_key = bs.tab_label | default: '' | downcase | strip | replace: ' ', '' | replace: '-', ''
        assign is_design_lab_tab = false
        if block.type == 'tab_designlab' or tab_label_key == 'designlab'
          assign is_design_lab_tab = true
        endif
        assign is_devices_tab = false
        assign tab_menu_handle = bs.menu | default: '' | downcase
        if tab_label_key == 'devices' or tab_menu_handle contains 'devices'
          assign is_devices_tab = true
        endif
      -%}

      <div
        class="vmd-panel{% if forloop.first %} vmd-panel--active{% endif %}"
        data-vmd-panel="{{ block.id }}"
        role="tabpanel"
        {% unless forloop.first %}hidden{% endunless %}
      >

        {%- comment -%} Optional banner {%- endcomment -%}
        {%- if bs.banner_image != blank or bs.banner_headline != blank -%}
          {%- liquid
            assign banner_from = bs.banner_from | default: '#1D2636'
            assign banner_to   = bs.banner_to   | default: '#2B3A55'
            assign gradient_style = 'background: linear-gradient(135deg, ' | append: banner_from | append: ' 0%, ' | append: banner_to | append: ' 130%);'
            assign use_img_as_bg = false
            if bs.banner_image != blank
              assign img_ratio = bs.banner_image.width | times: 1.0 | divided_by: bs.banner_image.height
              if img_ratio >= 2.0
                assign use_img_as_bg = true
              endif
            endif
            if use_img_as_bg
              assign img_url = bs.banner_image | image_url: width: 560
              assign banner_style = 'background-image: url(' | append: img_url | append: '); background-size: cover; background-position: center;'
              assign banner_class = 'vmd-banner'
            else
              assign banner_style = gradient_style
              assign banner_class = 'vmd-banner vmd-banner--device-img'
            endif
          -%}
          <div class="{{ banner_class }}" style="{{ banner_style }}">
            <div class="vmd-banner__overlay"></div>
            <div class="vmd-banner__text">
              {%- if bs.banner_eyebrow != blank -%}
                <div class="vmd-banner__eyebrow" style="color: {{ bs.banner_eyebrow_color | default: '#63B9DE' }};">{{ bs.banner_eyebrow }}</div>
              {%- endif -%}
              <div class="vmd-banner__headline">{{ bs.banner_headline }}</div>
              {%- if bs.banner_sub != blank -%}
                <div class="vmd-banner__sub">{{ bs.banner_sub }}</div>
              {%- endif -%}
              {%- if bs.banner_cta != blank and bs.banner_url != blank -%}
                <a href="{{ bs.banner_url }}" class="vmd-banner__cta">
                  {{- bs.banner_cta -}}
                  <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M5 12h14M13 5l7 7-7 7"/></svg>
                </a>
              {%- endif -%}
            </div>
            <div class="vmd-banner__device">
              {%- unless use_img_as_bg -%}
                {%- if bs.banner_image != blank -%}
                  <img
                    src="{{ bs.banner_image | image_url: width: 160 }}"
                    alt="{{ bs.banner_image.alt | escape }}"
                    width="{{ bs.banner_image.width }}"
                    height="{{ bs.banner_image.height }}"
                    loading="lazy"
                  >
                {%- endif -%}
              {%- endunless -%}
            </div>
          </div>
        {%- endif -%}

        {%- comment -%} Content by block type {%- endcomment -%}
        {%- if is_design_lab_tab -%}
          {% render 'valor-design-lab-nav',
            variant: 'drawer',
            block_settings: bs,
            block_id: block.id
          %}
        {%- else -%}
          {%- case block.type -%}

            {%- when 'tab_featured' -%}
              {%- if tab_menu.links.size > 0 -%}
                <ul class="vmd-links" role="list">
                  {%- for link in tab_menu.links -%}
                    <li>
                      <a href="{{ link.url }}" class="vmd-link{% if link.active %} vmd-link--active{% endif %}">
                        <span class="vmd-link__title">{{ link.title }}</span>
                        <span class="vmd-link__arrow" aria-hidden="true">
                          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M7 17 17 7M7 7h10v10"/></svg>
                        </span>
                      </a>
                    </li>
                  {%- endfor -%}
                </ul>
              {%- endif -%}

            {%- when 'tab_accordion' -%}
            {%- if tab_menu.links.size > 0 -%}
              <ul class="vmd-acc-list" role="list">
                {%- for link in tab_menu.links -%}
                  <li class="vmd-acc-item" data-vmd-acc-item>
                    {%- if link.links != blank -%}
                      <button class="vmd-acc-parent" data-vmd-acc aria-expanded="false">
                        {{- link.title -}}
                        <svg class="vmd-acc-chev" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" aria-hidden="true"><path d="M6 9l6 6 6-6"/></svg>
                      </button>
                      <ul class="vmd-acc-subs" role="list">
                        {%- if bs.show_view_all and link.url != blank and link.url != '#' -%}
                          <li>
                            <a href="{{ link.url }}" class="vmd-sublink vmd-sublink--view-all">
                              View all {{ link.title }}
                              <svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M5 12h14M13 5l7 7-7 7"/></svg>
                            </a>
                          </li>
                        {%- endif -%}
                        {%- for sub_link in link.links -%}
                          <li>
                            <a href="{{ sub_link.url }}" class="vmd-sublink">
                              {%- if is_devices_tab -%}
                                {% render 'valor-menu-title-with-new-badge', title: sub_link.title, badge_class: 'vmd-dl-new' %}
                              {%- else -%}
                                {{ sub_link.title }}
                              {%- endif -%}
                            </a>
                          </li>
                        {%- endfor -%}
                      </ul>
                    {%- else -%}
                      <a href="{{ link.url }}" class="vmd-acc-parent vmd-acc-parent--link">{{ link.title }}</a>
                    {%- endif -%}
                  </li>
                {%- endfor -%}
              </ul>
            {%- endif -%}

          {%- when 'tab_brands' -%}
            {%- comment -%} Per-brand tiles: upload a logo image OR fall back to text, set in the theme editor {%- endcomment -%}
            {%- assign brand_max = 20 -%}
            {%- assign brand_rendered = 0 -%}
            {%- capture brand_tiles -%}
              {%- for i in (1..brand_max) -%}
                {%- assign url_key  = 'brand_' | append: i | append: '_url' -%}
                {%- assign img_key  = 'brand_' | append: i | append: '_image' -%}
                {%- assign name_key = 'brand_' | append: i | append: '_name' -%}
                {%- assign b_url  = bs[url_key] -%}
                {%- assign b_img  = bs[img_key] -%}
                {%- assign b_name = bs[name_key] -%}
                {%- assign b_fallback_file = blank -%}
                {%- case i -%}
                  {%- when 1 -%}{%- assign b_fallback_file = 'mybatpro-dropdown_fa2c8e6a-5f6c-4ce6-acd7-f6dc4bb2538a.png' -%}
                  {%- when 2 -%}{%- assign b_fallback_file = 'mybat-dropdown_ff10186c-dcf8-4fd1-a4c2-2aa5b7b76bc3.png' -%}
                  {%- when 3 -%}{%- assign b_fallback_file = 'echelon-dropdown_275aeb52-2f1f-4e89-9f3c-6009af5f173c.png' -%}
                  {%- when 4 -%}{%- assign b_fallback_file = 'ampnergy-dropdown_d1bd5268-9745-4d1c-9cef-abe4a5ca1ac3.png' -%}
                  {%- when 5 -%}{%- assign b_fallback_file = 'baseline-dropdown_886171a7-48f3-45a7-a28c-22258f9d8cce.png' -%}
                  {%- when 6 -%}{%- assign b_fallback_file = 'ecoblvd-dropdown_cd89d25d-d588-4860-b96a-d0631d4ba72d.png' -%}
                  {%- when 7 -%}{%- assign b_fallback_file = 'ondigo-dropdown_8ac29982-58f3-4e3e-98d7-ac9d32d61cf0.png' -%}
                  {%- when 8 -%}{%- assign b_fallback_file = 'adata-dropdown_908142ec-696d-4d7d-8f79-ada55995017d.png' -%}
                  {%- when 9 -%}{%- assign b_fallback_file = 'beats-dropdown.png' -%}
                  {%- when 12 -%}{%- assign b_fallback_file = 'deejays-dropdown.png' -%}
                  {%- when 14 -%}{%- assign b_fallback_file = 'luxmo-dropdown.png' -%}
                  {%- when 15 -%}{%- assign b_fallback_file = 'maxpower-dropdown.png' -%}
                  {%- when 16 -%}{%- assign b_fallback_file = 'mlb-dropdown_a615b1c1-6087-4116-99d3-5504d6fd5f87.png' -%}
                  {%- when 17 -%}{%- assign b_fallback_file = 'scosche-dropdown.png' -%}
                  {%- when 18 -%}{%- assign b_fallback_file = 'sentry-dropdown.png' -%}
                  {%- when 19 -%}{%- assign b_fallback_file = 'RWAN-logo_1.png' -%}
                {%- endcase -%}
                {%- assign b_fallback_img = blank -%}
                {%- if b_fallback_file != blank -%}
                  {%- assign b_fallback_img = images[b_fallback_file] -%}
                {%- endif -%}
                {%- assign b_use_fallback_img = false -%}
                {%- if b_fallback_img != blank -%}
                  {%- if b_url != blank or b_name != blank -%}
                    {%- assign b_use_fallback_img = true -%}
                  {%- endif -%}
                {%- endif -%}
                {%- comment -%} Pull the collection's image when the link points to a collection {%- endcomment -%}
                {%- assign b_coll_img = nil -%}
                {%- if b_url contains '/collections/' -%}
                  {%- assign b_coll_handle = b_url | split: '/collections/' | last | split: '/' | first | split: '?' | first | split: '#' | first -%}
                  {%- assign b_coll_img = collections[b_coll_handle].image -%}
                  {%- comment -%} Ignore Shopify's blank placeholder image so it falls back to text {%- endcomment -%}
                  {%- if b_coll_img != blank -%}
                    {%- assign _coll_img_src = b_coll_img | image_url: width: 320 | downcase -%}
                    {%- if _coll_img_src contains 'placeholder' -%}
                      {%- assign b_coll_img = nil -%}
                    {%- endif -%}
                  {%- endif -%}
                {%- endif -%}
                {%- if b_img != blank or b_coll_img != blank or b_use_fallback_img or b_name != blank -%}
                  {%- assign brand_rendered = brand_rendered | plus: 1 -%}
                  {%- assign b_alt = b_name | strip_html | strip | escape -%}
                  <a href="{{ b_url | default: '#' }}" class="vmd-brand-pill">
                    {%- if b_img != blank -%}
                      {{ b_img | image_url: width: 320 | image_tag: loading: 'lazy', class: 'vmd-brand-pill__img', alt: b_alt }}
                    {%- elsif b_coll_img != blank -%}
                      {{ b_coll_img | image_url: width: 320 | image_tag: loading: 'lazy', class: 'vmd-brand-pill__img', alt: b_alt }}
                    {%- elsif b_use_fallback_img -%}
                      {{ b_fallback_img | image_url: width: 320 | image_tag: loading: 'lazy', class: 'vmd-brand-pill__img', alt: b_alt }}
                    {%- else -%}
                      {{ b_name }}
                    {%- endif -%}
                  </a>
                {%- endif -%}
              {%- endfor -%}
            {%- endcapture -%}

            {%- if brand_rendered > 0 -%}
              <div class="vmd-section-title">{{ bs.tab_label | default: 'Brands' }}</div>
              <div class="vmd-brand-pills">{{ brand_tiles }}</div>
            {%- elsif tab_menu.links.size > 0 -%}
              <div class="vmd-section-title">{{ bs.tab_label | default: 'Brands' }}</div>
              <div class="vmd-brand-pills">
                {%- for link in tab_menu.links -%}
                  <a href="{{ link.url }}" class="vmd-brand-pill">
                    <span class="vmd-brand-pill__name">{{ link.title }}</span>
                  </a>
                {%- endfor -%}
              </div>
            {%- endif -%}

        {%- endcase -%}
        {%- endif -%}

      </div>
    {%- endfor -%}

    <div class="vmd-body-spacer"></div>
  </div>

  {%- comment -%} ── Footer ────────────────────────────────────────── {%- endcomment -%}
  <div class="vmd-foot">
    {%- if s.footer_menu != blank and s.footer_menu.links.size > 0 -%}
      <nav class="vmd-foot-links" aria-label="Quick links">
        {%- for link in s.footer_menu.links -%}
          <a href="{{ link.url }}" class="vmd-foot-link">{{ link.title }}</a>
        {%- endfor -%}
      </nav>
    {%- endif -%}
    {%- if customer -%}
      <div class="vmd-account-card">
        <a href="/pages/my-account" class="vmd-account-card__left">
          <div class="vmd-avatar" id="vmd-account-avatar" aria-hidden="true">
            {{- customer.first_name | slice: 0 -}}{{- customer.last_name | slice: 0 -}}
          </div>
          <div>
            <div class="vmd-account-card__label">Signed in as</div>
            <div class="vmd-account-card__name" id="vmd-account-card-name">{{ customer.first_name }} {{ customer.last_name }}</div>
          </div>
        </a>
        <div class="vmd-account-card__tier" id="vmd-account-card-market"></div>
      </div>
    {%- else -%}
      <div class="vmd-account-card vmd-account-card--guest">
        {%- comment -%}Mobile: native shopify-account handles dialog directly{%- endcomment -%}
        <shopify-account menu="{{ settings.customer_account_menu }}" class="vmd-account-card__left vmd-account-sa">
          <span slot="signed-out-avatar" class="vmd-account-sa-content">
            <div class="vmd-avatar vmd-avatar--guest" aria-hidden="true">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><circle cx="12" cy="8" r="4"/><path d="M4 20c0-4 3.6-7 8-7s8 3 8 7"/></svg>
            </div>
            <div>
              <div class="vmd-account-card__label">Not signed in</div>
              <div class="vmd-account-card__name">Sign in to your account</div>
            </div>
          </span>
        </shopify-account>
        {%- comment -%}Desktop: triggers the header shopify-account pill instead{%- endcomment -%}
        <button type="button" class="vmd-account-card__left vmd-account-sa-trigger js-shopify-login-trigger">
          <div class="vmd-avatar vmd-avatar--guest" aria-hidden="true">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><circle cx="12" cy="8" r="4"/><path d="M4 20c0-4 3.6-7 8-7s8 3 8 7"/></svg>
          </div>
          <div>
            <div class="vmd-account-card__label">Not signed in</div>
            <div class="vmd-account-card__name">Sign in to your account</div>
          </div>
        </button>
        <a href="/pages/register" class="vmd-account-card__register">Register</a>
      </div>
    {%- endif -%}
  </div>

</valor-menu-drawer>

{% stylesheet %}
/* ================================================================
   VALOR MENU DRAWER — sections/valor-menu-drawer.liquid
   Self-contained styles, independent of color scheme system.
   Global vars used: --font-body--family, --font-heading--family,
                     --drawer-animation-speed, --animation-easing
   ================================================================ */

/* ── Isolated color tokens + drawer shell ───────────────────────── */
valor-menu-drawer {
  --vmd-navy:          	#2B3A55;
  --vmd-navy-deep:     	#1D2636;
  --vmd-sky-pale:      	#D9EEF6;
  --vmd-chalk:         	#F4F5F2;
  --vmd-parchment:     	#EEEDE7;
  --vmd-steel:         	#66717E;
  --vmd-navy-rgb:      	43, 58, 85;
  --vmd-white:         	#FFFFFF;
  --vmd-border:        	#0002;
  --vmd-border-strong: 	#0003;
  --vmd-accent:        	#C54448;
  --vmd-accent-deep:   	#7a2629;
  --vmd-font-body:     	var(--font-body--family, -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif);
  --vmd-font-heading:  	var(--font-heading--family, Georgia, 'Times New Roman', serif);

  position: fixed;
  top: 0;
  left: 0;
  width: 560px;
  max-width: 100%;
  height: 100dvh;
  background: var(--vmd-chalk);
  transform: translateX(-100%);
  display: flex;
  flex-direction: column;
  overflow: hidden;
  box-shadow: 4px 0 40px rgba(29, 38, 54, 0.16);
  z-index: var(--layer-menu-drawer, 200);
  transition: transform 0.28s cubic-bezier(0.4, 0, 0.2, 1);
}

/* Open state — toggled by ValorMenuDrawer.open() */
valor-menu-drawer.vmd-open {
  transform: translateX(0);
}

/* ── Hamburger button — sync open/close icon state ── */
button[data-vmd-trigger] .header-drawer-icon--close { display: none; }
body:has(valor-menu-drawer.vmd-open) button[data-vmd-trigger] .header-drawer-icon--open { display: none; }
body:has(valor-menu-drawer.vmd-open) button[data-vmd-trigger] .header-drawer-icon--close { display: flex; }

/* ── Shared drawer overlay (menu + cart) ── */
.valor-drawer-overlay {
  position: fixed;
  inset: 0;
  background: rgba(29, 38, 54, 0);
  backdrop-filter: blur(0px);
  z-index: 15;
  opacity: 0;
  pointer-events: none;
  transition: opacity 0.3s ease, backdrop-filter 0.3s ease, background 0.3s ease;
}
.valor-drawer-overlay.valor-open {
  opacity: 1;
  pointer-events: auto;
  background: rgba(29, 38, 54, 0.4);
  backdrop-filter: blur(3px);
}

/* ── Header ─────────────────────────────────────────────────────── */
valor-menu-drawer .vmd-head {
  padding: 18px var(--drawer-content-padding);
  /*display: flex;
  justify-content: space-between;
  align-items: center;
  flex-shrink: 0;*/
  border-bottom: 1px solid var(--vmd-border);
  display: flex;
  justify-content: center;
}

valor-menu-drawer .vmd-logo {
	display: flex; align-items: center; text-decoration: none;
	justify-content: center;
}
valor-menu-drawer .vmd-logo__img { height: 26px; width: auto; display: block; }
valor-menu-drawer .vmd-logo--text {
  font-family: var(--vmd-font-heading);
  font-size: 18px;
  font-weight: 400;
  color: var(--vmd-navy-deep);
}

valor-menu-drawer .vmd-close {
  width: 32px;
  height: 32px;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  color: var(--vmd-navy);
  background: transparent;
  border: none;
  padding: 0;
  cursor: pointer;
  transition: background 0.15s;
  /*flex-shrink: 0;*/
  position: absolute;
  left: var(--drawer-content-padding);
}
valor-menu-drawer .vmd-close:hover { background: var(--vmd-parchment); }

/* ── Tab bar ────────────────────────────────────────────────────── */
valor-menu-drawer .vmd-tabs {
  display: flex;
  gap: 2px;
  padding: 16px var(--drawer-content-padding) 0 var(--drawer-content-padding);
  border-bottom: 1px solid var(--vmd-border);
  flex-shrink: 0;
  overflow-x: auto;
  -webkit-overflow-scrolling: touch;
  scrollbar-width: none;
}
valor-menu-drawer .vmd-tabs::-webkit-scrollbar { display: none; }

valor-menu-drawer .vmd-tab {
  flex: 1;
  min-width: fit-content;
  white-space: nowrap;
  padding: 10px 14px;
  font-family: var(--vmd-font-body);
  font-size: 12px;
  font-weight: 500;
  letter-spacing: 0.04em;
  color: var(--vmd-steel);
  background: transparent;
  border: none;
  cursor: pointer;
  position: relative;
  transition: color 0.15s;
  text-align: center;
}
valor-menu-drawer .vmd-tab:hover { color: var(--vmd-navy); }
valor-menu-drawer .vmd-tab--active { color: var(--vmd-navy-deep); }
valor-menu-drawer .vmd-tab--active::after {
  content: '';
  position: absolute;
  bottom: -1px;
  left: 0;
  right: 0;
  height: 2px;
  background: var(--vmd-accent);
}

/* ── Search bar ─────────────────────────────────────────────────── */
valor-menu-drawer .vmd-search {
  padding: 10px var(--drawer-content-padding);
  border-bottom: 1px solid var(--vmd-border);
  flex-shrink: 0;
}
@media screen and (min-width: 750px) {
	valor-menu-drawer .vmd-search {
		display: none;
	}
}

valor-menu-drawer .vmd-search__btn {
  display: flex;
  align-items: center;
  gap: 8px;
  width: 100%;
  padding: 9px 12px;
  background: var(--vmd-white);
  border: 1px solid var(--vmd-border);
  border-radius: 8px;
