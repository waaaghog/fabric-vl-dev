          "default": "Express & Expedited Shipping"
        },
        {
          "type": "richtext",
          "id": "express_body",
          "label": "Express body",
          "default": "<p>Expedited options are available for an additional cost. Express shipping does not qualify for free shipping, regardless of order value.</p><p>All shipping rates are calculated using discounted carrier rates, primarily through FedEx.</p>"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Valor shipping policy",
      "blocks": [
        { "type": "policy_section" },
        { "type": "rates_section" }
      ]
    }
  ]
