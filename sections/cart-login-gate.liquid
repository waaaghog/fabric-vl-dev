{%- assign b2b_lock = false -%}
{%- if settings.b2b_mode -%}{%- if customer == nil or customer['b2b?'] == false -%}{%- assign b2b_lock = true -%}{%- endif -%}{%- endif -%}
{%- if b2b_lock -%}
<div class="clg-overlay">
  <div class="clg-card">
    <div class="clg-icon">
      <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
        <rect x="3" y="11" width="18" height="11" rx="2" ry="2"/>
        <path d="M7 11V7a5 5 0 0 1 10 0v4"/>
      </svg>
    </div>
    <h2 class="clg-title">{{ section.settings.title }}</h2>
    {%- if section.settings.notice != blank -%}
    <p class="clg-sub">{{ section.settings.notice }}</p>
    {%- endif -%}
    <a href="{{ routes.account_login_url }}" class="clg-btn">
      Sign in to your account
    </a>
    <a href="{{ routes.account_register_url }}" class="clg-register">
      Create an account
    </a>
  </div>
</div>
{%- endif -%}

{% stylesheet %}
.clg-overlay {
  position: fixed;
  inset: 0;
  z-index: 500;
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(244, 245, 242, 0.88);
  backdrop-filter: blur(6px);
  -webkit-backdrop-filter: blur(6px);
  padding: 24px;
}

.clg-card {
  background: #ffffff;
  border: 1px solid #0002;
  border-radius: 16px;
  padding: 40px 36px;
  max-width: 400px;
  width: 100%;
  text-align: center;
  box-shadow: 0 8px 40px rgba(29, 38, 54, 0.10);
}

.clg-icon {
  width: 56px;
  height: 56px;
  border-radius: 50%;
  background: rgba(29, 38, 54, 0.06);
  display: flex;
  align-items: center;
  justify-content: center;
  margin: 0 auto 20px;
  color: #2B3A55;
}

.clg-title {
  font-family: var(--font-heading--family, Georgia, serif);
  font-size: 22px;
  font-weight: 400;
  letter-spacing: -0.02em;
  color: #1D2636;
  margin: 0 0 10px;
  line-height: 1.15;
}

.clg-sub {
  font-size: 13px;
  color: #66717E;
  line-height: 1.55;
  margin: 0 0 24px;
}

.clg-btn {
  display: block;
  width: 100%;
  padding: 13px 20px;
  background: #1D2636;
  color: #F4F5F2;
  border-radius: 8px;
  text-decoration: none;
  font-size: 14px;
  font-weight: 500;
  letter-spacing: 0.01em;
  transition: background 0.15s;
  margin-bottom: 12px;
}
.clg-btn:hover { background: #2B3A55; }

.clg-register {
  display: block;
  font-size: 13px;
  color: #66717E;
  text-decoration: none;
  transition: color 0.15s;
}
.clg-register:hover { color: #1D2636; }
{% endstylesheet %}

{% schema %}
{
  "name": "Cart Login Gate",
  "settings": [
    {
      "type": "text",
      "id": "title",
      "label": "Heading",
      "default": "Sign in to proceed"
    },
    {
      "type": "textarea",
      "id": "notice",
      "label": "Notice text",
      "default": "Your cart is saved. Sign in to review your order and proceed to checkout."
    }
  ],
  "presets": [
    {
      "name": "Cart Login Gate"
    }
  ]
}
{% endschema %}
