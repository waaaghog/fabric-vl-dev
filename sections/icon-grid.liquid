      "max": 10,
      "step": 1,
      "default": 4
    },
    {
      "type": "range",
      "id": "columns_mobile",
      "label": "Items per row (mobile)",
      "min": 1,
      "max": 6,
      "step": 1,
      "default": 2
    },
    {
      "type": "range",
      "id": "gap_percent",
      "label": "Gap",
      "min": 1,
      "max": 20,
      "step": 1,
      "unit": "%",
      "default": 5
    },
    {
      "type": "range",
      "id": "gap_percent_mobile",
      "label": "Mobile gap",
      "min": 1,
      "max": 20,
      "step": 1,
      "unit": "%",
      "default": 5
    },
    {
      "type": "select",
      "id": "alignment",
