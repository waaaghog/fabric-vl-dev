
{%- liquid
  assign columns = section.settings.columns
  assign cols_minus1 = columns | minus: 1
  assign columns_mobile = section.settings.columns_mobile
  assign cols_minus1_mobile = columns_mobile | minus: 1
  assign gap = section.settings.gap_percent
  assign gap_mobile = section.settings.gap_percent_mobile
  assign scroll_width = section.settings.scroll_width
  assign alignment = section.settings.alignment
  if section.settings.wrap
    assign flex_wrap = 'wrap'
  else
    assign flex_wrap = 'nowrap'
  endif
  assign has_scroll = false
  if scroll_width > 100
    assign has_scroll = true
  endif
  assign sid = section.id
-%}

<div class="section-background color-{{ section.settings.color_scheme }}"></div>
<div
  class="section section--{{ section.settings.section_width }} color-{{ section.settings.color_scheme }} spacing-style icon-grid-section"
  style="{% render 'spacing-style', settings: section.settings %}"
  data-testid="icon-grid-section"
>
  {%- if section.settings.heading != blank -%}
    <div class="icon-grid-heading-row" style="margin-bottom: {{ section.settings.heading_gap }}px;">
      <h2
        class="icon-grid-heading"
        style="font-size: {{ section.settings.heading_size }}px; text-align: {{ section.settings.heading_alignment }};"
      >
        {{- section.settings.heading -}}
      </h2>
    </div>
  {%- endif -%}

  <div class="icon-grid-wrapper">
    {%- if has_scroll -%}
      <button
        class="icon-grid-arrow icon-grid-arrow--prev"
        aria-label="Scroll left"
        data-icon-grid-id="{{ sid }}"
        data-icon-grid-dir="-1"
      >
        {{- 'icon-chevron-left.svg' | inline_asset_content -}}
      </button>
    {%- endif -%}

    <div
      class="icon-grid-scroll-outer"
      id="icon-grid-{{ sid }}"
      style="
        --icon-grid-gap: {{ gap }};
        --icon-grid-gap-mobile: {{ gap_mobile }};
        --icon-grid-scroll-width: {{ scroll_width }};
        --icon-grid-columns: {{ columns }};
        --icon-grid-cols-minus1: {{ cols_minus1 }};
        --icon-grid-columns-mobile: {{ columns_mobile }};
        --icon-grid-cols-minus1-mobile: {{ cols_minus1_mobile }};
        --icon-grid-alignment: {{ alignment }};
        --icon-grid-wrap: {{ flex_wrap }};
      "
    >
      <div class="icon-grid-inner">
        {% content_for 'blocks' %}
      </div>
    </div>

    {%- if has_scroll -%}
      <button
        class="icon-grid-arrow icon-grid-arrow--next"
        aria-label="Scroll right"
        data-icon-grid-id="{{ sid }}"
        data-icon-grid-dir="1"
      >
        {{- 'icon-chevron-right.svg' | inline_asset_content -}}
      </button>
    {%- endif -%}
  </div>
</div>

<script>
  (function () {
    var btns = document.querySelectorAll('[data-icon-grid-id="{{ sid }}"]');
    btns.forEach(function (btn) {
      btn.addEventListener('click', function () {
        var el = document.getElementById('icon-grid-{{ sid }}');
        var amount = el.offsetWidth * 0.8;
        el.scrollBy({ left: parseInt(btn.dataset.iconGridDir) * amount, behavior: 'smooth' });
      });
    });
  })();
</script>

{% stylesheet %}
  .icon-grid-heading-row {
    width: 100%;
  }

  .icon-grid-heading {
    margin: 0;
    font-weight: 700;
    line-height: 1.2;
  }

  .icon-grid-wrapper {
    display: flex;
    align-items: center;
    gap: 12px;
    width: 100%;
  }

  .icon-grid-scroll-outer {
    container-type: inline-size;
    overflow-x: auto;
    overflow-y: visible;
    scrollbar-width: thin;
    scrollbar-color: currentColor transparent;
    flex: 1;
    min-width: 0;
    padding-top: 2px;
    padding-bottom: 2px;
  }

  .icon-grid-scroll-outer::-webkit-scrollbar {
    height: 3px;
  }

  .icon-grid-scroll-outer::-webkit-scrollbar-thumb {
    background-color: currentColor;
    border-radius: 2px;
  }

  .icon-grid-scroll-outer::-webkit-scrollbar-track {
    background: transparent;
  }

  .icon-grid-inner {
    display: flex;
    flex-wrap: var(--icon-grid-wrap, nowrap);
    justify-content: var(--icon-grid-alignment, space-between);
    align-items: flex-start;
    gap: calc(var(--icon-grid-gap) * 1cqw);
    min-width: calc(var(--icon-grid-scroll-width) * 1cqw);
  }

  @media (max-width: 749px) {
    .icon-grid-inner {
      gap: calc(var(--icon-grid-gap-mobile) * 1cqw);
    }
  }

  .icon-grid-inner > * {
    flex: 0 0 calc(
      (var(--icon-grid-scroll-width) * 1cqw - var(--icon-grid-gap) * 1cqw * var(--icon-grid-cols-minus1))
      / var(--icon-grid-columns)
    );
    min-width: 0;
    box-sizing: border-box;
  }

  @media (max-width: 749px) {
    .icon-grid-inner > * {
      flex: 0 0 calc(
        (var(--icon-grid-scroll-width) * 1cqw - var(--icon-grid-gap-mobile) * 1cqw * var(--icon-grid-cols-minus1-mobile))
        / var(--icon-grid-columns-mobile)
      );
    }
  }

  .icon-grid-section .icon-block__media {
    transition: transform 0.2s ease;
  }

  .icon-grid-section .icon-block__media:hover {
    transform: translateY(-1px);
  }

  .icon-grid-arrow {
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    width: 32px;
    height: 32px;
    padding: 0;
    background: none;
    border: none;
    cursor: pointer;
    color: currentColor;
    opacity: 0.6;
    transition: opacity 0.2s;
  }

  .icon-grid-arrow:hover {
    opacity: 1;
  }

  .icon-grid-arrow svg {
    width: 20px;
    height: 20px;
    display: block;
  }

  @media (max-width: 749px) {
    .icon-grid-arrow {
      display: none;
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Icon Grid",
  "class": "section-wrapper",
  "disabled_on": {
    "groups": ["header"]
  },
  "blocks": [
    { "type": "@theme" },
    { "type": "@app" }
  ],
  "settings": [
    {
      "type": "header",
      "content": "Heading"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading"
    },
    {
      "type": "range",
      "id": "heading_size",
      "label": "Heading size",
      "min": 14,
