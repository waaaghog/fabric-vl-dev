              "name": "t:names.custom_liquid",
              "settings": {
                "custom_liquid": "<style>\n  /* Localized styles for the dashboard mock */\n  .dash-mock {\n    background: #F4F5F2; /* var(--chalk) */\n    border-radius: 16px;\n    padding: 24px;\n    border: 1px solid rgba(29, 38, 54, 0.08);\n    font-family: 'Inter', sans-serif;\n  }\n  .dash-mock-head { display: flex; justify-content: space-between; align-items: center; margin-bottom: 20px; }\n  .dash-mock-head .title { font-size: 13px; font-weight: 600; color: #1D2636; }\n  .dash-mock-head .period { font-size: 11px; color: #66717E; background: #FFFFFF; padding: 4px 10px; border-radius: 999px; border: 1px solid rgba(29, 38, 54, 0.08); }\n  \n  .stat-row { display: grid; grid-template-columns: repeat(3, 1fr); gap: 8px; margin-bottom: 20px; }\n  .stat-box { background: #FFFFFF; border-radius: 10px; padding: 14px; border: 1px solid rgba(29, 38, 54, 0.08); }\n  .stat-box .lbl { font-size: 10px; letter-spacing: 0.08em; text-transform: uppercase; color: #66717E; font-weight: 500; }\n  .stat-box .val { font-size: 20px; font-weight: 600; color: #1D2636; margin-top: 6px; letter-spacing: -0.01em; }\n  .stat-box .delta { font-size: 11px; margin-top: 4px; display: flex; align-items: center; gap: 4px; }\n  .stat-box .delta.up { color: #2d7a3f; }\n  .stat-box .delta.down { color: #C54448; }\n  \n  .chart-mock { background: #FFFFFF; border-radius: 10px; padding: 18px; border: 1px solid rgba(29, 38, 54, 0.08); height: 140px; position: relative; }\n  .chart-mock svg { width: 100%; height: 100%; }\n</style>\n\n<div class=\"dash-mock\">\n  <div class=\"dash-mock-head\">\n    <div>\n      <div class=\"title\">Pacific Cellular — account overview</div>\n    </div>\n    <div class=\"period\">Last 30 days</div>\n  </div>\n  <div class=\"stat-row\">\n    <div class=\"stat-box\">\n      <div class=\"lbl\">Open orders</div>\n      <div class=\"val\">14</div>\n      <div class=\"delta up\">↑ 3 this week</div>\n    </div>\n    <div class=\"stat-box\">\n      <div class=\"lbl\">YTD volume</div>\n      <div class=\"val\">$284k</div>\n      <div class=\"delta up\">↑ 18% vs LY</div>\n    </div>\n    <div class=\"stat-box\">\n      <div class=\"lbl\">Co-op balance</div>\n      <div class=\"val\">$6,420</div>\n      <div class=\"delta down\">Expires Dec 31</div>\n    </div>\n  </div>\n  <div class=\"chart-mock\">\n    <svg viewBox=\"0 0 400 100\" preserveAspectRatio=\"none\">\n      <path d=\"M 0 80 Q 40 70, 60 65 T 120 45 T 180 55 T 240 30 T 300 38 T 360 20 T 400 25\"\n            stroke=\"#2B3A55\" stroke-width=\"2\" fill=\"none\"/>\n      <path d=\"M 0 80 Q 40 70, 60 65 T 120 45 T 180 55 T 240 30 T 300 38 T 360 20 T 400 25 L 400 100 L 0 100 Z\"\n            fill=\"#2B3A55\" opacity=\"0.08\"/>\n      <circle cx=\"240\" cy=\"30\" r=\"4\" fill=\"#C54448\"/>\n      <circle cx=\"400\" cy=\"25\" r=\"4\" fill=\"#63B9DE\"/>\n    </svg>\n  </div>\n</div>"
