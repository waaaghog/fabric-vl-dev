                    "custom_liquid": "<div class=\"center\">\n  <a href=\"#\" id=\"tidioChatBtn\" class=\"button button--primary\">\n    CHAT NOW\n  </a>\n</div>\n\n<script>\n(function () {\n  function openTidioWhenReady() {\n    // If Tidio is ready → open immediately\n    if (window.tidioChatApi && typeof window.tidioChatApi.open === \"function\") {\n      window.tidioChatApi.open();\n      return;\n    }\n\n    // Otherwise retry until it becomes available\n    let retries = 0;\n    const maxRetries = 20;\n\n    const interval = setInterval(function () {\n      retries++;\n\n      if (window.tidioChatApi && typeof window.tidioChatApi.open === \"function\") {\n        clearInterval(interval);\n        window.tidioChatApi.open();\n      }\n\n      if (retries >= maxRetries) {\n        clearInterval(interval);\n        console.warn(\"Tidio chat API not available.\");\n      }\n    }, 300);\n  }\n\n  function initButton() {\n    const btn = document.getElementById(\"tidioChatBtn\");\n    if (!btn) return;\n\n    btn.addEventListener(\"click\", function (e) {\n      e.preventDefault();\n      openTidioWhenReady();\n    });\n  }\n\n  // Wait for DOM\n  document.addEventListener(\"DOMContentLoaded\", initButton);\n\n  // Extra safety: Shopify theme editor / dynamic sections\n  document.addEventListener(\"shopify:section:load\", initButton);\n})();\n</script>"
