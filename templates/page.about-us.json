        "metric_summary": {
          "type": "hero_metric",
          "settings": {
            "label": "Summary",
            "value": "Nearly 30 years building the wireless accessory industry from product development to shelf execution - backed by manufacturing control, fulfillment scale, deep device coverage, and channel programs spanning carriers, national retail, off-price, dealer networks, OEM, and digital marketplaces. Because the shelf does not stock itself.",
            "unit": "",
            "full_width": true
          }
        },
        "value_foresight": {
          "type": "value",
          "settings": {
            "number": "i.",
            "title": "Foresight",
            "subtitle": "Built ahead of demand.",
            "description": "<p>Valor doesn't wait for the market to catch up. <strong>Decades of industry experience, early device insights, and in-house development capabilities</strong> help partners prepare for what customers will need next - before demand reaches the shelf.</p>"
          }
        },
        "value_velocity": {
          "type": "value",
          "settings": {
            "number": "ii.",
            "title": "Velocity",
            "subtitle": "Fast only matters when it shows up on time.",
            "description": "<p>Manufacturing control, deep inventory, and bicoastal distribution move products from development to delivery with <strong>fewer delays and more confidence.</strong> Speed isn't the headline here. Reliable speed is.</p>"
          }
        },
        "value_precision": {
          "type": "value",
          "settings": {
            "number": "iii.",
            "title": "Precision",
            "subtitle": "Details that drive performance.",
            "description": "<p>Every product decision matters - from <strong>device fit and material selection to packaging, compliance, and shelf presentation.</strong> Engineering discipline and category expertise built into products made for everyday use, retail-ready performance, and fewer almost-fits moments.</p>"
          }
        },
        "value_integrity": {
          "type": "value",
          "settings": {
            "number": "iv.",
            "title": "Integrity",
            "subtitle": "Three decades of proof.",
            "description": "<p>Since 1997, Valor has built its reputation through <strong>consistency, reliability, and long-term partner trust.</strong> The numbers help tell the story, but the real proof is simpler: partners keep coming back because Valor keeps showing up.</p>"
          }
        },
        "channel_carrier": {
          "type": "channel",
          "settings": {
            "label": "Carrier programs",
            "title": "Wireless carrier accessory programs",
            "description": "<p>Multi-year accessory programs across the carriers that anchor the U.S. wireless market - postpaid, prepaid, and cable-MVNO. Assortment planning tuned to device mix, launch calendars, seasonal cadence, packaging requirements, and reorder patterns. Because when a new phone hits the floor, the accessories shouldn't be three steps behind.</p>",
            "pills": "AT&T\nVerizon\nBoost Mobile\nCricket Wireless\nTotal Wireless\nXfinity\nSpectrum"
          }
        },
        "channel_retail": {
          "type": "channel",
          "settings": {
            "label": "National retail & off-price",
            "title": "Big shelves. Fast turns. Very little guesswork.",
            "description": "<p>Wholesale programs across the retail formats consumers actually shop - mass retail, big-box electronics, off-price, and home improvement. Same California and Texas infrastructure. Different channel demands. Same job: get the right products where they need to be.</p>",
            "pills": "Walmart\nTarget\nBest Buy\nHome Depot\nLowe's\nStaples\nTJ Maxx\nMarshalls\nHomeGoods\nRoss\nBurlington"
          }
        },
        "channel_marketplaces": {
          "type": "channel",
          "settings": {
            "label": "Digital marketplaces",
            "title": "Clicks, carts, and catalog control.",
            "description": "<p>Marketplace and direct-to-consumer programs built for digital velocity - without pulling inventory out from under physical retail. Listing infrastructure, catalog content, inventory allocation, marketplace operations, and social-commerce readiness for partners selling across online channels. Digital growth is great. Digital growth with inventory discipline is better.</p>",
            "pills": "Amazon\nTikTok Shop\nMarketplace ops\nCatalog & content\nListing infrastructure"
          }
        },
