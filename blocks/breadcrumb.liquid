
{%- liquid
  assign block_settings = block.settings
  assign product_resource = closest.product

  assign current_collection = collection
  if current_collection == blank
    assign current_collection = product_resource.collections | first
  endif
-%}

<nav
  class="breadcrumb spacing-style"
  role="navigation"
  aria-label="breadcrumbs"
  style="
    {% render 'spacing-style', settings: block_settings %}
    --breadcrumb-font-size: {{ block_settings.font_size }};
  "
  {{ block.shopify_attributes }}
>
  <a href="{{ routes.root_url }}">{{ 'accessibility.home' | t }}</a>

  {%- if current_collection != blank -%}
    <span class="breadcrumb__sep" aria-hidden="true">
      <svg width="10" height="10" viewBox="0 0 12 12" fill="none" xmlns="http://www.w3.org/2000/svg">
        <path d="M4.5 2.25L8.25 6L4.5 9.75" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
      </svg>
    </span>
    <a href="{{ current_collection.url }}">{{ current_collection.title }}</a>
  {%- endif -%}

  {%- if product_resource != blank -%}
    <span class="breadcrumb__sep" aria-hidden="true">
      <svg width="10" height="10" viewBox="0 0 12 12" fill="none" xmlns="http://www.w3.org/2000/svg">
        <path d="M4.5 2.25L8.25 6L4.5 9.75" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
      </svg>
    </span>
    <span class="breadcrumb__current">{{ product_resource.title }}</span>
  {%- endif -%}
</nav>

{% stylesheet %}
  .breadcrumb {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0.25em;
    font-size: var(--breadcrumb-font-size, 0.8125rem);
    color: rgb(var(--color-foreground-rgb) / 0.6);
  }

  .breadcrumb a {
    color: inherit;
    text-decoration: none;

    &:hover {
      color: var(--color-foreground);
      text-decoration: underline;
    }
  }

  .breadcrumb__sep {
    display: flex;
    align-items: center;
    opacity: 0.4;
  }

  .breadcrumb__current {
    color: var(--color-foreground);
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Breadcrumb",
  "tag": null,
  "settings": [
    {
      "type": "text",
      "id": "font_size",
      "label": "t:settings.size",
      "placeholder": "e.g. 0.875rem, 14px",
      "default": "0.8125rem"
    },
    {
      "type": "header",
      "content": "t:content.padding"
    },
    {
      "type": "range",
      "id": "padding-block-start",
      "label": "t:settings.top",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 0
    },
    {
      "type": "range",
      "id": "padding-block-end",
      "label": "t:settings.bottom",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 8
    },
    {
      "type": "range",
      "id": "padding-inline-start",
      "label": "t:settings.left",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 0
    },
    {
      "type": "range",
      "id": "padding-inline-end",
      "label": "t:settings.right",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 0
    }
  ],
  "presets": [
    {
      "name": "Breadcrumb",
      "category": "t:categories.product"
    }
  ]
}
{% endschema %}
