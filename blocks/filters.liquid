{% assign rps_metafields = shop.metafields['rapid-search'] %}
{% if content_for_header contains rps_metafields.storeFrontScriptDomain %}
  <script type="application/json" id="rpsFiltersBlockSettings">
    {{ block.settings | json }}
  </script>
{% endif %}
{%- doc -%}
  Renders the facet filtering component

  @param {object} results - The search results object
  @param {number} results_size - The number of products in the search results
  @param {object} [filters] - The filters object
{%- enddoc -%}

<script
  src="{{ 'facets.js' | asset_url }}"
  type="module"
  fetchpriority="low"
></script>

<script
  src="{{ 'tag-filter.js' | asset_url }}"
  type="module"
  fetchpriority="low"
></script>

<script
  src="{{ 'scrolling.js' | asset_url }}"
  type="module"
  fetchpriority="low"
></script>

{%- liquid
  assign block_settings = block.settings
  assign enable_filtering = block_settings.enable_filtering
  assign collection_product_count = 0
  if collection != blank
    assign collection_product_count = collection.all_products_count | default: collection.products_count | default: results_size
    if collection_product_count > 5000
      assign enable_filtering = false
    endif
  endif
  assign facets_btn_color = block_settings.mobile_button_color | default: 'initial'
  assign products_count = results_size
  assign sort_by = results.sort_by | default: results.default_sort_by
  assign filters = filters | default: results.filters
  assign total_active_values = 0

  # Calculate facets margin style
  capture facets_margin_style
    echo '--facets-margin: 0px '
    if block_settings.filter_style == 'vertical'
      echo block_settings.facets_margin_right | append: 'px' | append: ' 0px'
    else
      echo ' 0px ' | append: block_settings.facets_margin_bottom | append: 'px'
    endif
    echo ' 0px;'
  endcapture

  for filter in filters
    case filter.type
      when 'price_range'
        if filter.min_value.value != null or filter.max_value.value != null
          assign total_active_values = total_active_values | plus: 1
        endif
      when 'boolean'
        if filter.active_values[0].value
          assign total_active_values = total_active_values | plus: 1
        endif
      else
        assign active_value_count = filter.active_values | size
        assign total_active_values = total_active_values | plus: active_value_count
    endcase
  endfor

  assign active_tag_count = 0
  for tag in current_tags
    assign tag_downcase = tag | downcase
    if tag_downcase contains 'filter_' or tag_downcase == 'design lab' or tag_downcase contains 'design-lab'
      assign active_tag_count = active_tag_count | plus: 1
    endif
  endfor
  assign total_active_values = total_active_values | plus: active_tag_count

  if results.url
    assign results_url = results.url
  else
    assign terms = results.terms | escape
    assign results_url = '?q=' | append: terms | append: '&options%5Bprefix%5D=last&sort_by=' | append: sort_by
  endif

  assign is_active = false
  assign should_show_pane = true
  if block_settings.filter_style == 'vertical'
    assign should_show_pane = enable_filtering
  elsif block_settings.filter_style == 'drawer'
    assign should_show_pane = false
  endif

  assign desktop_facets_component_id = 'FacetFiltersFormComponent--' | append: section.id | append: '-desktop'
  assign enable_valor_filters = false
  if collection != blank or request.page_type == 'search' or template.name == 'search'
    assign enable_valor_filters = true
  endif

  assign show_valor_collection_toolbar = false
  if enable_valor_filters and block_settings.filter_style == 'vertical'
    assign show_valor_collection_toolbar = true
  endif

  assign default_stock_status_param = ''
  assign default_stock_status_value = ''
  if collection != blank and block_settings.filter_style == 'vertical'
    for filter in filters
      assign label_downcase = filter.label | downcase
      assign param_downcase = filter.param_name | downcase
      assign is_stock_status_filter = false

      if label_downcase contains 'availability' or label_downcase contains 'stock' or param_downcase contains 'availability' or param_downcase contains 'available' or param_downcase contains 'stock_status' or param_downcase contains 'stock-status'
        assign is_stock_status_filter = true
      endif

      if is_stock_status_filter and filter.type != 'price_range' and filter.values.size > 0
        for value in filter.values
          assign value_label_downcase = value.label | downcase
          assign value_downcase = value.value | downcase
          assign is_unavailable_value = false

          if value_downcase == '0' or value_label_downcase contains 'out of stock' or value_label_downcase contains 'out-of-stock' or value_label_downcase contains 'sold out' or value_label_downcase contains 'unavailable' or value_label_downcase contains 'not available'
            assign is_unavailable_value = true
          endif

          if is_unavailable_value == false
            if value_downcase == '1' or value_label_downcase contains 'in stock' or value_label_downcase contains 'in-stock' or value_label_downcase == 'available' or value_label_downcase contains 'available now'
              assign default_stock_status_param = value.param_name | default: filter.param_name
              assign default_stock_status_value = value.value
              break
            endif
          endif
        endfor
      endif

      if default_stock_status_param != blank
        break
      endif
    endfor
  endif

-%}

{% if enable_filtering or block_settings.enable_sorting or block_settings.enable_grid_density %}
  {% if block_settings.filter_style == 'vertical' or block_settings.filter_style == 'drawer' %}
    {% # These elements are always rendered in the horizontal bar that's why we apply the .facets--horizontal class %}
    <div
      class="facets facets--horizontal facets-controls-wrapper spacing-style{% if show_valor_collection_toolbar %} facets-controls-wrapper--valor-toolbar{% endif %}"
      style="{% render 'spacing-style', settings: block_settings %}{% if block_settings.text_label_case == 'uppercase' %} --facet-label-transform: uppercase;{% endif %}"
    >
      {% if show_valor_collection_toolbar %}
        <div class="valor-toolbar__left">
      {% endif %}
      {% if enable_filtering %}
        {% if block_settings.filter_style == 'drawer' %}
          <button
            class="button button-unstyled facets__summary facets--filters-title"
            on:click="#filters-drawer/showDialog"
            type="button"
            aria-haspopup="dialog"
          >
            <span class="facets__label">{{ 'content.filters' | t }}</span>
            <span class="svg-wrapper icon-caret icon-animated">
              {{- 'icon-caret.svg' | inline_asset_content -}}
            </span>
          </button>
        {% else %}
          <div class="facets--filters-title facets__label">{{ 'content.filters' | t }}</div>
        {% endif %}
      {% endif %}

      <div
        class="products-count-wrapper"
        data-testid="products-count"
      >
        <span role="status">
          {% if products_count > 25000 %}
            {{- 'content.item_count_cutoff' | t: count: 25000 -}}
          {% else %}
            {{- 'content.item_count' | t: count: products_count -}}
          {% endif %}
        </span>
      </div>

      {% if show_valor_collection_toolbar %}
        <div class="valor-toolbar__active-filters">
          {% render 'filter-remove-buttons',
            filters: filters,
            results_url: results_url,
            show_filter_label: block_settings.show_filter_label,
            should_show_clear_all: true,
            show_tag_bubbles: true,
            form_id: desktop_facets_component_id
          %}
        </div>
      </div>
      <div class="valor-toolbar__right">
      {% endif %}

      {% if block_settings.enable_sorting %}
        {% render 'sorting',
          results: results,
          sort_by: sort_by,
          filter_style: block_settings.filter_style,
          suffix: 'desktop',
          sort_position: 'desktop',
          should_use_select_on_mobile: false,
          show_sort_pill_status: show_valor_collection_toolbar,
          section_id: section.id
        %}
      {% endif %}

      {% if block_settings.enable_grid_density %}
        {% render 'grid-density-controls', viewport: 'desktop' %}
      {% endif %}

      {% if show_valor_collection_toolbar %}
      </div>
      {% endif %}
    </div>
  {% endif %}

  <div
    class="
      {% if should_show_pane == false %}
        hidden
      {% endif %}
      facets-block-wrapper
      facets-block-wrapper--{{ block_settings.filter_style }}
      {%- if block_settings.inherit_color_scheme == false %} color-{{ block_settings.color_scheme }}{% endif %}
      {%- if block_settings.filter_width == 'full-width' %} facets-block-wrapper--full-width{% endif %}
    "
    style="
      --grid-column--desktop:
        {%- if block_settings.filter_style == 'horizontal' -%}
          var(--{{ block_settings.filter_width }})
        {%- else -%}
          2 / var(--facets-vertical-col-width)
        {%- endif -%};
      {{ facets_margin_style }}
      --facets-inner-padding-block: {{ block_settings.padding-block-start }}px {{ block_settings.padding-block-end }}px;
      --facets-inner-padding-inline: var(--padding-xs);
    "
    {{ block.shopify_attributes }}
  >
    <div
      class="facets facets--{{ block_settings.filter_style }} spacing-style"
      style="{% render 'spacing-style', settings: block_settings %}{% if block_settings.text_label_case == 'uppercase' %} --facet-label-transform: uppercase;{% endif %}"
      aria-label="{{ 'accessibility.filters' | t }}"
    >
      <facets-form-component
        class="facets__form-wrapper"
        section-id="{{ section.id }}"
        form-style="{{ block_settings.filter_style }}"
        id="{{ desktop_facets_component_id }}"
        {% if default_stock_status_param != blank and default_stock_status_value != blank %}
          data-default-stock-status-param="{{ default_stock_status_param | escape }}"
          data-default-stock-status-value="{{ default_stock_status_value | escape }}"
        {% endif %}
      >
        <form
          action="{{ results_url }}"
          id="FacetFiltersForm--{{ section.id }}-desktop"
          class="facets__form"
          ref="facetsForm"
        >
          {% if should_show_pane %}
            {% unless show_valor_collection_toolbar %}
              {% render 'filter-remove-buttons',
                filters: filters,
                results_url: results_url,
                show_filter_label: block_settings.show_filter_label,
                should_show_clear_all: true,
                show_tag_bubbles: true
              %}
            {% endunless %}

            {% if enable_filtering %}
              {% assign total_active_values = 0 %}

              {% capture rendered_filters %}
                {%- for filter in filters -%}
                  {% case filter.type %}
                    {% when 'price_range' %}
                      {%- liquid
                        if filter.min_value.value != null or filter.max_value.value != null
                          assign total_active_values = total_active_values | plus: 1
                          assign is_active = true
                        endif

                        if block_settings.filter_style != 'vertical'
                          assign should_render_clear = true
                        else
                          assign should_render_clear = false
                        endif

                        render 'price-filter', filter: filter, filter_style: block_settings.filter_style, should_render_clear: should_render_clear, id_prefix: 'horizontal'
                      -%}
                    {% else %}
                      {% liquid
                        if filter.active_values.size > 0
                          assign is_active = true
                        endif

                        assign active_value_count = filter.active_values | size
                        assign total_active_values = total_active_values | plus: active_value_count
                        if block_settings.filter_style != 'vertical'
                          assign should_render_clear = true
                        else
                          assign should_render_clear = false
                        endif
                        render 'list-filter', filter: filter, filter_style: block_settings.filter_style, active_value_count: active_value_count, should_render_clear: should_render_clear, show_swatch_label: block_settings.show_swatch_label, sectionId: section.id
                      %}
                  {% endcase %}
                {%- endfor -%}
              {% endcapture %}
              {% assign total_active_values = total_active_values | plus: active_tag_count %}

              <div class="facets__filters-wrapper{% if block_settings.filter_style == 'vertical' and enable_valor_filters %} facets__filters-wrapper--valor{% endif %}">
                {% if block_settings.filter_style == 'horizontal' %}
                  {% liquid
                    assign more_attributes = 'on:click="#filters-drawer/showDialog"'
                    if block_settings.text_label_case == 'uppercase'
                      assign more_attributes = more_attributes | append: ' style="--text-transform: uppercase;"'
                    endif
                  %}
                  {% render 'overflow-list',
                    class: 'facets__overflow-list',
                    children: rendered_filters,
                    more-attributes: more_attributes,
                    more-button-attributes: 'aria-haspopup="dialog"',
                    minimum-items: 2,
                    data-testid: 'horizontal-filters-overflow-list'
                  %}
                {% elsif block_settings.filter_style == 'vertical' and enable_valor_filters %}
                  {% render 'valor-filter-sidebar',
                    filters: filters,
                    filter_style: block_settings.filter_style,
                    show_swatch_label: block_settings.show_swatch_label,
                    section_id: section.id
                  %}
                {% else %}
                  {{ rendered_filters }}
                  {% render 'tag-filters',
                    filter_style: block_settings.filter_style,
                    section_id: section.id
                  %}
                {% endif %}
              </div>

              {% if block_settings.filter_style == 'horizontal' %}
                <facet-remove-component
                  class="facets-horizontal-remove {% if is_active %}facets-horizontal-remove--active{% endif %}"
                  active-class="facets__clear-all-link--active"
                  data-url="{{ results_url }}"
                >
                  <button
                    type="button"
                    class="button-unstyled facets__clear-all-link facets__clear-all-link--horizontal {% if is_active %}facets__clear-all-link--active{% endif %}"
                    ref="clearButton"
                    on:click="/removeFilter?form="
                    on:keydown="/removeFilter?form="
                  >
                    {{- 'actions.clear_all' | t -}}
                  </button>
                </facet-remove-component>
              {% endif %}
            {% endif %}
            {% if block_settings.filter_style == 'horizontal' %}
              <div
                class="products-count-wrapper"
                data-testid="products-count"
              >
                <span role="status">
                  {% if products_count > 25000 %}
                    {{- 'content.item_count_cutoff' | t: count: 25000 -}}
                  {% else %}
                    {{- 'content.item_count' | t: count: products_count -}}
                  {% endif %}
                </span>
              </div>

              {% if block_settings.enable_sorting %}
                {% render 'sorting',
                  results: results,
                  sort_by: sort_by,
                  filter_style: block_settings.filter_style,
                  suffix: 'desktop',
                  sort_position: 'desktop',
                  should_use_select_on_mobile: false,
                  section_id: section.id
                %}
              {% endif %}

              {% if block_settings.enable_grid_density %}
                {% render 'grid-density-controls', viewport: 'desktop' %}
              {% endif %}
            {% endif %}
          {% endif %}
        </form>
      </facets-form-component>
    </div>
  </div>

  <div
    class="facets-toggle facets-toggle--btn-{{ block_settings.mobile_button_style | default: 'border' }}{% if enable_filtering == false %} facets-toggle--no-filters{% endif %}{% if block_settings.filter_style == 'horizontal' and block_settings.inherit_color_scheme == false %} color-{{ block_settings.color_scheme }}{% endif %}"
    style="
      --facets-inner-padding-block: {{ block_settings.padding-block-start }}px {{ block_settings.padding-block-end }}px; --facets-inner-padding-inline: var(--padding-xs);
      {{ facets_margin_style }}
      --facets-btn-color: {{ facets_btn_color }};
    "
  >
    <div class="facets-toggle__left">
      {% if enable_filtering %}
        <div class="facets-toggle__wrapper">
          <button
            class="button facets-toggle__button facets-toggle__pill-button button-unstyled"
            on:click="#filters-drawer/showDialog"
            type="button"
            aria-haspopup="dialog"
          >
            <span class="svg-wrapper">
              {{ 'icon-filter.svg' | inline_asset_content }}
            </span>

            {{ 'actions.show_filters' | t }}

            {% if total_active_values > 0 %}
              <div
                id="filter-count-bubble-toggle"
                class="filter-count-bubble"
                aria-label="{{ 'accessibility.filter_count' | t: count: total_active_values }}"
              >
                <span class="filter-count-bubble__background"></span>

                <span
                  ref="cartBubbleText"
                  class="filter-count-bubble__text"
                  aria-hidden="true"
                >
                  {{ total_active_values }}
                </span>
              </div>
            {% endif %}
          </button>
        </div>
      {% endif %}
    </div>

    <div class="facets-mobile-wrapper facets-controls-wrapper">
      {% if block_settings.enable_sorting %}
        <div class="facets-toggle__wrapper">
          <button
            class="button facets-toggle__sort-button facets-toggle__pill-button button-unstyled"
            on:click="#sort-sheet-{{ section.id }}/showDialog"
            type="button"
            aria-haspopup="dialog"
          >
            <span class="svg-wrapper">
              {{ 'icon-sort.svg' | inline_asset_content }}
            </span>
            {{ 'actions.sort' | t }}
          </button>
        </div>
      {% endif %}
    </div>
  </div>
{% else %}
  <div></div>
{% endif %}

{% if block_settings.enable_sorting %}
  <dialog-component
    id="sort-sheet-{{ section.id }}"
    class="sort-sheet-wrapper"
  >
    <dialog
      ref="dialog"
      class="sort-sheet drawer-bottom drawer-right color-{{ settings.drawer_color_scheme }}"
      scroll-lock
      aria-labelledby="sort-sheet-heading-{{ section.id }}"
    >
      {%- assign sort_title = 'actions.sort' | t -%}
      {%- assign sort_title_id = 'sort-sheet-heading-' | append: section.id -%}
      {% render 'universal-modal-header',
        title: sort_title,
        title_id: sort_title_id,
        additional_classes: 'drawer-shell__header--sticky'
      %}

      <facets-form-component
        section-id="{{ section.id }}"
        id="FacetFiltersFormComponent--{{ section.id }}-mobile-sort"
        {% if default_stock_status_param != blank and default_stock_status_value != blank %}
          data-default-stock-status-param="{{ default_stock_status_param | escape }}"
          data-default-stock-status-value="{{ default_stock_status_value | escape }}"
        {% endif %}
      >
        <form
          action="{{ results_url }}"
          id="FacetFiltersForm--{{ section.id }}-mobile-sort"
          ref="facetsForm"
        >
          <sorting-filter-component
            class="sort-sheet__sorting"
            on:change="/updateFilterAndSorting"
            data-should-use-select-on-mobile="false"
          >
            <details ref="details" open declarative-open>
              <summary ref="summary" class="visually-hidden">{{ 'actions.sort' | t }}</summary>
              <div
                ref="listbox"
                class="sort-sheet__options"
                role="listbox"
                aria-labelledby="sort-sheet-heading-{{ section.id }}"
              >
                {% for option in results.sort_options %}
                  <label for="sort-sheet-option-{{ option.value }}-{{ section.id }}">
                    <div
                      class="sort-sheet__option{% if option.value == sort_by %} sort-sheet__option--selected{% endif %}"
                      role="option"
                      aria-selected="{% if option.value == sort_by %}true{% else %}false{% endif %}"
                      tabindex="{% if option.value == sort_by %}0{% else %}-1{% endif %}"
                    >
                      <input
                        type="radio"
                        name="sort_by"
                        id="sort-sheet-option-{{ option.value }}-{{ section.id }}"
                        form="FacetFiltersForm--{{ section.id }}-mobile-sort"
                        value="{{ option.value }}"
                        class="sorting-filter__input"
                        data-option-name="{{ option.name }}"
                        {% if option.value == sort_by %}
                          checked
                        {% endif %}
                        aria-hidden="true"
                      >
                      <span class="sort-sheet__option-label">{{ option.name }}</span>
                    </div>
                  </label>
                {% endfor %}
              </div>
            </details>
          </sorting-filter-component>
        </form>
      </facets-form-component>
    </dialog>
  </dialog-component>
{% endif %}

{% if enable_filtering %}
  <dialog-component
    id="filters-drawer"
    class="facets-block-wrapper facets-block-wrapper--vertical color-{{ settings.drawer_color_scheme }}"
  >
    <dialog
      ref="dialog"
      class="facets facets--drawer drawer-bottom drawer-left spacing-style"
      style="{% render 'spacing-style', settings: block_settings %}"
      scroll-lock
      aria-labelledby="filters-drawer-heading"
    >
      {% assign form_component = 'FacetFiltersFormComponent--' | append: section.id | append: '-overflow' %}
      <facets-form-component
        class="facets__form-wrapper facets-drawer__form-wrapper"
        section-id="{{ section.id }}"
        id="{{ form_component }}"
        {% if default_stock_status_param != blank and default_stock_status_value != blank %}
          data-default-stock-status-param="{{ default_stock_status_param | escape }}"
          data-default-stock-status-value="{{ default_stock_status_value | escape }}"
        {% endif %}
      >
        <form
          action="{{ results_url }}"
          id="FacetFiltersForm--{{ section.id }}-overflow"
          class="facets__form"
          ref="facetsForm"
        >
          {%- capture filter_bubble -%}
            {% if total_active_values > 0 %}
              <span
                class="bubble facets__bubble"
                aria-hidden="true"
              >
                {{ total_active_values }}
              </span>
              <span class="visually-hidden">
                {{ 'accessibility.filter_count' | t: count: total_active_values }}
              </span>
            {% endif %}
          {%- endcapture -%}
          {%- assign filter_title = 'blocks.filter' | t -%}
          {% render 'universal-modal-header',
            title: filter_title,
            title_id: 'filters-drawer-heading',
            bubble_content: filter_bubble,
            additional_classes: 'facets__title-wrapper'
          %}

          <div
            class="facets-drawer__filters drawer-shell__body"
          >
            {% if enable_filtering %}
              {% render 'filter-remove-buttons',
                filters: filters,
                results_url: results_url,
                show_filter_label: block_settings.show_filter_label,
                should_show_clear_all: false,
                show_tag_bubbles: true
              %}

              <div class="facets__filters-wrapper{% if enable_valor_filters %} facets__filters-wrapper--valor{% endif %}">
                {% assign total_active_values = 0 %}
                {% assign is_active = false %}
                {%- for filter in filters -%}
                  {%- case filter.type -%}
                    {%- when 'price_range' -%}
                      {%- if filter.min_value.value != null or filter.max_value.value != null -%}
                        {%- assign is_active = true -%}
                      {%- endif -%}
                    {%- else -%}
                      {%- if filter.active_values.size > 0 -%}
                        {%- assign is_active = true -%}
                      {%- endif -%}
                  {%- endcase -%}
                {%- endfor -%}
                {%- for tag in current_tags -%}
                  {%- assign tag_downcase = tag | downcase -%}
                  {%- if tag_downcase contains 'filter_' or tag_downcase == 'design lab' or tag_downcase contains 'design-lab' -%}
                    {%- assign is_active = true -%}
                  {%- endif -%}
                {%- endfor -%}

                {% if enable_valor_filters %}
                  {% render 'valor-filter-sidebar',
                    filters: filters,
                    filter_style: 'vertical',
                    in_drawer: true,
                    show_swatch_label: block_settings.show_swatch_label,
                    section_id: section.id
                  %}
                {% else %}
                  {%- for filter in filters -%}
                    {% case filter.type %}
                      {% when 'price_range' %}
                        {%- liquid
                          render 'price-filter', filter: filter, filter_style: 'vertical', should_render_clear: false, id_prefix: 'dialog', in_drawer: true
                        -%}
                      {% else %}
                        {% liquid
                          assign active_value_count = filter.active_values | size
                          render 'list-filter', filter: filter, filter_style: 'vertical', active_value_count: active_value_count, should_render_clear: false, in_drawer: true, sectionId: section.id
                        %}
                    {% endcase %}
                  {%- endfor -%}

                  {% render 'tag-filters',
                    filter_style: 'vertical',
                    in_drawer: true,
                    section_id: section.id
                  %}
                {% endif %}
              </div>
            {% endif %}
          </div>
        </form>
      </facets-form-component>

      <div
        class="facets__drawer-actions"
      >
        <facet-remove-component
          data-url="{{ results_url }}"
          active-class="facets__clear-all--active"
        >
          <button
            type="button"
            class="button-secondary facets__clear-all{% if is_active %} facets__clear-all--active{% endif %}"
            ref="clearButton"
            on:click="/removeFilter?form={{ form_component }}"
            on:keydown="/removeFilter?form={{ form_component }}"
          >
            {{- 'actions.clear_all' | t -}}
          </button>
        </facet-remove-component>

        {% if products_count > 0 %}
          <button
            class="button facets__see-results"
            type="button"
            on:click="dialog-component/closeDialog"
          >
            {{- 'actions.see_items' | t: count: products_count -}}
          </button>
        {% endif %}
      </div>
    </dialog>
  </dialog-component>
{% endif %}

{% stylesheet %}
  .facets-block-wrapper {
    @media screen and (min-width: 750px) {
      margin: var(--facets-margin);
      grid-column: var(--grid-column--desktop);
    }
  }

  .facets-block-wrapper--vertical {
    @media screen and (min-width: 750px) {
      grid-column: var(--grid-column--desktop);
    }
  }

  .facets-toggle {
    display: flex;
    gap: var(--product-grid-gap-mobile);
    justify-content: space-between;
    align-items: center;
    margin: var(--facets-margin);
    padding-block: var(--facets-inner-padding-block);
    /*padding-inline: var(--facets-inner-padding-inline);*/
    padding-inline: var(--product-grid-gap-mobile);

    @media screen and (min-width: 750px) {
      display: none;
    }
  }

  .facets-toggle__button {
    min-height: var(--minimum-touch-target);
    box-shadow: none;

    @media screen and (min-width: 750px) {
      display: none;
    }
  }

  .facets-toggle__pill-button {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: var(--gap-xs);
    padding: var(--padding-xs) calc(var(--padding-md) + 5px);
    min-width: 105px;
    width: 100%;
    border: 1.5px solid var(--facets-btn-color, var(--color-border));
    font-size: var(--font-body--size);
    color: var(--color-foreground);
    background: transparent;
    line-height: 1;

    .svg-wrapper svg {
      width: 0.85rem;
      height: 0.85rem;
      display: block;
    }
  }

  .facets-toggle--btn-fill .facets-toggle__pill-button {
    background: var(--facets-btn-color, var(--color-foreground));
    color: var(--color-foreground);
    border: none;
  }

  .facets-toggle--btn-none .facets-toggle__pill-button {
    border: none;
    background: transparent;
  }

  .filter-count-bubble {
    position: relative;
    width: 20px;
    aspect-ratio: 1;
    border-radius: 50%;
    display: grid;
    line-height: 1.0;
    place-content: center;
    color: var(--color-foreground);
    border: var(--icon-stroke-width) solid var(--color-background);
  }

  .facets-mobile__title-wrapper .h3 {
    margin-block-end: 0;
    display: inline-flex;
    align-items: center;
    gap: var(--gap-xs);
  }

  .facets-mobile__title-wrapper .filter-count-bubble {
    width: 22px;
    height: 22px;
  }

  .facets-mobile__title-wrapper .filter-count-bubble__text {
    font-size: var(--font-size--xs);
  }

  .filter-count-bubble__background {
    position: absolute;
    inset: 0;
    background-color: rgb(var(--color-foreground-rgb) / 0.1);
    border-radius: var(--style-border-radius-50);
  }

  .filter-count-bubble__text {
    font-size: 11px;
    font-weight: 400;
    aspect-ratio: 1 / 1;
  }

  .facets-toggle--no-filters {
    @media screen and (max-width: 749px) {
      /* stylelint-disable-next-line declaration-no-important */
      justify-content: unset !important;

      & > .facets-mobile-wrapper {
        width: 100%;
      }
    }
  }

  .facets-block-wrapper--vertical + .facets-toggle {
    @media screen and (max-width: 749px) {
      margin: 0;
    }
  }

  .facets-mobile-wrapper {
    display: flex;
    align-items: center;
    gap: var(--gap-sm);
    justify-content: flex-end;
  }

  .facets-mobile-wrapper--multiple-controls {
    justify-content: space-between;
  }

  @media screen and (min-width: 750px) {
    dialog-component.facets-block-wrapper {
      position: absolute;
      width: 0;
      height: 0;
    }
  }

  .facets {
    --facets-form-horizontal-gap: 20px;
    --facets-horizontal-max-input-wrapper-height: 230px;
    --facets-upper-z-index: var(--layer-raised);
    --facets-open-z-index: var(--layer-heightened);
    --facets-sticky-z-index: var(--layer-sticky);
    --facets-panel-min-width: 120px;
    --facets-panel-height: 300px;
    --facets-grid-panel-width: 300px;
    --facets-clear-padding: var(--padding-md);
    --facets-clear-shadow: 0 -4px 14px 0 rgb(var(--color-foreground-rgb) / var(--facets-low-opacity));
    --facets-input-label-color: rgb(var(--color-input-text-rgb) / 0.6);
    --facets-clear-all-min-width: 120px;
    --facets-see-results-min-width: 55%;
    --facets-mobile-gap: 22px;
    --facets-low-opacity: 10%;
    --facets-hover-opacity: 75%;

    top: auto;
    bottom: 0;
    height: var(--drawer-height);
    max-height: var(--drawer-height);
    width: var(--drawer-width);
    max-width: var(--drawer-max-width);
    box-shadow: none;
    padding-block: 0;

    &:not(.facets--drawer) {
      @media screen and (min-width: 750px) {
        padding-inline: var(--padding-inline-start) var(--padding-inline-end);
        width: 100%;
        max-width: 100%;
      }
    }
  }

  .facets--horizontal {
    display: none;

    @media screen and (min-width: 750px) {
      padding-block: var(--padding-block-start) var(--padding-block-end);
      display: flex;
      align-items: center;
      position: relative;
      z-index: var(--facets-upper-z-index);
      border: none;
      height: auto;
      top: initial;
      bottom: initial;
      max-height: none;
      width: auto;
      overflow: visible;
    }
  }

  .facets--vertical {
    display: none;

    @media screen and (min-width: 750px) {
      padding-block: 0 var(--padding-block-end);
      display: block;
      position: static;
      top: auto;
      bottom: auto;
      height: auto;
      max-height: none;
      width: auto;
      overflow: visible;
    }
  }

  .facets--drawer {
    border-radius: 0;
    border-right: var(--style-border-drawer);
    box-shadow: var(--shadow-drawer);
    padding-inline: 0;
  }

  .facets--drawer[open] {
    display: flex;
    flex-direction: column;
    height: 80%;
    overflow: hidden;

    @media screen and (min-width: 750px) {
      height: 100%;
      max-height: 100%;
    }
  }

  .facets-drawer__form-wrapper {
    flex: 1 1 auto;
    min-height: 0;
    display: flex;
    flex-direction: column;
    overflow: hidden;
  }

  .facets-drawer__form-wrapper .facets__form {
    flex: 1 1 auto;
    min-height: 0;
    display: flex;
    flex-direction: column;
    overflow: hidden;
  }

  .facets-drawer__filters {
    flex: 1 1 auto;
    min-height: 0;
    overflow-y: auto;
    overflow-x: hidden;
    position: relative;
    scrollbar-width: none;
    -ms-overflow-style: none;
  }

  .facets-drawer__filters::-webkit-scrollbar {
    display: none;
  }

  .facets-drawer__filters .facets__filters-wrapper,
  .facets-drawer__filters .filter-remove-buttons,
  .facets-drawer__filters .sorting-filter-component {
    overflow: visible;
  }

  .facets.facets-controls-wrapper {
    @media screen and (min-width: 750px) {
      grid-column: column-1 / column-12;
      color: rgb(var(--color-foreground-rgb) / 0.7);
      gap: 0 var(--facets-form-horizontal-gap);
      padding-bottom: var(--padding-xs);
    }
  }

  .facets__inputs {
    display: flex;
    flex-direction: column;
    gap: var(--padding-lg);
    width: 100%;
  }

  :is(.facets--drawer, .facets--vertical) .facets__inputs:not(:has(.show-more)) {
    padding-block-end: var(--padding-xl);
  }

  /* Facets - Form */
  .facets__form-wrapper {
    display: flex;
    flex-direction: column;
    color: var(--color-foreground-muted);
    width: 100%;
  }

  .facets--horizontal .facets__form-wrapper {
    @media screen and (min-width: 750px) {
      flex-direction: row;
      height: auto;
    }
  }

  .facets__form {
    display: flex;
    flex-flow: column;
    width: 100%;
    height: 100%;
  }

  .facets--horizontal .facets__form {
    @media screen and (min-width: 750px) {
      flex-flow: row nowrap;
      height: auto;
    }
  }

  .facets:not(.facets--drawer) .facets__filters-wrapper {
    @media screen and (min-width: 750px) {
      margin-inline-end: var(--margin-md);
    }
  }

  .facets--horizontal .facets__filters-wrapper {
    @media screen and (min-width: 750px) {
      max-width: 60%;
      display: flex;
      flex-wrap: wrap;
      column-gap: var(--gap-xl);
      margin-inline-end: 0;
    }
  }

  /* Facets - Summary */
  .facets__summary {
    --variant-picker-swatch-width: 32px;
    --variant-picker-swatch-height: 32px;
    --icon-opacity: 0.5;

    @media screen and (min-width: 750px) {
      --variant-picker-swatch-width: 26px;
      --variant-picker-swatch-height: 26px;
    }

    font-size: var(--font-h5--size);
    display: flex;
    justify-content: space-between;

    &:hover {
      --icon-opacity: 1;
    }
  }

  .facets__filters-wrapper:hover .facets__summary,
  .facets__filters-wrapper:has(.facets__panel[open]) .facets__summary {
    opacity: var(--facets-hover-opacity);
  }

  .facets__filters-wrapper .facets__summary:hover,
  .facets__filters-wrapper .facets__panel[open] .facets__summary {
    opacity: 1;
  }

  .facets--horizontal .facets__summary {
    @media screen and (min-width: 750px) {
      font-size: var(--font-body--size);
      justify-content: flex-start;
      height: var(--minimum-touch-target);
	  display: flex;
	  align-items: center;
    }
  }

  .facets__summary .icon-caret {
    height: 0.85rem;
    width: 0.85rem;
    color: rgb(var(--color-foreground-rgb) / var(--icon-opacity));
    margin-block: var(--margin-2xs);
    transition: color var(--animation-speed) var(--animation-easing);
  }

  .facets--drawer .facets__summary .icon-caret {
    margin-inline-start: var(--margin-2xs);
  }

  /* Facets - Bubble */
  .facets__bubble {
    display: inline-flex;
    font-family: var(--font-body--family);
    font-weight: 400;
    aspect-ratio: 1 / 1;
  }

  /* Facets - Inputs */
  .facets__inputs-wrapper {
    margin-block: var(--padding-xs) var(--padding-xs);
  }

  .facets__inputs .show-more {
    display: flex;
    flex-direction: column;
    gap: var(--gap-xl);
    margin-block-end: var(--padding-xl);
  }

  .facets:not(.facets--drawer) .facets__inputs-wrapper {
    @media screen and (min-width: 750px) {
      gap: var(--gap-sm);
    }
  }

  .facets--horizontal .facets__inputs .show-more {
    @media screen and (min-width: 750px) {
      display: contents;
    }
  }

  .facets--horizontal .facets__inputs-wrapper {
    @media screen and (min-width: 750px) {
      max-height: var(--facets-horizontal-max-input-wrapper-height);
      scrollbar-width: none;
      -ms-overflow-style: none;
      overflow-x: auto;
      padding: var(--padding-md);
      margin-block: 0;
    }
  }

  .facets--vertical .facets__inputs:has(.show-more) .facets__inputs-wrapper {
    padding-block: var(--padding-sm);
    padding-inline: var(--padding-sm);
    margin-block: calc(var(--padding-sm) * -1);
    margin-inline: calc(var(--padding-sm) * -1);
  }

  @media screen and (max-width: 749px) {
    .facets__inputs:has(.show-more) .facets__inputs-wrapper {
      padding-block: var(--padding-sm);
      padding-inline: var(--padding-sm);
      margin-block: calc(var(--padding-sm) * -1);
      margin-inline: calc(var(--padding-sm) * -1);
    }
  }

  .facets__inputs-wrapper:not(:has(.facets__inputs-list)),
  .facets__inputs-wrapper .facets__inputs-list {
    display: flex;
    gap: var(--facets-mobile-gap);
    flex-direction: column;

    @media screen and (min-width: 750px) {
      gap: var(--gap-2xl);
    }
  }

  @media screen and (min-width: 750px) {
    .facets--vertical .facets__inputs-wrapper .facets__inputs-list--swatches {
      gap: var(--gap-sm);
    }

    .facets--horizontal
      .facets__inputs-wrapper
      .facets__inputs-list--swatches:not(.facets__inputs-list--swatches-grid) {
      display: grid;
      grid-template-columns: repeat(var(--swatch-columns, 4), 1fr);
    }
  }

  .facets__inputs-wrapper .facets__inputs-list--swatches {
    --facets-mobile-gap: var(--gap-sm);
  }

  .facets__inputs-wrapper .facets__inputs-list--grid {
    --min-column-width: 20%;

    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(var(--min-column-width), 1fr));
    gap: var(--gap-sm);

    @media screen and (min-width: 750px) {
      --min-column-width: 50px;
    }
  }

  .facets-block-wrapper:not(.facets-block-wrapper--vertical) .facets__inputs-list--grid {
    @media screen and (min-width: 750px) {
      width: var(--facets-grid-panel-width);
    }
  }

  .facets__inputs-wrapper--row:not(:has(.facets__inputs-list)),
  .facets__inputs-wrapper--row .facets__inputs-list {
    flex-wrap: wrap;
    flex-direction: row;
  }

  .facets__inputs .show-more__button {
    --show-more-icon-size: 22px;
    --show-more-gap: 8px;

    gap: var(--show-more-gap);

    @media screen and (min-width: 750px) {
      --show-more-icon-size: 16px;
      --show-more-gap: 6px;
    }
  }

  .facets__inputs .show-more__button .icon-plus {
    width: var(--show-more-icon-size);
    height: var(--show-more-icon-size);

    svg {
      width: 0.85rem;
      height: 0.85rem;
    }
  }

  /* Facets - Panel */
  .facets__panel {
    padding: 0 var(--drawer-padding);
  }

  .facets:not(.facets--drawer) .facets__panel,
  .facets-controls-wrapper .facets__panel {
    @media screen and (min-width: 750px) {
      padding: 0;
    }
  }

  .facets--horizontal .facets__panel {
    @media screen and (min-width: 750px) {
      position: relative;
    }
  }

  .facets-mobile-wrapper .facets__panel-content {
    border-radius: var(--style-border-radius-popover);
  }

  .facets-mobile-wrapper {
    --facets-upper-z-index: var(--layer-raised);
    --facets-panel-min-width: 120px;
    --facets-panel-height: 300px;
  }

  .facets--horizontal .facets__panel-content {
    @media screen and (min-width: 750px) {
      border-radius: var(--style-border-radius-popover);
      position: absolute;
      top: 100%;
      width: max-content;
      min-width: var(--facets-panel-min-width);
      max-width: var(--facets-panel-width);
      max-height: var(--facets-panel-height);
      z-index: var(--facets-upper-z-index);
      box-shadow: var(--shadow-popover);
      border: var(--style-border-popover);
      background-color: var(--color-background);
      overflow-y: hidden;
      gap: 0;
    }
  }

  :is(.facets--drawer, .facets--vertical) :is(.facets__item, .sorting-filter)::before {
    content: '';
    display: block;
    height: 0;
    width: calc(100% - var(--drawer-padding) * 2);
    border-top: var(--style-border-width) solid var(--color-border);
    margin: 0 auto;
  }

  :is(.facets--drawer, .facets--vertical) .facets__item:first-child::before {
    border-top: none;
  }

  @media screen and (min-width: 750px) {
    .facets:not(.facets--drawer) :is(.facets__item, .sorting-filter)::before {
      width: 100%;
    }

    .facets--horizontal .facets__item:not(:first-of-type)::before,
    .facets--horizontal .sorting-filter::before {
      content: none;
    }
  }

  @media screen and (min-width: 750px) {
    .facets--vertical .facets__item:not(:first-of-type)::before,
    .facets--vertical .sorting-filter::before {
      content: '';
    }
  }

  /* Facets - Text */
  .facets__label,
  .facets__clear-all-link,
  .clear-filter {
    text-decoration-color: transparent;
    text-decoration-thickness: 0.075em;
    text-underline-offset: 0.125em;
    transition: text-decoration-color var(--animation-speed) var(--animation-easing);
  }

  .facets__clear-all-link {
    display: none;
    cursor: pointer;
    padding: var(--padding-xs);
    color: var(--button-color);
    transition: text-decoration-color var(--animation-speed) var(--animation-easing),
      color var(--animation-speed) var(--animation-easing);
  }

  .facets__clear-all-link:hover {
    --button-color: var(--color-primary-hover);

    text-decoration: underline;
    text-decoration-color: var(--button-color);
  }

  .facets__clear-all-link--horizontal {
    height: var(--minimum-touch-target);
    padding-inline: var(--facets-form-horizontal-gap);
    min-width: var(--facets-clear-all-min-width);
  }

  .facets__clear-all-link--active {
    display: block;
  }

  .facets__label,
  .products-count-wrapper {
    text-transform: var(--facet-label-transform);
  }

  .clear-filter {
    background-color: transparent;
    box-shadow: none;
    padding: 0;
  }

  .clear-filter:hover {
    text-decoration: underline;
  }

  /* Clear button */
  .facets__clear {
    display: none;
  }

  .facets--horizontal .facets__clear {
    @media screen and (min-width: 750px) {
      width: 100%;
      justify-content: flex-end;
      padding: 0 var(--facets-clear-padding) var(--facets-clear-padding) 0;
      cursor: pointer;
    }
  }

  .facets__clear--active {
    @media screen and (min-width: 750px) {
      display: flex;
    }
  }

  /* Facets - Label */
  .facets__label {
    /*color: var(--color-foreground);*/
	color: #555;
    cursor: pointer;
    white-space: nowrap;
	text-transform: uppercase;

    @media screen and (min-width: 750px) {
      margin-inline-end: var(--margin-2xs);
    }
  }

  /* Products count */
  .products-count-wrapper {
    display: none;
  }

  .facets--horizontal .products-count-wrapper {
    @media screen and (min-width: 750px) {
      display: flex;
      margin-left: auto;
      flex-shrink: 0;
      align-items: center;
      height: var(--minimum-touch-target);
    }
  }
  .products-count-wrapper span {
    display: none;
  }

  /* Valor collection toolbar */
  .facets-controls-wrapper--valor-toolbar {
    --valor-toolbar-surface: #ffffff;
    --valor-toolbar-border: #d9dee3;
    --valor-toolbar-navy: #2b3a55;
    --valor-toolbar-navy-deep: #1d2636;
    --valor-toolbar-steel: #66717e;
    --valor-toolbar-accent: #c54448;

    @media screen and (min-width: 750px) {
      justify-content: space-between;
      align-items: center;
      gap: 20px;
      padding-block: 0;
      margin-block-start: 24px;
    }
  }

  .valor-toolbar__left,
  .valor-toolbar__right {
    display: flex;
    align-items: center;
  }

  .valor-toolbar__left {
    min-width: 0;
    flex: 1 1 auto;
    flex-wrap: wrap;
    gap: 14px;
  }

  .valor-toolbar__right {
    flex: 0 0 auto;
    gap: 6px;
    margin-inline-start: auto;
  }

  .facets-controls-wrapper--valor-toolbar .facets--filters-title {
    display: none;
  }

  .facets-controls-wrapper--valor-toolbar .products-count-wrapper {
    display: flex;
    align-items: center;
    flex-shrink: 0;
    height: auto;
    min-height: 38px;
    margin-left: 0;
    color: var(--valor-toolbar-navy-deep);
    font-size: 13px;
    font-weight: 700;
    text-transform: none;
  }

  .facets-controls-wrapper--valor-toolbar .products-count-wrapper span {
    display: block;
  }

  .valor-toolbar__active-filters {
    min-width: 0;
    display: flex;
    align-items: center;
  }

  .valor-toolbar__active-filters .facets-remove {
    display: none;
    flex-wrap: wrap;
    align-items: center;
    gap: 6px;
    margin: 0;
    padding: 0;
  }

  .valor-toolbar__active-filters .facets-remove:has(facet-remove-component) {
    display: flex;
    margin: 0;
  }

  .valor-toolbar__active-filters .facets-remove__pill {
    min-height: 30px;
    padding: 6px 10px 6px 14px;
    border: 1px solid var(--valor-toolbar-border);
    border-radius: 999px;
    background: var(--valor-toolbar-surface);
    box-shadow: none;
    color: var(--valor-toolbar-navy);
    font-size: 11px;
    line-height: 1.2;
  }

  .valor-toolbar__active-filters .facets-remove__pill .svg-wrapper {
    width: 10px;
    height: 10px;
    margin-inline-start: 4px;
  }

  .valor-toolbar__active-filters .facets__clear-all-link {
    display: block;
    padding: 6px 0;
    color: var(--valor-toolbar-accent);
    font-size: 11px;
    font-weight: 700;
    text-decoration: underline;
    text-underline-offset: 3px;
  }

  .facets-controls-wrapper--valor-toolbar .sorting-filter::before {
    content: none;
  }

  .facets-controls-wrapper--valor-toolbar .sorting-filter .facets__panel {
    position: relative;
    padding: 0;
  }

  .facets-controls-wrapper--valor-toolbar .sorting-filter .facets__summary {
    display: inline-flex;
    min-width: 190px;
    min-height: 38px;
    height: 38px;
    align-items: center;
    justify-content: flex-start;
    gap: 8px;
    padding: 9px 14px;
    border: 1px solid var(--valor-toolbar-border);
    border-radius: 999px;
    background: var(--valor-toolbar-surface);
    color: var(--valor-toolbar-navy);
    font-size: 12px;
    font-weight: 500;
    line-height: 1;
    text-transform: none;
    box-shadow: none;
  }

  .facets-controls-wrapper--valor-toolbar .sorting-filter .facets__summary:hover {
    border-color: var(--valor-toolbar-navy);
  }

  .facets-controls-wrapper--valor-toolbar .sorting-filter__summary-icon {
    width: 14px;
    height: 14px;
    flex: 0 0 14px;
    color: var(--valor-toolbar-steel);
  }

  .facets-controls-wrapper--valor-toolbar .sorting-filter__summary-text {
    overflow: hidden;
    color: var(--valor-toolbar-navy);
    text-overflow: ellipsis;
    white-space: nowrap;
  }

  .facets-controls-wrapper--valor-toolbar .sorting-filter .icon-caret {
    width: 10px;
    height: 10px;
    margin: 0;
    margin-inline-start: auto;
    color: var(--valor-toolbar-steel);
  }

  .facets-controls-wrapper--valor-toolbar .sorting-filter__options {
    margin-block-start: 8px;
    border-color: var(--valor-toolbar-border);
    border-radius: 8px;
  }

  .facets-controls-wrapper--valor-toolbar .column-options-wrapper {
    height: 38px;
    margin: 0;
    padding: 3px;
    border: 1px solid var(--valor-toolbar-border);
    border-radius: 999px;
    background: var(--valor-toolbar-surface);
  }

  .facets-controls-wrapper--valor-toolbar .column-options {
    gap: 2px;
  }

  .facets-controls-wrapper--valor-toolbar .column-picker {
    display: flex;
    width: 32px;
    height: 32px;
    align-items: center;
    justify-content: center;
    padding: 0;
    border-radius: 50%;
    background: transparent;
    color: var(--valor-toolbar-steel);
  }

  .facets-controls-wrapper--valor-toolbar .column-options__option:hover .column-picker {
    background: rgb(29 38 54 / 0.06);
  }

  .facets-controls-wrapper--valor-toolbar .column-options__option-input:checked ~ .column-picker {
    background: var(--valor-toolbar-navy-deep);
    color: #ffffff;
  }

  @media screen and (max-width: 989px) and (min-width: 750px) {
    .facets-controls-wrapper--valor-toolbar {
      align-items: flex-start;
      flex-wrap: wrap;
    }

    .valor-toolbar__right {
      width: 100%;
      justify-content: flex-end;
    }
  }

  /* Mobile specific components */
  .facets__title-wrapper {
    background-color: var(--color-background);
    color: var(--color-foreground);
    position: sticky;
    top: 0;
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding-block: var(--padding-xs);
    padding-inline-start: var(--drawer-padding);
    padding-inline-end: var(--padding-2xs);
    z-index: var(--facets-sticky-z-index);
  }

  :is(.facets--horizontal, .facets--vertical) .facets__title-wrapper {
    @media screen and (min-width: 750px) {
      display: none;
    }
  }

  .facets-drawer__title {
    --variant-picker-swatch-width: 32px;
    --variant-picker-swatch-height: 32px;

    margin: 0;
    display: flex;
    align-items: center;
    gap: var(--gap-xs);

    @media screen and (min-width: 750px) {
      --variant-picker-swatch-width: 26px;
      --variant-picker-swatch-height: 26px;
    }
  }

  /* Filter drawer header - match menu drawer style */
  .facets--drawer .facets__title-wrapper {
    padding-inline: var(--padding-xl);
    padding-block: var(--padding-md);
    border-bottom: var(--style-border-width) solid var(--color-border);
  }

  /* Align close icon with row content:
     - drawer panel uses var(--drawer-padding) which differs from var(--padding-xl)
     - override panel padding to match header, then cancel close button's own padding */
  .facets--drawer .facets__panel {
    padding-inline: var(--padding-xl);
  }

  .facets--drawer .facets-drawer__close {
    margin-inline-end: calc(3px - var(--padding-sm));
  }

  /* Filter drawer title match menu heading font */
  .facets--drawer .facets-drawer__title {
    font-family: var(--font-heading--family);
    font-weight: var(--font-heading--weight);
    font-size: var(--font-size--h4);
  }

  /* Filter section headers match the menu/body font */
  .facets--drawer .facets__summary {
    font-family: var(--font-body--family);
    font-weight: var(--font-body--weight);
    font-size: var(--font-size--h5);
  }

  /* Caret: point right when collapsed, down when expanded mirrors cascade menu */
  .facets--drawer .facets__summary .icon-caret svg {
    transform: rotate(-90deg);
    transition: transform var(--animation-speed) var(--animation-easing);
  }

  .facets--drawer details[open] > .facets__summary .icon-caret svg {
    transform: rotate(0deg);
  }

  /* Sort row at top of filter drawer */
  .facets-drawer__sort-row {
    border-bottom: var(--style-border-width) solid var(--color-border);
  }

  /* Hide native select in drawer, show the custom accordion */
  .facets--drawer .facets-drawer__sort-row .sorting-filter__container {
    display: none !important;
  }

  /* Remove top divider pseudo-element */
  .facets-drawer__sort-row .sorting-filter::before {
    content: none;
  }

  /* Summary row: label left, pill right */
  .facets--drawer .facets-drawer__sort-row .facets__summary {
    display: flex;
    align-items: center;
    padding: var(--padding-sm) var(--drawer-padding);
    list-style: none;
    cursor: pointer;
  }

  .facets--drawer .facets-drawer__sort-row .facets__summary::-webkit-details-marker {
    display: none;
  }

  /* "Sort by:" muted label on left */
  .facets--drawer .facets-drawer__sort-row .facets__label {
    font-size: var(--font-body--size);
    color: var(--color-foreground-muted);
    font-weight: normal;
    flex-shrink: 0;
    margin-inline-end: auto;
  }

  /* Current value left half of pill */
  .facets--drawer .facets-drawer__sort-row .facets__status {
    display: inline-flex !important;
    align-items: center;
    background-color: rgb(var(--color-foreground-rgb) / 0.07);
    border-radius: 100px 0 0 100px;
    padding-block: var(--padding-2xs);
    padding-inline: var(--padding-sm) var(--padding-2xs);
    font-size: var(--font-body--size);
    font-weight: normal;
    color: var(--color-foreground);
    margin-inline-start: 0;
    width: auto;
  }

  /* Caret right half of pill */
  .facets--drawer .facets-drawer__sort-row .facets__summary .icon-caret {
    display: flex;
    align-items: center;
    background-color: rgb(var(--color-foreground-rgb) / 0.07);
    border-radius: 0 100px 100px 0;
    padding-block: var(--padding-2xs);
    padding-inline: var(--padding-2xs) var(--padding-sm);
  }

  /* Expand sort options inline inside the drawer (not as a floating popover) */
  .facets--drawer .facets-drawer__sort-row .sorting-filter__options {
    position: static;
    width: 100%;
    max-width: 100%;
    box-shadow: none;
    border: none;
    border-radius: 0;
    background: transparent;
    border-top: var(--style-border-width) solid var(--color-border);
  }

  .facets--drawer .facets-drawer__sort-row details[open] .sorting-filter__options {
    opacity: 1;
  }

  .facets--drawer .facets-drawer__sort-row .sorting-filter__options-inner {
    padding: var(--padding-xs) 0;
  }

  .facets--drawer .facets-drawer__sort-row .sorting-filter__option {
    min-width: 0;
    max-width: 100%;
    padding-inline: var(--drawer-padding);
  }

  /* Status */
  .facets__status:not(:empty) {
    width: max-content;
    display: flex;
    margin-inline-start: auto;
    font-weight: 500;
    color: var(--color-foreground);
  }

  .facets__panel[open] .facets__status {
    display: none;
  }

  .facets--filters-title {
    margin-block-end: 0;
    color: var(--color-foreground);
    height: fit-content;

    @media screen and (max-width: 749px) {
      display: none;
    }
  }

  .facets--horizontal .facets__panel .facets__status:has(:not(:empty)) {
    @media screen and (min-width: 750px) {
      display: flex;
      margin-inline-start: var(--margin-xs);
      margin-inline-end: var(--margin-xs);
    }
  }

  /* Horizontal filter style */
  .facets--horizontal .facets__form {
    @media screen and (min-width: 750px) {
      gap: 0 var(--facets-form-horizontal-gap);
    }
  }

  /* Facets - Actions */
  .facets__drawer-actions facet-remove-component {
    display: contents;
  }

  .facets__drawer-actions {
    --to-top-gradient-background: linear-gradient(
      to top,
      rgb(var(--color-background-rgb) / 0.9),
      rgb(var(--color-background-rgb) / 0.8),
      rgb(var(--color-background-rgb) / 0.4),
      transparent
    );

    position: sticky;
    bottom: 0;
    z-index: var(--facets-sticky-z-index);
    order: 1;
    display: flex;
    flex-shrink: 0;
    justify-content: space-between;
    align-items: stretch;
    gap: var(--gap-sm);
    padding-block-start: var(--padding-xs);
    padding-block-end: var(--padding-md);
    padding-inline: var(--padding-lg);
    margin-top: auto;
    background-image: var(--to-top-gradient-background);
    background-color: var(--color-background);
  }

  /* Clear all button */
  .facets__clear-all {
    display: none;
    cursor: pointer;
    min-width: var(--facets-clear-all-min-width);
    flex-grow: 1;
    padding-block: var(--padding-lg);
    color: var(--button-color, inherit);
  }

  .facets__clear-all--active {
    display: block;
    opacity: 1;
    transform: translateY(0);
    transition: transform var(--animation-values), opacity var(--animation-values);
  }

  @starting-style {
    .facets__clear-all--active {
      opacity: 0;
      transform: translateY(100%);
    }
  }

  .facets__see-results {
    min-width: var(--facets-see-results-min-width);
    flex-grow: 1;
    padding-block: var(--padding-lg);
  }

  .facets-horizontal-remove {
    display: flex;
    align-items: center;
  }

  .facets-horizontal-remove--active::before {
    content: '';
    border-inline-start: var(--style-border-width) solid var(--color-border);
    height: var(--font-body--size);
    position: absolute;
  }

  /* --- Filter/Sort split toolbar --- */

  .facets-toggle__left {
    display: flex;
    align-items: center;
    gap: 0;
  }
  @media screen and (max-width: 749px) {
	.facets-toggle__left,
	.facets-mobile-wrapper {
		flex: 1 1 50%;
	}
	.facets-mobile-wrapper > div,
	.facets-mobile-wrapper button,
	.facets-toggle__left > div,
	.facets-toggle__left button {
		width: 100%;
	}
  }

  .facets-toggle__separator {
    width: var(--style-border-width, 1px);
    height: 1.6rem;
    background-color: var(--color-border);
    flex-shrink: 0;
    margin-inline: var(--margin-2xs, 4px);
  }

  .facets-toggle__sort-button {
    box-shadow: none;
  }

  /* Hide grid density controls on mobile */
  @media screen and (max-width: 749px) {
    .facets-toggle .facets-mobile-wrapper .column-options-wrapper {
      display: none;
    }
  }

  /* --- Sort bottom sheet (mobile) --- */
  .sort-sheet-wrapper {
    @media screen and (min-width: 750px) {
      display: none;
    }
  }

  .sort-sheet__sorting details {
    border: none;
    padding: 0;
  }

  .sort-sheet__options {
    display: flex;
    flex-direction: column;
    padding-block-end: var(--padding-lg);
  }

  .sort-sheet__option {
    display: flex;
    align-items: center;
    padding-block: 0.75rem;
    padding-inline: var(--padding-xl);
    cursor: pointer;
    font-size: var(--font-body--size);
  }

  .sort-sheet__option--selected .sort-sheet__option-label {
    text-decoration: underline;
    text-underline-offset: 0.2em;
    font-weight: 500;
  }

  .sort-sheet__option-label {
    pointer-events: none;
  }

  /* Valor collection sidebar */
  .facets-block-wrapper--vertical .facets--vertical {
    @media screen and (min-width: 750px) {
      --valor-filter-sidebar-width: 220px;

      position: sticky;
      top: 96px;
      width: 100%;
      max-width: var(--valor-filter-sidebar-width);
    }
  }

  .facets__filters-wrapper--valor {
    --valor-filter-surface: #ffffff;
    --valor-filter-chalk: #f4f5f2;
    --valor-filter-border: #e2e5e8;
    --valor-filter-border-strong: #a8b0b8;
    --valor-filter-navy: #2b3a55;
    --valor-filter-navy-deep: #1d2636;
    --valor-filter-steel: #66717e;
    --valor-filter-sky: #63b9de;
    --valor-filter-track: #ece7dc;

    background: var(--valor-filter-surface);
    border: 1px solid var(--valor-filter-border);
    border-radius: 16px;
    width: 100%;
    max-width: var(--valor-filter-sidebar-width, 220px);
    overflow: hidden;
  }

  .facets--drawer .facets__filters-wrapper--valor {
    border-inline: 0;
    border-radius: 0;
    width: 100%;
    max-width: none;
  }

  :is(.facets--drawer, .facets--vertical) .facets__filters-wrapper--valor :is(.facets__item, .sorting-filter)::before {
    content: none;
  }

  .facets__filters-wrapper--valor > .facets__item {
    display: block;
    border-bottom: 1px solid var(--valor-filter-border);
  }

  .facets__filters-wrapper--valor > .facets__item:last-child {
    border-bottom: 0;
    padding-bottom: 0;
  }

  .facets__filters-wrapper--valor .facets__panel {
    padding: 0;
  }

  .facets__filters-wrapper--valor .facets__summary {
    width: 100%;
    min-height: 0;
    padding: 9px 10px;
    align-items: center;
    background: transparent;
    transition: background-color 0.15s ease;
  }

  .facets__filters-wrapper--valor .facets__summary:hover {
    background: var(--valor-filter-chalk);
  }

  .facets__filters-wrapper--valor .facets__summary[data-testid='price-filter'] {
    padding-bottom: 5px;
  }

  .facets__filters-wrapper--valor .facets__label {
    margin: 0;
    color: var(--valor-filter-navy-deep);
    cursor: pointer;
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 0.14em;
    line-height: 1.2;
    text-transform: uppercase;
  }

  .facets__filters-wrapper--valor .facets__summary .icon-caret {
    width: 12px;
    height: 12px;
    color: var(--valor-filter-steel);
    margin: 0;
    transition: transform 0.2s ease;
  }

  .facets__filters-wrapper--valor details[open] > .facets__summary .icon-caret {
    transform: rotate(180deg);
  }

  .facets__filters-wrapper--valor .facets__panel-content {
    padding: 0 20px 20px;
  }

  .facets__filters-wrapper--valor .facets__inputs,
  .facets__filters-wrapper--valor .facets__inputs:not(:has(.show-more)) {
    gap: 0;
    padding-block-end: 0;
  }

  .facets__filters-wrapper--valor .facets__inputs-wrapper,
  .facets__filters-wrapper--valor .facets__inputs:has(.show-more) .facets__inputs-wrapper {
    margin: 0;
    padding: 0;
  }

  .facets__filters-wrapper--valor .facets__inputs-wrapper:not(:has(.facets__inputs-list)),
  .facets__filters-wrapper--valor .facets__inputs-wrapper .facets__inputs-list {
    gap: 10px;
  }

  .facets__filters-wrapper--valor .facets__inputs-wrapper:has(.checkbox) {
    padding-bottom: 12px;
  }

  .facets__filters-wrapper--valor .facets__inputs-list-item {
    width: 100%;
  }

  .facets__filters-wrapper--valor .checkbox {
    width: 100%;
  }

  .facets__filters-wrapper--valor .checkbox__label {
    width: 100%;
    min-width: 0;
    align-items: center;
    gap: 10px;
    color: var(--valor-filter-navy-deep);
    font-size: 13px;
    line-height: 1.35;
    padding: 2px 0;
  }

  .facets__filters-wrapper--valor .checkbox__label-text {
    padding-inline-start: 0;
    white-space: normal;
  }

  .facets__filters-wrapper--valor .checkbox .icon-checkmark {
    width: 16px;
    height: 16px;
    border-width: 1.5px;
    border-color: var(--valor-filter-border-strong);
    border-radius: 4px;
    background: var(--valor-filter-surface);
  }

  .facets__filters-wrapper--valor .checkbox__input:checked + .checkbox__label .icon-checkmark {
    background: var(--valor-filter-navy-deep);
    border-color: var(--valor-filter-navy-deep);
  }

  .facets__filters-wrapper--valor .checkbox__input:checked + .checkbox__label {
    font-weight: 500;
  }

  .facets__filters-wrapper--valor .checkbox__count {
    margin-left: auto;
    color: var(--valor-filter-steel);
    font-size: 11px;
    font-weight: 500;
    line-height: 1;
  }

  .facets__filters-wrapper--valor .facets__inputs-list--swatches {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
  }

  .facets__filters-wrapper--valor accordion-custom[data-filter-param-name*='color'] .facets__inputs-list--swatches,
  .facets__filters-wrapper--valor accordion-custom[data-filter-param-name*='colour'] .facets__inputs-list--swatches {
    margin-block: 4px 10px;
  }

  .facets__filters-wrapper--valor .facets__inputs-list--swatches .facets__inputs-list-item {
    width: auto;
  }

  .facets__filters-wrapper--valor .variant-option--swatches {
    min-width: 0;
  }

  .facets__filters-wrapper--valor .variant-option__button-label--has-swatch {
    padding: 0;
  }

  .facets__filters-wrapper--valor .variant-option__swatch-wrapper {
    width: 26px;
    height: 26px;
    border-radius: 50%;
  }

  .facets__filters-wrapper--valor .variant-option__swatch-wrapper input {
    z-index: 2;
  }

  .facets__filters-wrapper--valor .variant-option__swatch-wrapper .swatch {
    width: 26px;
    height: 26px;
    border: 2px solid var(--valor-filter-surface);
    border-radius: 50%;
    outline: 1px solid var(--valor-filter-border-strong);
    pointer-events: none;
    transition: outline-color 0.15s ease, transform 0.15s ease;
  }

  .facets__filters-wrapper--valor .variant-option__swatch-wrapper:hover .swatch {
    transform: scale(1.08);
  }

  .facets__filters-wrapper--valor .variant-option__swatch-wrapper:has(input:checked) .swatch {
    outline: 2px solid var(--valor-filter-navy-deep);
    outline-offset: 1px;
  }

  .facets__filters-wrapper--valor .valor-derived-swatches {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
	flex-direction: row;
  }

  .facets__filters-wrapper--valor .valor-derived-swatches .facets__inputs-list-item {
    width: auto;
  }

  .valor-derived-swatch {
    position: relative;
    width: 26px;
    height: 26px;
  }

  .valor-derived-swatch__input {
    position: absolute;
    inset: 0;
    z-index: 2;
    width: 100%;
    height: 100%;
    margin: 0;
    padding: 0;
    border: 0;
    opacity: 0;
    appearance: auto;
    cursor: pointer;
  }

  .valor-derived-swatch__label {
    display: block;
    width: 26px;
    height: 26px;
    cursor: pointer;
  }

  .valor-derived-swatch__dot {
    display: block;
    width: 26px;
    height: 26px;
    border: 2px solid var(--valor-filter-surface);
    border-radius: 50%;
    outline: 1px solid var(--valor-filter-border-strong);
    background: var(--valor-swatch-background);
    pointer-events: none;
    transition: outline-color 0.15s ease, transform 0.15s ease;
  }

  .valor-derived-swatch__dot--clear {
    outline-style: dashed;
  }

  .valor-derived-swatch__dot--light {
    outline-color: var(--valor-filter-border-strong);
  }

  .valor-derived-swatch__label:hover .valor-derived-swatch__dot {
    transform: scale(1.08);
  }

  .valor-derived-swatch__input:checked + .valor-derived-swatch__label .valor-derived-swatch__dot {
    outline: 2px solid var(--valor-filter-navy-deep);
    outline-offset: 1px;
  }

  .facets__filters-wrapper--valor .facets__pill-label {
    min-height: 32px;
    border-radius: 999px;
    font-size: 12px;
  }

  .facets__filters-wrapper--valor .facets__inputs-list--pills {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
  }

  .facets__filters-wrapper--valor .facets__inputs-list--pills .facets__inputs-list-item {
    width: auto;
  }

  .facets__filters-wrapper--valor .facets__inputs-list--pills .facets__pill-label {
    width: auto;
    min-height: 30px;
    height: 30px;
    padding-inline: 14px;
    box-shadow: inset 0 0 0 1px var(--valor-filter-border);
    color: var(--valor-filter-navy-deep);
    font-size: 12px;
    font-weight: 500;
  }

  .facets__filters-wrapper--valor .facets__inputs-list--pills .facets__pill-input:checked + .facets__pill-label {
    background: var(--valor-filter-navy-deep);
    box-shadow: none;
    color: var(--valor-filter-surface);
  }

  .facets__filters-wrapper--valor accordion-custom[data-filter-param-name*='availability'],
  .facets__filters-wrapper--valor accordion-custom[data-filter-param-name*='available'],
  .facets__filters-wrapper--valor accordion-custom[data-filter-param-name*='stock'] {
    padding-bottom: 14px;
  }

  .facets__filters-wrapper--valor accordion-custom[data-filter-param-name*='availability'] .facets__inputs-list--pills,
  .facets__filters-wrapper--valor accordion-custom[data-filter-param-name*='available'] .facets__inputs-list--pills,
  .facets__filters-wrapper--valor accordion-custom[data-filter-param-name*='stock'] .facets__inputs-list--pills {
    flex-wrap: nowrap;
    gap: 6px;
    margin-block-end: 10px;
  }

  .facets__filters-wrapper--valor accordion-custom[data-filter-param-name*='availability'] .facets__panel-content,
  .facets__filters-wrapper--valor accordion-custom[data-filter-param-name*='available'] .facets__panel-content,
  .facets__filters-wrapper--valor accordion-custom[data-filter-param-name*='stock'] .facets__panel-content {
    padding-inline: 14px;
  }

  .facets__filters-wrapper--valor accordion-custom[data-filter-param-name*='availability'] .facets__inputs-list--pills .facets__pill-label,
  .facets__filters-wrapper--valor accordion-custom[data-filter-param-name*='available'] .facets__inputs-list--pills .facets__pill-label,
  .facets__filters-wrapper--valor accordion-custom[data-filter-param-name*='stock'] .facets__inputs-list--pills .facets__pill-label {
    padding-inline: 10px;
    font-size: 11px;
    white-space: nowrap;
  }

  .facets__filters-wrapper--valor .price-facet__range-track {
    position: relative;
    height: 3px;
    margin: 4px 12px 18px;
    background: var(--valor-filter-track);
    border-radius: 2px;
  }

  .facets__filters-wrapper--valor .price-facet__range-fill {
    position: absolute;
    inset-block: 0;
    left: var(--price-min-percent, 0%);
    right: var(--price-fill-right-percent, 0%);
    background: var(--valor-filter-navy-deep);
    border-radius: 2px;
  }

  .facets__filters-wrapper--valor .price-facet__range-handle {
    position: absolute;
    top: 50%;
    width: 14px;
    height: 14px;
    border: 1.5px solid var(--valor-filter-navy-deep);
    border-radius: 50%;
    background: var(--valor-filter-surface);
    transform: translate(-50%, -50%);
    pointer-events: none;
  }

  .facets__filters-wrapper--valor .price-facet__range-handle--min {
    left: var(--price-min-percent, 0%);
  }

  .facets__filters-wrapper--valor .price-facet__range-handle--max {
    left: var(--price-max-percent, 100%);
  }

  .facets__filters-wrapper--valor .price-facet__range-input {
    position: absolute;
    inset: -10px 0;
    z-index: 2;
    width: 100%;
    height: 24px;
    margin: 0;
    appearance: none;
    background: transparent;
    cursor: pointer;
    pointer-events: none;
  }

  .facets__filters-wrapper--valor .price-facet__range-input::-webkit-slider-thumb {
    width: 18px;
    height: 18px;
    appearance: none;
    border: 0;
    background: transparent;
    pointer-events: auto;
  }

  .facets__filters-wrapper--valor .price-facet__range-input::-moz-range-thumb {
    width: 18px;
    height: 18px;
    border: 0;
    background: transparent;
    pointer-events: auto;
  }

  .facets__filters-wrapper--valor .price-facet__range-input::-webkit-slider-runnable-track {
    height: 24px;
    background: transparent;
  }

  .facets__filters-wrapper--valor .price-facet__range-input::-moz-range-track {
    height: 24px;
    background: transparent;
  }

  .facets__filters-wrapper--valor .price-facet__inputs-wrapper {
    display: flex;
    width: 100%;
    gap: 8px;
    padding-inline: 4px;
  }

  .facets__filters-wrapper--valor .price-facet__separator,
  .facets__filters-wrapper--valor .price-facet__highest-price {
    display: none;
  }

  .facets__filters-wrapper--valor .price-facet__field {
    position: relative;
    flex: 1;
    min-width: 0;
    border: 1px solid var(--valor-filter-border-strong);
    border-radius: 8px;
    padding: 21px 12px 8px;
    background: var(--valor-filter-surface);
  }

  .facets__filters-wrapper--valor .price-facet__label {
    position: absolute;
    top: 8px;
    left: 12px;
    padding: 0;
    color: var(--valor-filter-steel);
    font-size: 9px;
    font-weight: 500;
    letter-spacing: 0.1em;
    line-height: 1;
    text-transform: uppercase;
    transform: none;
  }

  .facets__filters-wrapper--valor .price-facet__currency {
    position: absolute;
    left: 12px;
    bottom: 9px;
    color: var(--valor-filter-navy-deep);
    font-size: 13px;
    font-weight: 600;
    line-height: 1;
    pointer-events: none;
  }

  .facets__filters-wrapper--valor .price-facet__input {
    width: 100%;
    min-height: 0;
    border: 0;
    box-shadow: none;
    padding: 0 0 0 0.75em;
    background: transparent;
    color: var(--valor-filter-navy-deep);
    font-size: 13px;
    font-weight: 600;
    line-height: 1;
    text-align: left;
  }

  .dl-sidebar-toggle {
    background: linear-gradient(145deg, var(--valor-filter-navy-deep) 0%, #4a3868 100%);
    border-radius: 12px;
    color: var(--valor-filter-chalk);
    margin: 0 0 10px;
    padding: 16px 16px 14px;
    box-shadow: 0 4px 16px rgb(29 38 54 / 0.12);
  }

  .dl-sidebar-head {
    display: flex;
    align-items: center;
    gap: 12px;
    margin-bottom: 14px;
  }

  .dl-sidebar-icon {
    display: flex;
    flex: 0 0 auto;
    width: 32px;
    height: 32px;
    align-items: center;
    justify-content: center;
    border-radius: 8px;
    background: rgb(244 245 242 / 0.12);
    color: var(--valor-filter-sky);
  }

  .dl-sidebar-title {
    color: var(--valor-filter-chalk);
    font-family: var(--font-heading--family);
    font-size: 18px;
    line-height: 1.1;
  }

  .dl-sidebar-sub {
    margin-top: 2px;
    color: rgb(244 245 242 / 0.7);
    font-size: 11px;
    line-height: 1.3;
  }

  .dl-sidebar-pills {
    display: flex;
    width: 100%;
    gap: 0;
    padding: 3px;
    border: 1px solid rgb(244 245 242 / 0.1);
    border-radius: 999px;
    background: rgb(244 245 242 / 0.08);
  }

  .dlm-btn {
    display: inline-flex;
    flex: 1;
    align-items: center;
    justify-content: center;
    border: 0;
    border-radius: 999px;
    padding: 7px 14px;
    background: transparent;
    color: rgb(244 245 242 / 0.7);
    cursor: pointer;
    font: inherit;
    font-size: 12px;
    font-weight: 500;
    line-height: 1;
    text-align: center;
    text-decoration: none;
    transition: background-color 0.15s ease, color 0.15s ease;
    white-space: nowrap;
  }

  .dlm-btn:hover {
    color: var(--valor-filter-chalk);
  }

  .dlm-btn.active {
    background: var(--valor-filter-chalk);
    color: var(--valor-filter-navy-deep);
    cursor: pointer;
    font-weight: 600;
  }
{% endstylesheet %}

{% schema %}
{
  "name": "t:names.filters",
  "tag": null,
  "settings": [
    {
      "type": "checkbox",
      "id": "enable_filtering",
      "label": "t:settings.enable_filtering",
      "info": "t:info.enable_filtering_info",
      "default": false
    },
    {
      "type": "select",
      "id": "filter_style",
      "label": "t:settings.direction",
      "options": [
        {
          "value": "horizontal",
          "label": "t:options.horizontal"
        },
        {
          "value": "vertical",
          "label": "t:options.vertical"
        },
        {
          "value": "drawer",
          "label": "Drawer"
        }
      ],
      "default": "horizontal",
      "visible_if": "{{ block.settings.enable_filtering == true }}"
    },
    {
      "type": "select",
      "id": "filter_width",
      "label": "t:settings.width",
      "options": [
        {
          "value": "centered",
          "label": "t:options.page"
        },
        {
          "value": "full-width",
          "label": "t:options.full"
        }
      ],
      "default": "centered",
      "visible_if": "{{ block.settings.enable_filtering == true and block.settings.filter_style == 'horizontal' }}"
    },
    {
      "type": "select",
      "id": "text_label_case",
      "label": "t:settings.text_label_case",
      "options": [
        {
          "value": "default",
          "label": "t:options.default"
        },
        {
          "value": "uppercase",
          "label": "t:options.uppercase"
        }
      ],
      "default": "default",
      "visible_if": "{{ block.settings.enable_filtering == true }}"
    },
    {
      "type": "checkbox",
      "id": "show_swatch_label",
      "label": "t:settings.show_swatch_label",
      "default": false,
      "visible_if": "{{ block.settings.enable_filtering == true }}"
    },
    {
      "type": "checkbox",
      "id": "show_filter_label",
      "label": "t:settings.show_filter_label",
      "default": false,
      "visible_if": "{{ block.settings.enable_filtering == true }}"
    },
    {
      "type": "checkbox",
      "id": "enable_sorting",
      "label": "t:settings.enable_sorting",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "enable_grid_density",
      "label": "t:settings.enable_grid_density",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "inherit_color_scheme",
      "label": "t:settings.inherit_color_scheme",
      "default": true
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "t:settings.color_scheme",
      "default": "scheme-1",
      "visible_if": "{{ block.settings.inherit_color_scheme == false }}"
    },
    {
      "type": "header",
      "content": "Mobile button"
    },
    {
      "type": "select",
      "id": "mobile_button_style",
      "label": "Button style",
      "options": [
        { "value": "border", "label": "Border" },
        { "value": "fill", "label": "Fill" },
        { "value": "none", "label": "None" }
      ],
      "default": "border"
    },
    {
      "type": "color",
      "id": "mobile_button_color",
      "label": "Button color",
      "visible_if": "{{ block.settings.mobile_button_style != 'none' }}"
    },
    {
      "type": "header",
      "content": "t:content.padding"
    },
    {
      "type": "range",
      "id": "padding-block-start",
      "label": "t:settings.top",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 0
    },
    {
      "type": "header",
      "content": "t:content.margin"
    },
    {
      "type": "range",
      "id": "facets_margin_bottom",
      "label": "t:settings.bottom",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 8,
      "visible_if": "{{ block.settings.filter_style == 'horizontal' }}"
    },
    {
      "type": "range",
      "id": "facets_margin_right",
      "label": "t:settings.right",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 20,
      "visible_if": "{{ block.settings.filter_style == 'vertical' }}"
    }
  ]
}
{% endschema %}
