{% doc %}
  @prompt
    Add top and bottom padding to the group block content element with class "group-block-content layout-panel-flex layout-panel-flex--column". Create a custom CSS snippet or Liquid block that targets this element and applies configurable top and bottom padding spacing around it.
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-group-padding-{{ ai_gen_id }} {
    display: block;
    width: 100%;
  }

  .ai-group-padding-{{ ai_gen_id }} .group-block-content.layout-panel-flex.layout-panel-flex--column {
    padding-top: {{ block.settings.padding_top }}px;
    padding-bottom: {{ block.settings.padding_bottom }}px;
  }

  @media screen and (max-width: 749px) {
    .ai-group-padding-{{ ai_gen_id }} .group-block-content.layout-panel-flex.layout-panel-flex--column {
      padding-top: {{ block.settings.padding_top_mobile }}px;
      padding-bottom: {{ block.settings.padding_bottom_mobile }}px;
    }
  }
{% endstyle %}

<group-padding-{{ ai_gen_id }} class="ai-group-padding-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
</group-padding-{{ ai_gen_id }}>

<script>
  (function() {
    class GroupPadding{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
      }

      connectedCallback() {
        this.applyPadding();
      }

      applyPadding() {
        const targetElement = document.querySelector('.group-block-content.layout-panel-flex.layout-panel-flex--column');
        if (targetElement) {
          targetElement.classList.add('ai-group-padding-target-{{ ai_gen_id }}');
        }
      }
    }

    customElements.define('group-padding-{{ ai_gen_id }}', GroupPadding{{ ai_gen_id }});
  })();
</script>

{% schema %}
{
  "name": "Group block padding",
  "tag": null,
  "settings": [
    {
      "type": "header",
      "content": "Desktop padding"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Top padding",
      "min": 0,
      "max": 100,
      "step": 5,
      "unit": "px",
      "default": 20
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Bottom padding",
      "min": 0,
      "max": 100,
      "step": 5,
      "unit": "px",
      "default": 20
    },
    {
      "type": "header",
      "content": "Mobile padding"
    },
    {
      "type": "range",
      "id": "padding_top_mobile",
      "label": "Top padding",
      "min": 0,
      "max": 100,
      "step": 5,
      "unit": "px",
      "default": 15
    },
    {
      "type": "range",
      "id": "padding_bottom_mobile",
      "label": "Bottom padding",
      "min": 0,
      "max": 100,
      "step": 5,
      "unit": "px",
      "default": 15
    }
  ],
  "presets": [
    {
      "name": "Group block padding"
    }
  ]
}
{% endschema %}
