{% doc %}
  @prompt
    a modern team page with room for 3 executives, the three team member blocks should eb in 3 columns. 
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-team-page-{{ ai_gen_id }} {
    display: block;
    width: {{ block.settings.desktop_width_percent }}%;
    max-width: 100%;
    padding: {{ block.settings.section_padding }}px 20px;
    background-color: {{ block.settings.background_color }};
  }

  .ai-team-page__container-{{ ai_gen_id }} {
    max-width: 1200px;
    margin: 0 auto;
  }

  .ai-team-page__header-{{ ai_gen_id }} {
    text-align: center;
    margin-bottom: {{ block.settings.header_spacing }}px;
  }

  .ai-team-page__title-{{ ai_gen_id }} {
    font-size: {{ block.settings.title_size }}px;
    color: {{ block.settings.title_color }};
    margin: 0 0 16px;
    font-weight: 700;
  }

  .ai-team-page__subtitle-{{ ai_gen_id }} {
    font-size: {{ block.settings.subtitle_size }}px;
    color: {{ block.settings.subtitle_color }};
    margin: 0;
    line-height: 1.6;
  }

  .ai-team-page__grid-{{ ai_gen_id }} {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: {{ block.settings.grid_gap }}px;
    margin-top: {{ block.settings.grid_spacing }}px;
  }

  .ai-team-page__member-{{ ai_gen_id }} {
    text-align: center;
    background-color: {{ block.settings.card_background }};
    border-radius: {{ block.settings.card_border_radius }}px;
    padding: {{ block.settings.card_padding }}px;
    transition: transform 0.3s ease, box-shadow 0.3s ease;
  }

  .ai-team-page__member-{{ ai_gen_id }}:hover {
    transform: translateY(-8px);
    box-shadow: 0 12px 24px rgba(0, 0, 0, 0.1);
  }

  .ai-team-page__image-wrapper-{{ ai_gen_id }} {
    position: relative;
    width: 100%;
    max-width: {{ block.settings.image_size }}px;
    margin: 0 auto {{ block.settings.image_spacing }}px;
    aspect-ratio: 1;
    overflow: hidden;
    border-radius: {{ block.settings.image_border_radius }}px;
  }

  .ai-team-page__image-{{ ai_gen_id }} {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .ai-team-page__image-placeholder-{{ ai_gen_id }} {
    width: 100%;
    height: 100%;
    background-color: #f4f4f4;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .ai-team-page__image-placeholder-{{ ai_gen_id }} svg {
    width: 60%;
    height: 60%;
    opacity: 0.3;
  }

  .ai-team-page__name-{{ ai_gen_id }} {
    font-size: {{ block.settings.name_size }}px;
    color: {{ block.settings.name_color }};
    margin: 0 0 8px;
    font-weight: 600;
  }

  .ai-team-page__role-{{ ai_gen_id }} {
    font-size: {{ block.settings.role_size }}px;
    color: {{ block.settings.role_color }};
    margin: 0 0 12px;
    font-weight: 500;
  }

  .ai-team-page__bio-{{ ai_gen_id }} {
    font-size: {{ block.settings.bio_size }}px;
    color: {{ block.settings.bio_color }};
    line-height: 1.6;
    margin: 0;
  }

  .ai-team-page__empty-state-{{ ai_gen_id }} {
    position: absolute;
    bottom: 10px;
    left: 50%;
    transform: translateX(-50%);
    font-size: 12px;
    color: #999;
    text-align: center;
    pointer-events: none;
    white-space: nowrap;
  }

  @media screen and (max-width: 768px) {
    .ai-team-page__grid-{{ ai_gen_id }} {
      grid-template-columns: 1fr;
      gap: {{ block.settings.grid_gap | times: 0.75 }}px;
    }

    .ai-team-page__title-{{ ai_gen_id }} {
      font-size: {{ block.settings.title_size | times: 0.7 }}px;
    }

    .ai-team-page__subtitle-{{ ai_gen_id }} {
      font-size: {{ block.settings.subtitle_size | times: 0.9 }}px;
    }
  }
{% endstyle %}

<div class="ai-team-page-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-team-page__container-{{ ai_gen_id }}">
    {% if block.settings.section_title != blank or block.settings.section_subtitle != blank %}
      <div class="ai-team-page__header-{{ ai_gen_id }}">
        {% if block.settings.section_title != blank %}
          <h2 class="ai-team-page__title-{{ ai_gen_id }}">{{ block.settings.section_title }}</h2>
        {% endif %}
        {% if block.settings.section_subtitle != blank %}
          <div class="ai-team-page__subtitle-{{ ai_gen_id }}">{{ block.settings.section_subtitle }}</div>
        {% endif %}
      </div>
    {% endif %}

    <div class="ai-team-page__grid-{{ ai_gen_id }}">
      {% for i in (1..3) %}
        {% liquid
          assign name_key = 'member_' | append: i | append: '_name'
          assign role_key = 'member_' | append: i | append: '_role'
          assign bio_key = 'member_' | append: i | append: '_bio'
          assign image_key = 'member_' | append: i | append: '_image'

          assign member_name = block.settings[name_key]
          assign member_role = block.settings[role_key]
          assign member_bio = block.settings[bio_key]
          assign member_image = block.settings[image_key]
        %}

        <div class="ai-team-page__member-{{ ai_gen_id }}">
          <div class="ai-team-page__image-wrapper-{{ ai_gen_id }}">
            {% if member_image %}
              <img
                src="{{ member_image | image_url: width: 600 }}"
                alt="{{ member_name | escape }}"
                loading="lazy"
                width="600"
                height="600"
                class="ai-team-page__image-{{ ai_gen_id }}"
              >
            {% else %}
              <div class="ai-team-page__image-placeholder-{{ ai_gen_id }}">
                {{ 'image' | placeholder_svg_tag }}
                {% if member_name == blank %}
                  <div class="ai-team-page__empty-state-{{ ai_gen_id }}">
                    Add team member image
                  </div>
                {% endif %}
              </div>
            {% endif %}
          </div>

          {% if member_name != blank %}
            <h3 class="ai-team-page__name-{{ ai_gen_id }}">{{ member_name }}</h3>
          {% endif %}

          {% if member_role != blank %}
            <div class="ai-team-page__role-{{ ai_gen_id }}">{{ member_role }}</div>
          {% endif %}

          {% if member_bio != blank %}
            <div class="ai-team-page__bio-{{ ai_gen_id }}">{{ member_bio }}</div>
          {% endif %}
        </div>
      {% endfor %}
    </div>
  </div>
</div>

